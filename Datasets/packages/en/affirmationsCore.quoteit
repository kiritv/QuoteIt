{"formatVersion":"1","manifest":{"primaryCategory":"Mind & Well-being","subcategory":"Affirmations","audienceTags":["theme:mental-health","theme:self-worth","audience:morning","audience:meditation"],"sortPriority":40,"groupingLevels":[],"groupingLabels":[],"dataPath":"Data/Collections/Affirmations_Core.json","supplementalDataPath":null,"languageCode":"en","displayNameEnglish":"Daily Affirmations","script":"Latin","isRTL":false,"transliterationAvailable":false,"contentRating":"general","sourceId":"affirmationsCore","displayName":"Daily Affirmations","version":"2.0","language":"English","edition":"QuoteIt Curated","type":"quotes","browseOrder":"sequence","itemCount":804,"supportsRandom":true,"supportsBrowse":true},"data":[{"id":"affirm-core-0001","text":"I can handle this moment with calm and clarity.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0002","text":"My breath anchors me when my mind feels crowded.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0003","text":"I release what I cannot control and focus on what I can do now.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0004","text":"I am safe, grounded, and supported right here.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0005","text":"I can move slowly and still make meaningful progress.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0006","text":"I trust myself to navigate uncertainty one step at a time.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0007","text":"I belong in every room where I show up with honesty.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0008","text":"My voice matters, and I use it with respect and courage.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0009","text":"I am capable of learning what I do not know yet.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0010","text":"I carry myself with quiet confidence, not comparison.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0011","text":"I notice and appreciate the good already present in my day.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0012","text":"I am thankful for small moments that restore my energy.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0013","text":"Gratitude helps me return to what truly matters.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0014","text":"I value the people who support me and I show it.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0015","text":"I can hold ambition and gratitude at the same time.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0016","text":"I do what I said I would do, even in small ways.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0017","text":"I respect my schedule because my goals are worth it.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0018","text":"I can choose the harder right over the easier wrong.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0019","text":"My habits today create my freedom tomorrow.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0020","text":"I can restart my routine at any time without shame.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0021","text":"I focus on one meaningful task at a time.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0022","text":"Progress counts more than perfection.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0023","text":"I create space for deep work and protect it.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0024","text":"I finish what matters before I chase what is urgent.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0025","text":"My attention is valuable, and I spend it intentionally.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0026","text":"My body knows how to settle into rest.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0027","text":"I release today and welcome restorative sleep.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0028","text":"My mind can slow down; nothing needs solving right now.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0029","text":"I deserve deep rest without guilt.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0030","text":"Tonight I choose peace over replaying the day.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0031","text":"Healing can be gradual and still be real.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0032","text":"I am allowed to recover at my own pace.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0033","text":"I honor my progress, even when it is invisible.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0034","text":"I can ask for help and still be strong.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0035","text":"I treat myself with the kindness I would offer a friend.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0036","text":"I bend without breaking, and I rise with wisdom.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0037","text":"Setbacks are data, not definitions of who I am.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0038","text":"I can recover my focus after any interruption.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0039","text":"I carry lessons forward and leave fear behind.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0040","text":"I have overcome before, and I will again.","author":"Quote It","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0041","text":"I am enough exactly as I am.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0042","text":"I am worthy of love and belonging.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0043","text":"I deserve kindness — from others and from myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0044","text":"My worth is not determined by my productivity.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0045","text":"I am a complete and whole person.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0046","text":"I honor my own needs without guilt.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0047","text":"I am not my mistakes; I am the lessons I've learned from them.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0048","text":"I trust my own judgment.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0049","text":"My feelings are valid.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0050","text":"I value myself deeply.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0051","text":"I am deserving of rest and restoration.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0052","text":"I am allowed to take up space.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0053","text":"I accept myself unconditionally.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0054","text":"My voice deserves to be heard.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0055","text":"I am proud of how far I've come.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0056","text":"I celebrate my uniqueness.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0057","text":"I release the need for anyone else's approval.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0058","text":"I am whole — nothing is missing.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0059","text":"I am more than my body.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0060","text":"I am enough, and I always have been.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0061","text":"I embrace my authentic self.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0062","text":"I honor the person I am becoming.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0063","text":"I am deserving of good things.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0064","text":"I trust myself to navigate whatever comes.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0065","text":"I am capable of deep and meaningful connection.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0066","text":"I release comparisons; my journey is my own.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0067","text":"I am grounded in who I am.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0068","text":"I give myself permission to be imperfect.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0069","text":"I treat myself with the same compassion I offer others.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0070","text":"I am resilient beyond what I can currently see.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0071","text":"I choose to see myself through kind eyes.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0072","text":"I am not defined by my past.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0073","text":"I fully accept this moment of my life.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0074","text":"I release the pressure to be perfect.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0075","text":"I am learning and growing every day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0076","text":"I am lovable just as I am.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0077","text":"I nourish my sense of self.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0078","text":"I am becoming more fully myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0079","text":"I am confident in my abilities.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0080","text":"I step forward even when I feel afraid.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0081","text":"I trust my capacity to handle challenges.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0082","text":"I speak with clarity and confidence.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0083","text":"I believe in my own potential.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0084","text":"I am brave enough to try.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0085","text":"I face uncertainty with openness.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0086","text":"I am capable of achieving my goals.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0087","text":"I choose courage over comfort.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0088","text":"I act despite self-doubt.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0089","text":"I am resourceful and creative.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0090","text":"I trust myself to find a way forward.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0091","text":"I stand behind my decisions.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0092","text":"I bring value to everything I do.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0093","text":"I am ready for new challenges.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0094","text":"I welcome growth, even when it stretches me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0095","text":"I advocate for myself with grace and conviction.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0096","text":"I take bold, grounded action.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0097","text":"I trust the timing of my life.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0098","text":"I show up fully, even on hard days.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0099","text":"I am gaining confidence with every experience.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0100","text":"I am more capable than I give myself credit for.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0101","text":"I take one courageous step at a time.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0102","text":"I trust the process, even when I can't see the full path.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0103","text":"I am rising to meet this moment.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0104","text":"I am stronger than my fears.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0105","text":"I choose to focus on what I can control.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0106","text":"I am exactly where I need to be.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0107","text":"I pursue what matters to me with steady resolve.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0108","text":"I embrace risk as part of growth.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0109","text":"I am steadfast in the face of adversity.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0110","text":"I lead with both heart and courage.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0111","text":"I own my strengths fully.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0112","text":"I am determined, patient, and persistent.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0113","text":"I am learning to trust myself more each day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0114","text":"I take credit for my hard work.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0115","text":"I am not afraid to begin again.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0116","text":"I speak my truth with confidence.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0117","text":"I am building the life I want, one choice at a time.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0118","text":"I believe in myself unconditionally.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0119","text":"I am calm, centered, and at peace.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0120","text":"I breathe in calm and breathe out tension.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0121","text":"I choose peace in this moment.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0122","text":"I release what I cannot control.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0123","text":"I am a safe harbor in any storm.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0124","text":"I slow down and trust the process.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0125","text":"I return to stillness whenever I need to.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0126","text":"I am grounded, even when the world around me is uncertain.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0127","text":"I find my center in every breath.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0128","text":"I release anxiety and welcome calm.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0129","text":"Peace is always available to me within.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0130","text":"I choose to respond rather than react.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0131","text":"I give myself permission to slow down.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0132","text":"I am anchored in the present moment.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0133","text":"I let go of worry and choose trust.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0134","text":"I carry stillness with me wherever I go.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0135","text":"I create calm with my breath.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0136","text":"I release the urgency of this moment.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0137","text":"I am at home in my own body.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0138","text":"I trust that everything will unfold as it should.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0139","text":"I observe my thoughts without being controlled by them.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0140","text":"I soften, release, and let go.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0141","text":"I am not my anxiety.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0142","text":"I choose serenity over stress.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0143","text":"I allow myself to rest without guilt.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0144","text":"I am more peaceful than I was yesterday.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0145","text":"I release the need to have all the answers right now.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0146","text":"I meet this moment with openness and ease.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0147","text":"I am gentle with myself during difficult times.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0148","text":"I choose thoughts that support my peace.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0149","text":"I can be still and know that I am okay.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0150","text":"I trust in the stillness between my thoughts.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0151","text":"I am safe, I am calm, I am whole.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0152","text":"I breathe deeply and let tension dissolve.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0153","text":"I release the past with compassion.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0154","text":"I find peace in what is, not what could have been.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0155","text":"I am free from the need to rush.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0156","text":"I let go of what drains me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0157","text":"I create space for calm in my everyday life.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0158","text":"I am perfectly capable of resting.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0159","text":"I am grateful for the abundance in my life.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0160","text":"I attract goodness into my life.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0161","text":"I am open to receiving all good things.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0162","text":"I have everything I need in this moment.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0163","text":"I appreciate the beauty of small moments.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0164","text":"I choose to notice what is going right.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0165","text":"Abundance flows to me in expected and unexpected ways.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0166","text":"I am grateful for my health, my breath, my life.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0167","text":"I find joy in simple pleasures.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0168","text":"I welcome prosperity with an open heart.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0169","text":"I am thankful for the people who love me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0170","text":"Every day holds gifts worth noticing.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0171","text":"I have enough; I am enough; I do enough.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0172","text":"I celebrate progress, not just results.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0173","text":"I appreciate my unique gifts and strengths.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0174","text":"I am rich in what matters most.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0175","text":"I notice and celebrate small victories.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0176","text":"I am grateful for challenges that helped me grow.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0177","text":"I give generously and receive gracefully.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0178","text":"I am surrounded by more good than I sometimes realize.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0179","text":"I focus on what I have rather than what I lack.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0180","text":"I attract what I need at the right time.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0181","text":"I am thankful for this day, exactly as it is.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0182","text":"I find meaning in ordinary moments.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0183","text":"My life is full of possibility.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0184","text":"I live with an abundance mindset.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0185","text":"I am grateful for my body and all it does for me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0186","text":"I receive compliments and kindness with grace.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0187","text":"I appreciate the journey as much as the destination.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0188","text":"I am open to life's generous surprises.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0189","text":"I create and attract positive experiences.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0190","text":"I see opportunity where others see obstacles.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0191","text":"I trust that more good is coming.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0192","text":"I am a magnet for love, joy, and opportunity.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0193","text":"I nourish gratitude every morning.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0194","text":"I am grateful for what money cannot buy.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0195","text":"I celebrate others' success without diminishing my own.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0196","text":"I am content with this present moment.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0197","text":"Every day I find new reasons to be thankful.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0198","text":"I welcome abundance in all its forms.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0199","text":"I am healing, even on days I can't feel it.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0200","text":"I give myself permission to heal at my own pace.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0201","text":"I am more than my wounds.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0202","text":"I hold space for my pain without being consumed by it.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0203","text":"I am gently tending to my own healing.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0204","text":"My healing is valid and real, even when it's not linear.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0205","text":"I am allowed to feel pain and still believe in recovery.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0206","text":"I choose to nourish my recovery every day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0207","text":"I am moving through grief with courage and compassion.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0208","text":"I deserve to heal completely.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0209","text":"I honor my body's wisdom as it heals.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0210","text":"I release what no longer serves my well-being.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0211","text":"I am becoming stronger through this experience.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0212","text":"I invite healing into every part of my life.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0213","text":"I trust my body's capacity to restore itself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0214","text":"I am patient with my healing process.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0215","text":"I am not alone in my healing journey.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0216","text":"Every small step forward counts.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0217","text":"I am transforming pain into wisdom.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0218","text":"I choose hope, even in the midst of difficulty.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0219","text":"I am healing from the inside out.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0220","text":"I am worthy of the care and support I receive.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0221","text":"I allow myself to grieve fully.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0222","text":"My scars tell a story of survival.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0223","text":"I forgive myself for not knowing then what I know now.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0224","text":"I welcome gentleness as medicine.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0225","text":"I am resilient, resourceful, and healing.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0226","text":"I trust that this pain is not permanent.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0227","text":"I allow myself to feel, to grieve, and to release.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0228","text":"I am rebuilding, one day at a time.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0229","text":"I choose to see healing in every sunrise.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0230","text":"I am brave enough to face what hurt me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0231","text":"I am letting go of old pain to make room for new joy.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0232","text":"My healing journey is sacred.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0233","text":"I am actively choosing my well-being.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0234","text":"I surround myself with people who support my healing.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0235","text":"I am free from the grip of past hurts.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0236","text":"I am worthy of complete restoration.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0237","text":"I give myself grace on difficult days.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0238","text":"I am finding my way back to wholeness.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0239","text":"I am stronger than any challenge before me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0240","text":"I have overcome hard things before; I will do so again.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0241","text":"I rise after every fall.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0242","text":"I am built for resilience.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0243","text":"I carry the strength of everyone who came before me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0244","text":"I meet hardship with determination.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0245","text":"I bend but I do not break.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0246","text":"I find courage in my most difficult moments.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0247","text":"I refuse to give up on myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0248","text":"I am adaptable and resourceful.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0249","text":"I face what is difficult without losing myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0250","text":"I draw on deep wells of inner strength.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0251","text":"I persist when things are hard.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0252","text":"I transform obstacles into stepping stones.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0253","text":"I am not what happened to me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0254","text":"I choose to stand up, even when it would be easier not to.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0255","text":"I am defined by how I rise, not how I fall.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0256","text":"I have survived 100% of my difficult days so far.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0257","text":"I am a warrior, a survivor, a thriver.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0258","text":"I see setbacks as setups for comebacks.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0259","text":"My strength is greater than my circumstances.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0260","text":"I endure with grace and steadiness.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0261","text":"I grow through every challenge I face.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0262","text":"I remain hopeful even in the darkest moments.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0263","text":"I channel difficulty into growth.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0264","text":"I am capable of extraordinary perseverance.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0265","text":"I am rooted deeply enough to weather any storm.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0266","text":"I believe in my ability to keep going.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0267","text":"I am becoming more resilient every day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0268","text":"I emerge from hardship wiser and kinder.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0269","text":"I handle adversity without losing my humanity.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0270","text":"I call on my inner strength whenever I need it.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0271","text":"I do not have to be fearless to be brave.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0272","text":"I trust myself through uncertainty.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0273","text":"I stand tall in who I am.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0274","text":"My spirit cannot be broken.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0275","text":"I choose to see difficulty as a teacher.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0276","text":"I am not just surviving — I am learning to thrive.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0277","text":"Every hard experience has added to my depth.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0278","text":"I am forged by fire and I am still here.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0279","text":"I am growing every single day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0280","text":"I embrace change as an invitation to evolve.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0281","text":"I celebrate how far I've come.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0282","text":"I learn from every experience, pleasant or difficult.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0283","text":"I am becoming the best version of myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0284","text":"I take steps forward, no matter how small.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0285","text":"I trust the process of becoming.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0286","text":"I am always a work in progress — and that's okay.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0287","text":"I stretch beyond my comfort zone with curiosity.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0288","text":"I am open to feedback and new perspectives.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0289","text":"I choose growth over stagnation.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0290","text":"I welcome new chapters in my story.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0291","text":"I am not the same person I was a year ago.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0292","text":"I invest in my growth every day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0293","text":"I am committed to my own becoming.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0294","text":"I value progress over perfection.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0295","text":"I am planting seeds of change every day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0296","text":"I am evolving in ways I can't always see.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0297","text":"I give myself credit for every effort I make.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0298","text":"I am building the habits that serve my future self.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0299","text":"I learn as I go, and that is enough.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0300","text":"I am grateful for every lesson, even the hard ones.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0301","text":"I embrace the unknown as a space for growth.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0302","text":"I am patient with myself as I grow.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0303","text":"I trust that slow growth is still growth.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0304","text":"I notice my progress and let it encourage me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0305","text":"I am always moving forward, even on rest days.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0306","text":"I will not be the same person tomorrow that I am today.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0307","text":"I am becoming more than I thought possible.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0308","text":"I honor the courage it takes to keep growing.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0309","text":"I rise above old patterns and habits.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0310","text":"I am committed to lifelong learning.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0311","text":"I am not stuck; I am in transition.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0312","text":"I see my potential and I reach for it.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0313","text":"I create my future through my choices today.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0314","text":"I allow myself to start fresh at any time.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0315","text":"I am shaped by intention, not just circumstance.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0316","text":"I believe that better is always possible.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0317","text":"I grow in the direction of the light I choose.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0318","text":"I am becoming someone I can be proud of.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0319","text":"Today I choose joy.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0320","text":"This morning I wake with purpose and gratitude.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0321","text":"Today I am open to all the good coming my way.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0322","text":"I greet this day with a fresh, open heart.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0323","text":"Today is full of possibility.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0324","text":"I begin today with calm and clarity.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0325","text":"I choose how I show up today.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0326","text":"Each morning is a new opportunity to begin.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0327","text":"I am ready for whatever this day brings.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0328","text":"I face today with courage and grace.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0329","text":"I set my intention for a good day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0330","text":"I release yesterday and embrace today.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0331","text":"This day is a gift I do not take for granted.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0332","text":"I am fully present in this morning.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0333","text":"Today I give my best to what matters most.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0334","text":"I wake up with energy, purpose, and hope.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0335","text":"I approach today with openness and curiosity.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0336","text":"I carry peace into everything I do today.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0337","text":"Today I am exactly where I need to be.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0338","text":"I choose to make today meaningful.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0339","text":"My day begins with kindness — to myself and others.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0340","text":"I bring light to every room I enter today.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0341","text":"Today holds something good I haven't found yet.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0342","text":"I start this day as the person I am becoming.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0343","text":"I am aligned and ready for this day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0344","text":"This morning I honor my body, my mind, my spirit.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0345","text":"I am awake, alive, and grateful.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0346","text":"Today I will be gentle with myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0347","text":"I create the energy of my day with my first thoughts.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0348","text":"I step into this day confident in who I am.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0349","text":"I welcome today's lessons with open arms.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0350","text":"Today I move with intention.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0351","text":"I am refueled and ready to face this day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0352","text":"Today I choose to focus on what I can control.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0353","text":"Good things are unfolding for me today.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0354","text":"I greet this day as a chance to begin again.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0355","text":"I commit to kindness, presence, and effort today.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0356","text":"I bring my whole self to today.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0357","text":"I honor today by living it fully.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0358","text":"I am grateful to have today.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0359","text":"I release what no longer serves me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0360","text":"I let go of grudges and reclaim my peace.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0361","text":"I forgive freely, for my own sake.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0362","text":"I release the past with love and gratitude.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0363","text":"I am not my old stories.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0364","text":"I let go of the need to control what I cannot.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0365","text":"I free myself from the weight of resentment.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0366","text":"I release old pain and welcome new beginnings.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0367","text":"I allow things to end when it is time.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0368","text":"I release fear and choose love.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0369","text":"I no longer carry what is not mine to carry.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0370","text":"I free myself from the expectations of others.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0371","text":"I let go of perfectionism and embrace my humanity.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0372","text":"I release guilt and extend myself compassion.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0373","text":"I gently close doors that no longer open toward my growth.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0374","text":"I set down the burden of the past.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0375","text":"I forgive myself for not knowing what I didn't know.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0376","text":"I release the need for things to be different than they are.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0377","text":"I let people be who they are.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0378","text":"I loosen my grip on outcomes.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0379","text":"I make peace with what I cannot change.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0380","text":"I release all that dims my light.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0381","text":"I choose to begin again.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0382","text":"I let go of comparison and honor my own path.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0383","text":"I breathe out what holds me back.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0384","text":"I give myself permission to move on.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0385","text":"I am no longer available for what drains me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0386","text":"I dissolve old habits that do not serve my highest good.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0387","text":"I am lighter than I was.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0388","text":"I release the narrative that limits me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0389","text":"I choose liberation over old wounds.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0390","text":"I let go of the need to be right.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0391","text":"I am grateful for what was, and ready for what comes.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0392","text":"I choose freedom over familiarity.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0393","text":"I release others from my expectations.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0394","text":"I unhook from drama and return to center.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0395","text":"I am a new version of myself today.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0396","text":"I let go of shame and choose self-respect.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0397","text":"I give myself a fresh start.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0398","text":"I am worthy of deep and genuine love.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0399","text":"I attract relationships that lift me higher.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0400","text":"I give love freely and receive it openly.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0401","text":"I nurture the relationships that matter most to me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0402","text":"I set loving, clear boundaries.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0403","text":"I communicate with honesty and compassion.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0404","text":"I choose to love myself first.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0405","text":"I am surrounded by people who see and value me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0406","text":"I bring warmth and presence to my relationships.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0407","text":"I release relationships that diminish my spirit.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0408","text":"I am becoming the partner, friend, and person I aspire to be.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0409","text":"I hold space for others' journeys with compassion.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0410","text":"I love without losing myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0411","text":"I trust the people who have proven their trustworthiness.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0412","text":"I attract love by embodying love.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0413","text":"I am worthy of a relationship where I feel safe to be myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0414","text":"I forgive those who hurt me, for my own freedom.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0415","text":"I choose connection over isolation.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0416","text":"I am a good friend, partner, and human being.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0417","text":"I invest in the relationships that nourish me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0418","text":"I am grateful for the love that exists in my life.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0419","text":"I grow through every relationship.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0420","text":"I am learning to love myself more fully.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0421","text":"I give and receive love without conditions.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0422","text":"I maintain my sense of self within loving relationships.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0423","text":"I deserve a love that does not require me to shrink.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0424","text":"I speak lovingly to myself and to others.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0425","text":"I choose people who choose me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0426","text":"I am open to the love that is coming to me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0427","text":"I am worthy of being loved well.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0428","text":"I build bonds rooted in honesty and respect.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0429","text":"I am a safe presence for the people I love.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0430","text":"I approach my relationships with empathy and care.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0431","text":"I love and accept others as they are.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0432","text":"I am grateful for every loving connection in my life.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0433","text":"I nurture my relationship with myself above all others.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0434","text":"I release the fear of vulnerability in love.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0435","text":"I am capable of loving and being loved deeply.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0436","text":"I create relationships that reflect who I truly am.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0437","text":"I live with intention and purpose.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0438","text":"My life has meaning and direction.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0439","text":"I am aligned with my deepest values.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0440","text":"I make a difference in ways I may never fully see.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0441","text":"I am here for a reason.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0442","text":"I pursue what makes me feel most alive.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0443","text":"My work matters.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0444","text":"I show up for my purpose even on quiet days.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0445","text":"I know what I stand for.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0446","text":"I am building something meaningful.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0447","text":"I contribute to the world in my own unique way.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0448","text":"I follow the pull of what lights me up.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0449","text":"My life is a meaningful story I am writing every day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0450","text":"I give my gifts freely and without reservation.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0451","text":"I am exactly who I am meant to be.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0452","text":"I trust my sense of calling.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0453","text":"I do work that serves others and satisfies my soul.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0454","text":"I am living a life that aligns with my values.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0455","text":"I bring my full self to my purpose.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0456","text":"My small daily actions are connected to something larger.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0457","text":"I contribute something irreplaceable to the world.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0458","text":"I create beauty and meaning in ordinary moments.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0459","text":"I am guided by love, wisdom, and service.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0460","text":"I live with presence and intention.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0461","text":"I make choices that reflect what I most deeply value.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0462","text":"I am discovering my purpose a little more each day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0463","text":"I exist to love, create, and grow.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0464","text":"I lead a life that I am proud to live.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0465","text":"I am doing what matters.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0466","text":"I move in the direction of my highest calling.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0467","text":"I am the author of my own meaningful story.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0468","text":"I choose a life of depth over distraction.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0469","text":"I bring my whole self to what matters most.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0470","text":"I trust the path I am on.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0471","text":"I make a difference by being fully myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0472","text":"I act in service of something greater than myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0473","text":"I am building a legacy of love and courage.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0474","text":"My purpose unfolds as I live with integrity.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0475","text":"I honor my calling and show up for it daily.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0476","text":"I am living my values out loud.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0477","text":"I honor my body with care and respect.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0478","text":"I am grateful for my body's strength and resilience.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0479","text":"I listen to what my body needs.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0480","text":"I nourish myself with food, rest, and movement.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0481","text":"My body is doing its best for me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0482","text":"I am at peace with my body.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0483","text":"I move my body in ways that feel good.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0484","text":"I am more than my physical appearance.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0485","text":"I treat my body like someone I love.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0486","text":"I rest without guilt when I need to.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0487","text":"I celebrate what my body can do.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0488","text":"My mind is clear, focused, and at ease.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0489","text":"I choose thoughts that empower me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0490","text":"I am the observer of my thoughts, not their servant.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0491","text":"My mind is a powerful tool in service of my well-being.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0492","text":"I cultivate a healthy relationship with my inner world.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0493","text":"I release toxic thought patterns with gentleness.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0494","text":"I speak kindly to myself in my inner dialogue.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0495","text":"I nourish my mental health every day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0496","text":"I am gentle with myself when I am struggling.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0497","text":"My physical and mental health are equally important.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0498","text":"I check in with myself throughout the day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0499","text":"I am becoming more aware of my needs and feelings.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0500","text":"I move toward wellness with patience.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0501","text":"I prioritize sleep, stillness, and self-care.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0502","text":"I take my mental health seriously.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0503","text":"I create a life that nurtures my whole self.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0504","text":"I listen to my body before it has to shout.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0505","text":"I am worthy of the care I give to others.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0506","text":"I am grounded in my body and at home in myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0507","text":"I choose rest as an act of self-respect.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0508","text":"I notice tension and release it gently.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0509","text":"I am aligned — body, mind, and spirit.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0510","text":"My mental health is a priority, not a luxury.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0511","text":"I give my nervous system time to recover.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0512","text":"I am kinder to myself than I used to be.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0513","text":"I am healing at every level of my being.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0514","text":"I take nourishing breaks throughout my day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0515","text":"I trust the signals my body sends me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0516","text":"I am tending to myself with love.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0517","text":"I trust my instincts.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0518","text":"I am worthy of success.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0519","text":"I speak up for what I believe in.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0520","text":"I approach new situations with curiosity.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0521","text":"I learn quickly and adapt easily.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0522","text":"I am comfortable with not having all the answers.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0523","text":"I claim my space with confidence.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0524","text":"I express my ideas clearly.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0525","text":"I follow through on my commitments.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0526","text":"I am decisive and action-oriented.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0527","text":"I believe my contributions matter.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0528","text":"I am prepared for what this day requires.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0529","text":"I earn my own respect.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0530","text":"I handle criticism with maturity.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0531","text":"I ask for help when I need it.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0532","text":"I stay true to myself in every situation.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0533","text":"I choose my battles wisely.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0534","text":"I remain composed under pressure.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0535","text":"I trust the decisions I have made.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0536","text":"I grow with every challenge I embrace.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0537","text":"I breathe slowly and let peace fill my body.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0538","text":"I pause before responding.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0539","text":"I return to my breath when anxiety rises.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0540","text":"I notice stress without becoming it.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0541","text":"I create a calm environment around me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0542","text":"I find stillness in nature.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0543","text":"I allow difficult feelings without fighting them.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0544","text":"I rest as an act of resistance.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0545","text":"I slow my pace to match my breath.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0546","text":"I hold difficult moments lightly.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0547","text":"I give myself quiet time every day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0548","text":"I choose my thoughts carefully.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0549","text":"I am learning to sit with discomfort.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0550","text":"I make peace with uncertainty.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0551","text":"I dissolve tension with each exhale.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0552","text":"I find ground beneath my feet.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0553","text":"I trust the rhythm of my own unfolding.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0554","text":"I create space between stimulus and response.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0555","text":"I find peace in the present tense.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0556","text":"I am not in a hurry.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0557","text":"I forgive myself freely and often.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0558","text":"I treat myself with the warmth I offer a good friend.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0559","text":"I am kind to myself when I struggle.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0560","text":"I give myself grace on hard days.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0561","text":"I acknowledge my pain without judgment.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0562","text":"I do not have to earn rest.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0563","text":"I am doing the best I can with what I have.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0564","text":"I release self-blame and embrace understanding.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0565","text":"I do not measure my worth by my output.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0566","text":"I hold myself gently.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0567","text":"I am human, and that is enough.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0568","text":"I extend patience to my own process.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0569","text":"I give myself credit for trying.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0570","text":"I hold space for my own complexity.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0571","text":"My imperfections make me relatable and real.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0572","text":"I am worthy of my own compassion.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0573","text":"I celebrate small wins without needing perfection.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0574","text":"I am as deserving of care as anyone I love.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0575","text":"I silence the inner critic with kindness.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0576","text":"I speak to myself as I would to someone I cherish.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0577","text":"I draw good energy toward me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0578","text":"I am rich in love, laughter, and light.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0579","text":"I release scarcity and welcome sufficiency.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0580","text":"I trust in the generosity of life.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0581","text":"Good things are unfolding even when I can't see them.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0582","text":"I am grateful for what I have and open to more.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0583","text":"I use my gifts generously.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0584","text":"I find joy in giving as much as receiving.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0585","text":"My needs are always met.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0586","text":"I create abundance with my attitude.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0587","text":"I attract aligned opportunities.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0588","text":"I am thankful for the abundance already in my life.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0589","text":"I see beauty everywhere I look.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0590","text":"I choose a grateful lens.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0591","text":"I trust that there is enough for all of us.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0592","text":"I share freely without fear of running out.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0593","text":"My heart is full.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0594","text":"I am in the flow of life.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0595","text":"I welcome each new day as an abundant gift.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0596","text":"I expect and receive goodness.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0597","text":"I am gentle with myself as I recover.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0598","text":"I take small steps toward feeling better every day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0599","text":"I allow others to support me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0600","text":"I ask for what I need.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0601","text":"I release the need to rush my healing.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0602","text":"I find meaning even in painful experiences.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0603","text":"I turn toward my pain with curiosity, not fear.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0604","text":"I trust that healing is happening even when I don't feel it.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0605","text":"I am not alone in my struggle.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0606","text":"I welcome the support of those who love me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0607","text":"I am rebuilding and that is brave.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0608","text":"I let myself cry when I need to.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0609","text":"I hold my own hand through the dark.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0610","text":"I choose hope even on my hardest days.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0611","text":"I am growing in ways I cannot yet measure.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0612","text":"I trust my body's natural capacity to heal.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0613","text":"I give pain the space it needs and then let it move.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0614","text":"I find anchors of comfort in difficult times.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0615","text":"I choose softness when the world feels hard.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0616","text":"I am held even when I feel alone.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0617","text":"I face the unknown without retreating.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0618","text":"I continue even when the path is difficult.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0619","text":"I am not broken; I am in the process of becoming.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0620","text":"I find strength I didn't know I had.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0621","text":"I carry hardship with grace.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0622","text":"I am more resilient today than I was yesterday.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0623","text":"I meet this challenge with everything I have.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0624","text":"I do not give up on myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0625","text":"I choose to keep going.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0626","text":"I endure, adapt, and overcome.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0627","text":"I am stronger in the broken places.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0628","text":"I will not be defeated by this.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0629","text":"I find light even in the darkest seasons.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0630","text":"I keep faith with myself through struggle.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0631","text":"I honor the effort it takes to just show up.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0632","text":"I will be okay.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0633","text":"I am anchored in who I am.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0634","text":"I stand in the midst of difficulty without falling apart.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0635","text":"I have faced fear before and I faced it again.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0636","text":"Every difficulty I face strengthens me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0637","text":"I evolve beyond my comfort zone.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0638","text":"I am not afraid to begin.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0639","text":"I am committed to my own becoming.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0640","text":"I embrace the discomfort of growth.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0641","text":"I welcome correction as part of learning.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0642","text":"I grow from every experience.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0643","text":"I am always in the process of becoming more.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0644","text":"I take responsibility for my growth.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0645","text":"I lean into the edges of my understanding.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0646","text":"I allow myself to be a beginner.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0647","text":"I release old versions of myself with love.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0648","text":"I build on every lesson I've been given.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0649","text":"I show up for my own becoming.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0650","text":"I transform through action, not just intention.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0651","text":"I open to new ways of thinking.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0652","text":"I am curious about who I am still becoming.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0653","text":"I make progress even in the pause.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0654","text":"I trust that growth is always happening.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0655","text":"I am creating the person I want to be.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0656","text":"I let experience be my greatest teacher.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0657","text":"I bring meaning to every interaction.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0658","text":"I choose to live with intention.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0659","text":"I am connected to something larger than myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0660","text":"I trust where this path is leading.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0661","text":"I live in alignment with my deepest values.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0662","text":"My service matters.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0663","text":"I make a difference in ways I may never see.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0664","text":"I follow my purpose even when I am tired.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0665","text":"I give my gifts because it is right, not because it is easy.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0666","text":"I know what I am here to do.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0667","text":"I act with integrity in all that I do.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0668","text":"I create value wherever I show up.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0669","text":"I lead by example.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0670","text":"I choose depth over distraction every day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0671","text":"I am on purpose.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0672","text":"I listen for what life is calling me toward.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0673","text":"My work is my contribution to the world.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0674","text":"I move with clarity and commitment.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0675","text":"I am building something worth building.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0676","text":"I trust the work.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0677","text":"I choose how to see this moment.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0678","text":"This day will not come again; I honor it fully.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0679","text":"Today I give generously.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0680","text":"I wake up and begin again with hope.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0681","text":"I am grateful to be alive today.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0682","text":"I seize this morning with energy and purpose.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0683","text":"Today I let things be exactly as they are.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0684","text":"I will do one thing today that scares me a little.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0685","text":"Today I will be kind to strangers.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0686","text":"I wake with gratitude on my lips.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0687","text":"Today's challenges are shaping a stronger me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0688","text":"I start fresh every single morning.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0689","text":"I will pause today and appreciate what is good.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0690","text":"I begin this day from a place of abundance.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0691","text":"Today I will rest when I need to.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0692","text":"I face this morning with quiet courage.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0693","text":"I meet this day as an opportunity.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0694","text":"I find something wonderful in today.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0695","text":"Today I choose presence over distraction.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0696","text":"I enter today open, ready, and grateful.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0697","text":"I am at peace with my own rhythm.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0698","text":"I trust the unfolding of my life.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0699","text":"I release what I cannot fix.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0700","text":"I am more than my thoughts.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0701","text":"I am grounded, present, and aware.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0702","text":"I find safety within myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0703","text":"I am open to unexpected blessings.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0704","text":"I am deeply and completely loved.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0705","text":"I attract what I put out into the world.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0706","text":"I am free to be exactly who I am.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0707","text":"I live from my values, not my fears.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0708","text":"I do not need to be perfect to be worthy.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0709","text":"I release the stories that hold me back.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0710","text":"I am exactly enough today.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0711","text":"I celebrate how far I've come.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0712","text":"I make decisions aligned with my highest good.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0713","text":"I am patient with myself and others.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0714","text":"I choose thoughts that empower me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0715","text":"I am a force for good in the world.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0716","text":"My life is meaningful and purposeful.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0717","text":"I choose love over fear.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0718","text":"I am expanding in awareness and wisdom.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0719","text":"I welcome new possibilities with an open mind.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0720","text":"I am a confident and capable person.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0721","text":"I draw boundaries from a place of love.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0722","text":"I nourish myself intentionally.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0723","text":"I show up for myself every single day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0724","text":"I am creative, capable, and resourceful.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0725","text":"I trust that I am always guided.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0726","text":"I release perfectionism and choose progress.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0727","text":"I am connected to others through our shared humanity.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0728","text":"I choose kindness, starting with myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0729","text":"I am in alignment with my deepest truth.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0730","text":"I honor my sensitivity as a strength.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0731","text":"I am learning to love myself more each day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0732","text":"I protect my peace fiercely.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0733","text":"I listen to my inner wisdom.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0734","text":"I am grateful for my mind, body, and spirit.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0735","text":"I choose ease over struggle where I can.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0736","text":"I am not too much, and I am not too little — I am just right.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0737","text":"I am a gift to the people in my life.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0738","text":"I recognize my own beauty.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0739","text":"I live with an open and courageous heart.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0740","text":"I bring light to the spaces I inhabit.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0741","text":"I trust the ground beneath my feet.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0742","text":"I allow joy to flow freely into my life.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0743","text":"I lean into life with curiosity.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0744","text":"I am proud of who I am.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0745","text":"I release the need to compare my insides to others' outsides.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0746","text":"I honor the small victories that happen every day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0747","text":"I am planting seeds today for a harvest tomorrow.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0748","text":"I breathe deeply and find peace.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0749","text":"I trust my body's signals.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0750","text":"I choose nourishing thoughts.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0751","text":"I am in charge of my own happiness.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0752","text":"I hold space for joy even in uncertain times.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0753","text":"I find strength in community.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0754","text":"I let others' success inspire me.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0755","text":"I am anchored in love.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0756","text":"I release the pressure to have it all figured out.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0757","text":"I lean on my support system when I need to.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0758","text":"I take meaningful breaks without guilt.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0759","text":"I am resilient, resourceful, and ready.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0760","text":"I choose relationships that reflect my worth.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0761","text":"I communicate my needs clearly and lovingly.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0762","text":"I see myself with clear and compassionate eyes.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0763","text":"I am worthy of the life I am dreaming of.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0764","text":"I create beauty in my everyday life.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0765","text":"I am making meaningful progress.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0766","text":"I am fulfilled by the work I do.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0767","text":"I rest knowing tomorrow is a fresh start.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0768","text":"I am gentle with the parts of me still healing.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0769","text":"I am seen, heard, and valued.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0770","text":"I live fully in the present.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0771","text":"I am exactly where I need to be right now.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0772","text":"I choose to believe in myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0773","text":"I am open to being pleasantly surprised.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0774","text":"I forgive others as an act of freedom for myself.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0775","text":"I choose what I allow into my heart and mind.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0776","text":"I am curious, engaged, and alive.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0777","text":"I nourish the seeds of my dreams.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0778","text":"I take up space without apology.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0779","text":"I am radiant from within.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0780","text":"I am worthy of abundance in all its forms.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0781","text":"I show myself the same mercy I would show anyone I love.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0782","text":"I am enough — right now, as I am.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0783","text":"I trust that the universe is conspiring in my favor.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0784","text":"I am building a life I love, one day at a time.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0785","text":"I am courageous in my imperfection.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0786","text":"I am full of untapped potential.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0787","text":"I continue to grow even when growth is uncomfortable.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0788","text":"I believe in miracles and possibilities.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0789","text":"I am a work in progress worth celebrating.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0790","text":"I release the past and step boldly into my future.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0791","text":"I am loved beyond measure.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0792","text":"I do enough. I have enough. I am enough.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0793","text":"I find comfort in the constancy of my own breath.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0794","text":"I am becoming the person I have always hoped to be.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0795","text":"I honor myself in all that I do.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0796","text":"I carry hope with me everywhere I go.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0797","text":"I am the author of my own story.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0798","text":"I am powered by love, courage, and intention.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0799","text":"I wake up grateful and go to sleep at peace.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0800","text":"I am whole, worthy, and free.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0801","text":"I trust the process of my own becoming.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0802","text":"I am ready for what comes next.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0803","text":"I celebrate my existence every single day.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true},{"id":"affirm-core-0804","text":"I am enough, and I always will be.","author":"QuoteIt","source":"Affirmations Core","tags":["audience:meditation","audience:morning","language:en","theme:mental-health","theme:mental-health,self-worth","theme:self-worth","tradition:secular"],"isProverb":false,"isVerified":true,"isAffirmation":true}]}
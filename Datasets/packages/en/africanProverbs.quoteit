{"formatVersion":"1","manifest":{"sourceId":"africanProverbs","displayName":"African Proverbs","type":"quotes","language":"English","edition":"Public Domain Collection","primaryCategory":"Proverbs & Folk Wisdom","subcategory":"African","audienceTags":["wisdom","short-form"],"sortPriority":61,"itemCount":50,"supportsRandom":true,"supportsBrowse":true,"browseOrder":"sequence","groupingLevels":["region","topic"],"groupingLabels":["Region","Topic"],"dataPath":"Data/Collections/African_Proverbs.json","version":"1.0"},"data":[{"id":"africa-prov-1","text":"I am because we are.","author":"West Africa Proverb","source":"African Proverb — West Africa (Ubuntu)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"West Africa","topic":"Ubuntu"},"sequenceIndex":0},{"id":"africa-prov-2","text":"Umuntu ngumuntu ngabantu — A person is a person through other persons.","author":"South Africa Proverb","source":"African Proverb — South Africa (Ubuntu)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"South Africa","topic":"Ubuntu"},"sequenceIndex":1},{"id":"africa-prov-3","text":"It takes a village to raise a child.","author":"West Africa Proverb","source":"African Proverb — West Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"West Africa","topic":"General"},"sequenceIndex":2},{"id":"africa-prov-4","text":"Onye wetara oji wetara ndu — He who brings kola brings life.","author":"Nigeria Proverb","source":"African Proverb — Nigeria (Igbo)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Nigeria","topic":"Igbo"},"sequenceIndex":3},{"id":"africa-prov-5","text":"Until the lion learns to write, every story will glorify the hunter.","author":"West Africa Proverb","source":"African Proverb — West Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"West Africa","topic":"General"},"sequenceIndex":4},{"id":"africa-prov-6","text":"Haraka haraka haina baraka — Hurry hurry has no blessings.","author":"East Africa Proverb","source":"African Proverb — East Africa (Swahili)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"East Africa","topic":"Swahili"},"sequenceIndex":5},{"id":"africa-prov-7","text":"When spider webs unite, they can tie up a lion.","author":"Ethiopia Proverb","source":"African Proverb — Ethiopia (Amharic)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Ethiopia","topic":"Amharic"},"sequenceIndex":6},{"id":"africa-prov-8","text":"A man who has children does not die.","author":"Kenya Proverb","source":"African Proverb — Kenya (Kikuyu)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Kenya","topic":"Kikuyu"},"sequenceIndex":7},{"id":"africa-prov-9","text":"If you want to go fast, go alone. If you want to go far, go together.","author":"Ghana Proverb","source":"African Proverb — Ghana (Akan)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Ghana","topic":"Akan"},"sequenceIndex":8},{"id":"africa-prov-10","text":"However long the night, the dawn will break.","author":"Nigeria Proverb","source":"African Proverb — Nigeria (Yoruba)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Nigeria","topic":"Yoruba"},"sequenceIndex":9},{"id":"africa-prov-11","text":"Speak softly and carry a big stick; you will go far.","author":"East Africa Proverb","source":"African Proverb — East Africa (Swahili)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"East Africa","topic":"Swahili"},"sequenceIndex":10},{"id":"africa-prov-12","text":"A child who is not embraced by the village will burn it down to feel its warmth.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":11},{"id":"africa-prov-13","text":"The axe forgets, but the tree remembers.","author":"West Africa Proverb","source":"African Proverb — West Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"West Africa","topic":"General"},"sequenceIndex":12},{"id":"africa-prov-14","text":"Wisdom does not come overnight.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":13},{"id":"africa-prov-15","text":"He who does not know one thing knows another.","author":"Nigeria Proverb","source":"African Proverb — Nigeria (Yoruba)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Nigeria","topic":"Yoruba"},"sequenceIndex":14},{"id":"africa-prov-16","text":"The forest would be silent if no bird sang except those that sang best.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":15},{"id":"africa-prov-17","text":"Do not call the forest that shelters you a jungle.","author":"South Africa Proverb","source":"African Proverb — South Africa (Zulu)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"South Africa","topic":"Zulu"},"sequenceIndex":16},{"id":"africa-prov-18","text":"Rain does not fall on one roof alone.","author":"West Africa Proverb","source":"African Proverb — West Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"West Africa","topic":"General"},"sequenceIndex":17},{"id":"africa-prov-19","text":"A tree is straightened while it is young.","author":"East Africa Proverb","source":"African Proverb — East Africa (Swahili)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"East Africa","topic":"Swahili"},"sequenceIndex":18},{"id":"africa-prov-20","text":"Not everyone who chased the zebra caught it, but he who caught it chased it.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":19},{"id":"africa-prov-21","text":"A coward leaves no scar.","author":"Kenya Proverb","source":"African Proverb — Kenya (Kikuyu)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Kenya","topic":"Kikuyu"},"sequenceIndex":20},{"id":"africa-prov-22","text":"When the music changes, so does the dance.","author":"West Africa Proverb","source":"African Proverb — West Africa (Akan)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"West Africa","topic":"Akan"},"sequenceIndex":21},{"id":"africa-prov-23","text":"Inhlanhla ayilalelwa — Luck is not waited for.","author":"South Africa Proverb","source":"African Proverb — South Africa (Zulu)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"South Africa","topic":"Zulu"},"sequenceIndex":22},{"id":"africa-prov-24","text":"Show me your friend and I will show you your character.","author":"Nigeria Proverb","source":"African Proverb — Nigeria (Hausa)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Nigeria","topic":"Hausa"},"sequenceIndex":23},{"id":"africa-prov-25","text":"Wisdom is like a baobab tree; no one individual can embrace it.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":24},{"id":"africa-prov-26","text":"A generous heart, kind speech, and a life of service and compassion are the things which renew humanity.","author":"Ethiopia Proverb","source":"African Proverb — Ethiopia (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Ethiopia","topic":"General"},"sequenceIndex":25},{"id":"africa-prov-27","text":"Knowledge is like a garden: if it is not cultivated, it cannot be harvested.","author":"West Africa Proverb","source":"African Proverb — West Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"West Africa","topic":"General"},"sequenceIndex":26},{"id":"africa-prov-28","text":"A river that forgets its source will dry up.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":27},{"id":"africa-prov-29","text":"Kidole kimoja hakivunji chawa — One finger cannot kill a louse.","author":"Tanzania Proverb","source":"African Proverb — Tanzania (Swahili)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Tanzania","topic":"Swahili"},"sequenceIndex":28},{"id":"africa-prov-30","text":"Onye obula bu ulo ya — Every person is his own home.","author":"Nigeria Proverb","source":"African Proverb — Nigeria (Igbo)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Nigeria","topic":"Igbo"},"sequenceIndex":29},{"id":"africa-prov-31","text":"The opportunity that God sends does not wake up him who is asleep.","author":"Ghana Proverb","source":"African Proverb — Ghana (Akan)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Ghana","topic":"Akan"},"sequenceIndex":30},{"id":"africa-prov-32","text":"Wisdom is not like money to be tied up and hidden.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":31},{"id":"africa-prov-33","text":"If you do not have patience, you cannot make beer from water.","author":"West Africa Proverb","source":"African Proverb — West Africa (Wolof)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"West Africa","topic":"Wolof"},"sequenceIndex":32},{"id":"africa-prov-34","text":"However long the night, the day is sure to come.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":33},{"id":"africa-prov-35","text":"Unyamezele — Endure.","author":"South Africa Proverb","source":"African Proverb — South Africa (Xhosa)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"South Africa","topic":"Xhosa"},"sequenceIndex":34},{"id":"africa-prov-36","text":"A fool and water will go the way they are diverted.","author":"Ethiopia Proverb","source":"African Proverb — Ethiopia (Amharic)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Ethiopia","topic":"Amharic"},"sequenceIndex":35},{"id":"africa-prov-37","text":"A bird that flies off the earth and lands on an anthill is still on the ground.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":36},{"id":"africa-prov-38","text":"Ori buruku ko gbadura — An evil head does not respond to prayer.","author":"Nigeria Proverb","source":"African Proverb — Nigeria (Yoruba)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Nigeria","topic":"Yoruba"},"sequenceIndex":37},{"id":"africa-prov-39","text":"The one who tells the stories rules the world.","author":"West Africa Proverb","source":"African Proverb — West Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"West Africa","topic":"General"},"sequenceIndex":38},{"id":"africa-prov-40","text":"Speak gently; the strength of your words will carry far.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":39},{"id":"africa-prov-41","text":"Even the mightiest eagle comes down to earth to drink.","author":"Cameroon Proverb","source":"African Proverb — Cameroon (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Cameroon","topic":"General"},"sequenceIndex":40},{"id":"africa-prov-42","text":"If you have no teeth, do not break the clay pot.","author":"Kenya Proverb","source":"African Proverb — Kenya (Luo)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Kenya","topic":"Luo"},"sequenceIndex":41},{"id":"africa-prov-43","text":"A child that is not loved by its mother cries for no reason.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":42},{"id":"africa-prov-44","text":"Cattle are born with ears, their horns grow later.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":43},{"id":"africa-prov-45","text":"Before you ask a man for clothes, look at the clothes he is wearing.","author":"Niger Proverb","source":"African Proverb — Niger (Hausa)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Niger","topic":"Hausa"},"sequenceIndex":44},{"id":"africa-prov-46","text":"You cannot climb the ladder of success dressed in the costume of failure.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":45},{"id":"africa-prov-47","text":"Cross the river in a crowd and the crocodile won't eat you.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":46},{"id":"africa-prov-48","text":"Only a fool tests the depth of a river with both feet.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":47},{"id":"africa-prov-49","text":"If your mouth turns into a knife, it will cut off your lips.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":48},{"id":"africa-prov-50","text":"When you follow the path of your father, you learn to walk like him.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["proverb","africa","wisdom","language:english","collection:africanproverbs"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":49}]}
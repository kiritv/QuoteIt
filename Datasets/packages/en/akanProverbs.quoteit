{"formatVersion":"1","manifest":{"primaryCategory":"Proverbs & Folk Wisdom","subcategory":"African","audienceTags":["tradition:animism","theme:wisdom","theme:truth"],"sortPriority":63,"groupingLevels":[],"groupingLabels":[],"dataPath":"Data/Collections/Akan_Proverbs.json","supplementalDataPath":null,"languageCode":"en","displayNameEnglish":"Akan Proverbs","script":"Latin","isRTL":false,"transliterationAvailable":false,"contentRating":"general","sourceId":"akanProverbs","displayName":"Akan Proverbs","version":"1.0","language":"English","edition":"Christaller, Rattray & Burton Collections","type":"quotes","browseOrder":"sequence","itemCount":167,"supportsRandom":true,"supportsBrowse":true},"data":[{"id":"akan-000001","text":"Onipa na ohia onipa.","author":"Akan Proverb","source":"Akan proverb — Christaller 1879","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000002","text":"Obra wo ho a, work wo ho.","author":"Akan Proverb","source":"Akan oral tradition","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000003","text":"Wo pe se obi te wo asem a, ka no kyere no.","author":"Akan Proverb","source":"Akan oral tradition","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000004","text":"Suro nipa a, suro ne dee oye.","author":"Akan Proverb","source":"Akan oral tradition — Rattray 1916","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000005","text":"Obi kyere obi akwan a, yenyi no akwan.","author":"Akan Proverb","source":"Akan oral tradition","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000006","text":"Obi nkyere onipa se ohia nsu na osu a, suro no.","author":"Akan Proverb","source":"Akan oral tradition","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000007","text":"Akyere se ananse beye den a, anka nsa nni ho.","author":"Akan Proverb","source":"Akan oral tradition — Rattray 1916","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000008","text":"By the time the fool has learned the game, the players have dispersed.","author":"Akan Proverb","source":"Akan proverb — Christaller 1879","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000009","text":"Do not look where you fell, but where you slipped.","author":"Akan Proverb","source":"Akan proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000010","text":"The ruin of a nation begins in the homes of its people.","author":"Akan Proverb","source":"Akan proverb — Akan tradition","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000011","text":"A child who is not taught will sell the family's heritage.","author":"Akan Proverb","source":"Akan proverb — Christaller 1879","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000012","text":"It is the calm and silent water that drowns a man.","author":"Akan Proverb","source":"Akan proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000013","text":"You do not teach the paths of the forest to an old gorilla.","author":"Akan Proverb","source":"Akan proverb — Akan tradition","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000014","text":"It is the duty of children to wait on elders, and not the elders on children.","author":"Akan Proverb","source":"Akan proverb — Rattray 1916","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000015","text":"When a king has good counselors, his reign is peaceful.","author":"Akan Proverb","source":"Akan proverb — Akan tradition","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000016","text":"Wisdom is not like money to be tied up and hidden.","author":"Akan Proverb","source":"Akan proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000017","text":"The sky is vast enough for all birds to fly without colliding.","author":"Akan Proverb","source":"Akan proverb","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000018","text":"One does not cross the river without getting wet.","author":"Akan Proverb","source":"Akan proverb — Christaller 1879","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000019","text":"A tree is known by its fruit; a man by his deeds.","author":"Akan Proverb","source":"Akan proverb","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000020","text":"The chicken that digs for food will not sleep hungry.","author":"Akan Proverb","source":"Akan proverb","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000021","text":"When the chief limps, all his subjects limp.","author":"Akan Proverb","source":"Akan proverb — Rattray 1916","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000022","text":"No one boasts of what belongs to another.","author":"Akan Proverb","source":"Akan proverb — Christaller 1879","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000023","text":"Home affairs are not talked about on the public square.","author":"Akan Proverb","source":"Akan proverb","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000024","text":"A man's character is his guardian divinity.","author":"Akan Proverb","source":"Akan proverb","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000025","text":"The eye that has traveled is wiser than the elder who has only stayed at home.","author":"Akan Proverb","source":"Akan proverb","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000026","text":"One falsehood spoils a thousand truths.","author":"Akan Proverb","source":"Akan proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000027","text":"Rain beats a leopard's skin, but it does not wash out the spots.","author":"Akan Proverb","source":"Akan proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000028","text":"The poor man and the rich man do not play together.","author":"Akan Proverb","source":"Akan proverb — Christaller 1879","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000029","text":"It is not wrong to go back for what you forgot.","author":"Akan Proverb","source":"Akan proverb (Sankofa)","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000030","text":"If you are filled with pride, then you will have no room for wisdom.","author":"Akan Proverb","source":"Akan proverb","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"akan-000031","text":"_Et leo factus est, et desolata est terra et plenitudo ejus a voce rugitûs illius._","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000032","text":"A tous ces faits je ne puis m'empêcher d'en ajouter encore un, connu de tout le monde, mais qui n'en est pas moins remarquable; c'est la prise de Jérusalem par Tite.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000033","text":"1, 2.] _inanis et vacua_; c'est peut dire, elle était tout entière souillée et impure (il faut se souvenir que je parle ici des païens), et n'était devant [Marge: Gen.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000034","text":"6, 11.] lui qu'une retraite d'hommes ingrats et perfides, comme au temps du déluge: _Corrupta est terra coram Deo, et repleta est iniquitate_.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000035","text":"Cet obstacle aurait trop retardé le cours rapide qu'il avait promis aux premiers prédicateurs de la doctrine de son Fils.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000036","text":"Il a jeté de loin dans l'esprit des hommes des semences de plusieurs grandes vérités, pour les disposer à en recevoir d'autres plus importantes.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000037","text":"[Marge: Talents extérieurs accordés aux païens.] Elle doit aussi nous apprendre le cas qu'il faut faire de tout ce qu'il y a de plus brillant dans le monde, et de ce qui est le plus capable d'éblouir.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000038","text":"143, 15.] _Beatum dixerunt populum cui hæc sunt: beatus populus, cujus dominus Deus ejus_.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000039","text":"[Marge: Être sobre dans les louanges qu'on leur donne.] Une dernière réflexion, qui suit naturellement de ce que j'ai dit jusqu'ici, terminera cette première partie de ma Préface.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000040","text":"Il ne faut pas pourtant s'imaginer que S.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000041","text":"Augustin ait cru qu'il ne fût pas permis d'admirer ou de louer ce qu'il y a de beau dans les actions et de vrai dans les maximes des païens.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000042","text":"Il veut[15] qu'on y corrige ce qui se trouve de défectueux, et qu'on y approuve ce qu'elles ont de conforme à la règle.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000043","text":"Il loue les Romains en plusieurs occasions, et surtout dans ses livres de la Cité de Dieu, qui est l'un de ses derniers et de ses plus beaux ouvrages.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000044","text":"Ce ne sont donc point les louanges des païens en elles-mêmes, mais l'excès de ces louanges, que Saint Augustin condamne.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000045","text":"[Note 15: «Id in quoque corrigendum, quod pravum est; quod autem rectum est, approbandum.» (_De Bapt. cont. Donat._ lib. 7, cap. 16.)]","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000046","text":"Je reconnais en effet qu'il m'est échappé quelquefois des termes trop forts, et qui ne sont pas assez mesurés.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000047","text":"19.] _Illud constat inter omnes veraciter pios, neminem sine vera pietate, id est, veri Dei vero cultu, veram posse habere virtutem; nec eam veram esse, quando gloriæ servit humanæ_.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000048","text":"Un léger correctif, ajouté à ce récit, aurait ôté toute équivoque et tout lieu de plainte.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000049","text":"_Observations particulières sur cet ouvrage._","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000050","text":"Je souhaiterais pouvoir éviter en même temps et la stérile sécheresse des abrégés, qui ne donnent aucune idée distincte, et l'ennuyeuse exactitude des longues histoires, qui accablent un lecteur.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000051","text":"Le goût du public deviendra ma règle, et je tâcherai dans la suite de m'y conformer.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000052","text":"J'ai eu le bonheur de ne pas lui déplaire dans le premier ouvrage que j'ai composé.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000053","text":"Je souhaiterais bien que celui-ci eût un pareil succès, mais je n'oserais l'espérer.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000054","text":"Ici je n'ai pas le même avantage.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000055","text":"Je ne suis pas tout-à-fait le maître du choix.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000056","text":"La suite fournira des matières plus agréables, et des événements qui attachent davantage; et je ne manquerai pas de faire usage des précieuses richesses que les meilleurs auteurs nous offriront.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000057","text":"Il est aisé d'appliquer cette image à la composition de l'Histoire.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000058","text":"[Note 16: «Arborum flos est pleni veris indicium et anni renascentis; flos gaudium arborum.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000059","text":"Tunc se novas, aliasque quàm sunt, ostendunt: tunc variis colorum picturis in certamen usque luxuriant.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000060","text":"Sed hoc negatum plerisque.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000061","text":"Non enim omnes florent, et sunt tristes quædam, quæque non sentiunt gaudia annorum; nec ullo flore exhilarantur, natalesve pomorum recursus annuos versicolori nuntio promittunt.» (PLIN.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000062","text":"[Note 17: Comme les figuiers.]","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000063","text":"Je profite, autant que je puis, des solides réflexions que l'on trouve dans la seconde et la troisième partie de l'Histoire universelle de M.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000064","text":"Bossuet, qui est l'un des plus beaux et des plus utiles ouvrages que nous ayons.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000065","text":"Je tire aussi de grands secours de l'Histoire des Juifs, du savant M.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000066","text":"Prideaux, Anglais, où il a merveilleusement approfondi et éclairci ce qui regarde l'Histoire ancienne.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000067","text":"Il en sera ainsi de tout ce qui me tombera sous la main, dont je ferai tout l'usage qui pourra convenir à la composition de mon livre, et contribuer à sa perfection.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000068","text":"Je ne puis pas dire précisément de combien de volumes sera composé mon ouvrage; mais j'entrevois qu'il n'ira pas à moins de cinq ou six.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000069","text":"Des écoliers, pour peu qu'ils soient studieux, pourront faire aisément cette lecture en particulier dans le cours d'une année, sans que leurs autres études en souffrent.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000070","text":"Il aurait été utile, et même nécessaire, de donner à mes lecteurs quelque idée et quelque connaissance des auteurs anciens d'où je tire les faits que je rapporte ici.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000071","text":"La suite même de l'Histoire me donnera lieu d'en parler, et m'en fournira une occasion naturelle.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000072","text":"Cette religion était fausse, et ce culte mal entendu; mais le principe en était louable, et fondé sur la nature.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000073","text":"C'était un ruisseau corrompu qui partait d'une bonne source.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000074","text":"Du côté de l'exécution, il n'est pas moins faible et moins impuissant.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000075","text":"Ces ténèbres, cette faiblesse, l'obligent de recourir à une lumière et à une puissance supérieure.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000076","text":"Il a bien voulu se manifester à eux; et les conduire par des apparitions, par des songes, par des oracles, par des prophéties, et les protéger par des prodiges éclatants.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000077","text":"Tout ce que je viens de rapporter était un usage reçu et observé généralement parmi tous les peuples; et cet usage était fondé sur les principes de religion que j'ai montrés sommairement.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000078","text":"«Comme les dieux sont éternels, dit Cambyse à son fils, ils savent tout, et connaissent également le passé, le présent et l'avenir.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000079","text":"Entre ceux qui les consultent, ils donnent des avis salutaires à ceux qu'ils veulent favoriser, pour leur faire connaître ce qu'il faut faire et ce qu'il ne faut pas entreprendre.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000080","text":"J'ai cru, par cette même raison, ne devoir pas entièrement supprimer dans l'Histoire que je donne au public ce qui regarde cette matière, quoique pourtant j'en aie retranché une grande partie.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000081","text":"Je me propose de mettre à la fin de cet ouvrage un abrégé chronologique de tous les faits, et une table exacte des matières.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000082","text":"Mon guide pour la chronologie est ordinairement Ussérius.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000083","text":"Dans l'histoire des Carthaginois, je marque le plus souvent quatre époques: l'année de la création du monde, que je désigne par ces lettres, pour abréger, AN.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000084","text":"AVERTISSEMENTS DE L'AUTEUR, RÉPANDUS DANS L'IN-12, EN DIFFÉRENTS TOMES, ET RÉUNIS ICI TOUS ENSEMBLE[18].","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000085","text":"[Note 18: Voulant donner une édition complète des oeuvres de Rollin, nous avons dû conserver ces Avertissements, quoiqu'ils semblent maintenant inutiles.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000086","text":"Il nous a donc semblé préférable de les mettre tous ensemble après la Préface, dont ils forment en quelque sorte le complément.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000087","text":"[_Note des Éditeurs._]]","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000088","text":"AVERTISSEMENT DE L'AUTEUR POUR LE TOME TROISIÈME.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000089","text":"Je me suis trouvé hors d'état de tenir ma parole.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000090","text":"Les additions que j'ai faites dans le cours de l'impression, pour tâcher de ne rien omettre d'intéressant, ont fait croître le livre plus que je ne l'avais prévu.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000091","text":"J'ai donc été obligé de m'arrêter à la déroute de l'armée des Athéniens devant Syracuse, et à la mort de Nicias, qui arrivent la dix-neuvième année de la guerre du Péloponnèse.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000092","text":"J'aurais même souhaité pouvoir finir plus tôt ce volume; mais c'est ce qu'il ne m'a pas été possible de faire, quelque envie que j'en eusse.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000093","text":"J'ai retranché tout le reste, et l'ai renvoyé au volume suivant.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000094","text":"Je l'ai priée de continuer d'avoir égard aux personnes qui s'adresseront à elle avec un témoignage de ma part.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000095","text":"Je prendrai de meilleures mesures dans la suite, et ne tomberai plus dans le même inconvénient.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000096","text":"Dès que l'impression de ce troisième volume a été achevée, on a commencé à réimprimer les deux premiers.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000097","text":"J'y ai fait quelques corrections et quelques légers changements sur les avis que des amis m'ont donnés.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000098","text":"Je les aurais marqués à la fin de ce volume, si je n'avais craint de le trop charger: je le ferai dans les volumes suivants, afin que ceux qui ont la première édition puissent en faire usage.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000099","text":"D'ailleurs, en matière de littérature, comme dans la morale, les fautes reconnues et avouées sincèrement sont oubliées, ou, pour mieux dire, ne subsistent plus.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000100","text":"AVERTISSEMENT DE L'AUTEUR POUR LE QUATRIÈME VOLUME.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000101","text":"J'en avais déjà reconnu plusieurs par moi-même.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000102","text":"Les avis qu'on m'a donnés, soit dans des lettres particulières, soit dans des écrits publics, m'en ont fait encore remarquer d'autres.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000103","text":"J'espère les corriger toutes dans l'édition suivante de mon Histoire, que l'on doit bientôt commencer.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000104","text":"Il est bien aisé de prendre son parti, lorsque la critique tombe sur des fautes marquées et sensibles: il ne s'agit alors que de reconnaître qu'on s'est trompé, et de corriger ses fautes.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000105","text":"Mais il est une autre sorte de critique qui embarrasse et laisse dans l'incertitude, parce qu'elle ne porte pas avec elle une pareille évidence; et c'est le cas où je me trouve.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000106","text":"J'en apporterai un exemple entre plusieurs autres.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000107","text":"Quelques personnes croient que, dans mon Histoire, les réflexions sont trop longues et trop fréquentes.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000108","text":"Cependant je ne suis point attaché à mon sentiment, et si je m'apercevais qu'il fût contraire à celui du public, j'y renoncerais sans peine.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000109","text":"Je reviens encore à mes jeunes gens, et il faut qu'on me le pardonne; car[19] j'avoue que je ne puis les perdre de vue, et que tout ce qui peut contribuer à leur instruction me touche sensiblement.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000110","text":"On y développe d'une manière agréable et spirituelle ce qu'il y a de plus curieux dans la nature, pour ce qui regarde les animaux terrestres, les oiseaux, les insectes, les poissons.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000111","text":"S'il m'était permis de juger du succès de ce livre par le plaisir que la lecture m'en a causé, je pourrais assurer par avance qu'il sera grand.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000112","text":"C'est à ma prière, et sur mes vives sollicitations, que l'auteur a entrepris cet ouvrage, qui peut être beaucoup augmenté, s'il se trouve au goût du public.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000113","text":"[Note 19: «Neque enim me poenitet ad hoc quoque opus meum, et curam susceptorum semel adolescentium respicere.» (QUINTIL. lib. XI, c. 1.)]","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000114","text":"_Lettre de monsieur Rousseau._","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000115","text":"J'espère que le public ne me saura pas mauvais gré d'avoir inséré ici une lettre de M.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000116","text":"L'erreur est pardonnable, et Horace souhaiterait que, dans l'amitié, elle fût plus commune qu'elle n'est.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000117","text":"Vellem in amicitia sic erraremus, et isti Errori nomen virtus posuisset honestum.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000118","text":"A Bruxelles, le 27 août 1732.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000119","text":"«J'ai bien des grâces à vous rendre, monsieur, de l'agréable présent que vous m'avez fait du quatrième volume de votre Histoire.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000120","text":"Je l'ai lu pour ainsi dire tout d'une haleine, et avec une satisfaction qui n'a été interrompue en aucun endroit.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000121","text":"La plupart lisent pour satisfaire leur curiosité, et pour pouvoir dire qu'ils ont lu.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000122","text":"Trouverez-vous même parmi les plus sensés une demi-douzaine de lecteurs qui veuillent se donner le temps et la peine de méditer sur leur lecture?","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000123","text":"et quand ils se la donneraient, est-il sûr qu'ils soient capables de méditer comme il faut et où il faut?","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000124","text":"Les uns s'attacheront à un mot ou à une expression qui ne leur aura pas plu.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000125","text":"C'est pourtant pour le plus grand nombre que vous travaillez.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000126","text":"Ne faites donc point de difficulté, monsieur, de continuer comme vous avez commencé.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000127","text":"La fonction du philosophe et celle de l'historien sont les mêmes.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000128","text":"Ne croyez pas pourtant que mon intention, en vous écrivant ceci, soit de m'ériger avec vous en donneur de conseils.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000129","text":"Je suis avec beaucoup de respect,»","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000130","text":"MONSIEUR, Votre très-humble et très-obéissant serviteur, ROUSSEAU.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000131","text":"AVERTISSEMENT DE L'AUTEUR POUR LE TOME CINQUIÈME.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000132","text":"En voici déjà un qui paraît; et j'espère que, vers le mois d'août, il sera suivi d'un autre.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000133","text":"Je serais fâché qu'on me soupçonnât d'une pareille négligence, que je regarde comme directement contraire au devoir d'un écrivain.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000134","text":"Je ne le serais guère moins qu'on attribuât cette promptitude à une heureuse fécondité de génie, à une grande facilité de composition, à un fonds de connaissances amassé de longue main.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000135","text":"Je ne me reconnais point, ou peu, à tous ces traits.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000136","text":"C'est la possession où je me suis mis dès le commencement, et dont il semble que le public m'a passé titre.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000137","text":"Outre ces secours, j'en trouve d'autres qui ne sont pas moins importants, dont le public souffrira que je lui rende ici compte, parce que ma reconnaissance ne peut pas demeurer muette plus longtemps.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000138","text":"le marquis d'Asfeld), qui se sont tous deux également distingués, chacun dans leur profession, par un mérite rare et solide, me sont aussi tous deux d'un secours infini pour mon ouvrage.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000139","text":"Qu'on juge, après cela, si Colombe ne doit pas être pour moi un séjour agréable et utile en même temps.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000140","text":"Je voudrais que ce fût encore la coutume, comme autrefois, d'inscrire ses ouvrages du lieu où on les a composés.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000141","text":"Je mettrais à la tête des miens: DE MA MAISON DE COLOMBE[20]; car le maître de celle-ci veut que je la regarde comme mienne.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000142","text":"[Note 20: E Columbano meo.]","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000143","text":"AVERTISSEMENT DE L'AUTEUR POUR LE TOME ONZIÈME.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000144","text":"Le traité des arts et des sciences m'a conduit bien plus loin que je ne pensais, et il occupera encore le douzième volume tout entier au moins.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000145","text":"Une forte inclination me portait à prendre ce parti, qui me paraissait tout-à-fait convenable, et presque nécessaire.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000146","text":"Cependant les désirs du public, qui ne sont pas obscurs sur ce sujet, m'ont fait naître quelque doute.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000147","text":"Je n'ai pas voulu me déterminer moi-même, ni prendre pour règle de ma conduite mon inclination seule.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000148","text":"J'ai consulté séparément des amis sages et éclairés, qui m'ont tous condamné à entreprendre l'Histoire romaine, j'entends celle de la république.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000149","text":"Une conformité de sentiments si peu suspecte m'a frappé; et je n'ai plus eu de peine à me rendre à un avis que j'ai regardé comme une marque certaine de la volonté de Dieu sur moi.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000150","text":"Je commencerai ce nouvel ouvrage aussitôt que j'aurai achevé l'autre, ce que j'espère qui n'ira pas loin.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000151","text":"Agé de soixante et seize ans accomplis, je n'ai pas de temps à perdre.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000152","text":"Ce n'est pas que je me flatte de pouvoir le conduire jusqu'à sa fin: je l'avancerai autant que mes forces et ma santé me le permettront.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000153","text":"Au reste, je serais bien à plaindre si je n'attendais d'autre récompense d'un si long et si pénible travail que des louanges humaines.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000154","text":"Et qui peut se flatter néanmoins d'être assez attentif pour se défendre de la surprise d'une si douce illusion?","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000155","text":"Les païens ne travaillaient que dans cette vue.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000156","text":"Aussi est-il écrit d'eux: _Receperunt mercedem suam.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000157","text":"Vani vanam,_ ajoute un Père.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000158","text":"_Ils ont reçu leur récompense, aussi vaine qu'eux_.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000159","text":"25, 21.] _O bon et fidèle serviteur, parce que vous avez été fidèle en peu de choses, je vous établirai sur beaucoup: entrez dans la joie de votre Seigneur._ FIAT, FIAT.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000160","text":"AVERTISSEMENT DE L'AUTEUR POUR LE TREIZIÈME VOLUME.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000161","text":"Me voici enfin arrivé au terme d'un Ouvrage qui m'a occupé tout entier pendant plusieurs années.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000162","text":"Je ne puis m'empêcher, en le finissant, de marquer au public ma reconnaissance pour l'accueil favorable qu'il lui a fait.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000163","text":"J'ai éprouvé de sa part une bonté et une indulgence qui m'ont étonné, et auxquelles certainement je ne m'attendais pas.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000164","text":"Quoi qu'il en soit, l'Ouvrage est enfin achevé. On trouvera à la fin de ce dernier volume deux tables, l'une chronologique, l'autre des matières.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000165","text":"[Marge: En 1738.] J'espère donner au public le premier tome de l'Histoire romaine avant le mois de septembre prochain.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000166","text":"Pour en avancer la composition, j'ai cru devoir me reposer entièrement du soin des deux tables qui terminent l'Histoire ancienne sur des personnes qui ont bien voulu s'en charger.","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"akan-000167","text":"ÉDITIONS DES PRINCIPAUX AUTEURS GRECS CITÉS DANS LE TEXTE DE L'HISTOIRE ANCIENNE[21].","author":"Akan Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:resilience","theme:truth","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."}]}
{"formatVersion":"1","manifest":{"primaryCategory":"Proverbs & Folk Wisdom","subcategory":"African","audienceTags":["tradition:animism","theme:wisdom","theme:resilience"],"sortPriority":66,"groupingLevels":[],"groupingLabels":[],"dataPath":"Data/Collections/Amharic_Wisdom.json","supplementalDataPath":null,"languageCode":"en","displayNameEnglish":"Ethiopian Wisdom","script":"Latin","isRTL":false,"transliterationAvailable":false,"contentRating":"general","sourceId":"amharicWisdom","displayName":"Ethiopian Wisdom","version":"1.0","language":"English","edition":"Amharic & Tigrinya Oral Traditions","type":"quotes","browseOrder":"sequence","itemCount":30,"supportsRandom":true,"supportsBrowse":true},"data":[{"id":"amharic-000001","text":"Tolo belo yemiyaza gena aytasam.","author":"Ethiopian Proverb","source":"Amharic proverb","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000002","text":"Le'ijoch yetekemew, l'ijoch yetelef.","author":"Ethiopian Proverb","source":"Amharic oral tradition","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000003","text":"Ye'imeba lijoch be'imeba yibelalin.","author":"Ethiopian Proverb","source":"Amharic oral tradition","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000004","text":"A fool and water will go the way they are diverted.","author":"Ethiopian Proverb","source":"Ethiopian proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000005","text":"He who learns, teaches.","author":"Ethiopian Proverb","source":"Ethiopian proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000006","text":"Coffee and love taste best when hot.","author":"Ethiopian Proverb","source":"Ethiopian proverb","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000007","text":"The fool speaks; the wise man listens.","author":"Ethiopian Proverb","source":"Ethiopian proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000008","text":"When spider webs unite, they can tie up a lion.","author":"Ethiopian Proverb","source":"Ethiopian proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000009","text":"One who runs alone cannot be outdone.","author":"Ethiopian Proverb","source":"Amharic proverb","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000010","text":"A partridge and a rabbit don't eat from the same garden.","author":"Ethiopian Proverb","source":"Amharic oral tradition","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000011","text":"Where the heart is willing, it will find a thousand ways; where it is not, a thousand excuses.","author":"Ethiopian Proverb","source":"Ethiopian proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000012","text":"Do not blame God for having created the tiger; thank him for not having given it wings.","author":"Ethiopian Proverb","source":"Ethiopian proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000013","text":"The wise man does not speak without reason; the fool never speaks with one.","author":"Ethiopian Proverb","source":"Amharic oral tradition","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000014","text":"Even if you are small, do great things.","author":"Ethiopian Proverb","source":"Amharic oral tradition","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000015","text":"Truth does not fear examination.","author":"Ethiopian Proverb","source":"Tigrinya proverb","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000016","text":"A dog knows its master; a man knows his king.","author":"Ethiopian Proverb","source":"Amharic oral tradition","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000017","text":"One bird in hand is better than ten in the forest.","author":"Ethiopian Proverb","source":"Ethiopian proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000018","text":"If you offend, ask for pardon; if offended, forgive.","author":"Ethiopian Proverb","source":"Ethiopian proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000019","text":"Confiding a secret to an unworthy person is like carrying grain in a bag with holes.","author":"Ethiopian Proverb","source":"Ethiopian proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000020","text":"Patience is the mother of a beautiful child.","author":"Ethiopian Proverb","source":"Bantu proverb — widely adopted Ethiopian variant","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000021","text":"Hurry, hurry has no blessing.","author":"Ethiopian Proverb","source":"Ethiopian/Swahili proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000022","text":"The cattle is as good as the pasture in which it grazes.","author":"Ethiopian Proverb","source":"Amharic oral tradition","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000023","text":"A tree is known by its fruit.","author":"Ethiopian Proverb","source":"Ethiopian proverb — widely attributed","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000024","text":"What is said over the dead lion's body could not be said to him alive.","author":"Ethiopian Proverb","source":"Ethiopian proverb","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000025","text":"Without a leader, black ants are confused.","author":"Ethiopian Proverb","source":"Ethiopian proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000026","text":"Unity among fools is dangerous.","author":"Ethiopian Proverb","source":"Amharic oral tradition","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000027","text":"A good name is better than silver and gold.","author":"Ethiopian Proverb","source":"Ethiopian proverb","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000028","text":"It is better to walk than to curse the road.","author":"Ethiopian Proverb","source":"Senegalese/West African proverb","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000029","text":"The child who is not embraced by the village will burn it down to feel its warmth.","author":"Ethiopian Proverb","source":"Ethiopian/Zulu variant — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"amharic-000030","text":"Every sunrise brings a new day with new hopes.","author":"Ethiopian Proverb","source":"Ethiopian proverb — widely documented","tags":["audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."}]}
{"formatVersion":"1","manifest":{"primaryCategory":"Proverbs & Folk Wisdom","subcategory":"African","audienceTags":["tradition:animism","theme:wisdom","theme:community"],"sortPriority":67,"groupingLevels":[],"groupingLabels":[],"dataPath":"Data/Collections/Igbo_Proverbs.json","supplementalDataPath":null,"languageCode":"en","displayNameEnglish":"Igbo Proverbs","script":"Latin","isRTL":false,"transliterationAvailable":false,"contentRating":"general","sourceId":"igboProverbs","displayName":"Igbo Proverbs","version":"1.0","language":"English","edition":"Achebe-Documented & Oral Tradition","type":"quotes","browseOrder":"sequence","itemCount":30,"supportsRandom":true,"supportsBrowse":true},"data":[{"id":"igbo-000001","text":"Onye wetara oji wetara ndu.","author":"Igbo Proverb","source":"Igbo oral tradition — Achebe documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000002","text":"Egbe bere, ugo bere, nke si ibe ya ebena, nku kwa ya.","author":"Igbo Proverb","source":"Igbo proverb — Achebe, 'Things Fall Apart'","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000003","text":"Ofu onye anaghi azu madu.","author":"Igbo Proverb","source":"Igbo proverb — community wisdom","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000004","text":"Onye nwe ulo nwe uwa.","author":"Igbo Proverb","source":"Igbo oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000005","text":"When the moon is shining the cripple becomes hungry for a walk.","author":"Igbo Proverb","source":"Igbo proverb — Achebe, 'Things Fall Apart'","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000006","text":"A toad does not run in the daytime for nothing.","author":"Igbo Proverb","source":"Igbo proverb — Achebe documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000007","text":"Until the lion learns to write, every story will glorify the hunter.","author":"Igbo Proverb","source":"Igbo/Yoruba variant — widely documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000008","text":"The lizard that jumped from the high iroko tree said he would praise himself if no one else did.","author":"Igbo Proverb","source":"Igbo proverb — Achebe, 'Things Fall Apart'","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000009","text":"When old people speak it is not because of the sweetness of words in our mouths; it is because we see something you do not see.","author":"Igbo Proverb","source":"Igbo oral tradition — Achebe, 'Things Fall Apart'","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000010","text":"A man who pays respect to the great paves the way for his own greatness.","author":"Igbo Proverb","source":"Igbo proverb — Achebe, 'Things Fall Apart'","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000011","text":"If a child washes his hands he could eat with kings.","author":"Igbo Proverb","source":"Igbo proverb — Achebe, 'Things Fall Apart'","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000012","text":"When the roof falls, the lizard runs for cover.","author":"Igbo Proverb","source":"Igbo oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000013","text":"Proverbs are the palm oil with which words are eaten.","author":"Igbo Proverb","source":"Igbo proverb — Achebe, 'Things Fall Apart'","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000014","text":"Chi onye wu ya chi.","author":"Igbo Proverb","source":"Igbo oral tradition — one's personal god","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000015","text":"The fly that has no one to advise it follows the corpse into the ground.","author":"Igbo Proverb","source":"Igbo proverb — Achebe documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000016","text":"A man who makes trouble for others is also making it for himself.","author":"Igbo Proverb","source":"Igbo proverb","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000017","text":"Looking at a king's mouth one would never think he sucked at his mother's breast.","author":"Igbo Proverb","source":"Igbo proverb — Achebe documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000018","text":"When suffering knocks at your door and you say there is no seat for him, he tells you not to worry because he has brought his own stool.","author":"Igbo Proverb","source":"Igbo proverb — Achebe documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000019","text":"Those whose palm kernels were cracked for them by a benevolent spirit should not forget to be humble.","author":"Igbo Proverb","source":"Igbo proverb — Achebe, 'Things Fall Apart'","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000020","text":"A child that is not taught will sell the family heritage.","author":"Igbo Proverb","source":"Igbo oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000021","text":"Let the kite perch and let the eagle perch too.","author":"Igbo Proverb","source":"Igbo proverb — Achebe, 'Things Fall Apart'","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000022","text":"Never kill a man who says nothing.","author":"Igbo Proverb","source":"Igbo proverb","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000023","text":"An elder does not sit at home while the goat gives birth tied.","author":"Igbo Proverb","source":"Igbo oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000024","text":"What an old man sees sitting, a young man cannot see standing.","author":"Igbo Proverb","source":"Igbo proverb — widely documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000025","text":"The cock that crows in the morning belongs to one household but his voice is the property of the neighborhood.","author":"Igbo Proverb","source":"Igbo oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000026","text":"A man who does not know where the rain began to beat him cannot say where he dried his body.","author":"Igbo Proverb","source":"Igbo proverb — Achebe documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000027","text":"An old woman is always uneasy when dry bones are mentioned in a proverb.","author":"Igbo Proverb","source":"Igbo proverb — Achebe documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000028","text":"Having one child makes you a mother; having two makes you a woman.","author":"Igbo Proverb","source":"Igbo oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000029","text":"The sun will shine on those who stand before it shines on those who kneel under them.","author":"Igbo Proverb","source":"Igbo oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"igbo-000030","text":"He who will not endure the pain of the needle will not wear the beauty of the cloth.","author":"Igbo Proverb","source":"Igbo oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."}]}
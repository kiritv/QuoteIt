{"formatVersion":"1","manifest":{"primaryCategory":"Cultural Wisdom","subcategory":"African","audienceTags":["tradition:secular","theme:justice","theme:leadership","theme:resilience"],"sortPriority":60,"groupingLevels":["author"],"groupingLabels":["Author"],"dataPath":"Data/Collections/ModernAfrican_Voices.json","supplementalDataPath":null,"languageCode":"en","displayNameEnglish":"Modern African Voices","script":"Latin","isRTL":false,"transliterationAvailable":false,"contentRating":"general","sourceId":"modernAfricanVoices","displayName":"Modern African Voices","version":"1.0","language":"English","edition":"Mandela, Adichie, Achebe, Tutu, Maathai & More","type":"quotes","browseOrder":"sequence","itemCount":664,"supportsRandom":true,"supportsBrowse":true},"data":[{"id":"africa-prov-1","text":"I am because we are.","author":"West Africa Proverb","source":"African Proverb — West Africa (Ubuntu)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"West Africa","topic":"Ubuntu"},"sequenceIndex":0,"isVerified":true},{"id":"africa-prov-2","text":"Umuntu ngumuntu ngabantu — A person is a person through other persons.","author":"South Africa Proverb","source":"African Proverb — South Africa (Ubuntu)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"South Africa","topic":"Ubuntu"},"sequenceIndex":1,"isVerified":true},{"id":"africa-prov-3","text":"It takes a village to raise a child.","author":"West Africa Proverb","source":"African Proverb — West Africa (General)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"West Africa","topic":"General"},"sequenceIndex":2,"isVerified":true},{"id":"africa-prov-4","text":"Onye wetara oji wetara ndu — He who brings kola brings life.","author":"Nigeria Proverb","source":"African Proverb — Nigeria (Igbo)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Nigeria","topic":"Igbo"},"sequenceIndex":3,"isVerified":true},{"id":"africa-prov-5","text":"Until the lion learns to write, every story will glorify the hunter.","author":"West Africa Proverb","source":"African Proverb — West Africa (General)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"West Africa","topic":"General"},"sequenceIndex":4,"isVerified":true},{"id":"africa-prov-6","text":"Haraka haraka haina baraka — Hurry hurry has no blessings.","author":"East Africa Proverb","source":"African Proverb — East Africa (Swahili)","tags":["language:en","theme:gratitude","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"East Africa","topic":"Swahili"},"sequenceIndex":5,"isVerified":true},{"id":"africa-prov-7","text":"When spider webs unite, they can tie up a lion.","author":"Ethiopia Proverb","source":"African Proverb — Ethiopia (Amharic)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Ethiopia","topic":"Amharic"},"sequenceIndex":6,"isVerified":true},{"id":"africa-prov-8","text":"A man who has children does not die.","author":"Kenya Proverb","source":"African Proverb — Kenya (Kikuyu)","tags":["language:en","theme:action","theme:resilience","theme:wisdom","tradition:animism","tradition:confucianism"],"isProverb":true,"groups":{"region":"Kenya","topic":"Kikuyu"},"sequenceIndex":7,"isVerified":true},{"id":"africa-prov-9","text":"If you want to go fast, go alone. If you want to go far, go together.","author":"Ghana Proverb","source":"African Proverb — Ghana (Akan)","tags":["language:en","theme:resilience","theme:solitude","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Ghana","topic":"Akan"},"sequenceIndex":8,"isVerified":true},{"id":"africa-prov-10","text":"However long the night, the dawn will break.","author":"Nigeria Proverb","source":"African Proverb — Nigeria (Yoruba)","tags":["audience:evening","audience:morning","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Nigeria","topic":"Yoruba"},"sequenceIndex":9,"isVerified":true},{"id":"africa-prov-11","text":"Speak softly and carry a big stick; you will go far.","author":"East Africa Proverb","source":"African Proverb — East Africa (Swahili)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"East Africa","topic":"Swahili"},"sequenceIndex":10,"isVerified":true},{"id":"africa-prov-12","text":"A child who is not embraced by the village will burn it down to feel its warmth.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["language:en","theme:action","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":11,"isVerified":true},{"id":"africa-prov-13","text":"The axe forgets, but the tree remembers.","author":"West Africa Proverb","source":"African Proverb — West Africa (General)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"West Africa","topic":"General"},"sequenceIndex":12,"isVerified":true},{"id":"africa-prov-14","text":"Wisdom does not come overnight.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["audience:evening","language:en","theme:action","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":13,"isVerified":true},{"id":"africa-prov-15","text":"He who does not know one thing knows another.","author":"Nigeria Proverb","source":"African Proverb — Nigeria (Yoruba)","tags":["language:en","theme:action","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Nigeria","topic":"Yoruba"},"sequenceIndex":14,"isVerified":true},{"id":"africa-prov-16","text":"The forest would be silent if no bird sang except those that sang best.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["audience:evening","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":15,"isVerified":true},{"id":"africa-prov-17","text":"Do not call the forest that shelters you a jungle.","author":"South Africa Proverb","source":"African Proverb — South Africa (Zulu)","tags":["audience:evening","language:en","theme:action","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"South Africa","topic":"Zulu"},"sequenceIndex":16,"isVerified":true},{"id":"africa-prov-18","text":"Rain does not fall on one roof alone.","author":"West Africa Proverb","source":"African Proverb — West Africa (General)","tags":["language:en","theme:action","theme:resilience","theme:solitude","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"West Africa","topic":"General"},"sequenceIndex":17,"isVerified":true},{"id":"africa-prov-19","text":"A tree is straightened while it is young.","author":"East Africa Proverb","source":"African Proverb — East Africa (Swahili)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"East Africa","topic":"Swahili"},"sequenceIndex":18,"isVerified":true},{"id":"africa-prov-20","text":"Not everyone who chased the zebra caught it, but he who caught it chased it.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":19,"isVerified":true},{"id":"africa-prov-21","text":"A coward leaves no scar.","author":"Kenya Proverb","source":"African Proverb — Kenya (Kikuyu)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Kenya","topic":"Kikuyu"},"sequenceIndex":20,"isVerified":true},{"id":"africa-prov-22","text":"When the music changes, so does the dance.","author":"West Africa Proverb","source":"African Proverb — West Africa (Akan)","tags":["language:en","theme:action","theme:creativity","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"West Africa","topic":"Akan"},"sequenceIndex":21,"isVerified":true},{"id":"africa-prov-23","text":"Inhlanhla ayilalelwa — Luck is not waited for.","author":"South Africa Proverb","source":"African Proverb — South Africa (Zulu)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"South Africa","topic":"Zulu"},"sequenceIndex":22,"isVerified":true},{"id":"africa-prov-24","text":"Show me your friend and I will show you your character.","author":"Nigeria Proverb","source":"African Proverb — Nigeria (Hausa)","tags":["language:en","theme:action","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Nigeria","topic":"Hausa"},"sequenceIndex":23,"isVerified":true},{"id":"africa-prov-25","text":"Wisdom is like a baobab tree; no one individual can embrace it.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["language:en","theme:action","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":24,"isVerified":true},{"id":"africa-prov-26","text":"A generous heart, kind speech, and a life of service and compassion are the things which renew humanity.","author":"Ethiopia Proverb","source":"African Proverb — Ethiopia (General)","tags":["language:en","theme:creativity","theme:love","theme:resilience","theme:wisdom","tradition:animism","tradition:confucianism"],"isProverb":true,"groups":{"region":"Ethiopia","topic":"General"},"sequenceIndex":25,"isVerified":true},{"id":"africa-prov-27","text":"Knowledge is like a garden: if it is not cultivated, it cannot be harvested.","author":"West Africa Proverb","source":"African Proverb — West Africa (General)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"West Africa","topic":"General"},"sequenceIndex":26,"isVerified":true},{"id":"africa-prov-28","text":"A river that forgets its source will dry up.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["language:en","theme:nature","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":27,"isVerified":true},{"id":"africa-prov-29","text":"Kidole kimoja hakivunji chawa — One finger cannot kill a louse.","author":"Tanzania Proverb","source":"African Proverb — Tanzania (Swahili)","tags":["language:en","theme:action","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Tanzania","topic":"Swahili"},"sequenceIndex":28,"isVerified":true},{"id":"africa-prov-30","text":"Onye obula bu ulo ya — Every person is his own home.","author":"Nigeria Proverb","source":"African Proverb — Nigeria (Igbo)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Nigeria","topic":"Igbo"},"sequenceIndex":29,"isVerified":true},{"id":"africa-prov-31","text":"The opportunity that God sends does not wake up him who is asleep.","author":"Ghana Proverb","source":"African Proverb — Ghana (Akan)","tags":["audience:evening","language:en","theme:action","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Ghana","topic":"Akan"},"sequenceIndex":30,"isVerified":true},{"id":"africa-prov-32","text":"Wisdom is not like money to be tied up and hidden.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["language:en","theme:action","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":31,"isVerified":true},{"id":"africa-prov-33","text":"If you do not have patience, you cannot make beer from water.","author":"West Africa Proverb","source":"African Proverb — West Africa (Wolof)","tags":["language:en","theme:action","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"West Africa","topic":"Wolof"},"sequenceIndex":32,"isVerified":true},{"id":"africa-prov-34","text":"However long the night, the day is sure to come.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["audience:evening","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":33,"isVerified":true},{"id":"africa-prov-35","text":"Unyamezele — Endure.","author":"South Africa Proverb","source":"African Proverb — South Africa (Xhosa)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"South Africa","topic":"Xhosa"},"sequenceIndex":34,"isVerified":true},{"id":"africa-prov-36","text":"A fool and water will go the way they are diverted.","author":"Ethiopia Proverb","source":"African Proverb — Ethiopia (Amharic)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Ethiopia","topic":"Amharic"},"sequenceIndex":35,"isVerified":true},{"id":"africa-prov-37","text":"A bird that flies off the earth and lands on an anthill is still on the ground.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["audience:meditation","language:en","theme:creativity","theme:nature","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":36,"isVerified":true},{"id":"africa-prov-38","text":"Ori buruku ko gbadura — An evil head does not respond to prayer.","author":"Nigeria Proverb","source":"African Proverb — Nigeria (Yoruba)","tags":["language:en","theme:action","theme:resilience","theme:wisdom","tradition:animism","tradition:christianity"],"isProverb":true,"groups":{"region":"Nigeria","topic":"Yoruba"},"sequenceIndex":37,"isVerified":true},{"id":"africa-prov-39","text":"The one who tells the stories rules the world.","author":"West Africa Proverb","source":"African Proverb — West Africa (General)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"West Africa","topic":"General"},"sequenceIndex":38,"isVerified":true},{"id":"africa-prov-40","text":"Speak gently; the strength of your words will carry far.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism","tradition:confucianism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":39,"isVerified":true},{"id":"africa-prov-41","text":"Even the mightiest eagle comes down to earth to drink.","author":"Cameroon Proverb","source":"African Proverb — Cameroon (General)","tags":["language:en","theme:action","theme:creativity","theme:nature","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Cameroon","topic":"General"},"sequenceIndex":40,"isVerified":true},{"id":"africa-prov-42","text":"If you have no teeth, do not break the clay pot.","author":"Kenya Proverb","source":"African Proverb — Kenya (Luo)","tags":["language:en","theme:action","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Kenya","topic":"Luo"},"sequenceIndex":41,"isVerified":true},{"id":"africa-prov-43","text":"A child that is not loved by its mother cries for no reason.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["language:en","theme:love","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":42,"isVerified":true},{"id":"africa-prov-44","text":"Cattle are born with ears, their horns grow later.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":43,"isVerified":true},{"id":"africa-prov-45","text":"Before you ask a man for clothes, look at the clothes he is wearing.","author":"Niger Proverb","source":"African Proverb — Niger (Hausa)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Niger","topic":"Hausa"},"sequenceIndex":44,"isVerified":true},{"id":"africa-prov-46","text":"You cannot climb the ladder of success dressed in the costume of failure.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["audience:productivity","language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":45,"isVerified":true},{"id":"africa-prov-47","text":"Cross the river in a crowd and the crocodile won't eat you.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["language:en","theme:nature","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":46,"isVerified":true},{"id":"africa-prov-48","text":"Only a fool tests the depth of a river with both feet.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["language:en","theme:nature","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":47,"isVerified":true},{"id":"africa-prov-49","text":"If your mouth turns into a knife, it will cut off your lips.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":48,"isVerified":true},{"id":"africa-prov-50","text":"When you follow the path of your father, you learn to walk like him.","author":"Africa Proverb","source":"African Proverb — Africa (General)","tags":["language:en","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"groups":{"region":"Africa","topic":"General"},"sequenceIndex":49,"isVerified":true},{"id":"modern-african-000051","text":"There are thousands of people who feel that it is useless and futile for us to continue talking peace and non-violence — against a government whose only reply is savage attacks on an unarmed and defenceless people. And I think the time has come for us to consider, in the light of our experiences at this day at home, whether the methods which we have applied so far are adequate.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000052","text":"Ethiopia has always held a special place in my own imagination and the prospect of visiting attracted me more strongly than a trip to France, England and America combined. I felt I would be visiting my own genesis, unearthing the roots of what made me an African. Meeting the emperor himself would be like shaking hands with history.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000053","text":"For to be free is not merely to cast off one’s chains, but to live in a way that respects and enhances the freedom of others.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000054","text":"I hate race discrimination most intensely and in all its manifestations. I have fought it all during my life; I fight it now, and will do so until the end of my days. Even although I now happen to be tried by one whose opinion I hold in high esteem, I detest most violently the set-up that surrounds me here. It makes me feel that I am a black man in a white man's court. This should not be.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000055","text":"I must deal immediately and at some length with the question of violence. Some of the things so far told to the Court are true and some are untrue. I do not, however, deny that I planned sabotage. I did not plan it in a spirit of recklessness, nor because I have any love of violence. I planned it as a result of a calm and sober assessment of the political situation that had arisen after many years of tyranny, exploitation, and oppression of my people by the Whites.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000056","text":"During my lifetime I have dedicated myself to this struggle of the African people. I have fought against white domination, and I have fought against black domination. I have cherished the ideal of a democratic and free society in which all persons will live together in harmony and with . It is an ideal . But, my lord, if needs be, it is an ideal for which I am prepared to die.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000057","text":"The ANC has never at any period of its history advocated a revolutionary change in the economic structure of the country, nor has it, to the best of my recollection, ever condemned capitalist society.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000058","text":"Difficulties break some men but make others. No axe is sharp enough to cut the soul of a sinner who keeps on trying, one armed with the hope that he will rise even in the end.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000059","text":"I like friends who have independent minds because they tend to make you see problems from all angles.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000060","text":"I have never regarded any man as my superior, either in my life outside or inside prison.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000061","text":"Only free men can negotiate; prisoners cannot enter into contracts. Your freedom and mine cannot be separated.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000062","text":"The cause of Communism is the greatest cause in the history of mankind becasuse it seeks to remove from society all forms of oppression and exploitation, to liberate mankind and to ensure peace and prosperity to all.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000063","text":"Experience is the best legacy men could possess and never desert in life.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000064","text":"I stand here before you not as a prophet but as a humble servant of you, the people. Your tireless and heroic sacrifices have made it possible for me to be here today. I therefore place the remaining years of my life in your hands.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000065","text":"Exercise dissipates tension, and tension is the enemy of serenity. I found that I worked better and thought more clearly when I was in good physical condition, and so training became one of the inflexible disciplines of my life.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000066","text":"In Natal, apartheid is a deadly cancer in our midst, setting house against house, and eating away at the precious ties that bound us together. This strife among ourselves wastes our energy and destroys our unity. My message to those of you involved in this battle of brother against brother is this: take your guns, your knives, and your pangas, and throw them into the sea! Close down the death factories. End this war now!","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000067","text":"We are deeply concerned, both in our country and here, of the very large number of dropouts by schoolchildren. This is a very disturbing situation, because the youth of today are the leaders of tomorrow... try as much as possible to remain in school, because education is the most powerful weapon which we can use.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000068","text":"Coloured communities would like to see coloured representatives. That is not racism, that is how nature works.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000069","text":"I never think of the time I have lost. I just carry out a programme because it’s there. It’s mapped out for me.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000070","text":"Death is something inevitable. When a man has done what he considers to be his duty to his people and his country, he can rest in peace. I believe I have made that effort and that is, therefore, why I will sleep for the eternity.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000071","text":"I had no specific belief except that our cause was just, was very strong and it was winning more and more support.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000072","text":"A critical, independent and investigative press is the lifeblood of any democracy. The press must be free from state interference. It must have the economic strength to stand up to the blandishments of government officials. It must have sufficient independence from vested interests to be bold and inquiring without fear or favour. It must enjoy the protection of the constitution, so that it can protect our rights as citizens.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000073","text":"It is in the character of growth that we should learn from both pleasant and unpleasant experiences.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000074","text":"Real leaders must be ready to sacrifice all for the freedom of their people.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000075","text":"He dared to exhort nonviolence in a time when the violence of Hiroshima and Nagasaki had exploded on us; he exhorted morality when science, technology and the capitalist order had made it redundant; he replaced self-interest with group interest without minimizing the importance of self. In fact, the interdependence of the social and the personal is at the heart of his philosophy. He seeks the simultaneous and interactive development of the moral person and the moral society.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000076","text":"Friends, Comrades and fellow South Africans. I greet you all in the name of peace, democracy and freedom for all. I stand here before you not as a prophet but as a humble servant of you, the people. Your tireless and heroic sacrifices have made it possible for me to be here today. I therefore place the remaining years of my life in your hands.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000077","text":"The majority of South Africans, black and white, recognize that apartheid has no future. It has to be ended by our own decisive mass action in order to build peace and security. The mass campaign of defiance and other actions of our organization and people can only culminate in the establishment of democracy.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000078","text":"There must be an end to white monopoly on political power, and a fundamental restructuring of our political and economic systems to ensure that the inequalities of apartheid are addressed and our society thoroughly democratized.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000079","text":"Our march to freedom is irreversible. We must not allow fear to stand in our way. Universal suffrage on a common voters' roll in a united, democratic and non-racial South Africa is the only way to peace and racial harmony.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000080","text":"Peace will not come to our country and region until the apartheid system is ended. Therefore, we say we still have a struggle on our hands. Our common and noble efforts to abolish the system of white minority domination must continue. We are encouraged and strengthened by the fact of the agreement between ourselves, this Congress, as well as President [[George H. W. Bush|[George H.W.] Bush]] and his Administration, that sanctions should remain in place.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000081","text":"We have long wanted to visit your country and express the many feelings that we have about the Cuban revolution, about the role of Cuba in Africa, southern Africa, and the world. The Cuban people hold a special place in the hearts of the people of Africa. The Cuban internationalists have made a contribution to African independence, freedom, and justice, unparalleled for its principled and selfless character.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000082","text":"We admire the achievements of the Cuban revolution in the sphere of social welfare. We note the transformation from a country of imposed backwardness to universal literacy. We acknowledge your advances in the fields of health, education, and science.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000083","text":"We too are also inspired by the life and example of Jose Marti, who is not only a Cuban and Latin American hero but justly honoured by all who struggle to be free.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000084","text":"We also honour the great Che Guevara, whose revolutionary exploits, including on our own continent, were too powerful for any prison censors to hide from us. The life of Che is an inspiration to all human beings who cherish freedom. We will always honour his memory.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000085","text":"I must say that when we wanted to take up arms we approached numerous Western governments for assistance and we were never able to see any but the most junior ministers. When we visited Cuba we were received by the highest officials and were immediately offered whatever we wanted and needed. That was our earliest experience with Cuban internationalism.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000086","text":"Long live the Cuban revolution! Long live Comrade Fidel Castro!","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000087","text":"The three centuries of contact between the peoples of Africa, Europe and Asia on these shores have for too long been regarded as purely negative; as an object lesson in the incompatibility of peoples from different races, religions and cultures. Yet when viewed from another perspective, conflict can be a creative force through which the latent potential of a society is released.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000088","text":"As a movement we recognise the legitimacy of Palestinian nationalism just as we recognise the legitimacy of Zionism as a Jewish nationalism. We insist on the right of the state of Israel to exist within secure borders but with equal vigour support the Palestinian right to national self-determination.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000089","text":"South Africa needs all its people black and white; young and old; Christian, Muslim, Hindu or Jewish. There is a place for all of us provided we have the courage to work together to build that common future.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000090","text":"We stand here today as nothing more than a representative of the millions of our people who dared to rise up against a social system whose very essence is war, violence, racism, oppression, repression and the impoverishment of an entire people.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000091","text":"Because of their courage and persistence for many years, we can, today, even set the dates when all humanity will join together to celebrate one of the outstanding human victories of our century. When that moment comes, we shall, together, rejoice in a common victory over racism, apartheid and white minority rule.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000092","text":"I watched, along with all of you, as the tens of thousands of our people stood patiently in long queues for many hours. Some sleeping on the open ground overnight waiting to cast this momentous vote.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000093","text":"This is one of the most important moments in the life of our country. I stand here before you filled with deep pride and joy: — pride in the ordinary, humble people of this country. You have shown such a calm, patient determination to reclaim this country as your own, - and joy that we can loudly proclaim from the rooftops — free at last!","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000094","text":"Tomorrow, the entire ANC leadership and I will be back at our desks. We are rolling up our sleeves to begin tackling the problems our country faces. We ask you all to join us — go back to your jobs in the morning. Let's get South Africa working. For we must, together and without delay, begin to build a better life for all South Africans. This means creating jobs building houses, providing education and bringing peace and security for all.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000095","text":"Perhaps it was history that ordained that it be here, at the Cape of Good Hope that we should lay the foundation stone of our new nation. For it was here at this Cape, over three centuries ago, that there began the fateful convergence of the peoples of Africa, Europe and Asia on these shores.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000096","text":"The names of those who were incarcerated on Robben Island is a roll call of resistance fighters and democrats spanning over three centuries. If indeed this is a Cape of Good Hope, that hope owes much to the spirit of that legion of fighters and others of their calibre.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000097","text":"The people of South Africa have spoken in these elections. They want change! And change is what they will get. Our plan is to create jobs, promote peace and reconciliation, and to guarantee freedom for all South Africans.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000098","text":"Your Majesties, Your Highnesses, Distinguished Guests, Comrades and Friends. Today, all of us do, by our presence here, and by our celebrations in other parts of our country and the world, confer glory and hope to newborn liberty. Out of the experience of an extraordinary human disaster that lasted too long, must be born a society of which all humanity will be proud.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000099","text":"Our daily deeds as ordinary South Africans must produce an actual South African reality that will reinforce humanity's belief in justice, strengthen its confidence in the nobility of the human soul and sustain all our hopes for a glorious life for all. All this we owe both to ourselves and to the peoples of the world who are so well represented here today.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000100","text":"We thank all our distinguished international guests for having come to take possession with the people of our country of what is, after all, a common victory for justice, for peace, for human dignity. We trust that you will continue to stand by us as we tackle the challenges of building peace, prosperity, non-sexism, non-racialism and democracy.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000101","text":"The time for the healing of the wounds has come. The moment to bridge the chasms that divide us has come. The time to build is upon us.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000102","text":"We dedicate this day to all the heroes and heroines in this country and the rest of the world who sacrificed in many ways and surrendered their lives so that we could be free. Their dreams have become reality. Freedom is their reward.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000103","text":"Never, never and never again shall it be that this beautiful land will again experience the oppression of one by another and suffer the indignity of being the skunk of the world. Let freedom reign! The sun shall never set on so glorious a human achievement! God bless Africa!","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000104","text":"When a man is denied the right to live the life he believes in, he has no choice but to become an outlaw.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000105","text":"No one is born hating another person because of the colour of his skin, or his background, or his religion. People must learn to hate, and if they can learn to hate, they can be taught to love, for love comes more naturally to the human heart than its opposite.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000106","text":"Education is the great engine of personal development. It is through education that the daughter of a peasant can become a doctor, that the son of a mineworker can become the head of the mine, that a child of farmworkers can become the president of a great nation. It is what we make out of what we have, not what we are given, that separates one person from another.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000107","text":"A good head and a good heart are always a formidable combination.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000108","text":"I learned that courage was not the absence of fear, but the triumph over it. The brave man is not he who does not feel afraid, but he who conquers that fear.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000109","text":"In my country we go to prison first and then become President.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000110","text":"No one truly knows a nation until one has been inside its jails. A nation should not be judged by how it treats its highest citizens but its lowest ones.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000111","text":"There is nothing like returning to a place that remains unchanged to find the ways in which you yourself have altered.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000112","text":"You may succeed in delaying, but never in preventing the transition of South Africa to a democracy.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000113","text":"Any man that tries to rob me of my dignity will lose.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000114","text":"The victory of democracy in South Africa is the common achievement of all humanity.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000115","text":"The authorities liked to say that we received a balanced diet; it was indeed balanced — between the unpalatable and the inedible.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000116","text":"Prison itself is a tremendous education in the need for patience and perseverance. It is above all a test of one's commitment.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000117","text":"I always knew that someday I would once again feel the grass under my feet and walk in the sunshine as a free man.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000118","text":"I have always believed that exercise is the key not only to physical health but to peace of mind.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000119","text":"There is no easy walk to freedom anywhere, and many of us will have to pass through the valley of the shadow of death again and again before we reach the mountaintop of our desires.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000120","text":"I detest racialism because I regard it as a barbaric thing, whether it comes from a black man or a white man.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000121","text":"A man does not become a freedom fighter in the hope of winning awards, but when I was notified that I had won the 1993 Nobel peace prize jointly with Mr. F.W. de Klerk, I was deeply moved. The Nobel Peace Prize had a special meaning for me because of its involvement with South Africa... The award was a tribute to all South Africans, and especially to those who fought in the struggle; I would accept it on their behalf.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000122","text":"I have walked that long road to freedom. I have tried not to falter; I have made missteps along the way. But I have discovered the secret that after climbing a great hill, one only finds that there are many more hills to climb. I have taken a moment here to rest, to steal a view of the glorious vista that surrounds me, to look back on the distance I have come. But I can rest only for a moment, for with freedom comes responsibilities, and I dare not linger, for my long walk is not yet ended.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000123","text":"If you want to make peace with your enemy, you have to work with your enemy. Then he becomes your partner.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000124","text":"I am fundamentally an optimist. Whether that comes from nature or nurture, I cannot say. Part of being optimistic is keeping one's head pointed toward the sun, one's feet moving forward. There were many dark moments when my faith in humanity was sorely tested, but I would not and could not give myself up to despair. That way lays defeat and death.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000125","text":"I have come to join you today to add our own voice to the universal call for Palestinian self-determination and statehood. We would be beneath our own reason for existence as government and as a nation, if the resolution of the problems of the Middle East did not feature prominently on our agenda.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000126","text":"When in 1977, the United Nations passed the resolution inaugurating the International Day of Solidarity with the Palestinian people, it was asserting the recognition that injustice and gross human rights violations were being perpetrated in Palestine. In the same period, the UN took a strong stand against apartheid; and over the years, an international consensus was built, which helped to bring an end to this iniquitous system.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000127","text":"We know too well that our freedom is incomplete without the freedom of the Palestinians; without the resolution of conflicts in East Timor, the Sudan and other parts of the world.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000128","text":"I wish to take this opportunity to pay tribute to these Palestinian and Israeli leaders. In particular, we pay homage to the memory of Yitshak Rabin who paid the supreme sacrifice in pursuit of peace.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000129","text":"I was called a terrorist yesterday, but when I came out of jail, many people embraced me, including my enemies, and that is what I normally tell other people who say those who are struggling for liberation in their country are terrorists. I tell them that I was also a terrorist yesterday, but, today, I am admired by the very people who said I was one.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000130","text":"Let's hope that Ken Oosterbroek will be the last person to die.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000131","text":"It is never my custom to use words lightly. If twenty-seven years in prison have done anything to us, it was to use the silence of solitude to make us understand how precious words are and how real speech is in its impact on the way people live and die.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000132","text":"What counts in life is not the mere fact that we have lived. It is what difference we have made to the lives of others that will determine the significance of the life we lead.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000133","text":"We tried in our simple way to lead our life in a manner that may make a difference to those of others.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000134","text":"Those who conduct themselves with morality, integrity and consistency need not fear the forces of inhumanity and cruelty.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000135","text":"Education is the most powerful weapon we can use to change the world and is a powerful part of that world changing arsenal.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000136","text":"I remember we adjourned for lunch and a friendly Afrikaner warder asked me the question, \"Mandela, what do you think is going to happen to you in this case?\" I said to him, \"Agh, they are going to hang us.\" Now, I was really expecting some word of encouragement from him. And I thought he was going to say, \"Agh man, that can never happen.\" But he became serious and then he said, \"I think you are right, they are going to hang you.\"","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000137","text":"When the history of our times is written, will we be remembered as the generation that turned our backs in a moment of global crisis or will it be recorded that we did the right thing?","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000138","text":"You sharpen your ideas by reducing yourself to the level of the people you are with and a sense of humour and a complete relaxation, even when you’re discussing serious things, does help to mobilise friends around you. And I love that.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000139","text":"A fundamental concern for others in our individual and community lives would go a long way in making the world the better place we so passionately dreamt of.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000140","text":"Everyone can rise above their circumstances and achieve success if they are dedicated to and passionate about what they do.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000141","text":"I did not enjoy the violence of boxing so much as the science of it. I was intrigued by how one moved one's body to protect oneself, how one used a strategy both to attack and retreat, how one paced oneself over a match.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000142","text":"Like slavery and apartheid, poverty is not natural. It is man-made and it can be overcome and eradicated by the actions of human beings. And overcoming poverty is not a gesture of charity. It is an act of justice. It is the protection of a fundamental human right, the right to dignity and a decent life. While poverty persists, there is no true freedom.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000143","text":"The Gandhian influence dominated freedom struggles on the African continent right up to the 1960s because of the power it generated and the unity it forged among the apparently powerless. Nonviolence was the official stance of all major African coalitions, and the South African A.N.C. remained implacably opposed to violence for most of its existence.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000144","text":"Gandhi himself never ruled out violence absolutely and unreservedly. He conceded the necessity of arms in certain situations. He said, \"Where choice is set between cowardice and violence, I would advise violence... I prefer to use arms in defense of honor rather than remain the vile witness of dishonor ...\"","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000145","text":"A great measure of world poverty today and African poverty in particular is due to the continuing dependence on foreign markets for manufactured goods, which undermines domestic production and dams up domestic skills, apart from piling up unmanageable foreign debts. Gandhi's insistence on self-sufficiency is a basic economic principle that, if followed today, could contribute significantly to alleviating Third World poverty and stimulating development.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000146","text":"Gandhi rejects the Adam Smith notion of human nature as motivated by self-interest and brute needs and returns us to our spiritual dimension with its impulses for nonviolence, justice and equality. He exposes the fallacy of the claim that everyone can be rich and successful provided they work hard. He points to the millions who work themselves to the bone and still remain hungry.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000147","text":"If I am asked, by credible organizations, to mediate, I will consider that very seriously. But a situation of this nature does not need an individual, it needs an organization like the United Nations to mediate. We must understand the seriousness of this situation. The United States has made serious mistakes in the conduct of its foreign affairs, which have had unfortunate repercussions long after the decisions were taken.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000148","text":"You will notice that France, Germany, Russia, China are against this decision. It is clearly a decision that is motivated by George W. Bush's desire to please the arms and oil industries in the United States of America. If you look at those factors, you'll see that an individual like myself, a man who has lost power and influence, can never be a suitable mediator.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000149","text":"I really wanted to retire and rest and spend more time with my children, my grandchildren and of course with my wife. But the problems are such that for anybody with a conscience who can use whatever influence he may have to try to bring about peace, it's difficult to say no.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000150","text":"It's a tragedy what is happening, what Bush is doing. All Bush wants is Iraqi oil. There is no doubt that the U.S. is behaving badly. Why are they not seeking to confiscate weapons of mass destruction from their ally Israel? This is just an excuse to get Iraq’s oil.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000151","text":"Bush is now undermining the United Nations. He is acting outside it, not withstanding the fact that the United Nations was the idea of President Roosevelt and Winston Churchill. Both Bush, as well as Tony Blair, are undermining an idea which was sponsored by their predecessors. They do not care. Is it because the secretary-general of the United Nations [Ghanaian Kofi Annan] is now a black man? They never did that when secretary-generals were white.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000152","text":"If there is a country that has committed unspeakable atrocities in the world, it is the United States of America. They don't care for human beings.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000153","text":"Israel should withdraw from all the areas which it won from the Arabs in 1967, and in particular Israel should withdraw completely from the Golan Heights, from south Lebanon and from the West Bank.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000154","text":"I cannot conceive of Israel withdrawing if the Arab states do not recognize Israel, within secure borders.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000155","text":"One of the reasons I am so pleased to be in Israel is as a tribute to the enormous contribution of the Jewish community of South Africa [to South Africa]. I am so proud of them.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000156","text":"We consider ourselves to be comrades in arms to the Palestinian Arabs in their struggle for the liberation of Palestine. There is not a single citizen in South Africa who is not ready to stand by his Palestinian brothers in their legitimate fight against the Zionist racists.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000157","text":"Free Nelson Mandela!","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000158","text":"We can only agree with the words of the great Nelson Mandela, that indeed education is a powerful weapon for changing the world.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000159","text":"I simply don't understand why the Nobel academy gave him a peace prize or why Charlie Dimmock and Alan Titchmarsh gave him a new garden. And I don't see why he should be given a statue in Trafalgar Square, either. If we're after someone who stands up for the oppressed, what about Jesus? I feel fairly sure he never blew up a train.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000160","text":"The Dalai Lama, who was very fond of Nelson Mandela, also a Nobel Peace Prize winner, and had met him many times, was twice refused a visa by the South African authorities, who feared Chinese reprisals. It's a shame, because Tenzin Gyatso is the one who undoubtedly best defined Nelson Mandela: \"He was a man of courage, principles and absolute integrity and the best tribute we could pay him is to continue to work for reconciliation and friendship among all peoples of the world. »","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000161","text":"The epitome of courage and intelligence.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000162","text":"Most great instigators of social change have intimate personal knowledge of trauma. Oprah Winfrey comes to mind, as do Maya Angelou, Nelson Mandela, and Elie Wiesel. Read the life history of any visionary, and you will find insights and passions that came from having dealt with devastation.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000163","text":"When he was in prison I admired him for his moral strength...Of his period in power I can see few results. Apartheid no longer exists, at least to all appearances, but no one understands what the new government in South Africa is doing.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000164","text":"How can a man who committed adultery and left his wife and children be Christ? The whole world worships Nelson too much. He is only a man.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000165","text":"Nelson Mandela is, for me, the single statesman in the world. The single statesman, in that literal sense, who is not solving all his problems with guns. It's truly unbelievable. Truly.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000166","text":"I’ve also got an autographed copy of Nelson Mandela’s “Conversations With Myself.” It’s a collection of his writings and speeches, an extension of sorts to “Long Walk to Freedom.” I like to flip through it from time to time because it always seems to give me an extra boost when I need it. I cherish this both because it was signed by him and because he gave it to me as a gift when my family visited his home in 2011.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000167","text":"All nations have iconic historical figures on whom they draw for inspiration and strength at times of national crisis. We have the icon and we have the crisis but South Africa tragically appears to be still too disparate, divided, and confused to know how to best draw from Mandela’s example to mould a new nation. That is the sadness of Mandela’s closing years.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000168","text":"Huge crowds! The day when Nelson Mandela was duly inaugurated the first democratically elected president of South Africa... And you sat there, and you looked at the benches of the newly elected legislators, and there were all these \"terrorists\" — as they had been regarded by the former apartheid government. And there they were sitting. Many had been on Robben Island, in exile, many had been tortured. Many of us kept having to pinch ourselves to say, \"No, man, I am dreaming.\"","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000169","text":"He walked like a man who does not take the earth for granted. He took one step after another with obvious care and delight. Right next to him, Winnie Mandela stayed close, attuned and alert, and radiant.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000170","text":"this miracle was no kind of rerun! This Nelson Mandela a.k.a. terrorist a.k.a. communist a.k.a. felon who had vowed to resist violence with violence, to acknowledge respect with respect, and to confront the catastrophe of time with total rebellion against the waste and the weakening that time entails, this same Mandela was returning to near-universal tribute and acclaim: \"His freedom,\" a white man on the radio declared, \"is the moment the world has been waiting for.\"","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000171","text":"It is hard to eulogize any man — to capture in words not just the facts and the dates that make a life, but the essential truth of a person — their private joys and sorrows; the quiet moments and unique qualities that illuminate someone’s soul. How much harder to do so for a giant of history, who moved a nation toward justice, and in the process moved billions around the world.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000172","text":"He was not a bust made of marble; he was a man of flesh and blood — a son and a husband, a father and a friend. And that’s why we learned so much from him, and that’s why we can learn from him still. For nothing he achieved was inevitable. In the arc of his life, we see a man who earned his place in history through struggle and shrewdness, and persistence and faith. He tells us what is possible not just in the pages of history books, but in our own lives as well.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000173","text":"It took a man like Madiba to free not just the prisoner, but the jailer as well to show that you must trust others so that they may trust you; to teach that reconciliation is not a matter of ignoring a cruel past, but a means of confronting it with inclusion and generosity and truth. He changed laws, but he also changed hearts.","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000174","text":"Nelson Mandela – Biography at Nobelprize.org","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000175","text":"The Mandela Page at ANC","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000176","text":"Mandela: An Audio History","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000177","text":"Complete speech from the Live 8 concert","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000178","text":"Nelson Mandela Foundation - 46664","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000179","text":"Nelson Mandela Children's Fund","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000180","text":"Nelson Mandela at Writespirit.Net","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000181","text":"Nelson Mandela Quotes Video","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000182","text":"Quotes By Nelson Mandela","author":"Nelson Mandela","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000183","text":"The problem with gender is that it prescribes how we should be rather than recognising how we are. Now imagine how much happier we would be, how much freer to be our true individual selves if we didn't have the weight of gender expectations.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000184","text":"No matter who we are, we dream.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000185","text":"In Nigeria I'm not black ... We don't do race in Nigeria. We do ethnicity a lot, but not race. My friends here don't really get it. Some of them sound like white Southerners from 1940. They say, \"Why are black people complaining about race? Racism doesn't exist!' It's just not a part of their existence.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000186","text":"I don’t think sexism is worse than racism, it’s impossible even to compare ... It’s that I feel lonely in my fight against sexism, in a way that I don’t feel in my fight against racism. My friends, my family, they get racism, they get it. The people I’m close to who are not black get it. But I find that with sexism you are constantly having to explain, justify, convince, make a case for.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000187","text":"I don’t think I’m more inherently likely to do domestic work, or childcare ... It doesn’t come pre-programmed in your vagina, right?","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000188","text":"Because we write fiction we mine our souls. Of course you put yourself into your fiction, your fiction is you.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000189","text":"This is the kind of capitalism I hate. This is bullying capitalism. Look, I am Igbo, I come from a trading culture. My people are merchant and I'm all for buying and selling. But capitalism has to be a fair exchange.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000190","text":"Feminism is not that men and women are the same. If men and women are the same, we won't have sexism. We are just stating the differences and people should stop giving negative value to all the attributes that women have. It's not that men and women are the same but they've equally human.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000191","text":"I think you travel to search and you come back home to find yourself there.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000192","text":"Culture does not make people. People make culture. If it is true that the full humanity of women is not our culture, then we can and must make it our culture.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000193","text":"Why did people ask \"What is it about?\" as if a novel had to be about only one thing.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000194","text":"Race doesn't really exist for you because it has never been a barrier. Black folks don't have that choice.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000195","text":"When it comes to dressing well, American culture is so self-fulfilled that it has not only disregarded this courtesy of self-presentation, but has turned that disregard into a virtue. \"We are too superior/busy/cool/not-uptight to bother about how we look to other people, and so we can wear pajamas to school and underwear to the mall.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000196","text":"I'm chasing you. I'm going to chase you until you give this a chance.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000197","text":"They never said “I don’t know.” They said, instead, “I’m not sure,” which did not give any information but still suggested the possibility of knowledge.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000198","text":"She liked that [Obinze] wore their relationship so boldly, like a brightly colored shirt. Sometimes she worried that she was too happy. She would sink into moodiness, and snap at Obinze, or be distant. And her joy would become a restless thing, flapping its wings inside her, as though looking for an opening to fly away.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000199","text":"She rested her head against his and felt, for the first time, what she would often feel with him: a self-affection. He made her like herself.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000200","text":"With him, she was at ease: her skin felt as though it was her right size. She told him how she very much wanted God to exist but feared He did not, how she worried that she should know what she wanted to do with her life but did not even know what she wanted to study at university. It seemed so natural, to talk to him about odd things. She had never done that before. The trust, so sudden and yet so complete, and the intimacy, frightened her.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000201","text":"\"Being defiant can be a good thing sometimes,\" Aunty Ifeoma said. \"Defiance is like marijuana - it is not a bad thing when it is used right.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000202","text":"\"I cannot control even the dreams that I have made.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000203","text":"\"People have crushes on priests all the time, you know. It’s exciting to have to deal with God as a rival.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000204","text":"\"The white missionaries brought us their god,” Amaka was saying. “Which was the same color as them, worshiped in their language and packaged in the boxes they made. Now that we take their god back to them, shouldn’t we at least repackage it?\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000205","text":"\"Eugene has to stop doing God's job. God is big enough to do his own job. If God will judge our father for choosing to follow the way of our ancestors, then let God do the judging, not Eugene.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000206","text":"\"There was a helplessness to his joy, the same kind of helplessness as in that woman’s despair.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000207","text":"Things started to fall apart when my brother, Jaja, did not go to communion and Papa flung his heavy missal across the room and broke the figurines on the étagère.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000208","text":"I meant to say I am sorry that Papa broke your figurines, but the words that came out were, ‘I’m sorry your figurines broke, Mama.’","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000209","text":"Imagine what the Standard would be if we were all quiet.’","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000210","text":"It was a joke. Ade Coker was laughing; so was his wife, Yewande. But Papa did not laugh. Jaja and I turned and went back upstairs, silently.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000211","text":"I thought the Igwe was supposed to stay at his place and receive guests. I didn’t know he visits people’s homes,’ Amaka said, as we went downstairs. ‘I guess that’s because your father is a Big Man.’","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000212","text":"When she made a U-turn and went back the way we had come, I let my mind drift, imagining God laying out the hills of Nsukka with his wide white hands, crescent-moon shadows underneath his nails just like Father Benedict’s.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000213","text":"Morality, as well as the sense of taste, is relative.’","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000214","text":"This cannot go on, nwunye m,’ Aunty Ifeoma said. ‘When a house is on fire, you run out before the roof collapses on your head.’","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000215","text":"Rain splashed across the floor of the veranda, even though the sun blazed and I had to narrow my eyes to look out the door of Aunty Ifeoma’s living room. Mama used to tell Jaja and me that God was undecided about what to send, rain or sun. We would sit in our rooms and look out at the raindrops glinting with sunlight, waiting for God to decide.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000216","text":"She picked up an enterprising snail that was crawling out of the open basket. She threw it back in and muttered, ‘God take power from the devil.’ I wondered if it was the same snail, crawling out, being thrown back in, and then crawling out again. Determined. I wanted to buy the whole basket and set that one snail free.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000217","text":"That night when I bathed, with a bucket half full of rainwater, I did not scrub my left hand, the hand that Father Amadi had held gently to slide the flower off my finger. I did not heat the water, either, because I was afraid that the heating coil would make the rainwater lose the scent of the sky. I sang as I bathed. There were more earthworms in the bathtub, and I left them alone, watching the water carry them and send them down the drain.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000218","text":"Kambili is right,’ she said. ‘Something from God was happening there.’","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000219","text":"Of course God does. Look at what He did to his faithful servant Job, even to His own Son. But have you ever wondered why? Why did He have to murder his own son so we would be saved? Why didn’t he just go ahead and save us?'","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000220","text":"We will take Jaja to Nsukka first, and then we’ll go to America to visit Aunty Ifeoma,’ I said. ‘We’ll plant new orange trees in Abba when we come back, and Jaja will plant purple hibiscus, too, and I’ll plant ixora so we can suck the juices of the flowers.’ I am laughing. I reach out and place my arm around Mama’s shoulder and she leans toward me and smiles.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000221","text":"Things started to fall apart at home.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000222","text":"A love sip, he called it, because you shared the little things you loved with the people you loved […] The tea was always too hot, always burned my tongue.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000223","text":"Jaja’s defiance seems like Ifeoma’s experimental purple hibiscus: rare, fragrant with the undertones of freedom, a different kind of freedom from the one the crowds waving green leaves chanted at Government Square after the coup. A freedom to be, to do.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000224","text":"\"Then she wished, more rationally, that she could love him without needing him. Need gave him power without his trying; need was the choicelessness she often felt around him.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000225","text":"\"This was love: a string of coincidences that gathered significance and became miracles\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000226","text":"\"Is love this misguided need to have you beside me most of the time? Is love this safety I feel in our silences? Is it this belonging, this completeness?\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000227","text":"\"...my point is that the only authentic identity for the African is the tribe...I am Nigerian because a white man created Nigeria and gave me that identity. I am black because the white man constructed black to be as different as possible from his white. But I was Igbo before the white man came.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000228","text":"\"The truth has become an insult.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000229","text":"\"This is our world, although the people who drew this map decided to put their own land on top of ours. There is no top or bottom, you see.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000230","text":"\"There are some things that are so unforgivable that they make other things easily forgivable.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000231","text":"\"A gorgeous pitless account of love, violence and betrayal.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000232","text":"\"Greatness depends on where you are coming from.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000233","text":"\"I look to stories for consolation,the kind of small consolation that one needs to want to wake up everyday;as template for life;for news on how others live;for reminders that life's mysteries have no key\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000234","text":"\"A successful story for me exist in a moral universe, not one where goodness always triumph, because that would be false but one with an inherent awareness of goodness\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000235","text":"\"My own definition is a feminist is a man or woman who says 'yes,there's a problem with gender as it is today and we must fix it,we must do better.All of us,women and men,must do better.\" chimamanda quote based on gender.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000236","text":"\"Marriage can be a source of joy and love and mutual support but why do we teach girls to aspire to marriage and we don’t teach boys the same? We raise girls to see each other as competitors not for jobs or accomplishments, which I think can be a good thing, but for the attention of men. We teach girls that they cannot be sexual beings in the way that boys are.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000237","text":"“Of course I am not worried about intimidating men. The type of man who will be intimidated by me is exactly the type of man I have no interest in.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000238","text":"“The problem with gender is that it prescribes how we should be rather than recognizing how we are. Imagine how much happier we would be, how much freer to be our true individual selves, if we didn’t have the weight of gender expectations.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000239","text":"“Show a people as one thing, only one thing, over and over again, and that is what they become.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000240","text":"\"So true--when people see an absence of women in engineering, science and technology, then it becomes self-reinforcing.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000241","text":"\"The single story creates stereotypes, and the problem with stereotypes is not that they are untrue, but that they are incomplete. They make one story become the only story.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000242","text":"\"Many stories matter. Stories that have been used to dispossess and to malign.But stories can also be used to empower,and to humanize.Stories can break the dignity of a people.But stories can also repair that broken dignity\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000243","text":"\"Creative writing programmes are not very necessary. They just exist so that people like us can make a living.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000244","text":"\"How can we resist exploitation if we don’t have the tools to understand exploitation. Which of your favourite quotes by Chimamanda did we miss?\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000245","text":"\"There are many different ways to be poor in the world but increasingly there seems to be one single way to be rich.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000246","text":"Marriage can be a good thing, a source of joy, love, and mutual support. But why do we teach girls to aspire to marriage, but we don’t teach boys to do the same?","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000247","text":"\"Masculinity is a hard, small cage, and we put boys inside this cage.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000248","text":"\"Of course I am not worried about intimating men. The type of man who will be intimidated is exactly the type of man I have no interest in.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000249","text":"\"Please love by giving and by taking. Give and be given. If you are only giving and not taking, you’ll know. You’ll know from that small and true voice inside you that we females are so often socialized to silence. Don’t silence that voice. Dare to take.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000250","text":"trans women are trans women","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000251","text":"\"And even though I helped to clean the wounded, I had never taken anyone into my room.But I took this girl into my room.Her name was chinasa.\"","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000252","text":"You hate men, you hate bras, you hate African culture, you think women should always be in charge, you don’t wear makeup, you don’t shave, you’re always angry, you don’t have a sense of humor, you don’t use deodorant.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000253","text":"I often make the mistake of thinking that something that is obvious to me is just as obvious to everyone else.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000254","text":"We have evolved. But our ideas of gender have not evolved very much.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000255","text":"The trick was to understand America, to know that America was give-and-take. You gave up a lot but you gained a lot, too.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000256","text":"It was something like pain and different from pain.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000257","text":"Bear it, that is what it means to be a woman...","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000258","text":"If he was going to have a child, of course he should have a say, but how much of a say, since the body was mine, since in creating a child, Nature demanded so much of the woman and so little of the man.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000259","text":"I read somewhere that love was about this, the nuggets of knowledge about our beloved that we so fluently hold","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000260","text":"You can’t nice your way to being loved.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000261","text":"Some kindnesses you do not ever forget. You carry them to your grave, held warmly somewhere, brought up and savored from time to time.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000262","text":"How you imagine something will be is always worse than how it actually ends up being,","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000263","text":"I looked at my mother, standing by the window. How had I never really seen her? It was my father who destroyed, and it was my mother I blamed for the ruins left behind.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000264","text":"The frequent flare of sad longing.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000265","text":"I felt translucent, so fragile that one more rejection would make me come fully undone.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000266","text":"Tears were so cheap now","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000267","text":"Nature must not want humans to reproduce, otherwise birthing would be easy, even enjoyable:","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000268","text":"They learned instead from mainstream pornography, where women were always shaved smooth and never had periods, and so they became men who thought the contrived histrionics onscreen were How Things Were Done.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000269","text":"Something was growing inside me, alien, uninvited, and it felt like an infestation.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000270","text":"He would kill you, but he would do it slowly","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000271","text":"I felt ragged and hopeless, high on my desperation. I had already ripped up my dignity, so I might as well scatter the pieces.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000272","text":"\"I think I should leave. Is that okay?” he asked as though he needed my permission to abandon me. He would kill you, but he would do it courteously.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000273","text":"Nature demanded so much of the woman and so little of the man","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000274","text":"Some days I was fine and some days I was under water, barely breathing","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000275","text":"It felt like the Old Testament. A plague. A primitive wind blowing at will, evil but purposelessly so, an overcoming in my body that didn’t need to be.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000276","text":"Love was about this, the nuggets of knowledge about our beloved that we so fluently hold.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000277","text":"When I had severe cramps as a teenager, she would say, “Bear it, that is what it means to be a woman,” and it was years before I knew that girls took Buscopan for period pain.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000278","text":"sifted through my memories, as though through debris, trying to find a reason.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000279","text":"my dark day further darkened.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000280","text":"for a moment I felt an intense desire to pass out and escape my life","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000281","text":"was suspended in a place of no feeling,","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000282","text":"The labor and delivery ward needed to have a false eye-lash policy","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000283","text":"What did “It’s time to get married” mean, anyway? Why did she have to marry at all?","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000284","text":"What was “normal”? That Nature traded in unnecessary pain? It wasn’t his intestines being set on fire, after all.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000285","text":"He rolled his eyes in a kind of disbelieving amusement. “What, the single friend will seduce the husband, or the single friend will make the wife want to be single again?","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000286","text":"I made myself boneless and amenable. I spent weekends willing the landline next to my bed to ring. Often it didn’t. Then he would call, before midnight, to ask if I was still up, so he could visit and leave before dawn.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000287","text":"Each morning, I coated concealer on the dark bags under my eyes. Most days, I caressed a bottle of Advil, longing for the translucent green pills, but knowing that I would never take them.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000288","text":"I didn’t question whether it was real, because I knew it was. I questioned where it had gone. How could emotions just change? Where did it go, the thing that used to be?","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000289","text":"I believed then that love had to feel like hunger to be true.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000290","text":"I began to cry. Tears were so cheap now. How do some memories insist on themselves?","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000291","text":"Ours was an ancient story, the woman wants the baby and the man doesn’t want the baby and a middle ground does not exist.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000292","text":"I knew how I was supposed to feel, but I did not know how I felt. It was not transcendental. There was a festering red pain between my legs. Somewhere in my consciousness, a mild triumph hovered, because it was over, finally it was over, and I had pushed out the baby. So animalistic, so violent—the push and pressure, the blood, the doctor urging me, the cranking and stretching of flesh and organ and bone.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000293","text":"We scrub and scrape our armpits and upper lip and legs because we hate to have hair there. Then we pamper and treat the hair on our heads because we love hair there. But it’s all hair. It’s the wanting that makes the difference.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000294","text":"Zikky, it won’t be easy, but it won’t be as hard as you think. How you imagine something will be is always worse than how it actually ends up being,","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000295","text":"We mostly spoke English; Igbo was for mimicking relatives and for saying painful things.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000296","text":"He grew up with his dreams already dreamt for him","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000297","text":"Respect: a starched deference, a string of ashen rituals. It was my mother who sat beside my father at weddings and ceremonies; it was her photo that appeared above the label of “wife” in the booklet his club published in his honor. Respect was her reward for acquiescing.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000298","text":"He said, “I thought you let me because you had protection.” I said, “What are you talking about? You know I stopped taking the pill because it made me fat, and I assumed you knew what it meant, what it could mean.” He said, “There was miscommunication.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000299","text":"In my head, there was a queue of emotions I could not name, wanting to be tried out one after the other.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000300","text":"A geyser of anxiety had erupted deep inside me and I was spurting fear.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000301","text":"Only later did I see how, to survive, she wielded her niceness like a subtle sharp knife.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000302","text":"was to remember like a brief blur my life as it once was, when I was only a daughter, not a mother.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000303","text":"My father told jokes and laughed and charmed everyone, and broke things and walked on the shards without knowing he had broken things.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000304","text":"I felt light from relief, weightless, unburdened.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000305","text":"How swift the moment is when your life becomes a different life.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000306","text":"Symptoms can mean nothing if a mind just cannot.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000307","text":"And I never told the boy who didn’t love me, the boy I was trying to make love me when I didn’t yet know that you cannot nice your way into being loved.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000308","text":"Her silence bruised the air between us.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000309","text":"A fog blanketed me, a kind of deadness. I didn’t cry; crying seemed too ordinary for this moment.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000310","text":"Grief is a cruel kind of education. You learn how ungentle mourning can be, how full of anger. You learn how glib condolences can feel. You learn how much grief is about language, the failure of language and the grasping for language.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000311","text":"I finally understand why people get tattoos of those they have lost. The need to proclaim not merely the loss but the love, the continuity. I am my father’s daughter. It is an act of resistance and refusal: grief telling you it is over and your heart saying it is not; grief trying to shrink your love to the past and your heart saying it is present.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000312","text":"For the rest of my life, I will live with my hands outstretched for things that are no longer there.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000313","text":"How is it that the world keeps going, breathing in and out unchanged, while in my soul there is a permanent scattering?","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000314","text":"It does not matter whether I want to be changed, because I am changed.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000315","text":"Age is irrelevant in grief; at issue is not how old he was but how loved.","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000316","text":"“I have always longed to be known, truly known by another human being.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000317","text":"“Women in general are more likely to have richer interior lives and are also socialized to just sort of embrace more complexity emotionally.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000318","text":"“Writing fiction is the love of my life. It's the thing that I think gives me meaning.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000319","text":"“I’ve always been willing to take the consequences of speaking my mind. ... No, no, no. I said what I believe.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000320","text":"“Social media has reshaped the traditional power dynamic by giving some access to the powerless, it has also made it easy to mistake the loudest voices for the truest.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000321","text":"“If you don’t understand, ask questions. If you’re uncomfortable about asking questions, say you are uncomfortable about asking questions and then ask anyway. It’s easy to tell when a question is coming from a good place. Then listen some more.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000322","text":"“There are two answers to the things they will teach you about our land: the real answer and the answer you give in school to pass. You must read books and learn both answers.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000323","text":"“We do a great disservice to boys in how we raise them. We stifle the humanity of boys. We define masculinity in a very narrow way. Masculinity is a hard, small cage, and we put boys inside this cage.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000324","text":"“I feel that I have been fortunate to have found success, and I also want the young writers to have what I did not have when I was starting out my writing career … Writing doesn’t exist in a vacuum; we talk about politics, everything.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000325","text":"“Feminism for me is about justice; it’s about the idea that all human beings are equal… Feminism just means equality of opportunity.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000326","text":"“I am not apologetic for being a Nigerian. I won’t apologise for it; it’s who and what I am.”","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000327","text":"(Whose writing today most inspires you?) Chimamanda Ngozi Adichie’s work — both fiction and nonfiction...","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000328","text":"List of A-Z quotes from Chimamanda Ngozi Adichie - Uzomedia","author":"Chimamanda Ngozi Adichie","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000329","text":"The world is like a Mask dancing. If you want to see it well, you do not stand in one place.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000330","text":"found a girl who will suit [him] admirably","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000331","text":"it is impossible for [him] to marry Nweke’s daughter","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000332","text":"deeply affected by his father’s grief","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000333","text":"the first rain in the year","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000334","text":"that women supply with success to recapture their husbands’ straying affection","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000335","text":"obstinately ahead of his more superstitious neighbors in these matters","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000336","text":"In the cosmopolitan atmosphere of the city it had always seemed to her something of a joke that a person’s tribe could determine who he married.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000337","text":"‘I can’t—we must—I mean it is impossible for me to marry Nweke’s daughter.’ ‘Impossible. Why?’ asked his father. ‘I don’t love her.’ ‘Nobody said you did. Why should you?’","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000338","text":"What one looks for in a wife are a good character and a Christian background.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000339","text":"Yes. They are most unhappy if the engagement is not arranged by them. In our case it’s worse—you are not even an Ibo.This was said so seriously and so bluntly that Nene could not find speech immediately. In the cosmopolitan atmosphere of the city it had always seemed to her something of a joke that a person’s tribe could determine whom he married.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000340","text":"As Nnaemeka walked home that evening he turned over in his mind the different ways of overcoming his father’s opposition, especially now that he had gone and found a girl for him. He had thought of showing his letter to Nene but decided on second thoughts not to, at least for the moment.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000341","text":"“I don’t love her.\"“Nobody said you did. Why should you?” he asked.“Marriage today is different…”“Look here, my son,” interrupted his father, “nothing is different. What one looks for in a wife are a good character and a Christian background.”Nnaemeka saw there was no hope along the present line of argument.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000342","text":"Nene Atang from Calabar. She is the only girl I can marry.” This was a very rash reply and Nnaemeka expected the storm to burst. But it did not. His father merely walked away into his room. This was most unexpected and perplexed Nnaemeka. His father’s silence was infinitely more menacing than a flood of threatening speech. That night the old man did not eat.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000343","text":"Nnaemeka, for his own part, was very deeply affected by his father’s grief. But he kept hoping that it would pass away. If it had occurred to him that never in the history of his people had a man married a woman who spoke a different tongue, he might have been less optimistic.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000344","text":"The story eventually got to the little village in the heart of the Ibo country that Nnaemeka and his young wife were a most happy couple. But his father was one of the few people who knew nothing about this. He always displayed so much temper whenever his son’s name was mentioned that everyone avoided it in his presence. By a tremendous effort of will he had succeeded in pushing his son to the back of his mind. The strain had nearly killed him but he had persevered, and won.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000345","text":"Proverbs are the palm-oil with which words are eaten.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000346","text":"When the moon is shining the cripple becomes hungry for a walk.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000347","text":"We shall all live. We pray for life, children, a good harvest and happiness. You will have what is good for you and I will have what is good for me. Let the kite perch and let the egret perch too. If one says no to the other, let his wing break.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000348","text":"A proud heart can survive general failure because such a failure does not prick its pride. It is more difficult and more bitter when a man fails alone.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000349","text":"The Ibo people have a proverb that when a man says yes his chi says yes also. Okonkwo said yes very strongly, so his chi agreed. And not only his chi but his clan too, because it judged a man by the work of his hands.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000350","text":"But he was not the man to go about telling his neighbors that he was in error. And so people said he had no respect for the gods of the clan. His enemies said that his good fortune had gone to his head.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000351","text":"Even the village rain-maker no longer claimed to be able to intervene. He could not stop the rain now, just as he would not attempt to start it in the heart of the dry season, without serious danger to his own health.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000352","text":"No matter how prosperous a man was, if he was unable to rule his women and his children (and especially his women) he was not really a man.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000353","text":"\"When did you become a shivering old woman,\" Okonkwo asked himself, \"you, who are known in all the nine villages for your valor in war? How can a man who has killed five men in battle fall to pieces because he has added a boy to their number? Okonkwo, you have become a woman indeed.\"","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000354","text":"\"You sound as if you question the authority and the decision of the Oracle, who said he should die.\" \"I do not. Why should I? But the Oracle did not ask me to carry out its decision.\" [...] \"The Earth cannot punish me for obeying her mesenger,\" Okonkwo said. \"A child's fingers are not scalded by a piece of hot yam which its mother puts into its palm.\"","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000355","text":"After such treatment it would think twice before coming again, unless it was one of the stubborn ones who returned, carrying the stamp of their mutilation--a missing finger or perhaps a dark line where the medicine man's razor had cut them.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000356","text":"\"Beware Okonkwo!\" she warned. \"Beware of exchanging words with Agbala. Does a man speak when a god speaks? Beware!\"","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000357","text":"The land of the living was not far removed from the domain of the ancestors. There was coming and going between them, especially at festivals and also when an old man died, because an old man was very close to the ancestors. A man's life from birth to death was a series of transition rites which brought him nearer and nearer to his ancestors.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000358","text":"If the clan did not exact punishment for an offense against the great goddess, her wrath was loosed on all the land and not just on the offender. As the elders said, if one finger brought oil it soiled all the others.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000359","text":"It was like beginning life anew without the vigor and enthusiasm of youth, like learning to become left-handed in old age.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000360","text":"\"We have heard stories about white men who make the powerful guns and the strong drinks and took slaves away across the seas, but no one thought the stories were true.\" [said Obierika] \"There is no story that is not true,\" said Uchendu. \"The world has no end, and what is good among one people is an abomination with others. We have albinos among us. Do you not think that they came to our clan by mistake, that they have strayed from their way to a land where everybody is like them?\"","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000361","text":"Chielo, the priestess of Agbala, called the converts the excrement of the clan, and the new faith was a mad dog that had come to eat it up.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000362","text":"\"Let us give them a portion of the Evil Forest. They boast about victory over death. Let us give them a real battlefield in which to show their victory.\" [...] They offered them as much of the Evil Forest as they cared to take. And to their great amazement the missionaries thanked them and burst into song.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000363","text":"Okonkwo was popularly called the \"Roaring Flame.\" As he looked into the log fire he recalled the name. He was a flaming fire. How then could he have begotten a son like Nwoye, degenerate and effeminate? [...] He sighed heavily, and as if in sympathy the smoldering log also sighed. And immediately Okonkwo's eyes were opened and he saw the whole matter clearly. Living fire begets cold, impotent ash. He sighed again, deeply.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000364","text":"The white man is very clever. He came quietly with his religion. We were amused at his foolishness and allowed him to stay. Now he has won our brothers, and our clan can no longer act like one. He has put a knife on the things that held us together and we have fallen apart.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000365","text":"As a man danced so the drums were beaten for him.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000366","text":"Eneke the bird was asked why he was always on the wing and he replied: \"Men have learned to shoot without missing their mark and I have learned to fly without perching on a twig.\"","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000367","text":"Whenever you see a toad jumping in broad daylight, then know that something is after its life.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000368","text":"A man who lived on the banks of the Niger should not wash his hands with spittle.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000369","text":"Real tragedy is never resolved. It goes on hopelessly forever. Conventional tragedy is too easy. The hero dies and we feel a purging of the emotions. A real tragedy takes place in a corner, in an untidy spot, to quote W. H. Auden.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000370","text":"You cannot plant greatness as you plant yams or maize. Who ever planted an iroko tree — the greatest tree in the forest? You may collect all the iroko seeds in the world, open the soil and put them there. It will be in vain. The great tree chooses where to grow and we find it there, so it is with the greatness in men.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000371","text":"If one finger brings oil it soils the others.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000372","text":"A man to whom you do a favor will not understand if you say nothing, make no noise, just walk away. You may cause more trouble by refusing a bribe than by accepting it.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000373","text":"When there is a big tree small ones climb on its back to reach the sun.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000374","text":"Although he was still only a child it looked as though the deity had already marked him out as his future Chief. Even before he had learnt to speak more than a few words he had been strongly drawn to the god’s ritual.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000375","text":"When a handshake goes beyond the elbow we know it has turned to another thing.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000376","text":"A man does not speak a lie to his son,” he said. “Remember that always. To say My father told me is to swear the greatest oath","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000377","text":"The man was a complete nonentity until we crowned him, and now he carries on as though he had been nothing else all his life. It’s the same with Court Clerks and even messengers. They all manage to turn themselves into little tyrants over their own people. It seems to be a trait in the character of the negro","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000378","text":"a man should hold his compound together, not plant dissension among his children","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000379","text":"The man who brings ant-infested faggots into his hut should not grumble when lizards begin to pay him a visit","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000380","text":"He looked as bright as a new shilling in his immaculate white robes.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000381","text":"We had all accepted things from white skins that none of us would have brooked from our own people.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000382","text":"A man of worth never gets up to unsay what he said yesterday.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000383","text":"In Chief Nanga’s company it was impossible not to be merry.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000384","text":"What mattered was that a man had treated me as no man had a right to treat another—not even if he was master and the other slave; and my manhood requires that I made him pay for his insult in full measure.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000385","text":"That’s all they cared for,’ [Max] said with a solemn face. ‘Women, cars, landed property. But what else can you expect when intelligent people leave politics to illiterates like Chief Nanga?","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000386","text":"At first Onitsha looked very strange to Chike. He could not say who was a thief or kidnapper and who was not. In Umuofia every thief was known, but here even people who lived under the same roof were strangers to one another.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000387","text":"After the incident of the leopard skin Chike lost some of his eagerness for crossing the Niger. He did not see how he could obtain one shilling without stealing or begging.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000388","text":"The largest sum of money he had ever had at one time was threepence.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000389","text":"Then the stranger went away and Mr. Nwaba retired to his room. Chike did not give much thought to the incident at the time. But he was to remember it later.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000390","text":"In his joy, he said again, ‘Thank you, sir.’ The man did not reply; he was talking to his friend again, with a cigarette in his mouth.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000391","text":"So Chike’s adventure on the River Niger brought him close to danger and then rewarded him with good fortune. It also exposed Mr. Peter Nwaba, the rich but miserly trader. For it was he who had led the other thieves.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000392","text":"Praise bounteous providence if you will that grants even an ogre a tiny glow-worm tenderness encapsulated in icy caverns of a cruel heart or else despair for in the very germ of that kindred love is lodged the perpetuity of evil.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000393","text":"By immediately identifying his people as “men of soul” .","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000394","text":"Measure out / [their] joys and agonies / too, our long, long passion week / in paces of the dance”","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000395","text":"A dead end nor total loss.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000396","text":"Lying in wait for the people’s land and resources.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000397","text":"He calls the ground where men return in death a place of “safety” and “strength” .","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000398","text":"He warns them not to become “disinherited”.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000399","text":"Lame foot in the air.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000400","text":"They led and he followed blindly, his heavy chest heaving up and down in silent weeping ... it was the worst kind of madness, deep and tongue-tied.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000401","text":"We did not ask him for money yesterday; we shall not ask him tomorrow. But today is our day; we have climbed the iroko tree and would be foolish not to take down all the firewood we need.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000402","text":"I don't believe anybody will be so unlike other people that they will be unhappy when their sons are engaged to marry.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000403","text":"People create stories create people; or rather stories create people create stories.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000404","text":"When suffering knocks at your door and you say there is no seat for him, he tells you not to worry because he has brought his own stool.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000405","text":"War is war. The strong will always crush the weak. The only difference is that in the process some have made a lot of money and others a lot of misery.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000406","text":"In his mind, he could see the ravages of war: destruction, suffering, hunger, and the grotesque faces of men turned beasts by the bitterness of combat.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000407","text":"A Conrad student informed me in Scotland that Africa is merely a setting for the disintegration of the mind of Mr. Kurtz. Which is partly the point. Africa as setting and backdrop which eliminates the African as human factor. Africa as a metaphysical battlefield devoid of all recognizable humanity, into which the wandering European enters at his peril.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000408","text":"The real question is the dehumanization of Africa and Africans which this age-long attitude has fostered and continues to foster in the world. And the question is whether a novel which celebrates this dehumanization, which depersonalizes a portion of the human race, can be called a great work of art.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000409","text":"It always surprised him, he went on to say, because he never had thought of Africa as having that kind of stuff, you know.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000410","text":"The earth seemed unearthly.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000411","text":"Conrad saw and condemned the evil of imperial exploitation but was strangely unaware of the racism on which it sharpened its iron tooth.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000412","text":"We were wanderers on a prehistoric earth, on an earth that wore the aspect of an unknown planet.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000413","text":"A certain enormous buck nigger encountered in Haiti fixed my conception of blind, furious, unreasoning rage, as manifested in the human animal to the end of my days.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000414","text":"What art tries to do is domesticate whatever is around and press it into the service of man. Morality is basic to the nature of art.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000415","text":"Well there is an assumption there that Conrad's...Heart of Darkness is great art and I don't accept that. Great art flourishes on problems or anguish or prejudice. But the role of the writer must be very clear. The writer must not be on the side of oppression. In other words there must be no confusion. I write about prejudice; I write about wickedness; I write about murder, I write about rape: but I must not be caught on the side of murder or rape. It is as simple as that.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000416","text":"[W]hatever you are is never enough; you must find a way to accept something, however small, from the other to make you whole and to save you from the mortal sin of righteousness and extremism. (p. 154)","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000417","text":"The guilty suffers; the sufferer is guilty. As for the righteous, those whose arms are straight, they will always prosper!","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000418","text":"Don't disparage the day that still has an hour of light in its hand.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000419","text":"As the saying goes, the unexamined life is not worth-living.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000420","text":"My people have a saying which my father often used. A man whose horse is missing will look everywhere even in the roof.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000421","text":"Those who mismanage our affairs would silence our criticism by pretending they have facts not available to the rest of us. Our best weapon against them is not to marshal facts, of which they are truly managers, but passion. Passion is our hope and strength.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000422","text":"That we may accept a limitation on our actions but never, under no circumstances, must we accept restriction on our thinking.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000423","text":"I wouldn't put myself under the democratic dictatorship even of angels and archangels.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000424","text":"Do your people have a proverb about a man looking for something inside the bag of a man looking for something?","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000425","text":"In the end I began to understand. There is such a thing as absolute power over narrative. Those who secure this privilege for themselves can arrange stories about others pretty much where, and as, they like. Just as in corrupt, totalitarian regimes, those who exercise power over others can do anything.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000426","text":"In the end I began to understand. There is such a thing as absolute power over narrative. Those who secure this privilege for themselves can arrange stories about others pretty much where, and as, they like. Just as in corrupt, totalitarian regimes, those who exercise power over others can do anything. They can bring out crowds of demonstrators whenever they need them.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000427","text":"The Igbo people of Southern Nigeria are more than ten million strong and must be accounted one of the major peoples of Africa. Conventional practice would call them a tribe, but I no longer follow that convention. I call them a nation","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000428","text":"The dispossession that caused my shrillness is in retreat though the marks of its pillage are still everywhere. I can see, in spite of them, that I have come a long way.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000429","text":"It began to dawn on me that although fiction was undoubtedly fictitious it could also be true or false, not with the truth or falsehood of a news item but as to its disinterestedness, its intention, its integrity.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000430","text":"We cannot trample upon the humanity of others without devaluing our own. The Igbo, always practical, put it concretely in their proverb Onye ji onye n'ani ji onwe ya: \"He who will hold another down in the mud must stay in the mud to keep him down.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000431","text":"...when we are comfortable and inattentive, we run the risk of committing grave injustices absentmindedly.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000432","text":"Africa is people\" may seem too simple and too obvious to some of us. But I have found in the course of my travels through the world that the most simple things can still givwe us a lot of trouble, even the brightest among us: this is particularly so in matters concerning Africa.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000433","text":"I do not see that it is necessary for any people to prove to another that they build cathedrals or pyramids before they can be entitled to peace and safety.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000434","text":"Paradoxically, a saint like [Albert] Schweitzer can give one a lot more trouble than King Leopold II, villain of unmitigated guilt, because along with doing good and saving African lives Schweitzer also managed to announce that the African was indeed his brother, but only his junior brother.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000435","text":"The point in all this is that language is a handy whipping boy to summon and belabor when we have failed in some serious way. In other words, we play politics with language, and in so doing conceal the reality and the complexity of our situation from ourselves and from those foolish enough to put their trust in us.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000436","text":"It is appropriate that we celebrate Martin Luther King, a man who struggled so valiantly to restore humanity to the oppressed and the oppressor.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000437","text":"Some people flinch when you talk about art in the context of the needs of society thinking you are introducing something far too common for a discussion of art. Why should art have a purpose and a use? Art shouldn't be concerned with purpose and reason and need, they say. These are improper. But from the very beginning, it seems to me, stories have indeed been meant to be enjoyed, to appeal to that part of us which enjoys good form and good shape and good sound.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000438","text":"There is a moral obligation, I think, not to ally oneself with power against the powerless.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000439","text":"People from different parts of the world can respond to the same story if it says something to them about their own history and their own experience.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000440","text":"Every generation must recognize and embrace the task it is peculiarly designed by history and by providence to perform.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000441","text":"Writing has always been a serious business for me. I felt it was a moral obligation. A major concern of the time was the absence of the African voice. Being part of that dialogue meant not only sitting at the table but effectively telling the African story from an African perspective - in full earshot of the world.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000442","text":"The triumph of the written word is often attained when the writer achieves union and trust with the reader, who then becomes ready to be drawn into unfamiliar territory, walking in borrowed literary shoes so to speak, toward a deeper understanding of self or society, or of foreign peoples, cultures, and situations.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000443","text":"There was another epidemic that was not talked about much, a silent scourge—the explosion of mental illness: major depression, psychosis, schizophrenia, manic-depression, personality disorders, grief response, post-traumatic stress disorder, anxiety disorders, etc.—on a scale none of us had ever witnessed.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000444","text":"Camara Laye’s The Dark Child and Chinua Achebe’s Things Fall Apart because they gave me a glorious shock of recognition. Until I read them, I was not consciously aware that people who looked like me could exist in books. I grew up in a Nigerian university town, and all the books I read before then were foreign children’s books with white characters doing unfamiliar things.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000445","text":"I do reread novels I love, like Chinua Achebe’s “Arrow of God,” to remind myself of what fiction can do.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000446","text":"When I read Things Fall Apart which is about an Ibo tribe in Nigeria, a tribe I never saw, a system-to put it that way or a society, the rules of which were a mystery to me, I recognized everybody in it. And that book was about my father. How we got over I don't know, we did!\"","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000447","text":"I rank Achebe very highly, especially his Arrow of God, and I consider it a tragedy that he has had to live under such disturbed conditions and writes so little.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000448","text":"Chinua Achebe was a real education for me, a real education.","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000449","text":"Things Fall Apart quotes analyzed; study guide with themes, characters, multimedia, teacher resources","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000450","text":"No Longer at Ease quotes","author":"Chinua Achebe","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000451","text":"Apartheid is as evil, as immoral, as un-Christian, in my view, as Nazism. And in my view, the Reagan administration’s support and collaboration with it is equally immoral, evil and totally un-Christian, without remainder. (Washington, D.C. 1984)","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000452","text":"If you are neutral in situations of injustice, you have chosen the side of the oppressor. If an elephant has its foot on the tail of a mouse and you say that you are neutral, the mouse will not appreciate your neutrality.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000453","text":"I am fifty-two years of age. I am a bishop in the Anglican Church, and a few people might be constrained to say that I was reasonably responsible. In the land of my birth I cannot vote, whereas a young person of eighteen can vote. And why? Because he or she possesses that wonderful biological attribute — a white skin.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000454","text":"Be nice to the whites, they need you to rediscover their humanity.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000455","text":"I am a leader by default, only because nature does not allow a vacuum.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000456","text":"History, like beauty, depends largely on the beholder, so when you read that, for example, David Livingstone discovered the Victoria Falls, you might be forgiven for thinking that there was nobody around the Falls until Livingstone arrived on the scene.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000457","text":"Freedom and liberty lose out by default because good people are not vigilant.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000458","text":"Children are a wonderful gift. They have an extraordinary capacity to see into the heart of things and to expose sham and humbug for what they are.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000459","text":"For goodness sake, will they hear, will white people hear what we are trying to say? Please, all we are asking you to do is to recognize that we are humans, too.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000460","text":"When a pile of cups is tottering on the edge of the table and you warn that they will crash to the ground, in South Africa you are blamed when that happens.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000461","text":"I am not interested in picking up crumbs of compassion thrown from the table of someone who considers himself my master. I want the full menu of rights.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000462","text":"Those who invest in South Africa should not think they are doing us a favor; they are here for what they get out of our cheap and abundant labor, and they should know that they are buttressing one of the most vicious systems.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000463","text":"A person is a person because he recognizes others as persons.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000464","text":"You don’t choose your family. They are God’s gift to you, as you are to them.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000465","text":"We don't want apartheid liberalized. We want it dismantled. You can't improve something that is intrinsically evil.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000466","text":"We who advocate peace are becoming an irrelevance when we speak peace. The government speaks rubber bullets, live bullets, tear gas, police dogs, detention, and death.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000467","text":"At home in South Africa I have sometimes said in big meetings where you have black and white together: 'Raise your hands!' Then I have said: 'Move your hands,' and I've said 'Look at your hands - different colors representing different people. You are the Rainbow People of God.'","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000468","text":"It was relatively easy, we now realize, to categorize countries and nations. You knew who your enemies were and whom you could count on as collaborators and friends. And even more importantly, you had ready-made scapegoats to take the blame when things were going wrong.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000469","text":"There are different kinds of justice. Retributive justice is largely Western. The African understanding is far more restorative - not so much to punish as to redress or restore a balance that has been knocked askew.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000470","text":"Resentment and anger are bad for your blood pressure and your digestion.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000471","text":"Without forgiveness there can be no future for a relationship between individuals or within and between nations.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000472","text":"South Africa, so utterly improbably, is a beacon of hope in a dark and troubled world.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000473","text":"[T]here is always the possibility of change. If it happened in South Africa, why can't it happen anywhere?","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000474","text":"People marched and demonstrated, and the Berlin Wall fell, and communism was ended. People marched and demonstrated, and apartheid ended. And democracy and freedom were born. And now people are marching, and people are demonstrating, because people are saying no to war!","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000475","text":"The just war theory says you need a legitimate authority to declare and to wage war. Only the United Nations is that legitimate authority. Any other war is immoral. The just war says, “Have you exhausted all possible peaceful means?” And the world says, “No, we haven’t yet!” And any war before you have exhausted all possible peaceful means is immoral. And those who want to wage war against Iraq must know it would be an immoral war.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000476","text":"You know, those who are going to be killed in Iraq are not collateral damage. They are human beings of flesh and blood. They are children. They are mothers. They are brothers. They are grandfathers. You know what? They are our sisters and brothers, for we belong in one family. We are members of one family, God’s family, the human family. And how can we say we want to drop bombs on our sisters and brothers, on our children?","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000477","text":"We said no to communism. We said no to apartheid. We said no to injustice. We said no to oppression. And we said yes to freedom, yes to democracy. Now I ask you: What do we say to war? CROWD: No! (February 15, 2003 speaking before a massive rally in New York to oppose the imminent U.S. invasion of Iraq).","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000478","text":"God has such a deep reverence for our freedom that he'd rather let us freely go to Hell than be compelled to go to Heaven.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000479","text":"We may be surprised at the people we find in heaven. God has a soft spot for sinners. His standards are quite low.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000480","text":"We refuse to be treated as the doormat for the government to wipe its jackboots on.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000481","text":"I give great thanks to God that he has created a Dalai Lama. Do you really think, as some have argued, that God will be saying: \"You know, that guy, the Dalai Lama, is not bad. What a pity he's not a Christian\"? I don't think that is the case — because, you see, God is not a Christian.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000482","text":"He has a childlike, boyish, impish, mischievousness. And I have to try and make him behave properly, like a holy man!","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000483","text":"We used to say to the apartheid government: you may have the guns, you may have all this power, but you have already lost. Come: join the winning side. His Holiness and the Tibetan people are on the winning side.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000484","text":"I don't preach a social gospel; I preach the Gospel, period. The gospel of our Lord Jesus Christ is concerned for the whole person. When people were hungry, Jesus didn't say, \"Now is that political or social?\" He said, \"I feed you.\" Because the good news to a hungry person is bread.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000485","text":"What has happened to us? It seems as if we have perverted our freedom, our rights into license, into being irresponsible. Perhaps we did not realise just how apartheid has damaged us so that we seem to have lost our sense of right and wrong.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000486","text":"I would not worship a God who is homophobic and that is how deeply I feel about this. I would refuse to go to a homophobic heaven. No, I would say sorry, I mean I would much rather go to the other place. I am as passionate about this campaign as I ever was about apartheid. For me, it is at the same level.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000487","text":"Whether Jews like it or not, they are a peculiar people. They can't ever hope to be judged by the same standards which are used for other people.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000488","text":"None of us can say that had I been exposed to the same circumstances and conditions that I wouldn't have turned out the same way. Perpetrators don't have horns, don't have tails, they are as ordinary looking as you and I.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000489","text":"Forgiveness is one of the key ideas in this world. Forgiveness is not just some nebulous, vague idea that one can easily dismiss. It has to do with uniting people through practical politics. Without forgiveness there is no future.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000490","text":"Forgiveness is taking seriously the awfulness of what has happened when you are treated unfairly. It is opening the door for the other person to have a chance to begin again. Without forgiveness, resentment builds in us, a resentment which turns into hostility and anger. Hatred eats away at our well-being.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000491","text":"Forgiveness is an absolute necessity for continued human existence.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000492","text":"Israel will never get true security and safety through oppressing another people. A true peace can ultimately be built only on justice. We condemn the violence of suicide bombers, and we condemn the corruption of young minds taught hatred; but we also condemn the violence of military incursions in the occupied lands, and the inhumanity that won't let ambulances reach the injured.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000493","text":"We in South Africa had a relatively peaceful transition. If our madness could end as it did, it must be possible to do the same everywhere else in the world. If peace could come to South Africa, surely it can come to the Holy Land.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000494","text":"People are scared in this country, to say wrong is wrong because the Jewish lobby is powerful — very powerful. Well, so what? For goodness sake, this is God's world! We live in a moral universe. The apartheid government was very powerful, but today it no longer exists. Hitler, Mussolini, Stalin, Pinochet, Milosevic, and Idi Amin were all powerful, but in the end they bit the dust.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000495","text":"Sometimes you want to whisper in God's ear, \"God, we know you are in charge, but why don't you make it slightly more obvious?\"","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000496","text":"You and I are created for transcendence, laughter, caring. God deliberately did not make the world perfect, for God is looking for you and me to be fellow workers with God.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000497","text":"It is for real that injustice and oppression will not have the last word. There was a time when Hitler looked like he was going to vanquish all of Europe, and where is he now?","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000498","text":"When people say that the Bible and politics don't mix, I ask them which Bible they are reading.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000499","text":"There comes a point where we need to stop just pulling people out of the river. We need to go upstream and find out why they’re falling in.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000500","text":"The U.N. is as effective as its member states allow it to be.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000501","text":"When the missionaries came to Africa they had the Bible and we had the land. They said \"Let us pray.\" We closed our eyes. When we opened them, we had the Bible and they had the land.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000502","text":"The first thing we learn from history is that we learn nothing from history.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000503","text":"If the reasons for Desmond Tutu becoming one of the world's most prominent advocates of faith-based social justice and religious tolerance could be reduced to a single succinct statement, it would be this: his fierce and uncompromising determination to tell the truth as he sees it.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000504","text":"Nothing epitomizes Desmond Tutu's radicalism (using the word radical, as he likes to say, in the original sense of getting to the root of an issue) more than his views on the relationship of his faith to the faith of others.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000505","text":"There are so many people in South Africa, within the country, who are muzzled. And there are others who may not be muzzled within South Africa but whose passports are withdrawn, people like Bishop Desmond Tutu-a very important voice; you know, a writer is nothing compared with him. He is a big figure, a real leader, and he can't go abroad and speak. So I think that those of us who can, as long as we can, we have to use the opportunity.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000506","text":"Dalawampu't limang taon na ang nakalilipas ang mga tao ay maaaring idahilan para sa hindi gaanong alam, o paggawa ng marami, tungkol sa pagbabago ng klima. Ngayon wala kaming dahilan.","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000507","text":"I met with members of the South African Supreme Court, spoke with doctors at an HIV/AIDS clinic, and spent time with Bishop Desmond Tutu, whose joyful spirit I had gotten to know during his visits to Washington. \"So is it true, Barack,\" he said with an impish smile, \"that you are going to be our first African president of the United States? Ah, that would make us all verrry proud!\"","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000508","text":"Desmond Tutu Peace Foundation - USA","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000509","text":"Desmond and Leah Tutu Legacy Foundation - South Africa","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000510","text":"Tutu Foundation UK - United Kingdom","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000511","text":"Nobel Peace Prize Site Bio","author":"Desmond Tutu","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000512","text":"\"We must resist the notion that there is only one way to be a woman, one way to be African, and one way to be human.\"","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000513","text":"\"I think what the Nobel committee is doing is going beyond war and looking at what humanity can do to prevent war. Sustainable management of our natural resources will promote peace.\"","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000514","text":"(WHAT'S THE PLANET'S BIGGEST CHALLENGE?) The environment. We are sharing our resources in a very inequitable way. We have parts of the world that are very deprived and parts of the world that are very rich. And that is partly the reason why we have conflict.","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000515","text":"\"Until you dig a hole, you plant a tree, you water it and make it survive, you haven't done a thing. You are just talking.\"","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000516","text":"\"In the course of history, there comes a time when humanity is called to shift to a new level of consciousness, to reach a higher moral ground- a time when we have to shed our fear and give hope to each other. That time is now.\"","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000517","text":"We are called to assist the Earth to heal her wounds and in the process heal our own—indeed, to embrace the whole creation in all its diversity, beauty, and wonder.","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000518","text":"Human rights are not things that are put on the table for people to enjoy. These are things you fight for and then you protect.","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000519","text":"The generation that destroys the environment is not the generation that pays the price. That is the problem.","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000520","text":"I’m very conscious of the fact that you can’t do it alone. It’s teamwork. When you do it alone you run the risk that when you are no longer there nobody else will do it.","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000521","text":"Education, if it means anything, should not take people away from the land, but instill in them even more respect for it, because educated people are in a position to understand what is being lost. The future of the planet concerns all of us, and all of us should do what we can to protect it. As I told the foresters, and the women, you don't need a diploma to plant a tree.","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000522","text":"“What people see as fearlessness is really persistence.”","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000523","text":"“Hallowed landscapes lost their sacredness and were exploited as the local people became insensitive to the destruction, accepting it as a sign of progress.”","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000524","text":"“You would see me there now, cultivating the earth and carrying firewood on my back up the hills to my home, where I would light a fire and cook the evening meal. I would not tell stories, because they have been replaced by books, the radio, and television”","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000525","text":"“You don't need a diploma to plant a tree.”","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000526","text":"No matter how dark the cloud, there is always a thin, silver lining, and that is what we must look for. The silver lining will come, if not to us then to next generation or the generation after that. And maybe with that generation the lining will no longer be thin.","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000527","text":". “African women in general need to know that it’s OK for them to be the way they are — to see the way they are as a strength, and to be liberated from fear and from silence.”","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000528","text":"“Today we are faced with a challenge that calls for a shift in our thinking, so that humanity stops threatening its life-support system. We are called to assist the Earth to heal her wounds and in the process heal our own … Recognizing that sustainable development, democracy and peace are indivisible is an idea whose time has come.”","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000529","text":"nobody knows the solution to every problem; rather than blindly following the prescriptions of others, Africans need to think and act for themselves, and learn from their mistakes.","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000530","text":"We all share one planet and are one humanity; there is no escaping this reality.","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000531","text":"\"The people are starving. They need food; they need medicine; they need education. They do not need a skyscraper to house the ruling party and a 24-hour TV station.\"","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000532","text":"Peace on earth depends on our ability to secure our living environment. Maathai stands at the front of the fight to promote ecologically viable social, economic and cultural development in Kenya and in Africa. She has taken a holistic approach to sustainable development that embraces democracy, human rights and women's rights in particular. She thinks globally and acts locally.","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000533","text":"Wangari Maathai Quotable Quotes at Friends of the Green Belt Movement North America","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000534","text":"Article on Wangari Maathai","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000535","text":"Nobel Committee official press release","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000536","text":"Quotable Quotes on Maathai's home page","author":"Wangari Maathai","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000537","text":"African music, though very old, is always being rediscovered in the West.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000538","text":"I always wanted to leave home. I never knew they were going to stop me from coming back. Maybe, if I knew, I never would have left. It is kind of painful to be away from everything that you've ever know. Nobody will know the pain of exile until you are in exile. No matter where you go, there are times when people show you kindness and love, and there are times when they make you know that you are with them but not of them. That's when it hurts.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000539","text":"I will probably die singing.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000540","text":"When I was young, I never bought records because my brother Joseph played saxophone and had a record player. I loved listening to his records: The Dorsey Brothers, Duke Ellington, all the big American jazz bands, and vocalists like Ella Fitzgerald, Ernestine Anderson, and Kitty White, a singer from the US who was a friend of Nina Simone. Nobody in America seems to know about her, but she was quite popular in South Africa.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000541","text":"In those years, when I came to the States, people were always asking me why I didn’t sing anymore. I’d tell them, ‘I sing all around the world—Asia, Africa, Europe—but if you don’t sing in the US, then you haven’t really made it.’ That’s why I’ll always be grateful to Paul Simon. He allowed me to bring my music back to my friends in this country.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000542","text":"I didn’t have much, but I was always happy to share what I did have. It seemed like every African that came to New York City would show up at my apartment door at dinnertime, and I couldn’t turn them away. I wasn’t much older than any of them, but they started calling me ‘Mama Africa’ and the name stuck.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000543","text":"It is absurd to say that we Africans were not in Africa when white people first came. And secondly, The conqueror writes history. They came, they conquered and they wrote. Now, you don't expect people who came to invade us to write the truth about us. They will always write negative things about us. And they have to do that because they have to justify their invasions in all the countries.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000544","text":"We don't write our history. It has always been handed down to us orally by our elders.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000545","text":"The white man, where ever he is, whether he is in the majority or the minority, he rules. It just proves to everyone that we have to keep fighting.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000546","text":"Everywhere I performed in Brazil, I never saw black people. I only performed to white people. And they (the white people) said it's because they (the black people) can't afford to come here - it's too expensive. That is another form of keeping them from coming to where they can enjoy themselves together with white people. They keep them poor.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000547","text":"\"The truth shall never be covered by a lie.\"","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000548","text":"In New York I heard A Piece of Ground, written by a white South African, Jeremy Taylor. I modified it a little and sang it myself. That song is very special to me because it deals with the land question in southern Africa. We were dispossessed of our land.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000549","text":"The tragedy of civil wars in countries like Angola and Mozambique is that they left many civilians maimed. Poverty is the reason HIV/AIDS spread so rapidly in the African townships and slums. Poverty is the real killer.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000550","text":"The man at the desk took my passport. He did not speak to me. He took a rubber stamp and slammed it down. Then he walked away. I picked up my passport. It was stamped 'Invalid'. 'They have done it,' I told myself. 'They have exiled me. I am not permitted to go home — not now, maybe not ever. My family, my home. Everything that has gone into the making of myself, gone'.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000551","text":"I look at an ant and see myself: a native South African, endowed with a strength much greater than my size, so I might cope with the weight of racism that crushes my spirit.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000552","text":"That was the only time my mother saw me on stage. At one point in the play I am strangled and my mother jumped from her seat and screamed: 'No. You will not get away with murder. You cannot do this to my daughter.' Friends explained to her that this was not for real — that we were acting. But she made such a fuss. Everyone was so embarrassed. On stage my heart sank.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000553","text":"I still don't know why they banned me\" she says. \"I said to them, 'What did I do? I never killed anybody. I was never arrested for anything bad, so why can't I go home?.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000554","text":"I'm not a political singer. I don't know what the word means. People think I consciously decided to tell the world what was happening in South Africa. No! I was singing about my life, and in South Africa we always sang about what was happening to us — especially the things that hurt us.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000555","text":"Belafonte sent his people to pick me up and I went back and shook his hand, then went back to my little flat. I was very happy to have met a president of the United States - little me!","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000556","text":"[Belafonte]'d take me to perform for Martin Luther King's cause. But when they were marching I did not take part, because I was not a citizen","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000557","text":"[Belafonte] was a good teacher and looked after me. He said, 'You have such great talent, you must try not to be a tornado - be like a submarine. It was good advice when I found myself speaking at the UN Committee Against Apartheid and then the UN General Assembly.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000558","text":"It was not a ban from the government. It was a cancellation by people who felt I should not be with Stokely because he was a rebel to them. I didn't care about that. He was somebody I loved, who loved me, and it was my life.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000559","text":"[W]hen the President's visitors came to Guinea, we were all called on to go and entertain them. I've never seen a country that did what Sékou Touré did for artists. Even in South Africa today we are not nurtured like that.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000560","text":"It's because they want to sound like Americans. I'd like to see them develop our music and sing it their way, but they think sounding American is going to take them higher, but it is not. They have beautiful voices, but they want to sound like Whitney Houston. You can't beat people like that at their own game. And they can't beat me at mine, either!","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000561","text":"Girls are the future mothers of the , it is important we focus on their wellbeing.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000562","text":"Her voice and her battles influenced the process of liberation and democratic rebirth in South Africa.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000563","text":"We will miss her energy and her respectful concern for the world's most vulnerable.","author":"Miriam Makeba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000564","text":"The basic tenet of black consciousness is that the black man must reject all value systems that seek to make him a foreigner in the country of his birth and reduce his basic human dignity.","author":"Steve Biko","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000565","text":"Even today, we are still accused of racism. This is a mistake. We know that all interracial groups in South Africa are relationships in which whites are superior, blacks inferior. So as a prelude whites must be made to realize that they are only human, not superior. Same with blacks. They must be made to realize that they are also human, not inferior.","author":"Steve Biko","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000566","text":"You are either alive and proud or you are dead, and when you are dead, you can't care anyway.","author":"Steve Biko","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000567","text":"It is better to die for an idea that will live, than to live for an idea that will die.","author":"Steve Biko","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000568","text":"The most potent weapon in the hands of the oppressor is the mind of the oppressed.","author":"Steve Biko","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000569","text":"Apartheid — both petty and grand — is obviously evil. Nothing can justify the arrogant assumption that a clique of foreigners has the right to decide on the lives of a majority.","author":"Steve Biko","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000570","text":"The system concedes nothing without demand, for it formulates its very method of operation on the basis that the ignorant will learn to know, the child will grow into an adult and therefore demands will begin to be made. It gears itself to resist demands in whatever way it sees fit.","author":"Steve Biko","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000571","text":"In time, we shall be in a position to bestow on South Africa the greatest possible gift&mdash;a more human face.","author":"Steve Biko","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000572","text":"We must realise that prophetic cry of black students: \"Black man you are on your own!\"","author":"Steve Biko","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000573","text":"Dictatorships fall not only when they have implacable opponents but also exemplary victims: Steve Biko in South Africa, Benigno Aquino in the Philippines, Jerzy Popieluszko in Poland. Through their deaths, they awakened the living to the conviction that it was the regime that should die instead.","author":"Steve Biko","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000574","text":"For centuries, Europeans dominated the African continent. The white man arrogated to himself the right to rule and to be obeyed by the non-white; his mission, he claimed, was to \"civilize\" Africa. Under this cloak, the Europeans robbed the continent of vast riches and inflicted unimaginable suffering on the African people.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000575","text":"Capitalism is too complicated a system for a newly independent nation. Hence the need for a socialistic society.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000576","text":"Just as in the days of the Egyptians, so today God had ordained that certain among the African race should journey westwards to equip themselves with knowledge and experience for the day when they would be called upon to return to their motherland and to use the learning they had acquired to help improve the lot of their brethren. ...I had not realized at the time that I would contribute so much towards the fulfillment of this prophecy.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000577","text":"We cannot tell our peoples that material benefits in growth and modern progress are not for them. If we do, they will throw us out and seek other leaders who promise more … We have to modernize. Either we shall do so with the interest and support of the West or we shall be compelled to turn elsewhere. This is not a warning or a threat, but a straight statement of political reality.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000578","text":"To the true African journalist, his newspaper is a collective organizer, a collective instrument of mobilization and a collective educator—a weapon, first and foremost, to overthrow colonialism and imperialism and to assist total African independence and unity.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000579","text":"Capitalism is a development by refinement from feudalism just as feudalism is a development by refinement from slavery. … Capitalism is but the gentleman's method of slavery.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000580","text":"The difference between myself and Castro is that I am not aligned and he is; I am a socialist and he is a communist.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000581","text":"The independence of Ghana is meaningless until it is linked to the total liberation of Africa.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000582","text":"I am not African because I was born in Africa but because Africa was born in me.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000583","text":"As long as we are ruled by others we shall lay our mistakes at their door, and our sense of responsibility will remain dulled. Freedom brings responsibilities, and our experience can be enriched only by the acceptance of these responsibilities.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000584","text":"Seek ye first the political kingdom and all things shall be added unto you.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000585","text":"Never in the history of the world has an alien ruler granted self-rule to a people on a silver platter.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000586","text":"\" We face neither East nor West; we face forward.” Source: “Kwame Nkrumah: The Conakry Years,” by June Milne.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000587","text":"\" The independence of Ghana is meaningless unless it is linked up with the total liberation of the African continent.” Source: “Africa Must Unite,” by Kwame Nkrumah.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000588","text":"\"It is far better to be free to govern or misgovern yourself than to be governed by anybody else.” Source: “I Speak of Freedom: A Statement of African Ideology,” by Kwame Nkrumah.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000589","text":"of the analysis of facts and events, and this kind of evaluation is, I feel, as good a starting point of the inquiry into the relations between philosophy and society as any other. Philosophy, in understanding human society, call for an analysis of facts and events, and an attempt to see how they fit into human life, and so how they make up human experience. In this way, philosophy, like history, can come to enrich, indeed to define, the experience of man.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000590","text":"When they came across doctrines of a combative nature, like those of Marxism, they reduced them to arid abstractions, to common-room subtleties. In this way, through the good graces of their colonialist patrons, these students, now competent in the art of forming not a concrete environmental view of social political problems, but an abstract, 'liberal' outlook, began to fulfil the hopes and expectations of their guides and guardians.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000591","text":"There were the vast numbers of ordinary Africans, who, animated by a lively , sought knowledge as an instrument of national emancipation and integrity. This is not to say that these Africans overlooked the purely cultural value of their studies. But in order that their cultural acquisition should be valuable, they needed to be capable of appreciating it as free men.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000592","text":"The critical study of the philosophies of the past should lead to the study of modern theories. For these latter, born of the fire of contemporary struggles, are militant and alive.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000593","text":"The neo-colonialism of today represents imperialism in its final and perhaps its most dangerous stage.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000594","text":"The essence of neo-colonialism is that the State which is subject to it is, in theory, independent and has all the outward trappings of international sovereignty. In reality its economic system and thus its political policy is directed from outside.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000595","text":"The result of neo-colonialism is that foreign capital is used for the exploitation rather than for the development of the less developed parts of the world. Investment under neo-colonialism increases rather than decreases the gap between the rich and the poor countries of the world.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000596","text":"The post-war period inaugurated a very different colonial policy. A deliberate attempt was made to divert colonial earnings from the wealthy class and use them instead generally to finance the ‘Welfare State’. As will be seen from the examples given later, this was the method consciously adopted even by those working-class leaders who had before the war regarded the colonial peoples as their natural allies against their capitalist enemies at home.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000597","text":"Neo-colonialism is based upon the principle of breaking up former large united colonial territories into a number of small non-viable States which are incapable of independent development and must rely upon the former imperial power for defence and even internal security. Their economic and financial systems are linked, as in colonial days, with those of the former colonial ruler.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000598","text":"The introduction of neo-colonialism increases the rivalry between the great powers which was provoked by the old-style colonialism. However little real power the government of a neo-colonialist State may possess, it must have, from the very fact of its nominal independence, a certain area of manoeuvre. It may not be able to exist without a neo-colonialist master but it may still have the ability to change masters.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000599","text":"The less developed world will not become developed through the goodwill or generosity of the developed powers. It can only become developed through a struggle against the external forces which have a vested interest in keeping it undeveloped.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000600","text":"Foremost among the neo-colonialists is the United States, which has long exercised its power in Latin America. Fumblingly at first she turned towards Europe, and then with more certainty after world war two when most countries of that continent were indebted to her. Since then, with methodical thoroughness and touching attention to detail, the Pentagon set about consolidating its ascendancy, evidence of which can be seen all around the world.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000601","text":"Today the need both to maintain a welfare state, i.e. a parasite State at home, and to support a huge and ever-growing burden of armament cost makes it absolutely essential for developed capitalist countries to secure the maximum return in profit from such parts of the international financial complex as they control.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000602","text":"The only effective way to challenge this economic empire and to recover possession of our heritage, is for us to act on a Pan-African basis, through a Union Government.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000603","text":"Always be the servant of the people.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000604","text":"The guerrilla is the masses in arms.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000605","text":"The modifications introduced by imperialism in its strategy were expressed:(a) through the disappearance of the numerous old-fashioned \"colonies\" owing exclusive allegiance to a single metropolitan country.(b) through the replacement of \"national\" imperialisms by a \"collective\" imperialism in which the USA occupies a leading position.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000606","text":"The principle of mutual inter-imperialist assistance whereby American, British, French and West German monopoly capital extends joint control over the wealth of the non-liberated zones of Africa, Latin America and Asia, finds concrete expression in the formation of interlocked international financial institutions and bodies of credit.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000607","text":"A state can be said to be a neo-colonialist or client state if it is independent de jure and dependent de facto. It is a state where political power lies in the conservative forces of the former colony and where economic power remains under the control of international finance capital.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000608","text":"The three essential components of neo-colonialism are:1. Economic exploitation2. Puppet governments and client states3. Military assistance4. Economic \"aid.\"","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000609","text":"\"I prefer freedom in danger than servitude in tranquility\"","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000610","text":"I haven't dared go back to Ghana because my experience there was so precious that I don't want to risk spoiling it. I got so much health and stability from that country, and the people, the way it was with Kwame Nkrumah. He was deposed and subsequently killed, and I haven't wanted to go back.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000611","text":"The only leader I truly admired was Kwame Nkrumah because he had a certain charisma, a great understanding of politics, and a dramatic flair. He knew how to provide what people expected from a leader. I felt a lot of admiration for him and was quite disturbed when he fled to Guinea under such sad circumstances.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000612","text":"big business in America, surprised by the success of the Ghana revolution set itself to influence Nkrumah. Nkrumah was invited to the United States in 1958, and treated as never a Negro had been treated by the government. Hershey, a great manufacturer of chocolate, sent a special plane to take him to his factories; and the New York Cocoa Board of Trade dined him at the Waldorf-Astoria.","author":"Kwame Nkrumah","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000613","text":"We want to get our army involved with the people in productive work and remind it constantly that, without patriotic training, a soldier is only a criminal with power.","author":"Thomas Sankara","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000614","text":"In these tempestuous times, we can't leave our enemies of the past and the present the monopoly on thought, imagination, and creativity.","author":"Thomas Sankara","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000615","text":"When the people stand up, imperialism trembles.","author":"Thomas Sankara","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000616","text":"I would like to leave behind me the conviction that if we maintain a certain amount of caution and organization we deserve victory. ... You cannot carry out fundamental change without a certain amount of madness. In this case, it comes from nonconformity, the courage to turn your back on the old formulas, the courage to invent the future. It took the madmen of yesterday for us to be able to act with extreme clarity today. I want to be one of those madmen. ... We must dare to invent the future.","author":"Thomas Sankara","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000617","text":"The revolution and women’s liberation go together. We do not talk of women’s emancipation as an act of charity or out of a surge of human compassion. It is a basic necessity for the revolution to triumph.","author":"Thomas Sankara","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000618","text":"We must recognize today that it is normal for the wealthiest to be the greatest thieves. When a poor man steals it is merely a theft, a petty crime — it is solely about survival and necessity. The rich are the ones who steal from the treasury, customs duties, and who exploit the people.","author":"Thomas Sankara","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000619","text":"The dream of getting rich through a dog-eat-dog struggle, based on what happened in the capitalist jungle of the postwar years, has disappeared forever from Burkina. Our homeland has become a vast construction site where the criteria of morality, concern for social justice, and respect for everyone's fundamental right to live and to enjoy an increasingly better and better life are not just empty words but take material form in the social activity of every one of us.","author":"Thomas Sankara","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000620","text":"Capitalism is the arsonist of our forests.","author":"Thomas Sankara","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000621","text":"We must choose between champagne for a few or drinking water for all.","author":"Thomas Sankara","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000622","text":"No one is perfect in this imperfect world.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000623","text":"Without dignity there is no liberty, without justice there is no dignity, and without independence there are no free men.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000624","text":"A minimum of comfort is necessary for the practice of virtue.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000625","text":"The Soviet Union is the only great power whose position has reflected the will and wishes of our people. Therefore the Soviet Union proves to be the only great power that has supported the Congolese people in their struggle from the beginning.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000626","text":"I took the money not for myself, but for my political activities, I hurt no private individual, only the Belgian state, which at the time was my worst enemy, it had plunderd us, now i plunderd it.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000627","text":"While our brothers in Kenya, Nyasa-land, Rhodesia, South Africa and Angola are still fighting for their freedom, look at the wonderful future that smiles at us.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000628","text":"We are no longer your monkeys.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000629","text":"At the moment when Congo reaches independence, the whole government wishes to pay solemn homage to the King of the Belgians, and to the noble people he represents for the work done here over three quarters of a century. I would not wish my feelings to be wrongly interpreted... Long live King Baudouin, Long live Belgium, Long live the independent Congo.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000630","text":"Our dearest wish perhaps, some may find it utopian is to found in the Congo a Nation in which differences of race and religion will melt away, a homogeneous society composed of Belgians and Congolese who with a single impulse will link their hearts to the destinies of the country.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000631","text":"The aspirations of the peoples of colonial countries, are identical, their destinies are similar and the goals they pursue in their national development are the same: liberation of Africa from the yoke of colonialism. Africa will never be free and independent if any part of it remains under foreign domination.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000632","text":"We protest against any attempts to split our national territory. The Congo’s greatness is based on the maintenance of its political and economic unity.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000633","text":"All together, dear brothers and sisters, workers and government employees, workers by brain and by hand, rich and poor, Africans and Europeans, Catholics and Protestants, Kimbanguists and Kitawalists, let us unite and create a great nation.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000634","text":"We know, that some Congolese are well off, but they are in the minority; meanwhile we are concerned with the majority of the population.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000635","text":"The European powers, want to enlist the sympathies of those African leaders who follow their lead and deceive their own people. Some of these powers see the meaning of their presence in the Congo and in Africa in exploiting their riches as much as possible, availing themselves of the services of the corrupt leaders.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000636","text":"I know that an overwhelming majority of the Belgian people are against the oppression of Africans. They disapprove of a colonial status for the Congo under which 14 million Congolese are exposed to the diktat of a tiny economic oligarchy. If the Belgian people were to have their say, the Congo would never have experienced the misfortunes which are affecting it now.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000637","text":"Tensions in the relations between the Congo and Belgium are being exacerbated only by the groups interested in exploiting the Congo’s wealth and who egg the authorities on to extend the colonial regime, as well as by some officials who are pursuing their private interests.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000638","text":"History attests, that independence is never brought to you on a silver platter. It must be won. To that end we must organise ourselves and mobilise all the healthy forces in the country. The Congolese have responded to our appeal and thanks to this united strength we have dealt a mortal blow to rotten colonialism.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000639","text":"Kamina, is the first enterprise we are going to nationalise in Congo.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000640","text":"We became the target of attacks because we no longer want to submit ... and reject corruption. They tried to bribe us and millions were promised to me, but I refused, I did not take a single centime.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000641","text":"My dear countrymen! In joy and in sorrow I will always be with you. It is together with you that I fought to free my country from foreign rule. Together with you I am fighting to strengthen our national independence. Together with you, I will fight to preserve the integrity and national unity of the Republic of the Congo.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000642","text":"Neither cruelty, nor violence, nor torture will make me beg for mercy, because I prefer to die with my head raised high, with unshakeable faith... In my country’s predestination rather than live in submission forsaking my sacred principles.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000643","text":"Our wounds are too fresh and too smarting for us to be able to have known ironies, insults, and blows which we had to undergo morning, noon and night because we were Negroes. We have seen our lands spoiled in the name of laws which only recognised the right of the strongest. We have known laws which differed according to whether it dealt with a black man or a white.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000644","text":"We have known the atrocious sufferings of those who were imprisoned for their political opinions or religious beliefs and of those exiled in their own country. Their fate was worse than death itself. Who will forget the rifle-fire from which so many of our brothers perished, or the gaols in to which were brutally thrown those who did not want to submit to a regime of justice, oppression and exploitation which were the means the colonialists employed to dominate us?","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000645","text":"in this sphere even Belgium who, understanding in the end the sense of history, did not try any harder to oppose our independence, is prepared to give us her help and friendship.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000646","text":"We had then made our views felt to the world. We had stopped Adlai Stevenson from speaking at the United Nations while protesting about the death of Lumumba. New York was seething. Everyone who had any consciousness was out in the streets.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000647","text":"Those who expect from it an exposition of the dynamic nationalism for which he is now the symbol will be disappointed. Lumumba at that time was a self-conscious évolué and an exponent of gradualism, much more concerned to mediate between the Belgian colonial system and the mass of Congolese peasants than to demand immediate independence.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000648","text":"Like the murder of Patrice Lumumba in the Congo, the murder of Malcolm X deprived the world of a potentially great leader. I could not agree with either of these men, but I could see in them a capacity for leadership which I could respect and which was only beginning to mature in judgment and statesmanship.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000649","text":"Speeches and writings by and about Patrice Lumumba, at the Marxists Internet Archive.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000650","text":"Virtual Memorial to Patrice Lumumba, at Find-A-grave.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000651","text":"Patrice Lumumba: 50 Years Later, Remembering the U.S.-Backed Assassination – video report","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000652","text":"SpyCast – 1 December 2007: On Assignment to Congo-Peter chats with Larry Devlin, the CIA's legendary station chief in Congo during the 1960s.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000653","text":"Africa Within. A rich source of information on Lumumba, including a reprint of Stephen R. Weissman's 21 July 2002 article from the Washington Post.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000654","text":"BBC Lumumba apology: Congo's mixed feelings.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000655","text":"Mysteries of History Lumumba assassination.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000656","text":"Lumumba and the Congo Documentary of Lumumba's life and work in the Congo.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000657","text":"BBC An \"On this day\" text. It features an audio clip of a BBC correspondent on Lumumba's death.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000658","text":"Belgian Parliament The findings of the Belgian Commission of 2001 investigating Belgian involvement in the death of Lumumba. Documents at the bottom of the page are in English.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000659","text":"Beat Knowledge tribute to Lumumba Tribute to Lumumba on 50th anniversary of his assassination (17 January 2011).","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000660","text":"Belgian Commission's Conclusion A particular document from the previous link.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000661","text":"D'Lynn Waldron Dr. D'Lynn Waldron's extensive archive of articles, photographs, and documents from her days as a foreign press correspondent in Lumumba's 1960 Congo.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000662","text":"CIA plans included the assassination of Patrice Lumumba, report from the Washington Post by Karen DeYoung and Walter Pincus.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000663","text":"Patrice Emery Lumumba: Memory of Congolese Leader Lives on 50 Years Later.","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."},{"id":"modern-african-000664","text":"( Picture of Lumumba's children in Egypt, visited by the wife of East Germany's leading foreign politician Heinrich Rau. )","author":"Patrice Lumumba","source":"Wikiquote","tags":["language:en","theme:justice","theme:leadership","theme:resilience","tradition:secular"],"isProverb":false,"isVerified":false,"verificationNote":"Auto-scraped from Wikiquote; verify against original source."}]}
c-domain text"},{"id":"pali-ext-000859","text":"Scene on the Verge of the Hay-Mead Chapter XXVII.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000860","text":"Hiving the Bees Chapter XXVIII.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000861","text":"The Hollow Amid the Ferns Chapter XXIX.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000862","text":"Particulars of a Twilight Walk Chapter XXX.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000863","text":"Hot Cheeks and Tearful Eyes Chapter XXXI.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000864","text":"Night—Horses Tramping Chapter XXXIII.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000865","text":"In the Sun—A Harbinger Chapter XXXIV.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000866","text":"Home Again—A Trickster Chapter XXXV.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000867","text":"At an Upper Window Chapter XXXVI.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000868","text":"Wealth in Jeopardy—The Revel Chapter XXXVII.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000869","text":"The Storm—The Two Together Chapter XXXVIII.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000870","text":"Rain—One Solitary Meets Another Chapter XXXIX.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000871","text":"On Casterbridge Highway Chapter XLI.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000872","text":"Suspicion—Fanny Is Sent For Chapter XLII.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000873","text":"Joseph and His Burden—Buck’s Head Chapter XLIII.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000874","text":"Under a Tree—Reaction Chapter XLV.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000875","text":"Troy’s Romanticism Chapter XLVI.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000876","text":"The Gurgoyle: Its Doings Chapter XLVII.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000877","text":"Adventures by the Shore Chapter XLVIII.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000878","text":"Doubts Arise—Doubts Linger Chapter XLIX.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000879","text":"Oak’s Advancement—A Great Hope Chapter L.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000880","text":"The Sheep Fair—Troy Touches His Wife’s Hand Chapter LI.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000881","text":"Bathsheba Talks with Her Outrider Chapter LII.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000882","text":"Converging Courses Chapter LIII.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000883","text":"Concurritur—Horæ Momento Chapter LIV.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000884","text":"The March Following—“Bathsheba Boldwood” Chapter LVI.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000885","text":"Beauty in Loneliness—After All Chapter LVII.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000886","text":"A Foggy Night and Morning—Conclusion","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000887","text":"The series of novels I projected being mainly of the kind called local, they seemed to require a territorial definition of some sort to lend unity to their scene.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000888","text":"Finding that the area of a single county did not afford a canvas large enough for this purpose, and that there were objections to an invented name, I disinterred the old one.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000889","text":"I did not anticipate that this application of the word to a modern use would extend outside the chapters of my own chronicles.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000890","text":"But the name was soon taken up elsewhere as a local designation.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000891","text":"But I ask all good and gentle readers to be so kind as to forget this, and to refuse steadfastly to believe that there are any inhabitants of a Victorian Wessex outside the pages of this and the companion volumes in which they were first discovered.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000892","text":"The church remains, by great good fortune, unrestored and intact, and a few of the old houses; but the ancient malt-house, which was formerly so characteristic of the parish, has been pulled down these twenty years; also most of the thatched and dormered cottages that were once lifeholds.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000893","text":"The game of prisoner’s base, which not so long ago seemed to enjoy a perennial vitality in front of the worn-out stocks, may, so far as I can say, be entirely unknown to the rising generation of schoolboys there.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000894","text":"For these the indispensable conditions of existence are attachment to the soil of one particular spot by generation after generation.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000895","text":"CHAPTER I Description of Farmer Oak—An Incident","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000896","text":"When Farmer Oak smiled, the corners of his mouth spread till they were within an unimportant distance of his ears, his eyes were reduced to chinks, and diverging wrinkles appeared round them, extending upon his countenance like the rays in a rudimentary sketch of the rising sun.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000897","text":"His Christian name was Gabriel, and on working days he was a young man of sound judgment, easy motions, proper dress, and general good character.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000898","text":"Or, to state his character as it stood in the scale of public opinion, when his friends and critics were in tantrums, he was considered rather a bad man; when they were pleased, he was rather a good man; when they were neither, he was a man whose moral colour was a kind of pepper-and-salt mixture.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000899","text":"Since he lived six times as many working-days as Sundays, Oak’s appearance in his old clothes was most peculiarly his own—the mental picture formed by his neighbours in imagining him being always dressed in that way.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000900","text":"He wore a low-crowned felt hat, spread out at the base by tight jamming upon the head for security in high winds, and a coat like Dr.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000901","text":"Oak carried about him, by way of watch, what may be called a small silver clock; in other words, it was a watch as to shape and intention, and a small clock as to size.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000902","text":"This instrument being several years older than Oak’s grandfather, had the peculiarity of going either too fast or not at all.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000903","text":"The smaller of its hands, too, occasionally slipped round on the pivot, and thus, though the minutes were told with precision, nobody could be quite certain of the hour they belonged to.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000904","text":"But some thoughtful persons, who had seen him walking across one of his fields on a certain December morning—sunny and exceedingly mild—might have regarded Gabriel Oak in other aspects than these.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000905","text":"In his face one might notice that many of the hues and curves of youth had tarried on to manhood: there even remained in his remoter crannies some relics of the boy.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000906","text":"His height and breadth would have been sufficient to make his presence imposing, had they been exhibited with due consideration.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000907","text":"But there is a way some men have, rural and urban alike, for which the mind is more responsible than flesh and sinew: it is a way of curtailing their dimensions by their manner of showing them.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000908","text":"And from a quiet modesty that would have become a vestal, which seemed continually to impress upon him that he had no great claim on the world’s room, Oak walked unassumingly and with a faintly perceptible bend, yet distinct from a bowing of the shoulders.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000909","text":"This may be said to be a defect in an individual if he depends for his valuation more upon his appearance than upon his capacity to wear well, which Oak did not.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000910","text":"He had just reached the time of life at which “young” is ceasing to be the prefix of “man” in speaking of one.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000911","text":"In short, he was twenty-eight, and a bachelor.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000912","text":"The field he was in this morning sloped to a ridge called Norcombe Hill.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000913","text":"Through a spur of this hill ran the highway between Emminster and Chalk-Newton.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000914","text":"Casually glancing over the hedge, Oak saw coming down the incline before him an ornamental spring waggon, painted yellow and gaily marked, drawn by two horses, a waggoner walking alongside bearing a whip perpendicularly.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000915","text":"The waggon was laden with household goods and window plants, and on the apex of the whole sat a woman, young and attractive.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000916","text":"Gabriel had not beheld the sight for more than half a minute, when the vehicle was brought to a standstill just beneath his eyes.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000917","text":"“The tailboard of the waggon is gone, Miss,” said the waggoner.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000918","text":"“Then I heard it fall,” said the girl, in a soft, though not particularly low voice. “I heard a noise I could not account for when we were coming up the hill.”","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000919","text":"The sensible horses stood—perfectly still, and the waggoner’s steps sank fainter and fainter in the distance.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000920","text":"The girl on the summit of the load sat motionless, surrounded by tables and chairs with their legs upwards, backed by an oak settle, and ornamented in front by pots of geraniums, myrtles, and cactuses, together with a caged canary—all probably from the windows of the house just vacated.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000921","text":"There was also a cat in a willow basket, from the partly-opened lid of which she gazed with half-closed eyes, and affectionately surveyed the small birds around.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000922","text":"The handsome girl waited for some time idly in her place, and the only sound heard in the stillness was the hopping of the canary up and down the perches of its prison.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000923","text":"Then she looked attentively downwards.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000924","text":"It was not at the bird, nor at the cat; it was at an oblong package tied in paper, and lying between them.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000925","text":"She turned her head to learn if the waggoner were coming.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000926","text":"He was not yet in sight; and her eyes crept back to the package, her thoughts seeming to run upon what was inside it.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000927","text":"At length she drew the article into her lap, and untied the paper covering; a small swing looking-glass was disclosed, in which she proceeded to survey herself attentively.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000928","text":"She parted her lips and smiled.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000929","text":"It was a fine morning, and the sun lighted up to a scarlet glow the crimson jacket she wore, and painted a soft lustre upon her bright face and dark hair.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000930","text":"The myrtles, geraniums, and cactuses packed around her were fresh and green, and at such a leafless season they invested the whole concern of horses, waggon, furniture, and girl with a peculiar vernal charm.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000931","text":"What possessed her to indulge in such a performance in the sight of the sparrows, blackbirds, and unperceived farmer who were alone its spectators,—whether the smile began as a factitious one, to test her capacity in that art,—nobody knows; it ended certainly in a real smile.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000932","text":"She blushed at herself, and seeing her reflection blush, blushed the more.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000933","text":"The change from the customary spot and necessary occasion of such an act—from the dressing hour in a bedroom to a time of travelling out of doors—lent to the idle deed a novelty it did not intrinsically possess.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000934","text":"The picture was a delicate one.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000935","text":"Woman’s prescriptive infirmity had stalked into the sunlight, which had clothed it in the freshness of an originality.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000936","text":"A cynical inference was irresistible by Gabriel Oak as he regarded the scene, generous though he fain would have been.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000937","text":"There was no necessity whatever for her looking in the glass.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000938","text":"She did not adjust her hat, or pat her hair, or press a dimple into shape, or do one thing to signify that any such intention had been her motive in taking up the glass.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000939","text":"She simply observed herself as a fair product of Nature in the feminine kind, her thoughts seeming to glide into far-off though likely dramas in which men would play a part—vistas of probable triumphs—the smiles being of a phase suggesting that hearts were imagined as lost and won.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000940","text":"Still, this was but conjecture, and the whole series of actions was so idly put forth as to make it rash to assert that intention had any part in them at all.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000941","text":"The waggoner’s steps were heard returning. She put the glass in the paper, and the whole again into its place.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000942","text":"When the waggon had passed on, Gabriel withdrew from his point of espial, and descending into the road, followed the vehicle to the turnpike-gate some way beyond the bottom of the hill, where the object of his contemplation now halted for the payment of toll.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000943","text":"About twenty steps still remained between him and the gate, when he heard a dispute.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000944","text":"It was a difference concerning twopence between the persons with the waggon and the man at the toll-bar.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000945","text":"“Mis’ess’s niece is upon the top of the things, and she says that’s enough that I’ve offered ye, you great miser, and she won’t pay any more.” These were the waggoner’s words.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000946","text":"“Very well; then mis’ess’s niece can’t pass,” said the turnpike-keeper, closing the gate.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000947","text":"Oak looked from one to the other of the disputants, and fell into a reverie.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000948","text":"There was something in the tone of twopence remarkably insignificant.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000949","text":"Gabriel’s features adhered throughout their form so exactly to the middle line between the beauty of St.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000950","text":"John and the ugliness of Judas Iscariot, as represented in a window of the church he attended, that not a single lineament could be selected and called worthy either of distinction or notoriety.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000951","text":"The red-jacketed and dark-haired maiden seemed to think so too, for she carelessly glanced over him, and told her man to drive on.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000952","text":"She might have looked her thanks to Gabriel on a minute scale, but she did not speak them; more probably she felt none, for in gaining her a passage he had lost her her point, and we know how women take a favour of that kind.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000953","text":"The gatekeeper surveyed the retreating vehicle. “That’s a handsome maid,” he said to Oak.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000954","text":"“But she has her faults,” said Gabriel.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000955","text":"“And the greatest of them is—well, what it is always.”","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000956","text":"“Beating people down? ay, ’tis so.”","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000957","text":"Gabriel, perhaps a little piqued by the comely traveller’s indifference, glanced back to where he had witnessed her performance over the hedge, and said, “Vanity.”","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000958","text":"CHAPTER II NIGHT—THE FLOCK—AN INTERIOR—ANOTHER INTERIOR","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000959","text":"It was nearly midnight on the eve of St. Thomas’s, the shortest day in the year. A desolating wind wandered from the north over the hill whereon Oak had watched the yellow waggon and its occupant in the sunshine of a few days earlier.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000960","text":"Norcombe Hill—not far from lonely Toller-Down—was one of the spots which suggest to a passer-by that he is in the presence of a shape approaching the indestructible as nearly as any to be found on earth.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000961","text":"It was a featureless convexity of chalk and soil—an ordinary specimen of those smoothly-outlined protuberances of the globe which may remain undisturbed on some great day of confusion, when far grander heights and dizzy granite precipices topple down.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000962","text":"The hill was covered on its northern side by an ancient and decaying plantation of beeches, whose upper verge formed a line over the crest, fringing its arched curve against the sky, like a mane.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000963","text":"To-night these trees sheltered the southern slope from the keenest blasts, which smote the wood and floundered through it with a sound as of grumbling, or gushed over its crowning boughs in a weakened moan.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000964","text":"The dry leaves in the ditch simmered and boiled in the same breezes, a tongue of air occasionally ferreting out a few, and sending them spinning across the grass.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000965","text":"A group or two of the latest in date amongst the dead multitude had remained till this very mid-winter time on the twigs which bore them and in falling rattled against the trunks with smart taps.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000966","text":"Between this half-wooded half-naked hill, and the vague still horizon that its summit indistinctly commanded, was a mysterious sheet of fathomless shade—the sounds from which suggested that what it concealed bore some reduced resemblance to features here.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000967","text":"The thin grasses, more or less coating the hill, were touched by the wind in breezes of differing powers, and almost of differing natures—one rubbing the blades heavily, another raking them piercingly, another brushing them like a soft broom.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000968","text":"The sky was clear—remarkably clear—and the twinkling of all the stars seemed to be but throbs of one body, timed by a common pulse.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000969","text":"The North Star was directly in the wind’s eye, and since evening the Bear had swung round it outwardly to the east, till he was now at a right angle with the meridian.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000970","text":"A difference of colour in the stars—oftener read of than seen in England—was really perceptible here.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000971","text":"The sovereign brilliancy of Sirius pierced the eye with a steely glitter, the star called Capella was yellow, Aldebaran and Betelgueux shone with a fiery red.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000972","text":"To persons standing alone on a hill during a clear midnight such as this, the roll of the world eastward is almost a palpable movement.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000973","text":"After such a nocturnal reconnoitre it is hard to get back to earth, and to believe that the consciousness of such majestic speeding is derived from a tiny human frame.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000974","text":"Suddenly an unexpected series of sounds began to be heard in this place up against the sky. They had a clearness which was to be found nowhere in the wind, and a sequence which was to be found nowhere in nature. They were the notes of Farmer Oak’s flute.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000975","text":"The tune was not floating unhindered into the open air: it seemed muffled in some way, and was altogether too curtailed in power to spread high or wide.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000976","text":"It came from the direction of a small dark object under the plantation hedge—a shepherd’s hut—now presenting an outline to which an uninitiated person might have been puzzled to attach either meaning or use.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000977","text":"The hut stood on little wheels, which raised its floor about a foot from the ground.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000978","text":"Such shepherds’ huts are dragged into the fields when the lambing season comes on, to shelter the shepherd in his enforced nightly attendance.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000979","text":"It was only latterly that people had begun to call Gabriel “Farmer” Oak.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000980","text":"During the twelvemonth preceding this time he had been enabled by sustained efforts of industry and chronic good spirits to lease the small sheep-farm of which Norcombe Hill was a portion, and stock it with two hundred sheep.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000981","text":"Previously he had been a bailiff for a short time, and earlier still a shepherd only, having from his childhood assisted his father in tending the flocks of large proprietors, till old Gabriel sank to rest.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000982","text":"This venture, unaided and alone, into the paths of farming as master and not as man, with an advance of sheep not yet paid for, was a critical juncture with Gabriel Oak, and he recognised his position clearly.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000983","text":"The first movement in his new progress was the lambing of his ewes, and sheep having been his speciality from his youth, he wisely refrained from deputing the task of tending them at this season to a hireling or a novice.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000984","text":"The wind continued to beat about the corners of the hut, but the flute-playing ceased.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000985","text":"A rectangular space of light appeared in the side of the hut, and in the opening the outline of Farmer Oak’s figure.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000986","text":"He carried a lantern in his hand, and closing the door behind him, came forward and busied himself about this nook of the field for nearly twenty minutes, the lantern light appearing and disappearing here and there, and brightening him or darkening him as he stood before or behind it.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000987","text":"Oak’s motions, though they had a quiet energy, were slow, and their deliberateness accorded well with his occupation.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000988","text":"Fitness being the basis of beauty, nobody could have denied that his steady swings and turns in and about the flock had elements of grace.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000989","text":"Yet, although if occasion demanded he could do or think a thing with as mercurial a dash as can the men of towns who are more to the manner born, his special power, morally, physically, and mentally, was static, owing little or nothing to momentum as a rule.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000990","text":"A close examination of the ground hereabout, even by the wan starlight only, revealed how a portion of what would have been casually called a wild slope had been appropriated by Farmer Oak for his great purpose this winter.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000991","text":"Detached hurdles thatched with straw were stuck into the ground at various scattered points, amid and under which the whitish forms of his meek ewes moved and rustled.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000992","text":"The ring of the sheep-bell, which had been silent during his absence, recommenced, in tones that had more mellowness than clearness, owing to an increasing growth of surrounding wool.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000993","text":"This continued till Oak withdrew again from the flock.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000994","text":"He returned to the hut, bringing in his arms a new-born lamb, consisting of four legs large enough for a full-grown sheep, united by a seemingly inconsiderable membrane about half the substance of the legs collectively, which constituted the animal’s entire body just at present.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000995","text":"The little speck of life he placed on a wisp of hay before the small stove, where a can of milk was simmering.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000996","text":"Oak extinguished the lantern by blowing into it and then pinching the snuff, the cot being lighted by a candle suspended by a twisted wire.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000997","text":"A rather hard couch, formed of a few corn sacks thrown carelessly down, covered half the floor of this little habitation, and here the young man stretched himself along, loosened his woollen cravat, and closed his eyes.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000998","text":"In about the time a person unaccustomed to bodily labour would have decided upon which side to lie, Farmer Oak was asleep.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-000999","text":"The inside of the hut, as it now presented itself, was cosy and alluring, and the scarlet handful of fire in addition to the candle, reflecting its own genial colour upon whatever it could reach, flung associations of enjoyment even over utensils and tools.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001000","text":"In the corner stood the sheep-crook, and along a shelf at one side were ranged bottles and canisters of the simple preparations pertaining to ovine surgery and physic; spirits of wine, turpentine, tar, magnesia, ginger, and castor-oil being the chief.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001001","text":"On a triangular shelf across the corner stood bread, bacon, cheese, and a cup for ale or cider, which was supplied from a flagon beneath.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001002","text":"Beside the provisions lay the flute, whose notes had lately been called forth by the lonely watcher to beguile a tedious hour.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001003","text":"The house was ventilated by two round holes, like the lights of a ship’s cabin, with wood slides.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001004","text":"The lamb, revived by the warmth, began to bleat, and the sound entered Gabriel’s ears and brain with an instant meaning, as expected sounds will.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001005","text":"Passing from the profoundest sleep to the most alert wakefulness with the same ease that had accompanied the reverse operation, he looked at his watch, found that the hour-hand had shifted again, put on his hat, took the lamb in his arms, and carried it into the darkness.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001006","text":"After placing the little creature with its mother, he stood and carefully examined the sky, to ascertain the time of night from the altitudes of the stars.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001007","text":"The Dog-star and Aldebaran, pointing to the restless Pleiades, were half-way up the Southern sky, and between them hung Orion, which gorgeous constellation never burnt more vividly than now, as it soared forth above the rim of the landscape.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001008","text":"Being a man not without a frequent consciousness that there was some charm in this life he led, he stood still after looking at the sky as a useful instrument, and regarded it in an appreciative spirit, as a work of art superlatively beautiful.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001009","text":"For a moment he seemed impressed with the speaking loneliness of the scene, or rather with the complete abstraction from all its compass of the sights and sounds of man.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001010","text":"Human shapes, interferences, troubles, and joys were all as if they were not, and there seemed to be on the shaded hemisphere of the globe no sentient being save himself; he could fancy them all gone round to the sunny side.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001011","text":"Occupied thus, with eyes stretched afar, Oak gradually perceived that what he had previously taken to be a star low down behind the outskirts of the plantation was in reality no such thing. It was an artificial light, almost close at hand.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001012","text":"Farmer Oak went towards the plantation and pushed through its lower boughs to the windy side.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001013","text":"A dim mass under the slope reminded him that a shed occupied a place here, the site being a cutting into the slope of the hill, so that at its back part the roof was almost level with the ground.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001014","text":"In front it was formed of board nailed to posts and covered with tar as a preservative.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001015","text":"Through crevices in the roof and side spread streaks and dots of light, a combination of which made the radiance that had attracted him.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001016","text":"Oak stepped up behind, where, leaning down upon the roof and putting his eye close to a hole, he could see into the interior clearly.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001017","text":"The place contained two women and two cows.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001018","text":"By the side of the latter a steaming bran-mash stood in a bucket.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001019","text":"One of the women was past middle age.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001020","text":"Her companion was apparently young and graceful; he could form no decided opinion upon her looks, her position being almost beneath his eye, so that he saw her in a bird’s-eye view, as Milton’s Satan first saw Paradise.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001021","text":"She wore no bonnet or hat, but had enveloped herself in a large cloak, which was carelessly flung over her head as a covering.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001022","text":"“There, now we’ll go home,” said the elder of the two, resting her knuckles upon her hips, and looking at their goings-on as a whole. “I do hope Daisy will fetch round again now. I have never been more frightened in my life, but I don’t mind breaking my rest if she recovers.”","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001023","text":"The young woman, whose eyelids were apparently inclined to fall together on the smallest provocation of silence, yawned without parting her lips to any inconvenient extent, whereupon Gabriel caught the infection and slightly yawned in sympathy.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001024","text":"“I wish we were rich enough to pay a man to do these things,” she said.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001025","text":"“As we are not, we must do them ourselves,” said the other; “for you must help me if you stay.”","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001026","text":"“Well, my hat is gone, however,” continued the younger. “It went over the hedge, I think. The idea of such a slight wind catching it.”","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001027","text":"The cow standing erect was of the Devon breed, and was encased in a tight warm hide of rich Indian red, as absolutely uniform from eyes to tail as if the animal had been dipped in a dye of that colour, her long back being mathematically level.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001028","text":"The other was spotted, grey and white.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001029","text":"Between the sheep and the cows Lucina had been busy on Norcombe Hill lately.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001030","text":"“I think we had better send for some oatmeal,” said the elder woman; “there’s no more bran.”","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001031","text":"“Yes, aunt; and I’ll ride over for it as soon as it is light.”","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001032","text":"“I can ride on the other: trust me.”","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001033","text":"Oak, upon hearing these remarks, became more curious to observe her features, but this prospect being denied him by the hooding effect of the cloak, and by his aërial position, he felt himself drawing upon his fancy for their details.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001034","text":"In making even horizontal and clear inspections we colour and mould according to the wants within us whatever our eyes bring in.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001035","text":"Had Gabriel been able from the first to get a distinct view of her countenance, his estimate of it as very handsome or slightly so would have been as his soul required a divinity at the moment or was ready supplied with one.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001036","text":"Having for some time known the want of a satisfactory form to fill an increasing void within him, his position moreover affording the widest scope for his fancy, he painted her a beauty.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001037","text":"By one of those whimsical coincidences in which Nature, like a busy mother, seems to spare a moment from her unremitting labours to turn and make her children smile, the girl now dropped the cloak, and forth tumbled ropes of black hair over a red jacket.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001038","text":"Oak knew her instantly as the heroine of the yellow waggon, myrtles, and looking-glass: prosily, as the woman who owed him twopence.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001039","text":"They placed the calf beside its mother again, took up the lantern, and went out, the light sinking down the hill till it was no more than a nebula. Gabriel Oak returned to his flock.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001040","text":"CHAPTER III A GIRL ON HORSEBACK—CONVERSATION","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001041","text":"The sluggish day began to break.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001042","text":"Even its position terrestrially is one of the elements of a new interest, and for no particular reason save that the incident of the night had occurred there Oak went again into the plantation.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001043","text":"Lingering and musing here, he heard the steps of a horse at the foot of the hill, and soon there appeared in view an auburn pony with a girl on its back, ascending by the path leading past the cattle-shed.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001044","text":"She was the young woman of the night before.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001045","text":"Gabriel instantly thought of the hat she had mentioned as having lost in the wind; possibly she had come to look for it.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001046","text":"He hastily scanned the ditch and after walking about ten yards along it found the hat among the leaves.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001047","text":"Gabriel took it in his hand and returned to his hut.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001048","text":"Here he ensconced himself, and peeped through the loophole in the direction of the rider’s approach.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001049","text":"She came up and looked around—then on the other side of the hedge.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001050","text":"Gabriel was about to advance and restore the missing article when an unexpected performance induced him to suspend the action for the present.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001051","text":"The path, after passing the cowshed, bisected the plantation.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001052","text":"It was not a bridle-path—merely a pedestrian’s track, and the boughs spread horizontally at a height not greater than seven feet above the ground, which made it impossible to ride erect beneath them.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001053","text":"The girl, who wore no riding-habit, looked around for a moment, as if to assure herself that all humanity was out of view, then dexterously dropped backwards flat upon the pony’s back, her head over its tail, her feet against its shoulders, and her eyes to the sky.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001054","text":"The rapidity of her glide into this position was that of a kingfisher—its noiselessness that of a hawk.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001055","text":"Gabriel’s eyes had scarcely been able to follow her.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001056","text":"The tall lank pony seemed used to such doings, and ambled along unconcerned.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001057","text":"Thus she passed under the level boughs.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001058","text":"The performer seemed quite at home anywhere between a horse’s head and its tail, and the necessity for this abnormal attitude having ceased with the passage of the plantation, she began to adopt another, even more obviously convenient than the first.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001059","text":"She had no side-saddle, and it was very apparent that a firm seat upon the smooth leather beneath her was unattainable sideways.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001060","text":"Springing to her accustomed perpendicular like a bowed sapling, and satisfying herself that nobody was in sight, she seated herself in the manner demanded by the saddle, though hardly expected of the woman, and trotted off in the direction of Tewnell Mill.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001061","text":"Oak was amused, perhaps a little astonished, and hanging up the hat in his hut, went again among his ewes.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001062","text":"An hour passed, the girl returned, properly seated now, with a bag of bran in front of her.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001063","text":"On nearing the cattle-shed she was met by a boy bringing a milking-pail, who held the reins of the pony whilst she slid off.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001064","text":"The boy led away the horse, leaving the pail with the young woman.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001065","text":"Soon soft spirts alternating with loud spirts came in regular succession from within the shed, the obvious sounds of a person milking a cow. Gabriel took the lost hat in his hand, and waited beside the path she would follow in leaving the hill.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001066","text":"She came, the pail in one hand, hanging against her knee.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001067","text":"The left arm was extended as a balance, enough of it being shown bare to make Oak wish that the event had happened in the summer, when the whole would have been revealed.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001068","text":"There was a bright air and manner about her now, by which she seemed to imply that the desirability of her existence could not be questioned; and this rather saucy assumption failed in being offensive because a beholder felt it to be, upon the whole, true.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001069","text":"Like exceptional emphasis in the tone of a genius, that which would have made mediocrity ridiculous was an addition to recognised power.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001070","text":"It was with some surprise that she saw Gabriel’s face rising like the moon behind the hedge.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001071","text":"The adjustment of the farmer’s hazy conceptions of her charms to the portrait of herself she now presented him with was less a diminution than a difference.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001072","text":"The starting-point selected by the judgment was her height.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001073","text":"She seemed tall, but the pail was a small one, and the hedge diminutive; hence, making allowance for error by comparison with these, she could have been not above the height to be chosen by women as best.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001074","text":"All features of consequence were severe and regular.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001075","text":"Without throwing a Nymphean tissue over a milkmaid, let it be said that here criticism checked itself as out of place, and looked at her proportions with a long consciousness of pleasure.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001076","text":"From the contours of her figure in its upper part, she must have had a beautiful neck and shoulders; but since her infancy nobody had ever seen them.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001077","text":"Had she been put into a low dress she would have run and thrust her head into a bush.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001078","text":"Yet she was not a shy girl by any means; it was merely her instinct to draw the line dividing the seen from the unseen higher than they do it in towns.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001079","text":"That the girl’s thoughts hovered about her face and form as soon as she caught Oak’s eyes conning the same page was natural, and almost certain.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001080","text":"The self-consciousness shown would have been vanity if a little more pronounced, dignity if a little less.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001081","text":"Rays of male vision seem to have a tickling effect upon virgin faces in rural districts; she brushed hers with her hand, as if Gabriel had been irritating its pink surface by actual touch, and the free air of her previous movements was reduced at the same time to a chastened phase of itself.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001082","text":"Yet it was the man who blushed, the maid not at all.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001083","text":"“It is mine,” said she, and, from a sense of proportion, kept down to a small smile an inclination to laugh distinctly: “it flew away last night.”","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001084","text":"“Well—it was.” She was surprised. “How did you know?” she said.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001085","text":"“You are Farmer Oak, are you not?”","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001086","text":"“That or thereabouts. I’m lately come to this place.”","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001087","text":"“A large farm?” she inquired, casting her eyes round, and swinging back her hair, which was black in the shaded hollows of its mass; but it being now an hour past sunrise the rays touched its prominent curves with a colour of their own.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001088","text":"“No; not large. About a hundred.” (In speaking of farms the word “acres” is omitted by the natives, by analogy to such old expressions as “a stag of ten.”)","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001089","text":"“I wanted my hat this morning,” she went on. “I had to ride to Tewnell Mill.”","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001090","text":"“Where?” she inquired, a misgiving bringing every muscle of her lineaments and frame to a standstill.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001091","text":"“Here—going through the plantation, and all down the hill,” said Farmer Oak, with an aspect excessively knowing with regard to some matter in his mind, as he gazed at a remote point in the direction named, and then turned back to meet his colloquist’s eyes.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001092","text":"A perception caused him to withdraw his own eyes from hers as suddenly as if he had been caught in a theft.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001093","text":"Recollection of the strange antics she had indulged in when passing through the trees was succeeded in the girl by a nettled palpitation, and that by a hot face.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001094","text":"It was a time to see a woman redden who was not given to reddening as a rule; not a point in the milkmaid but was of the deepest rose-colour.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001095","text":"From the Maiden’s Blush, through all varieties of the Provence down to the Crimson Tuscany, the countenance of Oak’s acquaintance quickly graduated; whereupon he, in considerateness, turned away his head.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001096","text":"The sympathetic man still looked the other way, and wondered when she would recover coolness sufficient to justify him in facing her again. He heard what seemed to be the flitting of a dead leaf upon the breeze, and looked. She had gone away.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001097","text":"With an air between that of Tragedy and Comedy Gabriel returned to his work.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001098","text":"Five mornings and evenings passed.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001099","text":"The young woman came regularly to milk the healthy cow or to attend to the sick one, but never allowed her vision to stray in the direction of Oak’s person.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"},{"id":"pali-ext-001100","text":"His want of tact had deeply offended her—not by seeing what he could not help, but by letting her know that he had seen it.","author":"The Buddha","source":"The Gospel of Buddha — Carus (1894)","tags":["audience:meditation","audience:morning","language:en","theme:impermanence","theme:liberation","theme:liberation,impermanence","tradition:buddhism"],"isProverb":false,"isVerified":false,"verificationNote":"Extracted from public-domain text"}]}
{"formatVersion":"1","manifest":{"primaryCategory":"Proverbs & Folk Wisdom","subcategory":"African","audienceTags":["tradition:animism","theme:wisdom","theme:community"],"sortPriority":64,"groupingLevels":[],"groupingLabels":[],"dataPath":"Data/Collections/Swahili_Proverbs.json","supplementalDataPath":null,"languageCode":"en","displayNameEnglish":"Swahili Proverbs","script":"Latin","isRTL":false,"transliterationAvailable":false,"contentRating":"general","sourceId":"swahiliProverbs","displayName":"Swahili Proverbs","version":"1.0","language":"English","edition":"Methali za Kiswahili — Taylor & TUKI","type":"quotes","browseOrder":"sequence","itemCount":201,"supportsRandom":true,"supportsBrowse":true},"data":[{"id":"swahili-000001","text":"Haraka haraka haina baraka.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000002","text":"Haba na haba hujaza kibaba.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000003","text":"Usiku wa manane ndio unaouliza jibu.","author":"Swahili Proverb","source":"Swahili oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000004","text":"Mtu ni watu.","author":"Swahili Proverb","source":"Swahili proverb — Ubuntu equivalent","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000005","text":"Umoja ni nguvu, utengano ni udhaifu.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000006","text":"Usipoziba ufa utajenga ukuta.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000007","text":"Mgeni siku mbili; siku ya tatu mpe jembe.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000008","text":"Asiyejua hana budi kujifunza.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000009","text":"Akili ni nywele, kila mtu ana zake.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000010","text":"Mtoto umleavyo ndivyo akuavyo.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000011","text":"Bahari haizuiwi na mkono mmoja.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000012","text":"Kujua ni kuelewa; kuelewa ni kutenda.","author":"Swahili Proverb","source":"Swahili oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000013","text":"Mchezo wa watoto ni kazi ya wazee.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000014","text":"Dawa ya moto ni moto.","author":"Swahili Proverb","source":"Swahili proverb — methali — Taylor 1891","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000015","text":"Mwenye nguvu mpishe.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000016","text":"Ujanja huzaa ujanja.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000017","text":"Penye nia pana njia.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000018","text":"Mtu hajui kilichomfika mpaka kilipomfika.","author":"Swahili Proverb","source":"Swahili oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000019","text":"Wenye nguvu hawatawaliwa na wanyonge.","author":"Swahili Proverb","source":"Swahili oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000020","text":"Ukweli ni kama mwanga wa jua — hauwezi kuficha.","author":"Swahili Proverb","source":"Swahili oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000021","text":"A dhow without a sail is a log.","author":"Swahili Proverb","source":"Swahili proverb — Taylor 1891","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000022","text":"The moon moves slowly, but it crosses the town.","author":"Swahili Proverb","source":"Swahili proverb — Giryama tradition, Taylor 1891","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000023","text":"The cautious seldom err.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000024","text":"The heart of a man is a forest.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000025","text":"One who tells the truth is never wrong.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000026","text":"Work is worship.","author":"Swahili Proverb","source":"Swahili proverb — methali","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000027","text":"A single bracelet does not jingle.","author":"Swahili Proverb","source":"Swahili proverb — Congo variant","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000028","text":"He who runs alone cannot be blamed for arriving first.","author":"Swahili Proverb","source":"Swahili oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000029","text":"Only a fool tests the depth of water with both feet.","author":"Swahili Proverb","source":"Swahili proverb — widely attributed","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000030","text":"The wise do not sit and wait for luck; they go out and make it.","author":"Swahili Proverb","source":"Swahili oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"swahili-000031","text":"Ngozi ya chui uzuri kwa macho, ndani adui.","author":"Swahili Proverb","source":"Methali za Kiswahili — Wikiquote","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Sourced from Wikiquote; verify against methali collection."},{"id":"swahili-000032","text":"Dhamiri safi ni tandiko laini.","author":"Swahili Proverb","source":"Methali za Kiswahili — Wikiquote","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Sourced from Wikiquote; verify against methali collection."},{"id":"swahili-000033","text":"Dua la kuku halimpati mwewe.","author":"Swahili Proverb","source":"Methali za Kiswahili — Wikiquote","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Sourced from Wikiquote; verify against methali collection."},{"id":"swahili-000034","text":"Fadhila ya punda ni mateke.","author":"Swahili Proverb","source":"Methali za Kiswahili — Wikiquote","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Sourced from Wikiquote; verify against methali collection."},{"id":"swahili-000035","text":"Fuata nyuki ule asali.","author":"Swahili Proverb","source":"Methali za Kiswahili — Wikiquote","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Sourced from Wikiquote; verify against methali collection."},{"id":"swahili-000036","text":"Jogoo mtenda mema kaliwa.","author":"Swahili Proverb","source":"Methali za Kiswahili — Wikiquote","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Sourced from Wikiquote; verify against methali collection."},{"id":"swahili-000037","text":"Kibarua hulima juani, tajiri hulia kivulini.","author":"Swahili Proverb","source":"Methali za Kiswahili — Wikiquote","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Sourced from Wikiquote; verify against methali collection."},{"id":"swahili-000038","text":"Msinji ukiinama hauna nguvu; usiushtaki ukuta ukianguka.","author":"Swahili Proverb","source":"Methali za Kiswahili — Wikiquote","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Sourced from Wikiquote; verify against methali collection."},{"id":"swahili-000039","text":"Ukijifanya asali nzi wote watakula.","author":"Swahili Proverb","source":"Methali za Kiswahili — Wikiquote","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Sourced from Wikiquote; verify against methali collection."},{"id":"swahili-000040","text":"Usisafirie nyota ya mwenzio.","author":"Swahili Proverb","source":"Methali za Kiswahili — Wikiquote","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Sourced from Wikiquote; verify against methali collection."},{"id":"swahili-000041","text":"Pole pole ndio mwendo.","author":"Swahili Proverb","source":"Methali za Kiswahili — Wikiquote","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Sourced from Wikiquote; verify against methali collection."},{"id":"swahili-000042","text":"Produced by Marilynda Fraser-Cunliffe, Stephanie Eason, and the Online Distributed Proofreading Team at https://www.pgdp.net.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000043","text":"(This file was made using scans of public domain works from the University of Michigan Digital Libraries.)","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000044","text":"Edited by EDWARD LEE THORNDIKE, Ph.D., and F. E. BEDDARD, M.A., F.R.S.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000045","text":"1. +The Study of Man.+ By A. C. HADDON.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000046","text":"2. +The Groundwork of Science.+ By ST. GEORGE MIVART.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000047","text":"3. +Rivers of North America.+ By ISRAEL C. RUSSELL.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000048","text":"4. +Earth Sculpture, or; The Origin of Land Forms.+ By JAMES GEIKIE.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000049","text":"5. +Volcanoes; Their Structure and Significance.+ By T. G. BONNEY.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000050","text":"6. +Bacteria.+ By GEORGE NEWMAN.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000051","text":"7. +A Book of Whales.+ By F. E. BEDDARD.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000052","text":"8. +Comparative Physiology of the Brain,+ etc. By JACQUES LOEB.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000053","text":"9. +The Stars.+ By SIMON NEWCOMB.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000054","text":"10. +The Basis of Social Relations.+ By DANIEL G. BRINTON.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000055","text":"11. +Experiments on Animals.+ By STEPHEN PAGET.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000056","text":"12. +Infection and Immunity.+ By GEORGE M. STERNBERG.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000057","text":"13. +Fatigue.+ By A. MOSSO.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000058","text":"14. +Earthquakes.+ By CLARENCE E. DUTTON.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000059","text":"15. +The Nature of Man.+ By ELIE METCHNIKOFF.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000060","text":"16. +Nervous and Mental Hygiene in Health and Disease.+ By AUGUST FOREL.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000061","text":"17. +The Prolongation of Life.+ By ELIE METCHNIKOFF.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000062","text":"18. +The Solar System.+ By CHARLES LANE POOR.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000063","text":"19. +Heredity.+ By J. ARTHUR THOMPSON, M.A.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000064","text":"20. +Climate.+ By ROBERT DECOURCY WARD.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000065","text":"21. +Age, Growth, and Death.+ By CHARLES S. MINOT.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000066","text":"22. +The Interpretation of Nature.+ By C. LLOYD MORGAN.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000067","text":"23. +Mosquito Life.+ By EVELYN GROESBEECK MITCHELL.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886; verify attribution."},{"id":"swahili-000068","text":"24. +Thinking, Feeling, Doing.+ By E. W. SCRIPTURE.","author":"East African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning
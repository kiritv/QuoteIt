{"formatVersion":"1","manifest":{"sourceId":"worldProverbs","displayName":"Proverbs","type":"quotes","language":"English","edition":"Public Domain Collection","primaryCategory":"Proverbs & Folk Wisdom","subcategory":"Global","audienceTags":["wisdom","short-form"],"sortPriority":60,"itemCount":1880,"supportsRandom":true,"supportsBrowse":true,"browseOrder":"sequence","groupingLevels":["topic","author"],"groupingLabels":["Topic","Author"],"dataPath":"Data/Collections/Proverbs.json","version":"1.0"},"data":[{"id":"world-prov-0001","text":"Absence cools moderate passions, and inflames violent ones.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Absence","author":"Public Domain Proverb"},"sequenceIndex":0},{"id":"world-prov-0002","text":"The absent are always at fault.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (2)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Absent","author":"Public Domain Proverb"},"sequenceIndex":1},{"id":"world-prov-0003","text":"Long absent, soon forgotten.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (3)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Absent","author":"Public Domain Proverb"},"sequenceIndex":2},{"id":"world-prov-0004","text":"Who hath aching teeth, hath ill tenants.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (4)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Aching Teeth","author":"Public Domain Proverb"},"sequenceIndex":3},{"id":"world-prov-0005","text":"Adversity makes a man wise, not rich.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (5)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Adversity","author":"Public Domain Proverb"},"sequenceIndex":4},{"id":"world-prov-0006","text":"Adversity tries friends.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (6)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Adversity","author":"Public Domain Proverb"},"sequenceIndex":5},{"id":"world-prov-0007","text":"Adversity flattereth no man.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (7)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Adversity","author":"Public Domain Proverb"},"sequenceIndex":6},{"id":"world-prov-0008","text":"Give neither advice nor salt until you are asked for it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (8)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Advice","author":"Public Domain Proverb"},"sequenceIndex":7},{"id":"world-prov-0009","text":"What every one asks, what every one gives, but what very few take--advice.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (9)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Advice","author":"Public Domain Proverb"},"sequenceIndex":8},{"id":"world-prov-0010","text":"In vain he craves advice who will not follow it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (10)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Advice","author":"Public Domain Proverb"},"sequenceIndex":9},{"id":"world-prov-0011","text":"Advice comes too late when a thing is done.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (11)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Advice","author":"Public Domain Proverb"},"sequenceIndex":10},{"id":"world-prov-0012","text":"He that's afraid of wounds must not come nigh a battle.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (12)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Afraid Of Wounds","author":"Public Domain Proverb"},"sequenceIndex":11},{"id":"world-prov-0013","text":"More afraid than hurt.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (13)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Afraid","author":"Public Domain Proverb"},"sequenceIndex":12},{"id":"world-prov-0014","text":"Age before honesty.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (14)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Age","author":"Public Domain Proverb"},"sequenceIndex":13},{"id":"world-prov-0015","text":"Old age is honourable.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (15)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Age (Old)","author":"Public Domain Proverb"},"sequenceIndex":14},{"id":"world-prov-0016","text":"Two of a trade seldom agree.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (16)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Agree","author":"Public Domain Proverb"},"sequenceIndex":15},{"id":"world-prov-0017","text":"Agree, for law is costly.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (17)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Agree","author":"Public Domain Proverb"},"sequenceIndex":16},{"id":"world-prov-0018","text":"An ague in the spring, Is physic for a king.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (18)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ague","author":"Public Domain Proverb"},"sequenceIndex":17},{"id":"world-prov-0019","text":"Agues come on horseback, but go away on foot.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (19)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Agues","author":"Public Domain Proverb"},"sequenceIndex":18},{"id":"world-prov-0020","text":"A man cannot live by the air.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (20)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Air","author":"Public Domain Proverb"},"sequenceIndex":19},{"id":"world-prov-0021","text":"No alchemy like saving.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (21)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Alchemy","author":"Public Domain Proverb"},"sequenceIndex":20},{"id":"world-prov-0022","text":"Good ale is meat, drink, and cloth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (22)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ale","author":"Public Domain Proverb"},"sequenceIndex":21},{"id":"world-prov-0023","text":"He that buys land buys many stones, He that buys flesh buys many bones, He that buys eggs buys many shells, He that buys ale buys nothing else.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (23)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ale","author":"Public Domain Proverb"},"sequenceIndex":22},{"id":"world-prov-0024","text":"Every one has a penny to spend at a new ale-house.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (24)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ale-House","author":"Public Domain Proverb"},"sequenceIndex":23},{"id":"world-prov-0025","text":"All's well that ends well.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (25)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"All'S Well","author":"Public Domain Proverb"},"sequenceIndex":24},{"id":"world-prov-0026","text":"No living man All things can.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (26)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"All Things","author":"Public Domain Proverb"},"sequenceIndex":25},{"id":"world-prov-0027","text":"Almost was never hanged.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (27)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Almost","author":"Public Domain Proverb"},"sequenceIndex":26},{"id":"world-prov-0028","text":"Steal the goose, and give the giblets in alms.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (28)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Alms","author":"Public Domain Proverb"},"sequenceIndex":27},{"id":"world-prov-0029","text":"Anger is short-lived in a good man.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (29)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Anger","author":"Public Domain Proverb"},"sequenceIndex":28},{"id":"world-prov-0030","text":"Keep from the anger of a great man.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (30)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Anger","author":"Public Domain Proverb"},"sequenceIndex":29},{"id":"world-prov-0031","text":"Angry men seldom want woe.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (31)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Angry Men","author":"Public Domain Proverb"},"sequenceIndex":30},{"id":"world-prov-0032","text":"He that is angry without a cause must be pleased without amends.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (32)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Angry","author":"Public Domain Proverb"},"sequenceIndex":31},{"id":"world-prov-0033","text":"None knows the weight of another's burden.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (33)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Another'S Burden","author":"Public Domain Proverb"},"sequenceIndex":32},{"id":"world-prov-0034","text":"Apples, eggs, and nuts, One may eat after sluts.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (34)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Apples","author":"Public Domain Proverb"},"sequenceIndex":33},{"id":"world-prov-0035","text":"April and May are the keys of the year.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (35)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"April","author":"Public Domain Proverb"},"sequenceIndex":34},{"id":"world-prov-0036","text":"When April blows his horn, It's both good for hay and corn.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (36)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"April","author":"Public Domain Proverb"},"sequenceIndex":35},{"id":"world-prov-0037","text":"April borrows three days of March, and they are ill.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (37)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"April","author":"Public Domain Proverb"},"sequenceIndex":36},{"id":"world-prov-0038","text":"March winds and April showers Bring forth May flowers.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (38)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"April Showers","author":"Public Domain Proverb"},"sequenceIndex":37},{"id":"world-prov-0039","text":"Argus at home, but a mole abroad.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (39)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Argus","author":"Public Domain Proverb"},"sequenceIndex":38},{"id":"world-prov-0040","text":"Never be ashamed to eat your meat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (40)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ashamed","author":"Public Domain Proverb"},"sequenceIndex":39},{"id":"world-prov-0041","text":"Every man must eat a peck of ashes before he dies.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (41)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ashes","author":"Public Domain Proverb"},"sequenceIndex":40},{"id":"world-prov-0042","text":"Ask but enough, and you may lower as you list.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (42)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ask","author":"Public Domain Proverb"},"sequenceIndex":41},{"id":"world-prov-0043","text":"Ask thy purse what thou shouldst buy.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (43)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ask","author":"Public Domain Proverb"},"sequenceIndex":42},{"id":"world-prov-0044","text":"Lose nothing for asking.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (44)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Asking","author":"Public Domain Proverb"},"sequenceIndex":43},{"id":"world-prov-0045","text":"The ass that brays most, eats least.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (45)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ass","author":"Public Domain Proverb"},"sequenceIndex":44},{"id":"world-prov-0046","text":"Every ass thinks himself worthy to stand with the king's horses.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (46)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ass","author":"Public Domain Proverb"},"sequenceIndex":45},{"id":"world-prov-0047","text":"August dry and warm, Harvest doth no harm.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (47)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"August","author":"Public Domain Proverb"},"sequenceIndex":46},{"id":"world-prov-0048","text":"If the twenty-fourth of August be fair and clear, Then hope for a prosperous autumn that year.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (48)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"August","author":"Public Domain Proverb"},"sequenceIndex":47},{"id":"world-prov-0049","text":"A wet August never brings dearth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (49)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"August","author":"Public Domain Proverb"},"sequenceIndex":48},{"id":"world-prov-0050","text":"Like author, like book. B","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (50)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Author","author":"Public Domain Proverb"},"sequenceIndex":49},{"id":"world-prov-0051","text":"Bachelors grin, but married men laugh till their hearts ache.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (51)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bachelors","author":"Public Domain Proverb"},"sequenceIndex":50},{"id":"world-prov-0052","text":"Bachelors' wives and maids' children are always well taught.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (52)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bachelors' Wives","author":"Public Domain Proverb"},"sequenceIndex":51},{"id":"world-prov-0053","text":"Where bad's the best, naught must be the choice.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (53)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bad","author":"Public Domain Proverb"},"sequenceIndex":52},{"id":"world-prov-0054","text":"Better be alone than in bad company.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (54)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bad Company","author":"Public Domain Proverb"},"sequenceIndex":53},{"id":"world-prov-0055","text":"A bad day never hath a good night.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (55)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bad Day","author":"Public Domain Proverb"},"sequenceIndex":54},{"id":"world-prov-0056","text":"He that cannot abide a bad market deserves not a good one.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (56)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bad Market","author":"Public Domain Proverb"},"sequenceIndex":55},{"id":"world-prov-0057","text":"Bring not a bagpipe to a man in trouble.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (57)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bagpipe","author":"Public Domain Proverb"},"sequenceIndex":56},{"id":"world-prov-0058","text":"He is most loved that hath most bags.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (58)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bags","author":"Public Domain Proverb"},"sequenceIndex":57},{"id":"world-prov-0059","text":"Be bail and pay for it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (59)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bail","author":"Public Domain Proverb"},"sequenceIndex":58},{"id":"world-prov-0060","text":"The balance distinguishes not between gold and lead.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (60)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Balance","author":"Public Domain Proverb"},"sequenceIndex":59},{"id":"world-prov-0061","text":"A bald head is soon shaven.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (61)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bald Head","author":"Public Domain Proverb"},"sequenceIndex":60},{"id":"world-prov-0062","text":"There's no great banquet but some fare ill.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (62)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Banquet","author":"Public Domain Proverb"},"sequenceIndex":61},{"id":"world-prov-0063","text":"Like a barber's chair, fit for every buttock.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (63)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Barber'S Chair","author":"Public Domain Proverb"},"sequenceIndex":62},{"id":"world-prov-0064","text":"One barber shaves not so close but another finds work.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (64)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Barber","author":"Public Domain Proverb"},"sequenceIndex":63},{"id":"world-prov-0065","text":"Barefooted men should not tread on thorns.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (65)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Barefooted","author":"Public Domain Proverb"},"sequenceIndex":64},{"id":"world-prov-0066","text":"Better a bare foot than no foot at all.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (66)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bare Foot","author":"Public Domain Proverb"},"sequenceIndex":65},{"id":"world-prov-0067","text":"Make the best of a bad bargain.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (67)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bargain","author":"Public Domain Proverb"},"sequenceIndex":66},{"id":"world-prov-0068","text":"A bargain is a bargain.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (68)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bargain","author":"Public Domain Proverb"},"sequenceIndex":67},{"id":"world-prov-0069","text":"At a great bargain make a great pause.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (69)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bargain","author":"Public Domain Proverb"},"sequenceIndex":68},{"id":"world-prov-0070","text":"What! keep a dog and bark myself?","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (70)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bark","author":"Public Domain Proverb"},"sequenceIndex":69},{"id":"world-prov-0071","text":"The greatest barkers are not always the sorest biters.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (71)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Barkers","author":"Public Domain Proverb"},"sequenceIndex":70},{"id":"world-prov-0072","text":"When the sloe-tree is as white as a sheet, Sow your barley, whether it be dry or wet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (72)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Barley","author":"Public Domain Proverb"},"sequenceIndex":71},{"id":"world-prov-0073","text":"Sir John Barleycorn is the strongest knight.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (73)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Barleycorn","author":"Public Domain Proverb"},"sequenceIndex":72},{"id":"world-prov-0074","text":"Barley straw's good fodder when the cow gives water.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (74)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Barley Straw","author":"Public Domain Proverb"},"sequenceIndex":73},{"id":"world-prov-0075","text":"You cannot know wine by the barrel.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (75)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Barrel","author":"Public Domain Proverb"},"sequenceIndex":74},{"id":"world-prov-0076","text":"Commend a wedded life, but keep thyself a batchelor.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (76)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Batchelor","author":"Public Domain Proverb"},"sequenceIndex":75},{"id":"world-prov-0077","text":"Every bean has its black.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (77)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bean","author":"Public Domain Proverb"},"sequenceIndex":76},{"id":"world-prov-0078","text":"Sow beans in the mud, they'll grow like wood.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (78)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beans","author":"Public Domain Proverb"},"sequenceIndex":77},{"id":"world-prov-0079","text":"Beans should blow before May doth go.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (79)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beans","author":"Public Domain Proverb"},"sequenceIndex":78},{"id":"world-prov-0080","text":"A man may bear till his back breaks.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (80)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bear","author":"Public Domain Proverb"},"sequenceIndex":79},{"id":"world-prov-0081","text":"Bear and forbear.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (81)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bear","author":"Public Domain Proverb"},"sequenceIndex":80},{"id":"world-prov-0082","text":"Bear with evil and expect good.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (82)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bear","author":"Public Domain Proverb"},"sequenceIndex":81},{"id":"world-prov-0083","text":"'Tis easy to find a staff to beat a dog.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (83)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beat","author":"Public Domain Proverb"},"sequenceIndex":82},{"id":"world-prov-0084","text":"Better to be beaten than be in bad company.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (84)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beaten","author":"Public Domain Proverb"},"sequenceIndex":83},{"id":"world-prov-0085","text":"A spaniel, a woman, and a walnut tree, The more they're beaten the better they be.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (85)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beaten","author":"Public Domain Proverb"},"sequenceIndex":84},{"id":"world-prov-0086","text":"Beauty buys no beef.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (86)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beauty","author":"Public Domain Proverb"},"sequenceIndex":85},{"id":"world-prov-0087","text":"Beauty is no inheritance.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (87)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beauty","author":"Public Domain Proverb"},"sequenceIndex":86},{"id":"world-prov-0088","text":"Beauty is but skin deep.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (88)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beauty","author":"Public Domain Proverb"},"sequenceIndex":87},{"id":"world-prov-0089","text":"As you make your bed so you must lie on it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (89)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bed","author":"Public Domain Proverb"},"sequenceIndex":88},{"id":"world-prov-0090","text":"He who lies long in bed his estate feels it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (90)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bed","author":"Public Domain Proverb"},"sequenceIndex":89},{"id":"world-prov-0091","text":"A swarm of bees in May is worth a load of hay, But a swarm of bees in July is not worth a fly.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (91)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bees","author":"Public Domain Proverb"},"sequenceIndex":90},{"id":"world-prov-0092","text":"Where bees are there is honey.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (92)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bees","author":"Public Domain Proverb"},"sequenceIndex":91},{"id":"world-prov-0093","text":"He that hires the horse must ride before.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (93)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Before","author":"Public Domain Proverb"},"sequenceIndex":92},{"id":"world-prov-0094","text":"Better be a beggar than a fool.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (94)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beggar","author":"Public Domain Proverb"},"sequenceIndex":93},{"id":"world-prov-0095","text":"A beggar can never be bankrupt.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (95)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beggar","author":"Public Domain Proverb"},"sequenceIndex":94},{"id":"world-prov-0096","text":"The beggar is never out of his way.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (96)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beggar","author":"Public Domain Proverb"},"sequenceIndex":95},{"id":"world-prov-0097","text":"Beggars must not be choosers.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (97)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beggars","author":"Public Domain Proverb"},"sequenceIndex":96},{"id":"world-prov-0098","text":"Beggars on horseback will ride to the devil.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (98)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beggars","author":"Public Domain Proverb"},"sequenceIndex":97},{"id":"world-prov-0099","text":"Trash and trumpery is the highway to beggary.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (99)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beggary","author":"Public Domain Proverb"},"sequenceIndex":98},{"id":"world-prov-0100","text":"Begging is an ill trade on a fast-day.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (100)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Begging","author":"Public Domain Proverb"},"sequenceIndex":99},{"id":"world-prov-0101","text":"A good beginning makes a good ending.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (101)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beginning","author":"Public Domain Proverb"},"sequenceIndex":100},{"id":"world-prov-0102","text":"Such a beginning, such an end.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (102)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beginning","author":"Public Domain Proverb"},"sequenceIndex":101},{"id":"world-prov-0103","text":"Good to begin well; better to end well.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (103)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Begin Well","author":"Public Domain Proverb"},"sequenceIndex":102},{"id":"world-prov-0104","text":"Well begun is half done.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (104)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Begun","author":"Public Domain Proverb"},"sequenceIndex":103},{"id":"world-prov-0105","text":"When two ride together one must ride behind.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (105)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Behind","author":"Public Domain Proverb"},"sequenceIndex":104},{"id":"world-prov-0106","text":"You would make me believe the moon is made of green cheese.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (106)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Believe","author":"Public Domain Proverb"},"sequenceIndex":105},{"id":"world-prov-0107","text":"Believe well and have well.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (107)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Believe","author":"Public Domain Proverb"},"sequenceIndex":106},{"id":"world-prov-0108","text":"Fear not the loss of the bell more than the loss of the steeple.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (108)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bell","author":"Public Domain Proverb"},"sequenceIndex":107},{"id":"world-prov-0109","text":"Bend the twig while it is young.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (109)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bend","author":"Public Domain Proverb"},"sequenceIndex":108},{"id":"world-prov-0110","text":"As the twig is bent the tree's inclined.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (110)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bent","author":"Public Domain Proverb"},"sequenceIndex":109},{"id":"world-prov-0111","text":"The best is cheapest.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (111)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Best","author":"Public Domain Proverb"},"sequenceIndex":110},{"id":"world-prov-0112","text":"The best lie is the worst.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (112)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Best","author":"Public Domain Proverb"},"sequenceIndex":111},{"id":"world-prov-0113","text":"Make the best of a bad bargain.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (113)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Best","author":"Public Domain Proverb"},"sequenceIndex":112},{"id":"world-prov-0114","text":"Let the best dog leap the stile first.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (114)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Best Dog","author":"Public Domain Proverb"},"sequenceIndex":113},{"id":"world-prov-0115","text":"Any fool can bet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (115)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bet","author":"Public Domain Proverb"},"sequenceIndex":114},{"id":"world-prov-0116","text":"The better the day, the better the deed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (116)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Better","author":"Public Domain Proverb"},"sequenceIndex":115},{"id":"world-prov-0117","text":"Beware of \"Had I wist.\"","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (117)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Beware","author":"Public Domain Proverb"},"sequenceIndex":116},{"id":"world-prov-0118","text":"Do as you are bidden and you'll never be to blame.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (118)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bidden","author":"Public Domain Proverb"},"sequenceIndex":117},{"id":"world-prov-0119","text":"Birchen twigs break no ribs.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (119)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Birchen Twigs","author":"Public Domain Proverb"},"sequenceIndex":118},{"id":"world-prov-0120","text":"A bird in the hand is worth two in the bush.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (120)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bird","author":"Public Domain Proverb"},"sequenceIndex":119},{"id":"world-prov-0121","text":"Every bird must hatch her own egg.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (121)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bird","author":"Public Domain Proverb"},"sequenceIndex":120},{"id":"world-prov-0122","text":"One beats the bush and another catcheth the bird.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (122)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bird","author":"Public Domain Proverb"},"sequenceIndex":121},{"id":"world-prov-0123","text":"Birds of a feather flock together.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (123)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Birds","author":"Public Domain Proverb"},"sequenceIndex":122},{"id":"world-prov-0124","text":"The bird that can sing and will not sing, must be made to sing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (124)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bird","author":"Public Domain Proverb"},"sequenceIndex":123},{"id":"world-prov-0125","text":"Even small birds must have meat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (125)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Birds (Small)","author":"Public Domain Proverb"},"sequenceIndex":124},{"id":"world-prov-0126","text":"If you cannot bite, never show your teeth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (126)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bite","author":"Public Domain Proverb"},"sequenceIndex":125},{"id":"world-prov-0127","text":"He that bites on every weed must needs light on poison.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (127)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bites","author":"Public Domain Proverb"},"sequenceIndex":126},{"id":"world-prov-0128","text":"A bit in the morning is better than nothing all day.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (128)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bit","author":"Public Domain Proverb"},"sequenceIndex":127},{"id":"world-prov-0129","text":"Thou art a bitter bird, said the raven to the starling.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (129)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bitter Bird","author":"Public Domain Proverb"},"sequenceIndex":128},{"id":"world-prov-0130","text":"A black plum is as sweet as a white.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (130)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Black Plum","author":"Public Domain Proverb"},"sequenceIndex":129},{"id":"world-prov-0131","text":"The sharper the blast, The shorter 'twill last.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (131)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Blast","author":"Public Domain Proverb"},"sequenceIndex":130},{"id":"world-prov-0132","text":"As blind as a bat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (132)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Blind","author":"Public Domain Proverb"},"sequenceIndex":131},{"id":"world-prov-0133","text":"Who so blind as he that will not see?","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (133)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Blind","author":"Public Domain Proverb"},"sequenceIndex":132},{"id":"world-prov-0134","text":"A blind man would be glad to see it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (134)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Blind Man","author":"Public Domain Proverb"},"sequenceIndex":133},{"id":"world-prov-0135","text":"Like a treatise on light and colours by a blind man.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (135)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Blind Man","author":"Public Domain Proverb"},"sequenceIndex":134},{"id":"world-prov-0136","text":"You cannot get blood out of a stone.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (136)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Blood","author":"Public Domain Proverb"},"sequenceIndex":135},{"id":"world-prov-0137","text":"'Tis a blot on his escutcheon.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (137)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Blot","author":"Public Domain Proverb"},"sequenceIndex":136},{"id":"world-prov-0138","text":"Blushing is virtue's colour.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (138)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Blushing","author":"Public Domain Proverb"},"sequenceIndex":137},{"id":"world-prov-0139","text":"He who blusters without reason has most reason to bluster.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (139)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Blusters","author":"Public Domain Proverb"},"sequenceIndex":138},{"id":"world-prov-0140","text":"Great boast, small roast.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (140)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Boast","author":"Public Domain Proverb"},"sequenceIndex":139},{"id":"world-prov-0141","text":"Whether you boil snow or pound it, you will have but water from it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (141)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Boil Snow","author":"Public Domain Proverb"},"sequenceIndex":140},{"id":"world-prov-0142","text":"Give a dog a bone in his mouth, and you may kick him and he can't bite.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (142)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bone","author":"Public Domain Proverb"},"sequenceIndex":141},{"id":"world-prov-0143","text":"I have a bone in my arm.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (143)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bone","author":"Public Domain Proverb"},"sequenceIndex":142},{"id":"world-prov-0144","text":"The nearer the bone the sweeter the meat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (144)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bone","author":"Public Domain Proverb"},"sequenceIndex":143},{"id":"world-prov-0145","text":"He that is born to be hanged shall never be drowned.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (145)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Born","author":"Public Domain Proverb"},"sequenceIndex":144},{"id":"world-prov-0146","text":"Borrowed garments never fit well.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (146)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Borrowed Garments","author":"Public Domain Proverb"},"sequenceIndex":145},{"id":"world-prov-0147","text":"Bought wit is best.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (147)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bought Wit","author":"Public Domain Proverb"},"sequenceIndex":146},{"id":"world-prov-0148","text":"Bought wit makes folk wise.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (148)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bought Wit","author":"Public Domain Proverb"},"sequenceIndex":147},{"id":"world-prov-0149","text":"They that are bound must obey.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (149)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bound","author":"Public Domain Proverb"},"sequenceIndex":148},{"id":"world-prov-0150","text":"A bow long bent at last waxeth weak.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (150)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bow","author":"Public Domain Proverb"},"sequenceIndex":149},{"id":"world-prov-0151","text":"It is easy to bowl down hill.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (151)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bowl","author":"Public Domain Proverb"},"sequenceIndex":150},{"id":"world-prov-0152","text":"Boys will be boys.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (152)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Boys","author":"Public Domain Proverb"},"sequenceIndex":151},{"id":"world-prov-0153","text":"Brag's a good dog, but Holdfast is a better.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (153)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Brag","author":"Public Domain Proverb"},"sequenceIndex":152},{"id":"world-prov-0154","text":"Brag's a good dog, but that he hath lost his tail.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (154)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Brag","author":"Public Domain Proverb"},"sequenceIndex":153},{"id":"world-prov-0155","text":"Brag's a good dog if he be well set on; but he dare not bite.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (155)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Brag","author":"Public Domain Proverb"},"sequenceIndex":154},{"id":"world-prov-0156","text":"Great braggers, little doers.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (156)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Braggers","author":"Public Domain Proverb"},"sequenceIndex":155},{"id":"world-prov-0157","text":"The brain that sows not corn, plants thistles.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (157)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Brain","author":"Public Domain Proverb"},"sequenceIndex":156},{"id":"world-prov-0158","text":"Much bran, little meal.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (158)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bran","author":"Public Domain Proverb"},"sequenceIndex":157},{"id":"world-prov-0159","text":"They that have no other meat, Bread and butter are glad to eat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (159)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bread And Butter","author":"Public Domain Proverb"},"sequenceIndex":158},{"id":"world-prov-0160","text":"He who would have a hare for breakfast must hunt over night.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (160)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Breakfast","author":"Public Domain Proverb"},"sequenceIndex":159},{"id":"world-prov-0161","text":"The best horse needs breaking, and the best child needs teaching.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (161)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Breaking","author":"Public Domain Proverb"},"sequenceIndex":160},{"id":"world-prov-0162","text":"That which is bred in the bone will never be out of the flesh.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (162)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bred","author":"Public Domain Proverb"},"sequenceIndex":161},{"id":"world-prov-0163","text":"Brevity is the soul of wit.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (163)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Brevity","author":"Public Domain Proverb"},"sequenceIndex":162},{"id":"world-prov-0164","text":"As you brew, so shall you bake.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (164)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Brew","author":"Public Domain Proverb"},"sequenceIndex":163},{"id":"world-prov-0165","text":"A bribe will enter without knocking.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (165)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bribe","author":"Public Domain Proverb"},"sequenceIndex":164},{"id":"world-prov-0166","text":"There is no deceit in a brimmer.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (166)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Brimmer","author":"Public Domain Proverb"},"sequenceIndex":165},{"id":"world-prov-0167","text":"A broken leg is not healed by a silk stocking.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (167)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Broken Leg","author":"Public Domain Proverb"},"sequenceIndex":166},{"id":"world-prov-0168","text":"A burden which one chooses is not felt.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (168)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Burden","author":"Public Domain Proverb"},"sequenceIndex":167},{"id":"world-prov-0169","text":"The back is made for the burden.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (169)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Burden","author":"Public Domain Proverb"},"sequenceIndex":168},{"id":"world-prov-0170","text":"No one knows the weight of another's burden.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (170)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Burden","author":"Public Domain Proverb"},"sequenceIndex":169},{"id":"world-prov-0171","text":"The greatest burdens are not the gainfullest.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (171)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Burdens","author":"Public Domain Proverb"},"sequenceIndex":170},{"id":"world-prov-0172","text":"A burnt child dreads the fire.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (172)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Burnt Child","author":"Public Domain Proverb"},"sequenceIndex":171},{"id":"world-prov-0173","text":"Business is the salt of life.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (173)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Business","author":"Public Domain Proverb"},"sequenceIndex":172},{"id":"world-prov-0174","text":"Every man as his business lies.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (174)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Business","author":"Public Domain Proverb"},"sequenceIndex":173},{"id":"world-prov-0175","text":"A bad bush is better than the open field.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (175)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Bush","author":"Public Domain Proverb"},"sequenceIndex":174},{"id":"world-prov-0176","text":"Who more busy than they that have least to do.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (176)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Busy","author":"Public Domain Proverb"},"sequenceIndex":175},{"id":"world-prov-0177","text":"Better pay the butcher than the doctor.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (177)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Butcher","author":"Public Domain Proverb"},"sequenceIndex":176},{"id":"world-prov-0178","text":"Butter is gold in the morning, silver at noon, lead at night.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (178)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Butter","author":"Public Domain Proverb"},"sequenceIndex":177},{"id":"world-prov-0179","text":"Why, butter would not melt in his mouth!","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (179)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Butter","author":"Public Domain Proverb"},"sequenceIndex":178},{"id":"world-prov-0180","text":"What is a pound of butter amongst a kennel of hounds?","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (180)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Butter","author":"Public Domain Proverb"},"sequenceIndex":179},{"id":"world-prov-0181","text":"Once a year butter is in the cow's horn.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (181)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Butter","author":"Public Domain Proverb"},"sequenceIndex":180},{"id":"world-prov-0182","text":"He knows on which side his bread is buttered.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (182)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Buttered","author":"Public Domain Proverb"},"sequenceIndex":181},{"id":"world-prov-0183","text":"Do not buy a pig in a poke.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (183)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Buy","author":"Public Domain Proverb"},"sequenceIndex":182},{"id":"world-prov-0184","text":"Let the buyer look out for himself.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (184)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Buyer","author":"Public Domain Proverb"},"sequenceIndex":183},{"id":"world-prov-0185","text":"Who buys hath need of a hundred eyes. Who sells hath need of one. C","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (185)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Buys","author":"Public Domain Proverb"},"sequenceIndex":184},{"id":"world-prov-0186","text":"You cannot eat your cake and have it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (186)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cake","author":"Public Domain Proverb"},"sequenceIndex":185},{"id":"world-prov-0187","text":"In a calm sea every man is a pilot.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (187)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Calm Sea","author":"Public Domain Proverb"},"sequenceIndex":186},{"id":"world-prov-0188","text":"Calm weather in June sets corn in tune.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (188)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Calm Weather","author":"Public Domain Proverb"},"sequenceIndex":187},{"id":"world-prov-0189","text":"A man can do more than he can.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (189)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Can","author":"Public Domain Proverb"},"sequenceIndex":188},{"id":"world-prov-0190","text":"Burn not your candle at both ends at once.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (190)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Candle","author":"Public Domain Proverb"},"sequenceIndex":189},{"id":"world-prov-0191","text":"On Candlemas day you must have half your straw and half your hay.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (191)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Candlemas","author":"Public Domain Proverb"},"sequenceIndex":190},{"id":"world-prov-0192","text":"If Candlemas day be fair and bright, Winter will have another flight; If on Candlemas day it be shower and rain, Winter is gone, and will not come again.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (192)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Candlemas","author":"Public Domain Proverb"},"sequenceIndex":191},{"id":"world-prov-0193","text":"When Candlemas day is come and gone, The snow lies on a hot stone.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (193)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Candlemas","author":"Public Domain Proverb"},"sequenceIndex":192},{"id":"world-prov-0194","text":"The hind had as lief see his wife on the bier, As Candlemas day should be pleasant and clear.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (194)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Candlemas Day","author":"Public Domain Proverb"},"sequenceIndex":193},{"id":"world-prov-0195","text":"On Candlemas day throw candle and candle-stick away.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (195)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Candlemas Day","author":"Public Domain Proverb"},"sequenceIndex":194},{"id":"world-prov-0196","text":"If the cap fit, wear it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (196)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cap","author":"Public Domain Proverb"},"sequenceIndex":195},{"id":"world-prov-0197","text":"Be captain of your own ship.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (197)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Captain","author":"Public Domain Proverb"},"sequenceIndex":196},{"id":"world-prov-0198","text":"Where the carcase is, there will the eagles be gathered together.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (198)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Carcase","author":"Public Domain Proverb"},"sequenceIndex":197},{"id":"world-prov-0199","text":"Many can pack the cards that cannot play.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (199)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cards","author":"Public Domain Proverb"},"sequenceIndex":198},{"id":"world-prov-0200","text":"Care's no cure.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (200)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Care","author":"Public Domain Proverb"},"sequenceIndex":199},{"id":"world-prov-0201","text":"Care will kill a cat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (201)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Care","author":"Public Domain Proverb"},"sequenceIndex":200},{"id":"world-prov-0202","text":"Take care of the pence, and the pounds will take care of themselves.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (202)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Care","author":"Public Domain Proverb"},"sequenceIndex":201},{"id":"world-prov-0203","text":"\"Care not,\" would have.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (203)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Care Not","author":"Public Domain Proverb"},"sequenceIndex":202},{"id":"world-prov-0204","text":"Don't run away with more than you can carry.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (204)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Carry","author":"Public Domain Proverb"},"sequenceIndex":203},{"id":"world-prov-0205","text":"Like carrying coals to Newcastle.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (205)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Carrying Coals","author":"Public Domain Proverb"},"sequenceIndex":204},{"id":"world-prov-0206","text":"Tis easy to build castles in the air.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (206)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Castles","author":"Public Domain Proverb"},"sequenceIndex":205},{"id":"world-prov-0207","text":"Rolling in cash he can't use, like a cat in a corn-bin.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (207)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cash","author":"Public Domain Proverb"},"sequenceIndex":206},{"id":"world-prov-0208","text":"An Englishman's house is his castle.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (208)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Castle","author":"Public Domain Proverb"},"sequenceIndex":207},{"id":"world-prov-0209","text":"When the cat's away, The mice will play.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (209)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cat","author":"Public Domain Proverb"},"sequenceIndex":208},{"id":"world-prov-0210","text":"A cat may look at a king.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (210)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cat","author":"Public Domain Proverb"},"sequenceIndex":209},{"id":"world-prov-0211","text":"The cat is hungry when a crust contents her.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (211)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cat","author":"Public Domain Proverb"},"sequenceIndex":210},{"id":"world-prov-0212","text":"The cat sees not the mouse ever.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (212)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cat","author":"Public Domain Proverb"},"sequenceIndex":211},{"id":"world-prov-0213","text":"I'll keep no more cats than will catch mice.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (213)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cats","author":"Public Domain Proverb"},"sequenceIndex":212},{"id":"world-prov-0214","text":"A cat has nine lives, yet care will kill a cat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (214)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cat","author":"Public Domain Proverb"},"sequenceIndex":213},{"id":"world-prov-0215","text":"When the cat winketh, little wots the mouse what the cat thinketh.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (215)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cat","author":"Public Domain Proverb"},"sequenceIndex":214},{"id":"world-prov-0216","text":"Though the cat winks awhile, yet sure she is not blind.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (216)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cat","author":"Public Domain Proverb"},"sequenceIndex":215},{"id":"world-prov-0217","text":"A cat loves fish, but she's loth to wet her feet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (217)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cat","author":"Public Domain Proverb"},"sequenceIndex":216},{"id":"world-prov-0218","text":"Catch that catch may.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (218)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Catch","author":"Public Domain Proverb"},"sequenceIndex":217},{"id":"world-prov-0219","text":"It's a bad cause that none dare speak in.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (219)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cause","author":"Public Domain Proverb"},"sequenceIndex":218},{"id":"world-prov-0220","text":"Those are wise who learn caution from their own experience; but those are wiser who learn it from the experience of others.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (220)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Caution","author":"Public Domain Proverb"},"sequenceIndex":219},{"id":"world-prov-0221","text":"There is nothing certain in this life but death and taxes!","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (221)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Certain","author":"Public Domain Proverb"},"sequenceIndex":220},{"id":"world-prov-0222","text":"Never quit certainty for hope.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (222)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Certainty","author":"Public Domain Proverb"},"sequenceIndex":221},{"id":"world-prov-0223","text":"I'm too old a bird to be caught by chaff.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (223)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Chaff","author":"Public Domain Proverb"},"sequenceIndex":222},{"id":"world-prov-0224","text":"As like as chalk and cheese.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (224)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Chalk","author":"Public Domain Proverb"},"sequenceIndex":223},{"id":"world-prov-0225","text":"The chamber of sickness is the chapel of devotion.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (225)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Chamber","author":"Public Domain Proverb"},"sequenceIndex":224},{"id":"world-prov-0226","text":"Look to the main chance.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (226)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Chance","author":"Public Domain Proverb"},"sequenceIndex":225},{"id":"world-prov-0227","text":"He that leaves certainty and sticks to chance, When fools pipe he may dance.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (227)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Chance","author":"Public Domain Proverb"},"sequenceIndex":226},{"id":"world-prov-0228","text":"It chanceth in an hour that comes not in seven years.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (228)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Chanceth","author":"Public Domain Proverb"},"sequenceIndex":227},{"id":"world-prov-0229","text":"Change of pasture makes fat calves.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (229)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Change","author":"Public Domain Proverb"},"sequenceIndex":228},{"id":"world-prov-0230","text":"The charitable give out at the door, and God puts in at the window.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (230)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Charitable","author":"Public Domain Proverb"},"sequenceIndex":229},{"id":"world-prov-0231","text":"Charity begins at home.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (231)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Charity","author":"Public Domain Proverb"},"sequenceIndex":230},{"id":"world-prov-0232","text":"He that chastiseth one, amendeth many.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (232)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Chastiseth","author":"Public Domain Proverb"},"sequenceIndex":231},{"id":"world-prov-0233","text":"Cheese it is a peevish elf, It digests all things but itself.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (233)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cheese","author":"Public Domain Proverb"},"sequenceIndex":232},{"id":"world-prov-0234","text":"After cheese comes nothing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (234)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cheese","author":"Public Domain Proverb"},"sequenceIndex":233},{"id":"world-prov-0235","text":"If you would have a good cheese, and have'n old, You must turn'n seven times before he is cold.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (235)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cheese","author":"Public Domain Proverb"},"sequenceIndex":234},{"id":"world-prov-0236","text":"A cherry year, a merry year.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (236)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cherry","author":"Public Domain Proverb"},"sequenceIndex":235},{"id":"world-prov-0237","text":"Count not your chickens before they are hatched.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (237)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Chickens","author":"Public Domain Proverb"},"sequenceIndex":236},{"id":"world-prov-0238","text":"Woe to the house where there is no chiding.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (238)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Chiding","author":"Public Domain Proverb"},"sequenceIndex":237},{"id":"world-prov-0239","text":"Train up a child in the way he should go, and when he is old he will not depart from it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (239)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Child","author":"Public Domain Proverb"},"sequenceIndex":238},{"id":"world-prov-0240","text":"A child may have too much of his mother's blessing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (240)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Child","author":"Public Domain Proverb"},"sequenceIndex":239},{"id":"world-prov-0241","text":"Child's pig, but father's bacon.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (241)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Child'S Pig","author":"Public Domain Proverb"},"sequenceIndex":240},{"id":"world-prov-0242","text":"Children and fools speak the truth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (242)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Children","author":"Public Domain Proverb"},"sequenceIndex":241},{"id":"world-prov-0243","text":"Children and fools have merry lives.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (243)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Children","author":"Public Domain Proverb"},"sequenceIndex":242},{"id":"world-prov-0244","text":"Children and chickens must be always picking.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (244)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Children","author":"Public Domain Proverb"},"sequenceIndex":243},{"id":"world-prov-0245","text":"Children are poor men's riches.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (245)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Children","author":"Public Domain Proverb"},"sequenceIndex":244},{"id":"world-prov-0246","text":"Children should hear, see, and say nothing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (246)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Children","author":"Public Domain Proverb"},"sequenceIndex":245},{"id":"world-prov-0247","text":"When children stand quiet they have done some harm.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (247)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Children","author":"Public Domain Proverb"},"sequenceIndex":246},{"id":"world-prov-0248","text":"Children are certain cares, but very uncertain comforts.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (248)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Children","author":"Public Domain Proverb"},"sequenceIndex":247},{"id":"world-prov-0249","text":"Children suck the mother when they are young, and the father when they are old.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (249)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Children","author":"Public Domain Proverb"},"sequenceIndex":248},{"id":"world-prov-0250","text":"So we have the chink, we'll bear the stink.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (250)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Chink","author":"Public Domain Proverb"},"sequenceIndex":249},{"id":"world-prov-0251","text":"A chip of the old block.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (251)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Chip","author":"Public Domain Proverb"},"sequenceIndex":250},{"id":"world-prov-0252","text":"Christmas comes but once a year.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (252)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Christmas","author":"Public Domain Proverb"},"sequenceIndex":251},{"id":"world-prov-0253","text":"Green Christmas, white Easter.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (253)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Christmas","author":"Public Domain Proverb"},"sequenceIndex":252},{"id":"world-prov-0254","text":"They talk of Christmas so long that it comes.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (254)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Christmas","author":"Public Domain Proverb"},"sequenceIndex":253},{"id":"world-prov-0255","text":"If Christmas Day on a Monday be, A great winter that year you will see.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (255)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Christmas Day","author":"Public Domain Proverb"},"sequenceIndex":254},{"id":"world-prov-0256","text":"Where God hath His church the devil will have his chapel.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (256)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Church","author":"Public Domain Proverb"},"sequenceIndex":255},{"id":"world-prov-0257","text":"The nearer the church the farther from God.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (257)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Church","author":"Public Domain Proverb"},"sequenceIndex":256},{"id":"world-prov-0258","text":"Pater-noster built churches, and Our Father pulls them down.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (258)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Churches","author":"Public Domain Proverb"},"sequenceIndex":257},{"id":"world-prov-0259","text":"Civil words cost nothing, and go a long way.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (259)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Civil Words","author":"Public Domain Proverb"},"sequenceIndex":258},{"id":"world-prov-0260","text":"Claw me, and I will claw you.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (260)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Claw","author":"Public Domain Proverb"},"sequenceIndex":259},{"id":"world-prov-0261","text":"As clear as mud.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (261)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Clear","author":"Public Domain Proverb"},"sequenceIndex":260},{"id":"world-prov-0262","text":"'Tis the clerk makes the justice.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (262)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Clerk","author":"Public Domain Proverb"},"sequenceIndex":261},{"id":"world-prov-0263","text":"Climb not too high, lest the fall be the greater.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (263)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Climb","author":"Public Domain Proverb"},"sequenceIndex":262},{"id":"world-prov-0264","text":"Who never climbed, never fell.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (264)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Climbed","author":"Public Domain Proverb"},"sequenceIndex":263},{"id":"world-prov-0265","text":"Hasty climbers have sudden falls.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (265)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Climbers","author":"Public Domain Proverb"},"sequenceIndex":264},{"id":"world-prov-0266","text":"Have not the cloak to make when it begins to rain.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (266)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cloak","author":"Public Domain Proverb"},"sequenceIndex":265},{"id":"world-prov-0267","text":"Though the sun shines, leave not your cloak at home.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (267)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cloak","author":"Public Domain Proverb"},"sequenceIndex":266},{"id":"world-prov-0268","text":"The clock goes as it pleases the clerk.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (268)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Clock","author":"Public Domain Proverb"},"sequenceIndex":267},{"id":"world-prov-0269","text":"A close mouth catcheth no flies.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (269)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Close Mouth","author":"Public Domain Proverb"},"sequenceIndex":268},{"id":"world-prov-0270","text":"It is good keeping his clothes who is going to swim.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (270)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Clothes","author":"Public Domain Proverb"},"sequenceIndex":269},{"id":"world-prov-0271","text":"Every cloud hath a silver lining.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (271)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cloud","author":"Public Domain Proverb"},"sequenceIndex":270},{"id":"world-prov-0272","text":"Clouds that the sun builds up darken him.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (272)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Clouds","author":"Public Domain Proverb"},"sequenceIndex":271},{"id":"world-prov-0273","text":"When the clouds are on the hills, They'll come down by the mills.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (273)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Clouds","author":"Public Domain Proverb"},"sequenceIndex":272},{"id":"world-prov-0274","text":"After clouds comes clear weather.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (274)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Clouds","author":"Public Domain Proverb"},"sequenceIndex":273},{"id":"world-prov-0275","text":"Cloudy mornings turn to clear evenings.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (275)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cloudy","author":"Public Domain Proverb"},"sequenceIndex":274},{"id":"world-prov-0276","text":"He is in clover.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (276)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Clover","author":"Public Domain Proverb"},"sequenceIndex":275},{"id":"world-prov-0277","text":"Even a clown clings to his cloak when it rains.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (277)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Clown","author":"Public Domain Proverb"},"sequenceIndex":276},{"id":"world-prov-0278","text":"Cut your coat according to your cloth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (278)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Coat","author":"Public Domain Proverb"},"sequenceIndex":277},{"id":"world-prov-0279","text":"It's not the gay coat that makes the gentleman.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (279)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Coat","author":"Public Domain Proverb"},"sequenceIndex":278},{"id":"world-prov-0280","text":"They that can cobble and clout, Shall have work when others go without.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (280)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cobble","author":"Public Domain Proverb"},"sequenceIndex":279},{"id":"world-prov-0281","text":"Let not the cobbler go beyond his last.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (281)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cobbler","author":"Public Domain Proverb"},"sequenceIndex":280},{"id":"world-prov-0282","text":"Who goes worse shod than the cobbler's wife?","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (282)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cobbler'S Wife","author":"Public Domain Proverb"},"sequenceIndex":281},{"id":"world-prov-0283","text":"If the cock moult before the hen, We shall have weather thick and thin; But if the hen moult before the cock, We shall have weather hard as a block.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (283)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cock","author":"Public Domain Proverb"},"sequenceIndex":282},{"id":"world-prov-0284","text":"The cock crows and the hen goes.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (284)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cock","author":"Public Domain Proverb"},"sequenceIndex":283},{"id":"world-prov-0285","text":"Every cock is proud on his own dunghill.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (285)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cock","author":"Public Domain Proverb"},"sequenceIndex":284},{"id":"world-prov-0286","text":"Where coin's not common, commons must be scant.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (286)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Coin","author":"Public Domain Proverb"},"sequenceIndex":285},{"id":"world-prov-0287","text":"Much coin much care.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (287)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Coin","author":"Public Domain Proverb"},"sequenceIndex":286},{"id":"world-prov-0288","text":"A cold April a barn will fill.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (288)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cold April","author":"Public Domain Proverb"},"sequenceIndex":287},{"id":"world-prov-0289","text":"A cold May and a windy Makes a full barn and a findy.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (289)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cold May","author":"Public Domain Proverb"},"sequenceIndex":288},{"id":"world-prov-0290","text":"In the coldest flint there is hot fire.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (290)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Coldest Flint","author":"Public Domain Proverb"},"sequenceIndex":289},{"id":"world-prov-0291","text":"It's an ill battle where the devil carries the colours.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (291)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Colours","author":"Public Domain Proverb"},"sequenceIndex":290},{"id":"world-prov-0292","text":"When you ride a young colt see your saddle be well girt.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (292)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Colt","author":"Public Domain Proverb"},"sequenceIndex":291},{"id":"world-prov-0293","text":"Two's company and three's none.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (293)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Company","author":"Public Domain Proverb"},"sequenceIndex":292},{"id":"world-prov-0294","text":"Tell me what company you keep, and I will tell you who you are.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (294)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Company","author":"Public Domain Proverb"},"sequenceIndex":293},{"id":"world-prov-0295","text":"It's good to have company in trouble.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (295)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Company","author":"Public Domain Proverb"},"sequenceIndex":294},{"id":"world-prov-0296","text":"Company in distress, Makes trouble less.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (296)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Company","author":"Public Domain Proverb"},"sequenceIndex":295},{"id":"world-prov-0297","text":"A merry companion on the road is as good as a nag.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (297)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Companion","author":"Public Domain Proverb"},"sequenceIndex":296},{"id":"world-prov-0298","text":"There's no companion like a penny.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (298)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Companion","author":"Public Domain Proverb"},"sequenceIndex":297},{"id":"world-prov-0299","text":"Comparisons are odious.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (299)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Comparisons","author":"Public Domain Proverb"},"sequenceIndex":298},{"id":"world-prov-0300","text":"They complain wrongfully of the sea, who twice suffer shipwreck.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (300)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Complain","author":"Public Domain Proverb"},"sequenceIndex":299},{"id":"world-prov-0301","text":"Cold of complexion, good of condition.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (301)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Complexion","author":"Public Domain Proverb"},"sequenceIndex":300},{"id":"world-prov-0302","text":"A woman conceals what she knows not.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (302)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Conceals","author":"Public Domain Proverb"},"sequenceIndex":301},{"id":"world-prov-0303","text":"A generous confession disarms slander.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (303)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Confession","author":"Public Domain Proverb"},"sequenceIndex":302},{"id":"world-prov-0304","text":"Confession of a fault makes half amends for it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (304)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Confession","author":"Public Domain Proverb"},"sequenceIndex":303},{"id":"world-prov-0305","text":"Open confession is good for the soul.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (305)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Confession","author":"Public Domain Proverb"},"sequenceIndex":304},{"id":"world-prov-0306","text":"It is no small conquest to overcome yourself.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (306)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Conquest","author":"Public Domain Proverb"},"sequenceIndex":305},{"id":"world-prov-0307","text":"A clear conscience is a sure card.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (307)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Conscience","author":"Public Domain Proverb"},"sequenceIndex":306},{"id":"world-prov-0308","text":"Constant dropping wears the stone.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (308)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Constant Dropping","author":"Public Domain Proverb"},"sequenceIndex":307},{"id":"world-prov-0309","text":"When all is consumed repentance comes too late.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (309)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Consumed","author":"Public Domain Proverb"},"sequenceIndex":308},{"id":"world-prov-0310","text":"Content is the true philosopher's stone.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (310)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Content","author":"Public Domain Proverb"},"sequenceIndex":309},{"id":"world-prov-0311","text":"A contented mind is a continual feast.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (311)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Contented","author":"Public Domain Proverb"},"sequenceIndex":310},{"id":"world-prov-0312","text":"He that hath nothing is not contented.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (312)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Contented","author":"Public Domain Proverb"},"sequenceIndex":311},{"id":"world-prov-0313","text":"He may well be contented who needs neither borrow nor flatter.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (313)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Contented","author":"Public Domain Proverb"},"sequenceIndex":312},{"id":"world-prov-0314","text":"People are sometimes better contented full than fasting.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (314)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Contented","author":"Public Domain Proverb"},"sequenceIndex":313},{"id":"world-prov-0315","text":"The greatest wealth is contentment with a little.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (315)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Contentment","author":"Public Domain Proverb"},"sequenceIndex":314},{"id":"world-prov-0316","text":"Look at your corn in May, You'll come weeping away; Look at the same in June You'll come home in another tune.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (316)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Corn","author":"Public Domain Proverb"},"sequenceIndex":315},{"id":"world-prov-0317","text":"Corn is cleansed with the wind, and the soul with chastening.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (317)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Corn","author":"Public Domain Proverb"},"sequenceIndex":316},{"id":"world-prov-0318","text":"I'll not change a cottage in possession for a kingdom in reversion.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (318)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cottage","author":"Public Domain Proverb"},"sequenceIndex":317},{"id":"world-prov-0319","text":"Counsel is never out of date.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (319)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Counsel","author":"Public Domain Proverb"},"sequenceIndex":318},{"id":"world-prov-0320","text":"Counsels in wine seldom prosper.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (320)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Counsels","author":"Public Domain Proverb"},"sequenceIndex":319},{"id":"world-prov-0321","text":"In wiving and thriving men should take counsel of all the world.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (321)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Counsel","author":"Public Domain Proverb"},"sequenceIndex":320},{"id":"world-prov-0322","text":"Three may keep counsel, if two be away.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (322)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Counsel","author":"Public Domain Proverb"},"sequenceIndex":321},{"id":"world-prov-0323","text":"He that will not be counselled cannot be helped.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (323)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Counselled","author":"Public Domain Proverb"},"sequenceIndex":322},{"id":"world-prov-0324","text":"Count not your chickens before they be hatched.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (324)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Count","author":"Public Domain Proverb"},"sequenceIndex":323},{"id":"world-prov-0325","text":"In every country the sun riseth in the morning.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (325)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Country","author":"Public Domain Proverb"},"sequenceIndex":324},{"id":"world-prov-0326","text":"You must go into the country to hear what news at London.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (326)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Country","author":"Public Domain Proverb"},"sequenceIndex":325},{"id":"world-prov-0327","text":"Every couple is not a pair.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (327)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Couple","author":"Public Domain Proverb"},"sequenceIndex":326},{"id":"world-prov-0328","text":"A friend at court is better than a penny in the purse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (328)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Court","author":"Public Domain Proverb"},"sequenceIndex":327},{"id":"world-prov-0329","text":"Far from court, far from care.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (329)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Court","author":"Public Domain Proverb"},"sequenceIndex":328},{"id":"world-prov-0330","text":"Courts have no almanacks.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (330)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Courts","author":"Public Domain Proverb"},"sequenceIndex":329},{"id":"world-prov-0331","text":"Less of your courtesy, and more of your purse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (331)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Courtesy","author":"Public Domain Proverb"},"sequenceIndex":330},{"id":"world-prov-0332","text":"Courtesy on one side never lasts long.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (332)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Courtesy","author":"Public Domain Proverb"},"sequenceIndex":331},{"id":"world-prov-0333","text":"Men dream in courtship but in wedlock wake.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (333)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Courtship","author":"Public Domain Proverb"},"sequenceIndex":332},{"id":"world-prov-0334","text":"Call me cousin; but cozen me not.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (334)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cousin","author":"Public Domain Proverb"},"sequenceIndex":333},{"id":"world-prov-0335","text":"Stretch your legs according to your coverlet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (335)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Coverlet","author":"Public Domain Proverb"},"sequenceIndex":334},{"id":"world-prov-0336","text":"He covers me with his wings, and bites me with his bill.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (336)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Covers","author":"Public Domain Proverb"},"sequenceIndex":335},{"id":"world-prov-0337","text":"Covet nothing over much.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (337)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Covet","author":"Public Domain Proverb"},"sequenceIndex":336},{"id":"world-prov-0338","text":"Covetousness brings nothing home.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (338)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Covetousness","author":"Public Domain Proverb"},"sequenceIndex":337},{"id":"world-prov-0339","text":"Many a good cow hath had a bad calf.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (339)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cow","author":"Public Domain Proverb"},"sequenceIndex":338},{"id":"world-prov-0340","text":"Look to the cow, and the sow, and the wheat mow, and all will be well enow.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (340)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cow","author":"Public Domain Proverb"},"sequenceIndex":339},{"id":"world-prov-0341","text":"Cowards are always cruel.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (341)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cowards","author":"Public Domain Proverb"},"sequenceIndex":340},{"id":"world-prov-0342","text":"Cowardice is afraid to be known or seen.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (342)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cowardice","author":"Public Domain Proverb"},"sequenceIndex":341},{"id":"world-prov-0343","text":"The greatest crabs are not always the best meat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (343)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Crabs","author":"Public Domain Proverb"},"sequenceIndex":342},{"id":"world-prov-0344","text":"He must crack the nut that would eat the kernel.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (344)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Crack","author":"Public Domain Proverb"},"sequenceIndex":343},{"id":"world-prov-0345","text":"Craft bringeth nothing home.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (345)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Craft","author":"Public Domain Proverb"},"sequenceIndex":344},{"id":"world-prov-0346","text":"Of all crafts, to be an honest man is the master-craft.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (346)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Crafts","author":"Public Domain Proverb"},"sequenceIndex":345},{"id":"world-prov-0347","text":"Crafty evasions save not the truth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (347)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Crafty","author":"Public Domain Proverb"},"sequenceIndex":346},{"id":"world-prov-0348","text":"To a crazy ship all winds are contrary.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (348)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Crazy Ship","author":"Public Domain Proverb"},"sequenceIndex":347},{"id":"world-prov-0349","text":"A creaking gate hangs longest on its hinges.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (349)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Creaking Gate","author":"Public Domain Proverb"},"sequenceIndex":348},{"id":"world-prov-0350","text":"The worst wheel of a cart creaks most.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (350)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Creaks","author":"Public Domain Proverb"},"sequenceIndex":349},{"id":"world-prov-0351","text":"Credit lost is a Venice glass broken.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (351)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Credit","author":"Public Domain Proverb"},"sequenceIndex":350},{"id":"world-prov-0352","text":"Creditors have better memories than debtors.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (352)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Creditors","author":"Public Domain Proverb"},"sequenceIndex":351},{"id":"world-prov-0353","text":"First creep and then go.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (353)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Creep","author":"Public Domain Proverb"},"sequenceIndex":352},{"id":"world-prov-0354","text":"Critics are like brushers of other men's clothes.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (354)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Critics","author":"Public Domain Proverb"},"sequenceIndex":353},{"id":"world-prov-0355","text":"A crooked tree will have a crooked shadow.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (355)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Crooked","author":"Public Domain Proverb"},"sequenceIndex":354},{"id":"world-prov-0356","text":"Crooked logs make straight fires.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (356)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Crooked","author":"Public Domain Proverb"},"sequenceIndex":355},{"id":"world-prov-0357","text":"No cross, no crown.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (357)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cross","author":"Public Domain Proverb"},"sequenceIndex":356},{"id":"world-prov-0358","text":"Every cross has its inscription.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (358)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cross","author":"Public Domain Proverb"},"sequenceIndex":357},{"id":"world-prov-0359","text":"Crosses are ladders for getting to heaven.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (359)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Crosses","author":"Public Domain Proverb"},"sequenceIndex":358},{"id":"world-prov-0360","text":"Crosses are ladders that lead to heaven.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (360)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Crosses","author":"Public Domain Proverb"},"sequenceIndex":359},{"id":"world-prov-0361","text":"The crow thinks her own bird fairest.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (361)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Crow","author":"Public Domain Proverb"},"sequenceIndex":360},{"id":"world-prov-0362","text":"A crow is never the whiter for washing herself often.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (362)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Crow","author":"Public Domain Proverb"},"sequenceIndex":361},{"id":"world-prov-0363","text":"It never goes well when the hen crows.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (363)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Crows","author":"Public Domain Proverb"},"sequenceIndex":362},{"id":"world-prov-0364","text":"Cruelty is a tyrant always attended by fear.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (364)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cruelty","author":"Public Domain Proverb"},"sequenceIndex":363},{"id":"world-prov-0365","text":"Cruelty is a devil's delight.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (365)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cruelty","author":"Public Domain Proverb"},"sequenceIndex":364},{"id":"world-prov-0366","text":"Where are the crumbs there are the chickens.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (366)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Crumbs","author":"Public Domain Proverb"},"sequenceIndex":365},{"id":"world-prov-0367","text":"Don't cry out before you're hurt.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (367)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cry","author":"Public Domain Proverb"},"sequenceIndex":366},{"id":"world-prov-0368","text":"Great cry and little wool.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (368)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cry","author":"Public Domain Proverb"},"sequenceIndex":367},{"id":"world-prov-0369","text":"When the cuckoo comes to the bare thorn, Sell your cow and buy your corn, But when she comes to a full bit, Sell your corn, and buy your sheep.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (369)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cuckoo","author":"Public Domain Proverb"},"sequenceIndex":368},{"id":"world-prov-0370","text":"What cannot be cured must be endured.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (370)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cured","author":"Public Domain Proverb"},"sequenceIndex":369},{"id":"world-prov-0371","text":"Curses are like chickens, they come home to roost.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (371)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Curses","author":"Public Domain Proverb"},"sequenceIndex":370},{"id":"world-prov-0372","text":"Custom is second nature.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (372)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Custom","author":"Public Domain Proverb"},"sequenceIndex":371},{"id":"world-prov-0373","text":"Once a use and ever a custom.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (373)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Custom","author":"Public Domain Proverb"},"sequenceIndex":372},{"id":"world-prov-0374","text":"Custom makes anything easy.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (374)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Custom","author":"Public Domain Proverb"},"sequenceIndex":373},{"id":"world-prov-0375","text":"A bad custom is like a good cake, better broken than kept.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (375)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Custom (Bad)","author":"Public Domain Proverb"},"sequenceIndex":374},{"id":"world-prov-0376","text":"Cut and come again.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (376)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cut","author":"Public Domain Proverb"},"sequenceIndex":375},{"id":"world-prov-0377","text":"No cut like unkindness.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (377)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cut","author":"Public Domain Proverb"},"sequenceIndex":376},{"id":"world-prov-0378","text":"I had not cut my wise teeth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (378)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cut","author":"Public Domain Proverb"},"sequenceIndex":377},{"id":"world-prov-0379","text":"Desperate cuts must have desperate cures. D","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (379)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Cuts","author":"Public Domain Proverb"},"sequenceIndex":378},{"id":"world-prov-0380","text":"No longer pipe, no longer dance.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (380)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dance","author":"Public Domain Proverb"},"sequenceIndex":379},{"id":"world-prov-0381","text":"He dances well to whom fortune pipes.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (381)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dances","author":"Public Domain Proverb"},"sequenceIndex":380},{"id":"world-prov-0382","text":"They love dancing well that dance among thorns.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (382)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dancing","author":"Public Domain Proverb"},"sequenceIndex":381},{"id":"world-prov-0383","text":"The danger's past, and God's forgotten.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (383)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Danger","author":"Public Domain Proverb"},"sequenceIndex":382},{"id":"world-prov-0384","text":"Dainty dogs may have to eat dirty puddings.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (384)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dainty Dogs","author":"Public Domain Proverb"},"sequenceIndex":383},{"id":"world-prov-0385","text":"It is as good to be in the dark as without light.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (385)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dark","author":"Public Domain Proverb"},"sequenceIndex":384},{"id":"world-prov-0386","text":"A dark man's a jewel in a fair woman's eye.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (386)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dark Man","author":"Public Domain Proverb"},"sequenceIndex":385},{"id":"world-prov-0387","text":"He that gropes in the dark finds that he would not.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (387)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dark","author":"Public Domain Proverb"},"sequenceIndex":386},{"id":"world-prov-0388","text":"My son is my son till he marries a wife, But my daughter's my daughter all the days of her life.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (388)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Daughter","author":"Public Domain Proverb"},"sequenceIndex":387},{"id":"world-prov-0389","text":"He that would the daughter win, Must with the mother first begin.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (389)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Daughter","author":"Public Domain Proverb"},"sequenceIndex":388},{"id":"world-prov-0390","text":"Daylight will peep through a small hole.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (390)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Daylight","author":"Public Domain Proverb"},"sequenceIndex":389},{"id":"world-prov-0391","text":"As dead as a door-nail.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (391)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dead","author":"Public Domain Proverb"},"sequenceIndex":390},{"id":"world-prov-0392","text":"He that waits for a dead man's shoes may go long enough barefoot.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (392)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dead Man'S Shoes","author":"Public Domain Proverb"},"sequenceIndex":391},{"id":"world-prov-0393","text":"There are none so deaf as those who will not hear.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (393)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Deaf","author":"Public Domain Proverb"},"sequenceIndex":392},{"id":"world-prov-0394","text":"Tell that tale to a deaf man.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (394)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Deaf Man","author":"Public Domain Proverb"},"sequenceIndex":393},{"id":"world-prov-0395","text":"It's a wicked thing to make a dearth one's garner.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (395)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dearth","author":"Public Domain Proverb"},"sequenceIndex":394},{"id":"world-prov-0396","text":"Death keeps no calendar.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (396)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Death","author":"Public Domain Proverb"},"sequenceIndex":395},{"id":"world-prov-0397","text":"Death is deaf and hears no denial.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (397)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Death","author":"Public Domain Proverb"},"sequenceIndex":396},{"id":"world-prov-0398","text":"Nothing is surer than death.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (398)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Death","author":"Public Domain Proverb"},"sequenceIndex":397},{"id":"world-prov-0399","text":"After death the doctor.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (399)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Death","author":"Public Domain Proverb"},"sequenceIndex":398},{"id":"world-prov-0400","text":"Debt is the worst kind of poverty.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (400)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Debt","author":"Public Domain Proverb"},"sequenceIndex":399},{"id":"world-prov-0401","text":"Out of debt, out of danger.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (401)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Debt","author":"Public Domain Proverb"},"sequenceIndex":400},{"id":"world-prov-0402","text":"In the deepest water is the best fishing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (402)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Deepest Water","author":"Public Domain Proverb"},"sequenceIndex":401},{"id":"world-prov-0403","text":"Deeds are fruits, words are but leaves.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (403)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Deeds","author":"Public Domain Proverb"},"sequenceIndex":402},{"id":"world-prov-0404","text":"A life spent worthily should be measured by deeds--not years.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (404)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Deeds","author":"Public Domain Proverb"},"sequenceIndex":403},{"id":"world-prov-0405","text":"Delays are dangerous.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (405)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Delays","author":"Public Domain Proverb"},"sequenceIndex":404},{"id":"world-prov-0406","text":"Never venture out of your depth until you can swim.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (406)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Depth","author":"Public Domain Proverb"},"sequenceIndex":405},{"id":"world-prov-0407","text":"Desert and reward seldom keep company.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (407)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Desert","author":"Public Domain Proverb"},"sequenceIndex":406},{"id":"world-prov-0408","text":"First deserve and then desire.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (408)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Deserve","author":"Public Domain Proverb"},"sequenceIndex":407},{"id":"world-prov-0409","text":"Desires are nourished by delays.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (409)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Desires","author":"Public Domain Proverb"},"sequenceIndex":408},{"id":"world-prov-0410","text":"What one man despises, another craves.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (410)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Despises","author":"Public Domain Proverb"},"sequenceIndex":409},{"id":"world-prov-0411","text":"Hanging and wiving go by destiny.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (411)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Destiny","author":"Public Domain Proverb"},"sequenceIndex":410},{"id":"world-prov-0412","text":"Talk of the devil and he'll be sure to appear.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (412)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Devil","author":"Public Domain Proverb"},"sequenceIndex":411},{"id":"world-prov-0413","text":"He that hath shipped the devil must make the best of him.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (413)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Devil","author":"Public Domain Proverb"},"sequenceIndex":412},{"id":"world-prov-0414","text":"Give the devil his due.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (414)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Devil","author":"Public Domain Proverb"},"sequenceIndex":413},{"id":"world-prov-0415","text":"Make not the devil blacker than he is.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (415)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Devil","author":"Public Domain Proverb"},"sequenceIndex":414},{"id":"world-prov-0416","text":"He needs must go that the devil drives.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (416)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Devil","author":"Public Domain Proverb"},"sequenceIndex":415},{"id":"world-prov-0417","text":"One must sometimes hold a candle to the devil.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (417)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Devil","author":"Public Domain Proverb"},"sequenceIndex":416},{"id":"world-prov-0418","text":"The devil is not always at one door.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (418)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Devil","author":"Public Domain Proverb"},"sequenceIndex":417},{"id":"world-prov-0419","text":"The Devil Was Sick, the Devil a Monk Would Be; The Devil Grew Well, the Devil a Monk Was He.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (419)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Devil","author":"Public Domain Proverb"},"sequenceIndex":418},{"id":"world-prov-0420","text":"St. Bartholomew brings the cold dew.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (420)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dew","author":"Public Domain Proverb"},"sequenceIndex":419},{"id":"world-prov-0421","text":"Never say die.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (421)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Die","author":"Public Domain Proverb"},"sequenceIndex":420},{"id":"world-prov-0422","text":"Young men may die, old men must.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (422)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Die","author":"Public Domain Proverb"},"sequenceIndex":421},{"id":"world-prov-0423","text":"Diligence is a good patrimony.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (423)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Diligence","author":"Public Domain Proverb"},"sequenceIndex":422},{"id":"world-prov-0424","text":"Diligence is the mother of good fortune.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (424)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Diligence","author":"Public Domain Proverb"},"sequenceIndex":423},{"id":"world-prov-0425","text":"After dinner sit awhile, after supper walk a mile.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (425)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dinner","author":"Public Domain Proverb"},"sequenceIndex":424},{"id":"world-prov-0426","text":"He who would enjoy his friend's dinner should not look into the kitchen.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (426)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dinner","author":"Public Domain Proverb"},"sequenceIndex":425},{"id":"world-prov-0427","text":"Two in distress make sorrows less.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (427)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Distress","author":"Public Domain Proverb"},"sequenceIndex":426},{"id":"world-prov-0428","text":"Sweet discourse makes short days and nights.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (428)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Discourse","author":"Public Domain Proverb"},"sequenceIndex":427},{"id":"world-prov-0429","text":"Discreet women have neither eyes nor ears.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (429)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Discreet","author":"Public Domain Proverb"},"sequenceIndex":428},{"id":"world-prov-0430","text":"An ounce of discretion is worth a pound of wit.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (430)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Discretion","author":"Public Domain Proverb"},"sequenceIndex":429},{"id":"world-prov-0431","text":"Disease is oft the tax of pleasure.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (431)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Disease","author":"Public Domain Proverb"},"sequenceIndex":430},{"id":"world-prov-0432","text":"To know the disease is half the cure.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (432)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Disease","author":"Public Domain Proverb"},"sequenceIndex":431},{"id":"world-prov-0433","text":"The first dish pleaseth all.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (433)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dish","author":"Public Domain Proverb"},"sequenceIndex":432},{"id":"world-prov-0434","text":"Do as you would be done by.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (434)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Do","author":"Public Domain Proverb"},"sequenceIndex":433},{"id":"world-prov-0435","text":"We must do as we may, if we cannot do as we would.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (435)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Do","author":"Public Domain Proverb"},"sequenceIndex":434},{"id":"world-prov-0436","text":"In dock, out nettle.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (436)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dock","author":"Public Domain Proverb"},"sequenceIndex":435},{"id":"world-prov-0437","text":"A doctor and a clown know more than a doctor alone.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (437)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Doctor","author":"Public Domain Proverb"},"sequenceIndex":436},{"id":"world-prov-0438","text":"An old doctor, a young lawyer.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (438)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Doctor","author":"Public Domain Proverb"},"sequenceIndex":437},{"id":"world-prov-0439","text":"Every dog has his day.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (439)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dog","author":"Public Domain Proverb"},"sequenceIndex":438},{"id":"world-prov-0440","text":"A good dog deserves a good bone.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (440)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dog","author":"Public Domain Proverb"},"sequenceIndex":439},{"id":"world-prov-0441","text":"It's a bad dog that deserves not a crust.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (441)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dog","author":"Public Domain Proverb"},"sequenceIndex":440},{"id":"world-prov-0442","text":"Dogs bark before they bite.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (442)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dogs Bark","author":"Public Domain Proverb"},"sequenceIndex":441},{"id":"world-prov-0443","text":"If you wish a thing done, go; if not, send.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (443)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Done","author":"Public Domain Proverb"},"sequenceIndex":442},{"id":"world-prov-0444","text":"A thousand pounds and a pottle of hay is all one thing at doomsday.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (444)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Doomsday","author":"Public Domain Proverb"},"sequenceIndex":443},{"id":"world-prov-0445","text":"When one door shuts another opens.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (445)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Door","author":"Public Domain Proverb"},"sequenceIndex":444},{"id":"world-prov-0446","text":"Do well, and have well.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (446)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Do Well","author":"Public Domain Proverb"},"sequenceIndex":445},{"id":"world-prov-0447","text":"He that's down, down with him.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (447)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Down","author":"Public Domain Proverb"},"sequenceIndex":446},{"id":"world-prov-0448","text":"You may draw him which way you will, with a twine thread.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (448)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Draw","author":"Public Domain Proverb"},"sequenceIndex":447},{"id":"world-prov-0449","text":"A drowning man will catch at a straw.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (449)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Drowning Man","author":"Public Domain Proverb"},"sequenceIndex":448},{"id":"world-prov-0450","text":"Drink water like an ox, wine like a king of Spain.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (450)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Drink","author":"Public Domain Proverb"},"sequenceIndex":449},{"id":"world-prov-0451","text":"He who drinks when he is not dry, will be dry when he has no drink.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (451)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Drink","author":"Public Domain Proverb"},"sequenceIndex":450},{"id":"world-prov-0452","text":"Drive not a second nail till the first is clenched.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (452)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Drive","author":"Public Domain Proverb"},"sequenceIndex":451},{"id":"world-prov-0453","text":"Many drops make a shower.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (453)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Drops","author":"Public Domain Proverb"},"sequenceIndex":452},{"id":"world-prov-0454","text":"If the ash before the oak comes out, There has been, or there will be drought.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (454)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Drought","author":"Public Domain Proverb"},"sequenceIndex":453},{"id":"world-prov-0455","text":"Pour not water on a drowned mouse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (455)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Drowned","author":"Public Domain Proverb"},"sequenceIndex":454},{"id":"world-prov-0456","text":"Ever drunk, ever dry.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (456)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Drunk","author":"Public Domain Proverb"},"sequenceIndex":455},{"id":"world-prov-0457","text":"A drunken night makes a cloudy morning.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (457)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Drunken","author":"Public Domain Proverb"},"sequenceIndex":456},{"id":"world-prov-0458","text":"Drunken folk often speak truth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (458)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Drunken Folk","author":"Public Domain Proverb"},"sequenceIndex":457},{"id":"world-prov-0459","text":"What soberness conceals, drunkenness reveals.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (459)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Drunkenness","author":"Public Domain Proverb"},"sequenceIndex":458},{"id":"world-prov-0460","text":"Dry bread at home is better than roast beef abroad.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (460)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dry Bread","author":"Public Domain Proverb"},"sequenceIndex":459},{"id":"world-prov-0461","text":"A dry cough is the trumpeter of death.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (461)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dry Cough","author":"Public Domain Proverb"},"sequenceIndex":460},{"id":"world-prov-0462","text":"A dry May and a dripping June, Does surely bring all things in tune. E","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (462)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Dry May","author":"Public Domain Proverb"},"sequenceIndex":461},{"id":"world-prov-0463","text":"Early to bed, and early to rise, Makes a man healthy, wealthy, and wise.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (463)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Early","author":"Public Domain Proverb"},"sequenceIndex":462},{"id":"world-prov-0464","text":"Early sow, early mow.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (464)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Early","author":"Public Domain Proverb"},"sequenceIndex":463},{"id":"world-prov-0465","text":"'Tis the early bird catches the worm.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (465)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Early Bird","author":"Public Domain Proverb"},"sequenceIndex":464},{"id":"world-prov-0466","text":"Little pitchers have long ears.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (466)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ears","author":"Public Domain Proverb"},"sequenceIndex":465},{"id":"world-prov-0467","text":"Walls have ears.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (467)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ears","author":"Public Domain Proverb"},"sequenceIndex":466},{"id":"world-prov-0468","text":"Wider ears and a shorter tongue.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (468)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ears","author":"Public Domain Proverb"},"sequenceIndex":467},{"id":"world-prov-0469","text":"A pennyworth of ease is worth a penny.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (469)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ease","author":"Public Domain Proverb"},"sequenceIndex":468},{"id":"world-prov-0470","text":"Think of ease, but work on.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (470)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ease","author":"Public Domain Proverb"},"sequenceIndex":469},{"id":"world-prov-0471","text":"That which is easily done is soon believed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (471)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Easily Done","author":"Public Domain Proverb"},"sequenceIndex":470},{"id":"world-prov-0472","text":"Live not to eat, but eat to live.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (472)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Eat","author":"Public Domain Proverb"},"sequenceIndex":471},{"id":"world-prov-0473","text":"Eat a bit before you drink.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (473)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Eat","author":"Public Domain Proverb"},"sequenceIndex":472},{"id":"world-prov-0474","text":"Eat at pleasure, Drink by measure.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (474)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Eat","author":"Public Domain Proverb"},"sequenceIndex":473},{"id":"world-prov-0475","text":"Eating and drinking takes away one's appetite.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (475)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Eating","author":"Public Domain Proverb"},"sequenceIndex":474},{"id":"world-prov-0476","text":"It is ill meddling with edged tools.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (476)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Edged Tools","author":"Public Domain Proverb"},"sequenceIndex":475},{"id":"world-prov-0477","text":"You cannot hide an eel in a sack.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (477)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Eel","author":"Public Domain Proverb"},"sequenceIndex":476},{"id":"world-prov-0478","text":"Don't put all your eggs into one basket.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (478)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Eggs","author":"Public Domain Proverb"},"sequenceIndex":477},{"id":"world-prov-0479","text":"'Tis hard to sail o'er the sea in an egg-shell.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (479)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Egg-Shell","author":"Public Domain Proverb"},"sequenceIndex":478},{"id":"world-prov-0480","text":"Rub your sore eye with your elbow.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (480)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Elbow","author":"Public Domain Proverb"},"sequenceIndex":479},{"id":"world-prov-0481","text":"Give it plenty of elbow grease.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (481)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Elbow Grease","author":"Public Domain Proverb"},"sequenceIndex":480},{"id":"world-prov-0482","text":"Better an empty house than a bad tenant.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (482)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Empty House","author":"Public Domain Proverb"},"sequenceIndex":481},{"id":"world-prov-0483","text":"An empty purse fills the face with wrinkles.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (483)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Empty Purse","author":"Public Domain Proverb"},"sequenceIndex":482},{"id":"world-prov-0484","text":"That's but an empty purse that's full of other men's money.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (484)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Empty Purse","author":"Public Domain Proverb"},"sequenceIndex":483},{"id":"world-prov-0485","text":"Empty vessels make the greatest sound.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (485)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Empty Vessels","author":"Public Domain Proverb"},"sequenceIndex":484},{"id":"world-prov-0486","text":"Everything hath an end, and a pudding hath two.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (486)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"End","author":"Public Domain Proverb"},"sequenceIndex":485},{"id":"world-prov-0487","text":"He that endureth is not overcome.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (487)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Endureth","author":"Public Domain Proverb"},"sequenceIndex":486},{"id":"world-prov-0488","text":"England is the Paradise of women.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (488)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"England","author":"Public Domain Proverb"},"sequenceIndex":487},{"id":"world-prov-0489","text":"An Englishman's house is his castle.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (489)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Englishman","author":"Public Domain Proverb"},"sequenceIndex":488},{"id":"world-prov-0490","text":"Enough is as good as a feast.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (490)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Enough","author":"Public Domain Proverb"},"sequenceIndex":489},{"id":"world-prov-0491","text":"Enough and to spare is too much.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (491)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Enough","author":"Public Domain Proverb"},"sequenceIndex":490},{"id":"world-prov-0492","text":"There's never enough where nothing's left.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (492)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Enough","author":"Public Domain Proverb"},"sequenceIndex":491},{"id":"world-prov-0493","text":"Better be envied than pitied.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (493)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Envied","author":"Public Domain Proverb"},"sequenceIndex":492},{"id":"world-prov-0494","text":"Envy never enriched any man.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (494)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Envy","author":"Public Domain Proverb"},"sequenceIndex":493},{"id":"world-prov-0495","text":"He lies like an epitaph.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (495)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Epitaph","author":"Public Domain Proverb"},"sequenceIndex":494},{"id":"world-prov-0496","text":"To err is human; to forgive divine.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (496)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Err","author":"Public Domain Proverb"},"sequenceIndex":495},{"id":"world-prov-0497","text":"Send a wise man on an errand and say nothing to him.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (497)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Errand","author":"Public Domain Proverb"},"sequenceIndex":496},{"id":"world-prov-0498","text":"'Tis a hard battle where none escapes.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (498)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Escapes","author":"Public Domain Proverb"},"sequenceIndex":497},{"id":"world-prov-0499","text":"He that throws away his estate with his hands, goes afterwards to pick it upon his feet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (499)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Estate","author":"Public Domain Proverb"},"sequenceIndex":498},{"id":"world-prov-0500","text":"He that knows himself best, esteems himself least.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (500)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Esteems","author":"Public Domain Proverb"},"sequenceIndex":499},{"id":"world-prov-0501","text":"An evening red and a morning grey, Is a sign of a fair day.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (501)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Evening","author":"Public Domain Proverb"},"sequenceIndex":500},{"id":"world-prov-0502","text":"He had need rise betimes that would please everybody.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (502)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Everybody","author":"Public Domain Proverb"},"sequenceIndex":501},{"id":"world-prov-0503","text":"Everybody's business is nobody's business.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (503)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Everybody'S Business","author":"Public Domain Proverb"},"sequenceIndex":502},{"id":"world-prov-0504","text":"Every man for himself, and God for us all.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (504)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Every Man","author":"Public Domain Proverb"},"sequenceIndex":503},{"id":"world-prov-0505","text":"Let every tub stand on its own bottom.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (505)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Every Tub","author":"Public Domain Proverb"},"sequenceIndex":504},{"id":"world-prov-0506","text":"Evil communications corrupt good manners.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (506)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Evil","author":"Public Domain Proverb"},"sequenceIndex":505},{"id":"world-prov-0507","text":"If you must have an evil, choose a little one.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (507)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Evil","author":"Public Domain Proverb"},"sequenceIndex":506},{"id":"world-prov-0508","text":"That which is evil is soon learnt.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (508)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Evil","author":"Public Domain Proverb"},"sequenceIndex":507},{"id":"world-prov-0509","text":"Evil is wrought by want of thought, As well as want of heart.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (509)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Evil","author":"Public Domain Proverb"},"sequenceIndex":508},{"id":"world-prov-0510","text":"The evil wound is cured, but not the evil name.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (510)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Evil Name","author":"Public Domain Proverb"},"sequenceIndex":509},{"id":"world-prov-0511","text":"Evil gotten, evil spent.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (511)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Evil Gotten","author":"Public Domain Proverb"},"sequenceIndex":510},{"id":"world-prov-0512","text":"Of evil grain no good seed can come.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (512)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Evil Grain","author":"Public Domain Proverb"},"sequenceIndex":511},{"id":"world-prov-0513","text":"Of two evils choose the lesser.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (513)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Evils","author":"Public Domain Proverb"},"sequenceIndex":512},{"id":"world-prov-0514","text":"Example teaches more than precept.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (514)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Example","author":"Public Domain Proverb"},"sequenceIndex":513},{"id":"world-prov-0515","text":"Exchange is no robbery.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (515)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Exchange","author":"Public Domain Proverb"},"sequenceIndex":514},{"id":"world-prov-0516","text":"A bad excuse is better than none at all.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (516)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Excuse","author":"Public Domain Proverb"},"sequenceIndex":515},{"id":"world-prov-0517","text":"Proportion your expenses to what you have, not to what you expect.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (517)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Expenses","author":"Public Domain Proverb"},"sequenceIndex":516},{"id":"world-prov-0518","text":"Experience is a dear school, but it is the only one we are apt to learn in.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (518)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Experience","author":"Public Domain Proverb"},"sequenceIndex":517},{"id":"world-prov-0519","text":"Experience is the mistress of fools.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (519)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Experience","author":"Public Domain Proverb"},"sequenceIndex":518},{"id":"world-prov-0520","text":"Extremes seldom last long.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (520)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Extremes","author":"Public Domain Proverb"},"sequenceIndex":519},{"id":"world-prov-0521","text":"Extremes meet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (521)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Extremes","author":"Public Domain Proverb"},"sequenceIndex":520},{"id":"world-prov-0522","text":"Better one eye than quite blind.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (522)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Eye","author":"Public Domain Proverb"},"sequenceIndex":521},{"id":"world-prov-0523","text":"What the eye sees not, the heart rues not.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (523)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Eye","author":"Public Domain Proverb"},"sequenceIndex":522},{"id":"world-prov-0524","text":"You should never touch your eye but with your elbow.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (524)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Eye","author":"Public Domain Proverb"},"sequenceIndex":523},{"id":"world-prov-0525","text":"What the eye does not see the heart does not grieve for.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (525)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Eye","author":"Public Domain Proverb"},"sequenceIndex":524},{"id":"world-prov-0526","text":"One eye-witness is better than ten hearsays. F","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (526)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Eye-Witness","author":"Public Domain Proverb"},"sequenceIndex":525},{"id":"world-prov-0527","text":"Her face was her fortune.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (527)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Face","author":"Public Domain Proverb"},"sequenceIndex":526},{"id":"world-prov-0528","text":"A single fact is worth a ship-load of argument.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (528)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fact","author":"Public Domain Proverb"},"sequenceIndex":527},{"id":"world-prov-0529","text":"Faint heart never won a fair lady.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (529)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Faint Heart","author":"Public Domain Proverb"},"sequenceIndex":528},{"id":"world-prov-0530","text":"Faint praise is disparagement.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (530)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Faint Praise","author":"Public Domain Proverb"},"sequenceIndex":529},{"id":"world-prov-0531","text":"Fair and foolish, black and proud, Long and lazy, little and loud.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (531)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fair And Foolish","author":"Public Domain Proverb"},"sequenceIndex":530},{"id":"world-prov-0532","text":"Fair and softly go far in a day.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (532)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fair And Softly","author":"Public Domain Proverb"},"sequenceIndex":531},{"id":"world-prov-0533","text":"Fair faces need no paint.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (533)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fair Faces","author":"Public Domain Proverb"},"sequenceIndex":532},{"id":"world-prov-0534","text":"A fair face may hide a foul heart.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (534)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fair Face","author":"Public Domain Proverb"},"sequenceIndex":533},{"id":"world-prov-0535","text":"Fair feathers make fair fowls.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (535)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fair Feathers","author":"Public Domain Proverb"},"sequenceIndex":534},{"id":"world-prov-0536","text":"Love asks faith, and faith asks firmness.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (536)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Faith","author":"Public Domain Proverb"},"sequenceIndex":535},{"id":"world-prov-0537","text":"One may sooner fall than rise.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (537)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fall","author":"Public Domain Proverb"},"sequenceIndex":536},{"id":"world-prov-0538","text":"If a man once fall, all will tread on him.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (538)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fall","author":"Public Domain Proverb"},"sequenceIndex":537},{"id":"world-prov-0539","text":"When the tree falls every man runs with his hatchet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (539)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Falls","author":"Public Domain Proverb"},"sequenceIndex":538},{"id":"world-prov-0540","text":"Keeping from falling is better than helping up.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (540)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Falling","author":"Public Domain Proverb"},"sequenceIndex":539},{"id":"world-prov-0541","text":"A false report rides post.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (541)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"False Report","author":"Public Domain Proverb"},"sequenceIndex":540},{"id":"world-prov-0542","text":"Familiarity breeds contempt.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (542)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Familiarity","author":"Public Domain Proverb"},"sequenceIndex":541},{"id":"world-prov-0543","text":"After a famine in the stall, Comes a famine in the hall.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (543)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Famine","author":"Public Domain Proverb"},"sequenceIndex":542},{"id":"world-prov-0544","text":"Under water famine, under snow bread.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (544)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Famine","author":"Public Domain Proverb"},"sequenceIndex":543},{"id":"world-prov-0545","text":"A famine in England begins at the horse-manger.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (545)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Famine","author":"Public Domain Proverb"},"sequenceIndex":544},{"id":"world-prov-0546","text":"Fancy passes beauty.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (546)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fancy","author":"Public Domain Proverb"},"sequenceIndex":545},{"id":"world-prov-0547","text":"Fancy goes a long way.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (547)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fancy","author":"Public Domain Proverb"},"sequenceIndex":546},{"id":"world-prov-0548","text":"Fancy may bolt bran and think it flour.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (548)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fancy","author":"Public Domain Proverb"},"sequenceIndex":547},{"id":"world-prov-0549","text":"You may go farther and fare worse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (549)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fare Worse","author":"Public Domain Proverb"},"sequenceIndex":548},{"id":"world-prov-0550","text":"As good to be out of the world as out of the fashion.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (550)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fashion","author":"Public Domain Proverb"},"sequenceIndex":549},{"id":"world-prov-0551","text":"Fast bind, fast find.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (551)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fast Bind","author":"Public Domain Proverb"},"sequenceIndex":550},{"id":"world-prov-0552","text":"Every one basteth the fat hog, while the lean one burneth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (552)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fat Hog","author":"Public Domain Proverb"},"sequenceIndex":551},{"id":"world-prov-0553","text":"Every one puts his fault on the times.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (553)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fault","author":"Public Domain Proverb"},"sequenceIndex":552},{"id":"world-prov-0554","text":"A fault once denied is twice committed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (554)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fault","author":"Public Domain Proverb"},"sequenceIndex":553},{"id":"world-prov-0555","text":"Fault-finders should be fault-menders.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (555)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fault-Finders","author":"Public Domain Proverb"},"sequenceIndex":554},{"id":"world-prov-0556","text":"Every one's faults are not written on their foreheads.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (556)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Faults","author":"Public Domain Proverb"},"sequenceIndex":555},{"id":"world-prov-0557","text":"Every man hath his faults.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (557)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Faults","author":"Public Domain Proverb"},"sequenceIndex":556},{"id":"world-prov-0558","text":"God send me a friend that may tell me my faults; if not, an enemy, he will be sure to.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (558)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Faults","author":"Public Domain Proverb"},"sequenceIndex":557},{"id":"world-prov-0559","text":"The faulty stands on his guard.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (559)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Faulty","author":"Public Domain Proverb"},"sequenceIndex":558},{"id":"world-prov-0560","text":"A feast is not made of mushrooms only.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (560)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Feast","author":"Public Domain Proverb"},"sequenceIndex":559},{"id":"world-prov-0561","text":"Merry is the feast-making until we come to the reckoning.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (561)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Feast-Making","author":"Public Domain Proverb"},"sequenceIndex":560},{"id":"world-prov-0562","text":"Fools make feasts, and wise men eat them.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (562)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Feasts","author":"Public Domain Proverb"},"sequenceIndex":561},{"id":"world-prov-0563","text":"Fine feathers make fine birds.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (563)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Feathers","author":"Public Domain Proverb"},"sequenceIndex":562},{"id":"world-prov-0564","text":"Feather by feather the goose is plucked.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (564)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Feather","author":"Public Domain Proverb"},"sequenceIndex":563},{"id":"world-prov-0565","text":"February makes a bridge, and March breaks it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (565)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"February","author":"Public Domain Proverb"},"sequenceIndex":564},{"id":"world-prov-0566","text":"February fill dike, be it black or be it white; But if it be white, it's the better to like.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (566)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"February","author":"Public Domain Proverb"},"sequenceIndex":565},{"id":"world-prov-0567","text":"Feed sparingly, and defy the physician.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (567)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Feed Sparingly","author":"Public Domain Proverb"},"sequenceIndex":566},{"id":"world-prov-0568","text":"Stretch not your feet Beyond the sheet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (568)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Feet","author":"Public Domain Proverb"},"sequenceIndex":567},{"id":"world-prov-0569","text":"Love and lordship like no fellowship.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (569)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fellowship","author":"Public Domain Proverb"},"sequenceIndex":568},{"id":"world-prov-0570","text":"No man loves his fetters, though of gold.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (570)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fetters","author":"Public Domain Proverb"},"sequenceIndex":569},{"id":"world-prov-0571","text":"Have but few friends, though many acquaintances.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (571)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Few Friends","author":"Public Domain Proverb"},"sequenceIndex":570},{"id":"world-prov-0572","text":"Where hearts are true Few words will do.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (572)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Few Words","author":"Public Domain Proverb"},"sequenceIndex":571},{"id":"world-prov-0573","text":"The fifer don't pay a fiddler.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (573)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fiddler","author":"Public Domain Proverb"},"sequenceIndex":572},{"id":"world-prov-0574","text":"Let not the fiddler play the fife, Nor fifer play the fiddle.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (574)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fiddler","author":"Public Domain Proverb"},"sequenceIndex":573},{"id":"world-prov-0575","text":"Fiddler's fare; meat, drink, and money.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (575)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fiddler'S Fare","author":"Public Domain Proverb"},"sequenceIndex":574},{"id":"world-prov-0576","text":"Fields have eyes, and woods have ears.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (576)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fields","author":"Public Domain Proverb"},"sequenceIndex":575},{"id":"world-prov-0577","text":"He wants to have a finger in every pie.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (577)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Finger","author":"Public Domain Proverb"},"sequenceIndex":576},{"id":"world-prov-0578","text":"The first blow is half the battle.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (578)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"First Blow","author":"Public Domain Proverb"},"sequenceIndex":577},{"id":"world-prov-0579","text":"First come, first served.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (579)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"First Come","author":"Public Domain Proverb"},"sequenceIndex":578},{"id":"world-prov-0580","text":"Fire and water are good servants but bad masters.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (580)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fire And Water","author":"Public Domain Proverb"},"sequenceIndex":579},{"id":"world-prov-0581","text":"Well may he smell of fire whose gown burneth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (581)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fire","author":"Public Domain Proverb"},"sequenceIndex":580},{"id":"world-prov-0582","text":"He that would catch fish must not mind getting wet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (582)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fish","author":"Public Domain Proverb"},"sequenceIndex":581},{"id":"world-prov-0583","text":"'Tis good fish if it were but caught.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (583)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fish","author":"Public Domain Proverb"},"sequenceIndex":582},{"id":"world-prov-0584","text":"The best fish are near the bottom.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (584)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fish","author":"Public Domain Proverb"},"sequenceIndex":583},{"id":"world-prov-0585","text":"I have other fish to fry.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (585)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fish","author":"Public Domain Proverb"},"sequenceIndex":584},{"id":"world-prov-0586","text":"Make not fish of one, and flesh of another.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (586)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fish","author":"Public Domain Proverb"},"sequenceIndex":585},{"id":"world-prov-0587","text":"Fish are not to be caught by a birdcall.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (587)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fish","author":"Public Domain Proverb"},"sequenceIndex":586},{"id":"world-prov-0588","text":"There's as good fish in the sea as were ever caught.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (588)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fish (Good)","author":"Public Domain Proverb"},"sequenceIndex":587},{"id":"world-prov-0589","text":"When the wind's in the south, It blows the bait into the fishes' mouth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (589)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fishes' Mouth","author":"Public Domain Proverb"},"sequenceIndex":588},{"id":"world-prov-0590","text":"He fisheth on that catcheth one.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (590)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fisheth On","author":"Public Domain Proverb"},"sequenceIndex":589},{"id":"world-prov-0591","text":"It's good fishing in troubled waters.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (591)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fishing","author":"Public Domain Proverb"},"sequenceIndex":590},{"id":"world-prov-0592","text":"Every shoe fits not every foot.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (592)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fits","author":"Public Domain Proverb"},"sequenceIndex":591},{"id":"world-prov-0593","text":"He's up at five, And he will thrive.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (593)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Five","author":"Public Domain Proverb"},"sequenceIndex":592},{"id":"world-prov-0594","text":"Get thy spindle and thy distaff ready, and God will send thee flax.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (594)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Flax","author":"Public Domain Proverb"},"sequenceIndex":593},{"id":"world-prov-0595","text":"No man can flay a stone.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (595)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Flay","author":"Public Domain Proverb"},"sequenceIndex":594},{"id":"world-prov-0596","text":"Where every hand fleeceth, the sheep go naked.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (596)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fleeceth","author":"Public Domain Proverb"},"sequenceIndex":595},{"id":"world-prov-0597","text":"A May flood never did good.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (597)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Flood","author":"Public Domain Proverb"},"sequenceIndex":596},{"id":"world-prov-0598","text":"Flowers are the pledge of fruit.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (598)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Flowers","author":"Public Domain Proverb"},"sequenceIndex":597},{"id":"world-prov-0599","text":"It is one thing to flourish and another to fight.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (599)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Flourish","author":"Public Domain Proverb"},"sequenceIndex":598},{"id":"world-prov-0600","text":"No flying without wings.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (600)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Flying","author":"Public Domain Proverb"},"sequenceIndex":599},{"id":"world-prov-0601","text":"Happy is he who knows his follies in his youth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (601)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Follies","author":"Public Domain Proverb"},"sequenceIndex":600},{"id":"world-prov-0602","text":"No one is a fool always; every one sometimes.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (602)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fool","author":"Public Domain Proverb"},"sequenceIndex":601},{"id":"world-prov-0603","text":"A fool may ask more questions in half an hour than a wise man can answer in seven years.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (603)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fool","author":"Public Domain Proverb"},"sequenceIndex":602},{"id":"world-prov-0604","text":"A fool may give a wise man counsel.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (604)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fool","author":"Public Domain Proverb"},"sequenceIndex":603},{"id":"world-prov-0605","text":"One fool makes many.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (605)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fool","author":"Public Domain Proverb"},"sequenceIndex":604},{"id":"world-prov-0606","text":"Every man is either a fool or a physician after thirty years of age.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (606)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fool","author":"Public Domain Proverb"},"sequenceIndex":605},{"id":"world-prov-0607","text":"An old fool is the worst of fools.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (607)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fool (Old)","author":"Public Domain Proverb"},"sequenceIndex":606},{"id":"world-prov-0608","text":"Better it is to meet a bear bereaved of her whelps, than a fool in his folly.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (608)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fool","author":"Public Domain Proverb"},"sequenceIndex":607},{"id":"world-prov-0609","text":"A fool is fulsome.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (609)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fool","author":"Public Domain Proverb"},"sequenceIndex":608},{"id":"world-prov-0610","text":"As the fool thinks, so the bell chinks.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (610)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fool Thinks","author":"Public Domain Proverb"},"sequenceIndex":609},{"id":"world-prov-0611","text":"Fools set stools for wise folk to stumble at.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (611)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fools","author":"Public Domain Proverb"},"sequenceIndex":610},{"id":"world-prov-0612","text":"A fool's bolt is soon shot.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (612)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fool'S Bolt","author":"Public Domain Proverb"},"sequenceIndex":611},{"id":"world-prov-0613","text":"Fools build houses, and wise men buy them.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (613)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fools Build","author":"Public Domain Proverb"},"sequenceIndex":612},{"id":"world-prov-0614","text":"Forbearance is no acquittance.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (614)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Forbearance","author":"Public Domain Proverb"},"sequenceIndex":613},{"id":"world-prov-0615","text":"Forbidden fruit is sweet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (615)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Forbidden Fruit","author":"Public Domain Proverb"},"sequenceIndex":614},{"id":"world-prov-0616","text":"Forced fruits fail in flavour.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (616)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Forced Fruits","author":"Public Domain Proverb"},"sequenceIndex":615},{"id":"world-prov-0617","text":"Forecast is better than work hard.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (617)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Forecast","author":"Public Domain Proverb"},"sequenceIndex":616},{"id":"world-prov-0618","text":"Forego, forget, forgive, Then happy you shall live.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (618)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Forego","author":"Public Domain Proverb"},"sequenceIndex":617},{"id":"world-prov-0619","text":"The foremost dog catches the hare.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (619)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Foremost Dog","author":"Public Domain Proverb"},"sequenceIndex":618},{"id":"world-prov-0620","text":"Forewarned is forearmed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (620)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Forewarned","author":"Public Domain Proverb"},"sequenceIndex":619},{"id":"world-prov-0621","text":"To forget a wrong is the best revenge.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (621)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Forget","author":"Public Domain Proverb"},"sequenceIndex":620},{"id":"world-prov-0622","text":"Forgive and forget.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (622)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Forgive","author":"Public Domain Proverb"},"sequenceIndex":621},{"id":"world-prov-0623","text":"Eaten bread is soon forgotten.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (623)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Forgotten","author":"Public Domain Proverb"},"sequenceIndex":622},{"id":"world-prov-0624","text":"Fortune favours the brave.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (624)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fortune","author":"Public Domain Proverb"},"sequenceIndex":623},{"id":"world-prov-0625","text":"Every man is the architect of his fortune.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (625)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fortune","author":"Public Domain Proverb"},"sequenceIndex":624},{"id":"world-prov-0626","text":"Change of fortune is the lot of life.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (626)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fortune","author":"Public Domain Proverb"},"sequenceIndex":625},{"id":"world-prov-0627","text":"Better a fortune in her than on her.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (627)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fortune","author":"Public Domain Proverb"},"sequenceIndex":626},{"id":"world-prov-0628","text":"When fortune smiles take the advantage.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (628)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fortune","author":"Public Domain Proverb"},"sequenceIndex":627},{"id":"world-prov-0629","text":"Fortune knocks once at least at every man's gate.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (629)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fortune Knocks","author":"Public Domain Proverb"},"sequenceIndex":628},{"id":"world-prov-0630","text":"Foul hands befoul all they touch.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (630)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Foul Hands","author":"Public Domain Proverb"},"sequenceIndex":629},{"id":"world-prov-0631","text":"Four farthings and a thimble make a tailor's pocket jingle.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (631)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Four Farthings","author":"Public Domain Proverb"},"sequenceIndex":630},{"id":"world-prov-0632","text":"The fox knows much, but more he that catcheth him.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (632)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fox","author":"Public Domain Proverb"},"sequenceIndex":631},{"id":"world-prov-0633","text":"A fox should not be of the jury at a goose trial.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (633)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fox","author":"Public Domain Proverb"},"sequenceIndex":632},{"id":"world-prov-0634","text":"When the fox preaches, beware of your geese.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (634)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fox","author":"Public Domain Proverb"},"sequenceIndex":633},{"id":"world-prov-0635","text":"Foxes, when they cannot reach the grapes, say they are not ripe.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (635)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Foxes","author":"Public Domain Proverb"},"sequenceIndex":634},{"id":"world-prov-0636","text":"Though the fox runs the chicken hath wings.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (636)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fox Runs","author":"Public Domain Proverb"},"sequenceIndex":635},{"id":"world-prov-0637","text":"Two things you won't fret o'er, If you're a wise man-- The thing you can't help, And the thing that you can.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (637)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fret","author":"Public Domain Proverb"},"sequenceIndex":636},{"id":"world-prov-0638","text":"He that sings on Friday shall weep on Sunday.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (638)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Friday","author":"Public Domain Proverb"},"sequenceIndex":637},{"id":"world-prov-0639","text":"As the Friday, so the Sunday, As the Sunday, so the week.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (639)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Friday","author":"Public Domain Proverb"},"sequenceIndex":638},{"id":"world-prov-0640","text":"Friday's sail, sure to fail.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (640)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Friday'S Sail","author":"Public Domain Proverb"},"sequenceIndex":639},{"id":"world-prov-0641","text":"A friend is not so soon gotten as lost.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (641)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Friend","author":"Public Domain Proverb"},"sequenceIndex":640},{"id":"world-prov-0642","text":"A friend in need is a friend indeed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (642)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Friend","author":"Public Domain Proverb"},"sequenceIndex":641},{"id":"world-prov-0643","text":"He loseth nothing who keeps God for his friend.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (643)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Friend","author":"Public Domain Proverb"},"sequenceIndex":642},{"id":"world-prov-0644","text":"Make not thy friend too cheap to thee, nor thyself to thy friend.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (644)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Friend","author":"Public Domain Proverb"},"sequenceIndex":643},{"id":"world-prov-0645","text":"In time of prosperity friends will be plenty, In time of adversity, not one among twenty.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (645)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Friends","author":"Public Domain Proverb"},"sequenceIndex":644},{"id":"world-prov-0646","text":"Save me from my friends.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (646)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Friends","author":"Public Domain Proverb"},"sequenceIndex":645},{"id":"world-prov-0647","text":"All are not friends that speak us fair.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (647)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Friends","author":"Public Domain Proverb"},"sequenceIndex":646},{"id":"world-prov-0648","text":"Love and lordship never like friendship.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (648)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Friendship","author":"Public Domain Proverb"},"sequenceIndex":647},{"id":"world-prov-0649","text":"What God will, no frost can kill.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (649)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Frost","author":"Public Domain Proverb"},"sequenceIndex":648},{"id":"world-prov-0650","text":"So many frosts in March, so many in May.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (650)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Frosts","author":"Public Domain Proverb"},"sequenceIndex":649},{"id":"world-prov-0651","text":"If you would fruit have, You must bring the leaf to the grave.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (651)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fruit","author":"Public Domain Proverb"},"sequenceIndex":650},{"id":"world-prov-0652","text":"Such as the tree is, such is the fruit.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (652)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fruit","author":"Public Domain Proverb"},"sequenceIndex":651},{"id":"world-prov-0653","text":"If you would enjoy the fruit, pluck not the flower.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (653)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fruit","author":"Public Domain Proverb"},"sequenceIndex":652},{"id":"world-prov-0654","text":"Frugality makes an easy chair for old age.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (654)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Frugality","author":"Public Domain Proverb"},"sequenceIndex":653},{"id":"world-prov-0655","text":"Frugality is an estate.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (655)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Frugality","author":"Public Domain Proverb"},"sequenceIndex":654},{"id":"world-prov-0656","text":"Out of the frying-pan into the fire.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (656)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Frying-Pan","author":"Public Domain Proverb"},"sequenceIndex":655},{"id":"world-prov-0657","text":"Take away fuel, take away flame.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (657)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Fuel","author":"Public Domain Proverb"},"sequenceIndex":656},{"id":"world-prov-0658","text":"A full purse makes the mouth to speak.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (658)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Full Purse","author":"Public Domain Proverb"},"sequenceIndex":657},{"id":"world-prov-0659","text":"A full purse never lacketh friends.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (659)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Full Purse","author":"Public Domain Proverb"},"sequenceIndex":658},{"id":"world-prov-0660","text":"Under the furze is hunger and cold. Under the broom is silver and gold. G","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (660)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Furze","author":"Public Domain Proverb"},"sequenceIndex":659},{"id":"world-prov-0661","text":"No gains without pains.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (661)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gains","author":"Public Domain Proverb"},"sequenceIndex":660},{"id":"world-prov-0662","text":"Touch a galled horse, and he will wince.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (662)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Galled Horse","author":"Public Domain Proverb"},"sequenceIndex":661},{"id":"world-prov-0663","text":"He that gapeth until he be fed Well may he gape until he be dead.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (663)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gapeth","author":"Public Domain Proverb"},"sequenceIndex":662},{"id":"world-prov-0664","text":"Many things grow in the garden that were never planted there.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (664)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Garden","author":"Public Domain Proverb"},"sequenceIndex":663},{"id":"world-prov-0665","text":"This rule in gardening never forget, To sow dry and set wet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (665)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gardening","author":"Public Domain Proverb"},"sequenceIndex":664},{"id":"world-prov-0666","text":"One flower makes no garland.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (666)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Garland","author":"Public Domain Proverb"},"sequenceIndex":665},{"id":"world-prov-0667","text":"Gems must not be valued by what they are set in.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (667)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gems","author":"Public Domain Proverb"},"sequenceIndex":666},{"id":"world-prov-0668","text":"Gentility without ability is worse than plain beggary.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (668)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gentility","author":"Public Domain Proverb"},"sequenceIndex":667},{"id":"world-prov-0669","text":"Gentle strokes make the sweetest harmony.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (669)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gentle Strokes","author":"Public Domain Proverb"},"sequenceIndex":668},{"id":"world-prov-0670","text":"Get what you can, and what you get, hold, 'Tis the stone which will turn your lead into gold.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (670)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Get","author":"Public Domain Proverb"},"sequenceIndex":669},{"id":"world-prov-0671","text":"Look not a gift horse in the mouth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (671)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gift Horse","author":"Public Domain Proverb"},"sequenceIndex":670},{"id":"world-prov-0672","text":"A gift with a kind countenance is a double gift.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (672)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gift","author":"Public Domain Proverb"},"sequenceIndex":671},{"id":"world-prov-0673","text":"To give and keep there is need of wit.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (673)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Give","author":"Public Domain Proverb"},"sequenceIndex":672},{"id":"world-prov-0674","text":"He giveth twice who gives in a trice.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (674)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Giveth","author":"Public Domain Proverb"},"sequenceIndex":673},{"id":"world-prov-0675","text":"Giving to the poor Increaseth your store.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (675)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Giving","author":"Public Domain Proverb"},"sequenceIndex":674},{"id":"world-prov-0676","text":"A man of gladness seldom falls into madness.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (676)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gladness","author":"Public Domain Proverb"},"sequenceIndex":675},{"id":"world-prov-0677","text":"What your glass tells you will not be told by counsel.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (677)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Glass","author":"Public Domain Proverb"},"sequenceIndex":676},{"id":"world-prov-0678","text":"Who loves his glass without a G, Take away L and that is he.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (678)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Glass","author":"Public Domain Proverb"},"sequenceIndex":677},{"id":"world-prov-0679","text":"Those who live in glass houses should not throw stones.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (679)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Glass Houses","author":"Public Domain Proverb"},"sequenceIndex":678},{"id":"world-prov-0680","text":"The more women look in their glasses, the less they look to their houses.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (680)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Glasses","author":"Public Domain Proverb"},"sequenceIndex":679},{"id":"world-prov-0681","text":"All that glitters is not gold.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (681)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Glitters","author":"Public Domain Proverb"},"sequenceIndex":680},{"id":"world-prov-0682","text":"Men strain at gnats, and swallow camels!","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (682)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gnats","author":"Public Domain Proverb"},"sequenceIndex":681},{"id":"world-prov-0683","text":"If you want a thing done, go; if not, send.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (683)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Go","author":"Public Domain Proverb"},"sequenceIndex":682},{"id":"world-prov-0684","text":"Better go about than fall into the ditch.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (684)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Go About","author":"Public Domain Proverb"},"sequenceIndex":683},{"id":"world-prov-0685","text":"God sends meat, and the devil sends cooks.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (685)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"God","author":"Public Domain Proverb"},"sequenceIndex":684},{"id":"world-prov-0686","text":"One God, no more; but friends good store.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (686)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"God","author":"Public Domain Proverb"},"sequenceIndex":685},{"id":"world-prov-0687","text":"When the child is christened, you may have godfathers enough.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (687)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Godfathers","author":"Public Domain Proverb"},"sequenceIndex":686},{"id":"world-prov-0688","text":"When God wills, all winds bring rain.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (688)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"God Wills","author":"Public Domain Proverb"},"sequenceIndex":687},{"id":"world-prov-0689","text":"A man may buy gold too dear.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (689)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gold","author":"Public Domain Proverb"},"sequenceIndex":688},{"id":"world-prov-0690","text":"Gold alone makes not prosperity.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (690)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gold","author":"Public Domain Proverb"},"sequenceIndex":689},{"id":"world-prov-0691","text":"As good as gold.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (691)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gold","author":"Public Domain Proverb"},"sequenceIndex":690},{"id":"world-prov-0692","text":"Gold goes in at any gate, except Heaven's.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (692)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gold","author":"Public Domain Proverb"},"sequenceIndex":691},{"id":"world-prov-0693","text":"No lock will hold 'Gainst the power of gold.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (693)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gold","author":"Public Domain Proverb"},"sequenceIndex":692},{"id":"world-prov-0694","text":"We must not look for a golden life in an iron age.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (694)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Golden","author":"Public Domain Proverb"},"sequenceIndex":693},{"id":"world-prov-0695","text":"Gold dust blinds all eyes.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (695)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gold Dust","author":"Public Domain Proverb"},"sequenceIndex":694},{"id":"world-prov-0696","text":"Do all the good you talk of; but talk not of all the good you do.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (696)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good","author":"Public Domain Proverb"},"sequenceIndex":695},{"id":"world-prov-0697","text":"Good and quickly seldom meet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (697)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good","author":"Public Domain Proverb"},"sequenceIndex":696},{"id":"world-prov-0698","text":"No man knows better what good is than he that has an endured evil.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (698)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good","author":"Public Domain Proverb"},"sequenceIndex":697},{"id":"world-prov-0699","text":"Though good be good yet better carries it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (699)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good","author":"Public Domain Proverb"},"sequenceIndex":698},{"id":"world-prov-0700","text":"When good cheer is lacking our friends will be packing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (700)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good Cheer","author":"Public Domain Proverb"},"sequenceIndex":699},{"id":"world-prov-0701","text":"A good word is as soon said as an ill one.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (701)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good Word","author":"Public Domain Proverb"},"sequenceIndex":700},{"id":"world-prov-0702","text":"Good counsel never comes too late.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (702)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good Counsel","author":"Public Domain Proverb"},"sequenceIndex":701},{"id":"world-prov-0703","text":"He's a good friend that speaks well of us behind our backs.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (703)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good Friend","author":"Public Domain Proverb"},"sequenceIndex":702},{"id":"world-prov-0704","text":"Good harvests make men prodigal, bad ones provident.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (704)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good Harvests","author":"Public Domain Proverb"},"sequenceIndex":703},{"id":"world-prov-0705","text":"A good maxim is never out of season.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (705)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good Maxim","author":"Public Domain Proverb"},"sequenceIndex":704},{"id":"world-prov-0706","text":"It is no use throwing good money after bad.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (706)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good Money","author":"Public Domain Proverb"},"sequenceIndex":705},{"id":"world-prov-0707","text":"The wife that expects to have a good name Is always at home as if she were lame, And the maid that is honest her chiefest delight Is still to be doing from morning to night.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (707)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good Name","author":"Public Domain Proverb"},"sequenceIndex":706},{"id":"world-prov-0708","text":"A man may lose his goods for want of demanding them.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (708)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Goods","author":"Public Domain Proverb"},"sequenceIndex":707},{"id":"world-prov-0709","text":"God reacheth us good things with our own hands.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (709)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good Things","author":"Public Domain Proverb"},"sequenceIndex":708},{"id":"world-prov-0710","text":"One can never have too much of a good thing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (710)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good Thing","author":"Public Domain Proverb"},"sequenceIndex":709},{"id":"world-prov-0711","text":"One never loseth by doing good turns.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (711)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good Turns","author":"Public Domain Proverb"},"sequenceIndex":710},{"id":"world-prov-0712","text":"One good turn deserves another.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (712)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good Turn","author":"Public Domain Proverb"},"sequenceIndex":711},{"id":"world-prov-0713","text":"Good words without deeds Are rushes and reeds.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (713)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Good Words","author":"Public Domain Proverb"},"sequenceIndex":712},{"id":"world-prov-0714","text":"The gown is hers who wears it, and the world is his who enjoys it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (714)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Gown","author":"Public Domain Proverb"},"sequenceIndex":713},{"id":"world-prov-0715","text":"Grasp no more than thy hand will hold.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (715)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Grasp","author":"Public Domain Proverb"},"sequenceIndex":714},{"id":"world-prov-0716","text":"Never split timber against the grain.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (716)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Grain","author":"Public Domain Proverb"},"sequenceIndex":715},{"id":"world-prov-0717","text":"Grasp all, lose all.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (717)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Grasp","author":"Public Domain Proverb"},"sequenceIndex":716},{"id":"world-prov-0718","text":"March grass never did good.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (718)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Grass","author":"Public Domain Proverb"},"sequenceIndex":717},{"id":"world-prov-0719","text":"If the grass grow in Janiveer, It grows the worse for't all the year.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (719)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Grass","author":"Public Domain Proverb"},"sequenceIndex":718},{"id":"world-prov-0720","text":"While the grass grows the steed starves.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (720)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Grass","author":"Public Domain Proverb"},"sequenceIndex":719},{"id":"world-prov-0721","text":"Grass grows not upon the highway.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (721)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Grass","author":"Public Domain Proverb"},"sequenceIndex":720},{"id":"world-prov-0722","text":"We shall lie all alike in our graves.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (722)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Graves","author":"Public Domain Proverb"},"sequenceIndex":721},{"id":"world-prov-0723","text":"A great dowry is a bed full of troubles.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (723)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Great Dowry","author":"Public Domain Proverb"},"sequenceIndex":722},{"id":"world-prov-0724","text":"Great marks are soonest hit.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (724)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Great Marks","author":"Public Domain Proverb"},"sequenceIndex":723},{"id":"world-prov-0725","text":"There would be no great ones if there were no little.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (725)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Great Ones","author":"Public Domain Proverb"},"sequenceIndex":724},{"id":"world-prov-0726","text":"A great ship needs deep waters.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (726)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Great Ship","author":"Public Domain Proverb"},"sequenceIndex":725},{"id":"world-prov-0727","text":"Green wood makes a hot fire.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (727)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Green Wood","author":"Public Domain Proverb"},"sequenceIndex":726},{"id":"world-prov-0728","text":"A green wound is soon healed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (728)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Green Wound","author":"Public Domain Proverb"},"sequenceIndex":727},{"id":"world-prov-0729","text":"A green winter makes a fat churchyard.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (729)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Green Winter","author":"Public Domain Proverb"},"sequenceIndex":728},{"id":"world-prov-0730","text":"Gray hairs are death's blossoms.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (730)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Grey Hairs","author":"Public Domain Proverb"},"sequenceIndex":729},{"id":"world-prov-0731","text":"Grief pent up will burst the heart.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (731)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Grief","author":"Public Domain Proverb"},"sequenceIndex":730},{"id":"world-prov-0732","text":"The mill cannot grind with the water that is past.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (732)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Grind","author":"Public Domain Proverb"},"sequenceIndex":731},{"id":"world-prov-0733","text":"An unbidden guest must bring his own stool with him.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (733)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Guest","author":"Public Domain Proverb"},"sequenceIndex":732},{"id":"world-prov-0734","text":"'Tis an ill guest that never drinks to his host.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (734)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Guest","author":"Public Domain Proverb"},"sequenceIndex":733},{"id":"world-prov-0735","text":"A guilty conscience needs no accuser. H","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (735)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Guilty Conscience","author":"Public Domain Proverb"},"sequenceIndex":734},{"id":"world-prov-0736","text":"Hail brings frost in the tail.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (736)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hail","author":"Public Domain Proverb"},"sequenceIndex":735},{"id":"world-prov-0737","text":"Half a loaf is better than no bread.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (737)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Half A Loaf","author":"Public Domain Proverb"},"sequenceIndex":736},{"id":"world-prov-0738","text":"Better be half hanged than ill wed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (738)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Half Hanged","author":"Public Domain Proverb"},"sequenceIndex":737},{"id":"world-prov-0739","text":"A hand-saw is a good thing, but not to shave with.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (739)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hand-Saw","author":"Public Domain Proverb"},"sequenceIndex":738},{"id":"world-prov-0740","text":"He knows not a hawk from a hand-saw.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (740)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hand-Saw","author":"Public Domain Proverb"},"sequenceIndex":739},{"id":"world-prov-0741","text":"He who is not handsome at twenty, nor strong at thirty, nor wise at forty, nor rich at fifty, will never be handsome, strong, rich, or wise.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (741)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Handsome","author":"Public Domain Proverb"},"sequenceIndex":740},{"id":"world-prov-0742","text":"He who is born to be hanged will never be drowned.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (742)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hanged","author":"Public Domain Proverb"},"sequenceIndex":741},{"id":"world-prov-0743","text":"One may as well be hanged for a sheep as a lamb.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (743)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hanged","author":"Public Domain Proverb"},"sequenceIndex":742},{"id":"world-prov-0744","text":"There are many ways of killing a dog beside hanging him.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (744)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hanging","author":"Public Domain Proverb"},"sequenceIndex":743},{"id":"world-prov-0745","text":"Happy is the bride the sun shines on, And the corpse the rain rains on.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (745)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Happy","author":"Public Domain Proverb"},"sequenceIndex":744},{"id":"world-prov-0746","text":"Where we least think, there goeth the hare away.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (746)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hare","author":"Public Domain Proverb"},"sequenceIndex":745},{"id":"world-prov-0747","text":"\"Hardly ever\" saves many a lie.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (747)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hardly Ever","author":"Public Domain Proverb"},"sequenceIndex":746},{"id":"world-prov-0748","text":"Little dogs start the hare, but great ones catch it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (748)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hare","author":"Public Domain Proverb"},"sequenceIndex":747},{"id":"world-prov-0749","text":"Sell not the hare's skin before you have caught him.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (749)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hare Skin","author":"Public Domain Proverb"},"sequenceIndex":748},{"id":"world-prov-0750","text":"Harm watch, harm catch.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (750)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Harm","author":"Public Domain Proverb"},"sequenceIndex":749},{"id":"world-prov-0751","text":"Wise men learn by others' harms, fools by their own.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (751)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Harms","author":"Public Domain Proverb"},"sequenceIndex":750},{"id":"world-prov-0752","text":"He that hath a good harvest may be content with some thistles.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (752)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Harvest","author":"Public Domain Proverb"},"sequenceIndex":751},{"id":"world-prov-0753","text":"More haste worse speed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (753)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Haste","author":"Public Domain Proverb"},"sequenceIndex":752},{"id":"world-prov-0754","text":"Haste trips up its own heels.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (754)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Haste","author":"Public Domain Proverb"},"sequenceIndex":753},{"id":"world-prov-0755","text":"Over haste makes certain waste.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (755)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Haste","author":"Public Domain Proverb"},"sequenceIndex":754},{"id":"world-prov-0756","text":"Haste over nothing but catching fleas.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (756)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Haste","author":"Public Domain Proverb"},"sequenceIndex":755},{"id":"world-prov-0757","text":"Hasty men never lack woe.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (757)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hasty Men","author":"Public Domain Proverb"},"sequenceIndex":756},{"id":"world-prov-0758","text":"Hasty resolutions seldom speed well.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (758)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hasty Resolutions","author":"Public Domain Proverb"},"sequenceIndex":757},{"id":"world-prov-0759","text":"Pull down your hat on the wind side.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (759)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hat","author":"Public Domain Proverb"},"sequenceIndex":758},{"id":"world-prov-0760","text":"When the tree is down, every one runs with his hatchet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (760)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hatchet","author":"Public Domain Proverb"},"sequenceIndex":759},{"id":"world-prov-0761","text":"'Tis safe riding in a good haven.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (761)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Haven","author":"Public Domain Proverb"},"sequenceIndex":760},{"id":"world-prov-0762","text":"Make hay while the sun shines.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (762)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hay","author":"Public Domain Proverb"},"sequenceIndex":761},{"id":"world-prov-0763","text":"Man is the head, but woman turns it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (763)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Head","author":"Public Domain Proverb"},"sequenceIndex":762},{"id":"world-prov-0764","text":"He that hath no head, needs no hat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (764)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Head","author":"Public Domain Proverb"},"sequenceIndex":763},{"id":"world-prov-0765","text":"Better be the head of an ass than the tail of a horse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (765)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Head","author":"Public Domain Proverb"},"sequenceIndex":764},{"id":"world-prov-0766","text":"When the head aches, all the body is the worse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (766)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Headache","author":"Public Domain Proverb"},"sequenceIndex":765},{"id":"world-prov-0767","text":"A man is not so soon healed as hurt.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (767)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Healed","author":"Public Domain Proverb"},"sequenceIndex":766},{"id":"world-prov-0768","text":"God healeth, and the physician hath the thanks.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (768)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Healeth","author":"Public Domain Proverb"},"sequenceIndex":767},{"id":"world-prov-0769","text":"Health is better than wealth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (769)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Health","author":"Public Domain Proverb"},"sequenceIndex":768},{"id":"world-prov-0770","text":"What the heart thinketh, the tongue speaketh.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (770)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Heart","author":"Public Domain Proverb"},"sequenceIndex":769},{"id":"world-prov-0771","text":"Hearts may agree though heads differ.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (771)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hearts","author":"Public Domain Proverb"},"sequenceIndex":770},{"id":"world-prov-0772","text":"Where the hedge is lowest, men commonly leap over.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (772)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hedge","author":"Public Domain Proverb"},"sequenceIndex":771},{"id":"world-prov-0773","text":"A low hedge is easily leapt over.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (773)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hedge","author":"Public Domain Proverb"},"sequenceIndex":772},{"id":"world-prov-0774","text":"A hedge between Keeps friendship green.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (774)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hedge","author":"Public Domain Proverb"},"sequenceIndex":773},{"id":"world-prov-0775","text":"Hedges have eyes, and walls have ears.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (775)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hedges","author":"Public Domain Proverb"},"sequenceIndex":774},{"id":"world-prov-0776","text":"Good take heed doth surely speed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (776)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Heed","author":"Public Domain Proverb"},"sequenceIndex":775},{"id":"world-prov-0777","text":"One pair of heels is often worth two pair of hands.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (777)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Heels","author":"Public Domain Proverb"},"sequenceIndex":776},{"id":"world-prov-0778","text":"It is a sad house where the hen crows louder than the cock.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (778)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hen Crows","author":"Public Domain Proverb"},"sequenceIndex":777},{"id":"world-prov-0779","text":"Love and a cough cannot be hid.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (779)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hid","author":"Public Domain Proverb"},"sequenceIndex":778},{"id":"world-prov-0780","text":"You cannot hide an eel in a sack.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (780)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hide","author":"Public Domain Proverb"},"sequenceIndex":779},{"id":"world-prov-0781","text":"Hide nothing from thy minister, physician, and lawyer.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (781)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hide","author":"Public Domain Proverb"},"sequenceIndex":780},{"id":"world-prov-0782","text":"High places have their precipices.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (782)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"High Places","author":"Public Domain Proverb"},"sequenceIndex":781},{"id":"world-prov-0783","text":"High winds blow on high hills.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (783)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"High Winds","author":"Public Domain Proverb"},"sequenceIndex":782},{"id":"world-prov-0784","text":"Every man is best known to himself.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (784)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Himself","author":"Public Domain Proverb"},"sequenceIndex":783},{"id":"world-prov-0785","text":"He is not wise that is not wise for himself.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (785)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Himself","author":"Public Domain Proverb"},"sequenceIndex":784},{"id":"world-prov-0786","text":"To fright a hind is not the way to catch her.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (786)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hind","author":"Public Domain Proverb"},"sequenceIndex":785},{"id":"world-prov-0787","text":"The hindermost dog may catch the hare.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (787)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hindermost Dog","author":"Public Domain Proverb"},"sequenceIndex":786},{"id":"world-prov-0788","text":"Happy is the man that has a hobby.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (788)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hobby","author":"Public Domain Proverb"},"sequenceIndex":787},{"id":"world-prov-0789","text":"Every man has his hobby-horse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (789)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hobby-Horse","author":"Public Domain Proverb"},"sequenceIndex":788},{"id":"world-prov-0790","text":"A hog in armour is still but a hog.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (790)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hog","author":"Public Domain Proverb"},"sequenceIndex":789},{"id":"world-prov-0791","text":"Do not holloa till you are out of the wood.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (791)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Holloa","author":"Public Domain Proverb"},"sequenceIndex":790},{"id":"world-prov-0792","text":"Home is home, be it ever so homely.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (792)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Home","author":"Public Domain Proverb"},"sequenceIndex":791},{"id":"world-prov-0793","text":"Honesty is the best policy; but he who acts on this principle is not an honest man.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (793)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Honesty","author":"Public Domain Proverb"},"sequenceIndex":792},{"id":"world-prov-0794","text":"A man never surfeits of too much honesty.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (794)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Honesty","author":"Public Domain Proverb"},"sequenceIndex":793},{"id":"world-prov-0795","text":"Better poor with honour than rich with shame.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (795)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Honour","author":"Public Domain Proverb"},"sequenceIndex":794},{"id":"world-prov-0796","text":"Honour and ease are seldom bed-fellows.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (796)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Honour","author":"Public Domain Proverb"},"sequenceIndex":795},{"id":"world-prov-0797","text":"Where honour ceaseth, there knowledge decreaseth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (797)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Honour","author":"Public Domain Proverb"},"sequenceIndex":796},{"id":"world-prov-0798","text":"He giveth one knock on the hoop, and another on the barrel.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (798)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hoop","author":"Public Domain Proverb"},"sequenceIndex":797},{"id":"world-prov-0799","text":"Hope deferred maketh the heart sick.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (799)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hope","author":"Public Domain Proverb"},"sequenceIndex":798},{"id":"world-prov-0800","text":"Hope humbles more than despair.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (800)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hope","author":"Public Domain Proverb"},"sequenceIndex":799},{"id":"world-prov-0801","text":"Hope is a good breakfast, but a bad supper.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (801)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hope","author":"Public Domain Proverb"},"sequenceIndex":800},{"id":"world-prov-0802","text":"If it were not for hope, the heart would break.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (802)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hope","author":"Public Domain Proverb"},"sequenceIndex":801},{"id":"world-prov-0803","text":"Till St. James's day be come and gone, You may have hops, or you may have none.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (803)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hops","author":"Public Domain Proverb"},"sequenceIndex":802},{"id":"world-prov-0804","text":"All are not hunters that blow the horn.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (804)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Horn","author":"Public Domain Proverb"},"sequenceIndex":803},{"id":"world-prov-0805","text":"A good horse cannot be of a bad colour.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (805)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Horse","author":"Public Domain Proverb"},"sequenceIndex":804},{"id":"world-prov-0806","text":"A good horse often wants a good spur.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (806)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Horse","author":"Public Domain Proverb"},"sequenceIndex":805},{"id":"world-prov-0807","text":"'Tis an ill horse will not carry his own provender.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (807)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Horse","author":"Public Domain Proverb"},"sequenceIndex":806},{"id":"world-prov-0808","text":"One man may lead a horse to water, but fifty cannot make him drink.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (808)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Horse","author":"Public Domain Proverb"},"sequenceIndex":807},{"id":"world-prov-0809","text":"Hot love is soon cold.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (809)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hot Love","author":"Public Domain Proverb"},"sequenceIndex":808},{"id":"world-prov-0810","text":"A hot May makes a fat churchyard.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (810)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hot May","author":"Public Domain Proverb"},"sequenceIndex":809},{"id":"world-prov-0811","text":"Hold not with the hounds and run with the hare.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (811)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hounds","author":"Public Domain Proverb"},"sequenceIndex":810},{"id":"world-prov-0812","text":"He that buys a house ready wrought, Hath many a pin and nail for nought.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (812)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"House","author":"Public Domain Proverb"},"sequenceIndex":811},{"id":"world-prov-0813","text":"Better one's house too little one day, than too big all the year round.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (813)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"House","author":"Public Domain Proverb"},"sequenceIndex":812},{"id":"world-prov-0814","text":"Wishers and woulders are never good householders.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (814)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Householders","author":"Public Domain Proverb"},"sequenceIndex":813},{"id":"world-prov-0815","text":"A noble housekeeper needs no doors.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (815)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Housekeeper","author":"Public Domain Proverb"},"sequenceIndex":814},{"id":"world-prov-0816","text":"Every man has his humour.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (816)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Humour","author":"Public Domain Proverb"},"sequenceIndex":815},{"id":"world-prov-0817","text":"The stillest humours are always the worst.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (817)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Humours","author":"Public Domain Proverb"},"sequenceIndex":816},{"id":"world-prov-0818","text":"It is all one a hundred years hence.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (818)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hundred Years","author":"Public Domain Proverb"},"sequenceIndex":817},{"id":"world-prov-0819","text":"As well be hung for a sheep as a lamb.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (819)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hung","author":"Public Domain Proverb"},"sequenceIndex":818},{"id":"world-prov-0820","text":"Hunger costs little; daintiness much.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (820)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hunger","author":"Public Domain Proverb"},"sequenceIndex":819},{"id":"world-prov-0821","text":"Hunger will break through stone walls.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (821)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hunger","author":"Public Domain Proverb"},"sequenceIndex":820},{"id":"world-prov-0822","text":"Hunger makes short devotion.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (822)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hunger","author":"Public Domain Proverb"},"sequenceIndex":821},{"id":"world-prov-0823","text":"Hunger makes hard bones sweet beans.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (823)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hunger","author":"Public Domain Proverb"},"sequenceIndex":822},{"id":"world-prov-0824","text":"Hunger is the finest sauce.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (824)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hunger","author":"Public Domain Proverb"},"sequenceIndex":823},{"id":"world-prov-0825","text":"Hungry flies bite sore.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (825)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hungry Flies","author":"Public Domain Proverb"},"sequenceIndex":824},{"id":"world-prov-0826","text":"A hungry horse makes a clean manger.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (826)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hungry Horse","author":"Public Domain Proverb"},"sequenceIndex":825},{"id":"world-prov-0827","text":"A hungry man, an angry man.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (827)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hungry Man","author":"Public Domain Proverb"},"sequenceIndex":826},{"id":"world-prov-0828","text":"Hungry men think the cook lazy.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (828)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hungry Men","author":"Public Domain Proverb"},"sequenceIndex":827},{"id":"world-prov-0829","text":"Bitter is sweet to hungry men.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (829)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Hungry Men","author":"Public Domain Proverb"},"sequenceIndex":828},{"id":"world-prov-0830","text":"Be a good husband, and you will get a penny to spend, a penny to lend, and a penny for a friend.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (830)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Husband","author":"Public Domain Proverb"},"sequenceIndex":829},{"id":"world-prov-0831","text":"In the husband wisdom, in the wife gentleness. I","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (831)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Husband","author":"Public Domain Proverb"},"sequenceIndex":830},{"id":"world-prov-0832","text":"An idle brain is the devil's workshop.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (832)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Idle Brain","author":"Public Domain Proverb"},"sequenceIndex":831},{"id":"world-prov-0833","text":"Idle folk have the least leisure.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (833)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Idle Folk","author":"Public Domain Proverb"},"sequenceIndex":832},{"id":"world-prov-0834","text":"Idle folk take the most pains.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (834)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Idle Folk","author":"Public Domain Proverb"},"sequenceIndex":833},{"id":"world-prov-0835","text":"A young man idle, an old man needy.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (835)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Idle","author":"Public Domain Proverb"},"sequenceIndex":834},{"id":"world-prov-0836","text":"Better be idle than ill employed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (836)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Idle","author":"Public Domain Proverb"},"sequenceIndex":835},{"id":"world-prov-0837","text":"Idleness is the key of beggary.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (837)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Idleness","author":"Public Domain Proverb"},"sequenceIndex":836},{"id":"world-prov-0838","text":"Of idleness comes no goodness.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (838)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Idleness","author":"Public Domain Proverb"},"sequenceIndex":837},{"id":"world-prov-0839","text":"Idleness is the root of all evil.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (839)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Idleness","author":"Public Domain Proverb"},"sequenceIndex":838},{"id":"world-prov-0840","text":"Idleness must thank itself if it goes barefoot.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (840)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Idleness","author":"Public Domain Proverb"},"sequenceIndex":839},{"id":"world-prov-0841","text":"The ignorant think all things wrong which they cannot understand.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (841)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ignorant","author":"Public Domain Proverb"},"sequenceIndex":840},{"id":"world-prov-0842","text":"It is an ill bird that defiles its own nest.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (842)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ill Bird","author":"Public Domain Proverb"},"sequenceIndex":841},{"id":"world-prov-0843","text":"'Tis an ill dog that deserves not a bone.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (843)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ill Dog","author":"Public Domain Proverb"},"sequenceIndex":842},{"id":"world-prov-0844","text":"He who hath no ill fortune, is dazed with good.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (844)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ill Fortune","author":"Public Domain Proverb"},"sequenceIndex":843},{"id":"world-prov-0845","text":"Ill got, ill spent.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (845)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ill Got","author":"Public Domain Proverb"},"sequenceIndex":844},{"id":"world-prov-0846","text":"Ill gotten gains seldom prosper.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (846)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ill Gotten","author":"Public Domain Proverb"},"sequenceIndex":845},{"id":"world-prov-0847","text":"When ill luck falls asleep, let nobody wake her.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (847)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ill Luck","author":"Public Domain Proverb"},"sequenceIndex":846},{"id":"world-prov-0848","text":"Ill news comes apace.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (848)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ill News","author":"Public Domain Proverb"},"sequenceIndex":847},{"id":"world-prov-0849","text":"Ill weeds grow apace.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (849)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ill Weeds","author":"Public Domain Proverb"},"sequenceIndex":848},{"id":"world-prov-0850","text":"One ill word asketh another.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (850)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ill Word","author":"Public Domain Proverb"},"sequenceIndex":849},{"id":"world-prov-0851","text":"Nothing is impossible to a willing mind.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (851)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Impossible","author":"Public Domain Proverb"},"sequenceIndex":850},{"id":"world-prov-0852","text":"Impudence is not courage.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (852)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Impudence","author":"Public Domain Proverb"},"sequenceIndex":851},{"id":"world-prov-0853","text":"Give him an inch, and he'll take an ell.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (853)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Inch","author":"Public Domain Proverb"},"sequenceIndex":852},{"id":"world-prov-0854","text":"God never measures men by inches.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (854)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Inches","author":"Public Domain Proverb"},"sequenceIndex":853},{"id":"world-prov-0855","text":"Industry is fortune's right hand and frugality her left.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (855)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Industry","author":"Public Domain Proverb"},"sequenceIndex":854},{"id":"world-prov-0856","text":"Jest not at another's infirmities.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (856)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Infirmities","author":"Public Domain Proverb"},"sequenceIndex":855},{"id":"world-prov-0857","text":"Ingratitude is the daughter of pride.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (857)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ingratitude","author":"Public Domain Proverb"},"sequenceIndex":856},{"id":"world-prov-0858","text":"Pocket an injury.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (858)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Injury","author":"Public Domain Proverb"},"sequenceIndex":857},{"id":"world-prov-0859","text":"He goes not out of his way that goes to a good inn.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (859)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Inn","author":"Public Domain Proverb"},"sequenceIndex":858},{"id":"world-prov-0860","text":"Woman's instinct is often truer than man's reasoning.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (860)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Instinct","author":"Public Domain Proverb"},"sequenceIndex":859},{"id":"world-prov-0861","text":"Hell is paved with good intentions.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (861)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Intentions","author":"Public Domain Proverb"},"sequenceIndex":860},{"id":"world-prov-0862","text":"He that hath many irons in the fire, some of them will cool.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (862)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Irons","author":"Public Domain Proverb"},"sequenceIndex":861},{"id":"world-prov-0863","text":"Itch and ease can no man please. J","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (863)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Itch","author":"Public Domain Proverb"},"sequenceIndex":862},{"id":"world-prov-0864","text":"Jack-in-office is a great man.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (864)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Jack","author":"Public Domain Proverb"},"sequenceIndex":863},{"id":"world-prov-0865","text":"Every Jack has his Jill.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (865)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Jack","author":"Public Domain Proverb"},"sequenceIndex":864},{"id":"world-prov-0866","text":"If Janiveer calends be summerly gay 'Twill be winterly weather till calends of May.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (866)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Janiveer","author":"Public Domain Proverb"},"sequenceIndex":865},{"id":"world-prov-0867","text":"Who in Janiveer sows oats, gets gold and groats.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (867)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Janiveer","author":"Public Domain Proverb"},"sequenceIndex":866},{"id":"world-prov-0868","text":"Better lose a jest than a friend.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (868)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Jest","author":"Public Domain Proverb"},"sequenceIndex":867},{"id":"world-prov-0869","text":"Many a true word is spoken in jest.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (869)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Jest","author":"Public Domain Proverb"},"sequenceIndex":868},{"id":"world-prov-0870","text":"Jesting lies bring serious sorrows.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (870)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Jesting","author":"Public Domain Proverb"},"sequenceIndex":869},{"id":"world-prov-0871","text":"Jests, like sweetmeats, are often sour sauce.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (871)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Jests","author":"Public Domain Proverb"},"sequenceIndex":870},{"id":"world-prov-0872","text":"'Tis a great journey to the world's end.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (872)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Journey","author":"Public Domain Proverb"},"sequenceIndex":871},{"id":"world-prov-0873","text":"No joy without annoy.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (873)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Joy","author":"Public Domain Proverb"},"sequenceIndex":872},{"id":"world-prov-0874","text":"There's no joy without alloy.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (874)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Joy","author":"Public Domain Proverb"},"sequenceIndex":873},{"id":"world-prov-0875","text":"Joy surfeited turns to sorrow.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (875)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Joy","author":"Public Domain Proverb"},"sequenceIndex":874},{"id":"world-prov-0876","text":"Judge not of men or things at first sight.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (876)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Judge","author":"Public Domain Proverb"},"sequenceIndex":875},{"id":"world-prov-0877","text":"Judge not a ship as she lies on the stocks.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (877)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Judge","author":"Public Domain Proverb"},"sequenceIndex":876},{"id":"world-prov-0878","text":"He hath a good judgment who is apt to distrust his own.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (878)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Judgment","author":"Public Domain Proverb"},"sequenceIndex":877},{"id":"world-prov-0879","text":"Calm weather in June Sets corn in tune.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (879)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"June","author":"Public Domain Proverb"},"sequenceIndex":878},{"id":"world-prov-0880","text":"If the first of July, it be rainy weather, 'Twill rain more or less for four weeks together.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (880)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"July","author":"Public Domain Proverb"},"sequenceIndex":879},{"id":"world-prov-0881","text":"Just is honest, and honest is just. K","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (881)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Just","author":"Public Domain Proverb"},"sequenceIndex":880},{"id":"world-prov-0882","text":"Keep a thing seven years, and you will find a use for it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (882)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Keep","author":"Public Domain Proverb"},"sequenceIndex":881},{"id":"world-prov-0883","text":"Keep some till more come.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (883)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Keep","author":"Public Domain Proverb"},"sequenceIndex":882},{"id":"world-prov-0884","text":"He that will eat the kernel, must crack the nut.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (884)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Kernel","author":"Public Domain Proverb"},"sequenceIndex":883},{"id":"world-prov-0885","text":"The wife is the key of the house.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (885)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Key","author":"Public Domain Proverb"},"sequenceIndex":884},{"id":"world-prov-0886","text":"All the keys hang not at one man's girdle.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (886)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Keys","author":"Public Domain Proverb"},"sequenceIndex":885},{"id":"world-prov-0887","text":"Still stand by kin Through thick and thin.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (887)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Kin","author":"Public Domain Proverb"},"sequenceIndex":886},{"id":"world-prov-0888","text":"Wood half burnt is easily kindled.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (888)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Kindled","author":"Public Domain Proverb"},"sequenceIndex":887},{"id":"world-prov-0889","text":"Kindness will always conquer.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (889)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Kindness","author":"Public Domain Proverb"},"sequenceIndex":888},{"id":"world-prov-0890","text":"Kindnesses, like grain, increase by sowing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (890)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Kindnesses","author":"Public Domain Proverb"},"sequenceIndex":889},{"id":"world-prov-0891","text":"Many kinsfolk, few friends.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (891)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Kinsfolk","author":"Public Domain Proverb"},"sequenceIndex":890},{"id":"world-prov-0892","text":"As easy kiss my hand.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (892)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Kiss","author":"Public Domain Proverb"},"sequenceIndex":891},{"id":"world-prov-0893","text":"Many kiss the child for the nurse's sake.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (893)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Kiss","author":"Public Domain Proverb"},"sequenceIndex":892},{"id":"world-prov-0894","text":"Kissing goes by favour.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (894)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Kissing","author":"Public Domain Proverb"},"sequenceIndex":893},{"id":"world-prov-0895","text":"A fat kitchen, a lean will.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (895)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Kitchen","author":"Public Domain Proverb"},"sequenceIndex":894},{"id":"world-prov-0896","text":"The taste of the kitchen is better than the smell.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (896)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Kitchen","author":"Public Domain Proverb"},"sequenceIndex":895},{"id":"world-prov-0897","text":"Silks and satins put out the fire in the kitchen.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (897)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Kitchen","author":"Public Domain Proverb"},"sequenceIndex":896},{"id":"world-prov-0898","text":"Knavery may serve for a turn, but honesty is best in the long run.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (898)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Knavery","author":"Public Domain Proverb"},"sequenceIndex":897},{"id":"world-prov-0899","text":"Knaves and fools divide the world.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (899)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Knaves","author":"Public Domain Proverb"},"sequenceIndex":898},{"id":"world-prov-0900","text":"When knaves fall out, true men come by their goods.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (900)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Knaves","author":"Public Domain Proverb"},"sequenceIndex":899},{"id":"world-prov-0901","text":"He tied a knot with his tongue he couldn't undo with his teeth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (901)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Knot","author":"Public Domain Proverb"},"sequenceIndex":900},{"id":"world-prov-0902","text":"Fools tie knots and wise men loose them.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (902)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Knots","author":"Public Domain Proverb"},"sequenceIndex":901},{"id":"world-prov-0903","text":"To split knotty timber use smooth wedges.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (903)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Knotty Timber","author":"Public Domain Proverb"},"sequenceIndex":902},{"id":"world-prov-0904","text":"Knowledge is power.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (904)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Knowledge","author":"Public Domain Proverb"},"sequenceIndex":903},{"id":"world-prov-0905","text":"Knowledge in youth is wisdom in age.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (905)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Knowledge","author":"Public Domain Proverb"},"sequenceIndex":904},{"id":"world-prov-0906","text":"The knowledge of the disease is half the cure.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (906)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Knowledge","author":"Public Domain Proverb"},"sequenceIndex":905},{"id":"world-prov-0907","text":"Knowledge, like physic, is more plague than profit, if it arrives too late.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (907)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Knowledge","author":"Public Domain Proverb"},"sequenceIndex":906},{"id":"world-prov-0908","text":"An ounce of knowledge may be worth a pound of comfort. L","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (908)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Knowledge","author":"Public Domain Proverb"},"sequenceIndex":907},{"id":"world-prov-0909","text":"He that labours and thrives, spins gold.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (909)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Labours","author":"Public Domain Proverb"},"sequenceIndex":908},{"id":"world-prov-0910","text":"Labour warms, sloth harms.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (910)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Labour","author":"Public Domain Proverb"},"sequenceIndex":909},{"id":"world-prov-0911","text":"The ladle cools the pot.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (911)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ladle","author":"Public Domain Proverb"},"sequenceIndex":910},{"id":"world-prov-0912","text":"Step after step the ladder is ascended.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (912)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ladder","author":"Public Domain Proverb"},"sequenceIndex":911},{"id":"world-prov-0913","text":"A woman's tongue wags like a lamb's tail.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (913)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lamb'S Tail","author":"Public Domain Proverb"},"sequenceIndex":912},{"id":"world-prov-0914","text":"The lame goeth as far as the staggerer.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (914)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lame","author":"Public Domain Proverb"},"sequenceIndex":913},{"id":"world-prov-0915","text":"After Lammas corn ripens as much by night as by day.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (915)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lammas","author":"Public Domain Proverb"},"sequenceIndex":914},{"id":"world-prov-0916","text":"Land was never lost for want of an heir.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (916)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Land","author":"Public Domain Proverb"},"sequenceIndex":915},{"id":"world-prov-0917","text":"Many a one for land, Takes a fool by the hand.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (917)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Land","author":"Public Domain Proverb"},"sequenceIndex":916},{"id":"world-prov-0918","text":"On a dark night an owl would be glad of a lantern.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (918)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lantern","author":"Public Domain Proverb"},"sequenceIndex":917},{"id":"world-prov-0919","text":"It is the last straw that breaks the camel's back.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (919)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Last Straw","author":"Public Domain Proverb"},"sequenceIndex":918},{"id":"world-prov-0920","text":"Better late than never.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (920)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Late","author":"Public Domain Proverb"},"sequenceIndex":919},{"id":"world-prov-0921","text":"Let them laugh that win.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (921)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Laugh","author":"Public Domain Proverb"},"sequenceIndex":920},{"id":"world-prov-0922","text":"That's where the laugh comes in.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (922)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Laugh","author":"Public Domain Proverb"},"sequenceIndex":921},{"id":"world-prov-0923","text":"They laugh the loudest who have least to lose.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (923)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Laugh","author":"Public Domain Proverb"},"sequenceIndex":922},{"id":"world-prov-0924","text":"In a thousand pounds of law there's not an ounce of love.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (924)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Law","author":"Public Domain Proverb"},"sequenceIndex":923},{"id":"world-prov-0925","text":"The law is not the same at morning and night.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (925)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Law","author":"Public Domain Proverb"},"sequenceIndex":924},{"id":"world-prov-0926","text":"He that loves law will get his fill.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (926)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Law","author":"Public Domain Proverb"},"sequenceIndex":925},{"id":"world-prov-0927","text":"Law makers should not be law breakers.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (927)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Law Makers","author":"Public Domain Proverb"},"sequenceIndex":926},{"id":"world-prov-0928","text":"Laws catch flies, but let hornets go free.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (928)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Laws","author":"Public Domain Proverb"},"sequenceIndex":927},{"id":"world-prov-0929","text":"Laws, like spiders' webs, are wrought, Large flies break through, the small are caught.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (929)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Laws","author":"Public Domain Proverb"},"sequenceIndex":928},{"id":"world-prov-0930","text":"Laws were made for rogues.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (930)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Laws","author":"Public Domain Proverb"},"sequenceIndex":929},{"id":"world-prov-0931","text":"A good lawyer, an evil neighbour.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (931)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lawyer","author":"Public Domain Proverb"},"sequenceIndex":930},{"id":"world-prov-0932","text":"Fair and softly as lawyers go to heaven.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (932)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lawyers","author":"Public Domain Proverb"},"sequenceIndex":931},{"id":"world-prov-0933","text":"Lazy folk take the most pains.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (933)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lazy Folk","author":"Public Domain Proverb"},"sequenceIndex":932},{"id":"world-prov-0934","text":"A man may lead a horse to the water, but he cannot make him drink unless he will.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (934)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lead","author":"Public Domain Proverb"},"sequenceIndex":933},{"id":"world-prov-0935","text":"'Tis folly to dig for lead with a silver shovel.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (935)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lead","author":"Public Domain Proverb"},"sequenceIndex":934},{"id":"world-prov-0936","text":"A small leak will sink a great ship.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (936)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Leak","author":"Public Domain Proverb"},"sequenceIndex":935},{"id":"world-prov-0937","text":"Never too old to learn.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (937)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Learn","author":"Public Domain Proverb"},"sequenceIndex":936},{"id":"world-prov-0938","text":"Learning makes a man fit company for himself.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (938)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Learning","author":"Public Domain Proverb"},"sequenceIndex":937},{"id":"world-prov-0939","text":"Least said is soonest mended.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (939)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Least","author":"Public Domain Proverb"},"sequenceIndex":938},{"id":"world-prov-0940","text":"The least boy always carries the greatest fiddle.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (940)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Least Boy","author":"Public Domain Proverb"},"sequenceIndex":939},{"id":"world-prov-0941","text":"Nothing like leather.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (941)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Leather","author":"Public Domain Proverb"},"sequenceIndex":940},{"id":"world-prov-0942","text":"The empty leech sucks sore.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (942)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Leech","author":"Public Domain Proverb"},"sequenceIndex":941},{"id":"world-prov-0943","text":"He that doth not lend doth lose his friend.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (943)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lend","author":"Public Domain Proverb"},"sequenceIndex":942},{"id":"world-prov-0944","text":"He would not lend his knife to the devil to stab himself.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (944)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lend","author":"Public Domain Proverb"},"sequenceIndex":943},{"id":"world-prov-0945","text":"A liar should have a good memory.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (945)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Liar","author":"Public Domain Proverb"},"sequenceIndex":944},{"id":"world-prov-0946","text":"Liars have short wings.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (946)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Liars","author":"Public Domain Proverb"},"sequenceIndex":945},{"id":"world-prov-0947","text":"The greater truth, the greater libel.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (947)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Libel","author":"Public Domain Proverb"},"sequenceIndex":946},{"id":"world-prov-0948","text":"The liberal man deviseth liberal things.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (948)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Liberal","author":"Public Domain Proverb"},"sequenceIndex":947},{"id":"world-prov-0949","text":"Too much liberty spoils all.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (949)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Liberty","author":"Public Domain Proverb"},"sequenceIndex":948},{"id":"world-prov-0950","text":"One lie makes many.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (950)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lie","author":"Public Domain Proverb"},"sequenceIndex":949},{"id":"world-prov-0951","text":"He lies as fast as a dog can trot.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (951)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lies","author":"Public Domain Proverb"},"sequenceIndex":950},{"id":"world-prov-0952","text":"Life is full of hazards, which experience neither bought nor taught will always enable us to foresee.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (952)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Life","author":"Public Domain Proverb"},"sequenceIndex":951},{"id":"world-prov-0953","text":"Life is half spent before we know what it is.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (953)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Life","author":"Public Domain Proverb"},"sequenceIndex":952},{"id":"world-prov-0954","text":"Life is sweet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (954)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Life","author":"Public Domain Proverb"},"sequenceIndex":953},{"id":"world-prov-0955","text":"Life lies not in living, but in liking.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (955)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Life","author":"Public Domain Proverb"},"sequenceIndex":954},{"id":"world-prov-0956","text":"While there's life there's hope.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (956)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Life","author":"Public Domain Proverb"},"sequenceIndex":955},{"id":"world-prov-0957","text":"He stands in his own light.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (957)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Light","author":"Public Domain Proverb"},"sequenceIndex":956},{"id":"world-prov-0958","text":"Every light has its shadow.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (958)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Light","author":"Public Domain Proverb"},"sequenceIndex":957},{"id":"world-prov-0959","text":"Every light is not the sun.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (959)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Light","author":"Public Domain Proverb"},"sequenceIndex":958},{"id":"world-prov-0960","text":"Light gains make a heavy purse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (960)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Light Gains","author":"Public Domain Proverb"},"sequenceIndex":959},{"id":"world-prov-0961","text":"As like as two peas.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (961)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Like","author":"Public Domain Proverb"},"sequenceIndex":960},{"id":"world-prov-0962","text":"Every one as they like best, as the good man said when he kissed his cow.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (962)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Like","author":"Public Domain Proverb"},"sequenceIndex":961},{"id":"world-prov-0963","text":"Like father like son.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (963)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Like","author":"Public Domain Proverb"},"sequenceIndex":962},{"id":"world-prov-0964","text":"Like will to like.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (964)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Like","author":"Public Domain Proverb"},"sequenceIndex":963},{"id":"world-prov-0965","text":"The lion's not half so fierce as he's painted.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (965)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lion","author":"Public Domain Proverb"},"sequenceIndex":964},{"id":"world-prov-0966","text":"Lips however rosy must be fed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (966)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lips","author":"Public Domain Proverb"},"sequenceIndex":965},{"id":"world-prov-0967","text":"Listeners never hear good of themselves.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (967)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Listeners","author":"Public Domain Proverb"},"sequenceIndex":966},{"id":"world-prov-0968","text":"Little and often fills the purse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (968)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Little","author":"Public Domain Proverb"},"sequenceIndex":967},{"id":"world-prov-0969","text":"Little mother, little daughter.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (969)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Little","author":"Public Domain Proverb"},"sequenceIndex":968},{"id":"world-prov-0970","text":"Little birds may peck a dead lion.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (970)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Little Birds","author":"Public Domain Proverb"},"sequenceIndex":969},{"id":"world-prov-0971","text":"Little boats must keep the shore.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (971)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Little Boats","author":"Public Domain Proverb"},"sequenceIndex":970},{"id":"world-prov-0972","text":"Little bodies have large souls.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (972)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Little Bodies","author":"Public Domain Proverb"},"sequenceIndex":971},{"id":"world-prov-0973","text":"A little good is soon spent.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (973)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Little Good","author":"Public Domain Proverb"},"sequenceIndex":972},{"id":"world-prov-0974","text":"Little goods, little care.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (974)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Little Goods","author":"Public Domain Proverb"},"sequenceIndex":973},{"id":"world-prov-0975","text":"One may see day at a little hole.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (975)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Little Hole","author":"Public Domain Proverb"},"sequenceIndex":974},{"id":"world-prov-0976","text":"A little house well fill'd, A little land well till'd, And a little wife well will'd.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (976)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Little House","author":"Public Domain Proverb"},"sequenceIndex":975},{"id":"world-prov-0977","text":"Little minds, like weak liquors, are soon soured.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (977)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Little Minds","author":"Public Domain Proverb"},"sequenceIndex":976},{"id":"world-prov-0978","text":"Little things please little minds.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (978)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Little Things","author":"Public Domain Proverb"},"sequenceIndex":977},{"id":"world-prov-0979","text":"Everything would live.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (979)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Live","author":"Public Domain Proverb"},"sequenceIndex":978},{"id":"world-prov-0980","text":"It's not how long, but how well, we live.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (980)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Live","author":"Public Domain Proverb"},"sequenceIndex":979},{"id":"world-prov-0981","text":"Live and learn.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (981)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Live","author":"Public Domain Proverb"},"sequenceIndex":980},{"id":"world-prov-0982","text":"Live and let live.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (982)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Live","author":"Public Domain Proverb"},"sequenceIndex":981},{"id":"world-prov-0983","text":"The longest liver dies at last.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (983)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Liver (Longest)","author":"Public Domain Proverb"},"sequenceIndex":982},{"id":"world-prov-0984","text":"He that lives not well one year sorrows for it seven.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (984)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lives","author":"Public Domain Proverb"},"sequenceIndex":983},{"id":"world-prov-0985","text":"He liveth long that liveth well.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (985)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Liveth","author":"Public Domain Proverb"},"sequenceIndex":984},{"id":"world-prov-0986","text":"A living dog is better than a dead lion.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (986)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Living Dog","author":"Public Domain Proverb"},"sequenceIndex":985},{"id":"world-prov-0987","text":"All lay load on the willing horse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (987)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Load","author":"Public Domain Proverb"},"sequenceIndex":986},{"id":"world-prov-0988","text":"You needn't lock the stable door when the steed is stolen.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (988)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lock","author":"Public Domain Proverb"},"sequenceIndex":987},{"id":"world-prov-0989","text":"Look before you leap.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (989)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Look","author":"Public Domain Proverb"},"sequenceIndex":988},{"id":"world-prov-0990","text":"They look one way and row another.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (990)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Look","author":"Public Domain Proverb"},"sequenceIndex":989},{"id":"world-prov-0991","text":"Long looked for comes at last.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (991)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Looked For","author":"Public Domain Proverb"},"sequenceIndex":990},{"id":"world-prov-0992","text":"'Tis a long lane that has no turning.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (992)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Long Lane","author":"Public Domain Proverb"},"sequenceIndex":991},{"id":"world-prov-0993","text":"He that longs most lacks most.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (993)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Longs","author":"Public Domain Proverb"},"sequenceIndex":992},{"id":"world-prov-0994","text":"The longest day must have an end.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (994)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Longest Day","author":"Public Domain Proverb"},"sequenceIndex":993},{"id":"world-prov-0995","text":"The loquacity of fools is a warning to the wise.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (995)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Loquacity","author":"Public Domain Proverb"},"sequenceIndex":994},{"id":"world-prov-0996","text":"New lords new laws.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (996)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lords","author":"Public Domain Proverb"},"sequenceIndex":995},{"id":"world-prov-0997","text":"Losers are always in the wrong.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (997)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Losers","author":"Public Domain Proverb"},"sequenceIndex":996},{"id":"world-prov-0998","text":"He that goeth out with often loss, At last comes home by Weeping Cross.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (998)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Loss","author":"Public Domain Proverb"},"sequenceIndex":997},{"id":"world-prov-0999","text":"'Tis not lost that comes at last.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (999)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lost","author":"Public Domain Proverb"},"sequenceIndex":998},{"id":"world-prov-1000","text":"Love is no lack.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1000)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Love","author":"Public Domain Proverb"},"sequenceIndex":999},{"id":"world-prov-1001","text":"Love is blind.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1001)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Love","author":"Public Domain Proverb"},"sequenceIndex":1000},{"id":"world-prov-1002","text":"Love is the touchstone of virtue.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1002)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Love","author":"Public Domain Proverb"},"sequenceIndex":1001},{"id":"world-prov-1003","text":"Love lives in cottages as well as in courts.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1003)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Love","author":"Public Domain Proverb"},"sequenceIndex":1002},{"id":"world-prov-1004","text":"Love me little, love me long.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1004)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Love","author":"Public Domain Proverb"},"sequenceIndex":1003},{"id":"world-prov-1005","text":"Love me, love my dog.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1005)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Love","author":"Public Domain Proverb"},"sequenceIndex":1004},{"id":"world-prov-1006","text":"They love too much who die for love.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1006)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Love","author":"Public Domain Proverb"},"sequenceIndex":1005},{"id":"world-prov-1007","text":"Whom we love best to them we can say least.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1007)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Love","author":"Public Domain Proverb"},"sequenceIndex":1006},{"id":"world-prov-1008","text":"Love and a cough cannot be hid.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1008)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Love And A Cough","author":"Public Domain Proverb"},"sequenceIndex":1007},{"id":"world-prov-1009","text":"Hot love is soon cold.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1009)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Love (Hot)","author":"Public Domain Proverb"},"sequenceIndex":1008},{"id":"world-prov-1010","text":"Lovers live on love, as larks on leeks.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1010)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lovers","author":"Public Domain Proverb"},"sequenceIndex":1009},{"id":"world-prov-1011","text":"Lowly sit and be richly warm.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1011)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lowly Sit","author":"Public Domain Proverb"},"sequenceIndex":1010},{"id":"world-prov-1012","text":"Give a man luck, and throw him into the sea.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1012)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Luck","author":"Public Domain Proverb"},"sequenceIndex":1011},{"id":"world-prov-1013","text":"The devil's children have the devil's luck.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1013)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Luck","author":"Public Domain Proverb"},"sequenceIndex":1012},{"id":"world-prov-1014","text":"What is worse than ill-luck?","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1014)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Luck (Ill)","author":"Public Domain Proverb"},"sequenceIndex":1013},{"id":"world-prov-1015","text":"It is better to be born lucky than rich.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1015)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lucky","author":"Public Domain Proverb"},"sequenceIndex":1014},{"id":"world-prov-1016","text":"It's better to be lucky than wise.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1016)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lucky","author":"Public Domain Proverb"},"sequenceIndex":1015},{"id":"world-prov-1017","text":"Happy go lucky.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1017)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lucky","author":"Public Domain Proverb"},"sequenceIndex":1016},{"id":"world-prov-1018","text":"Never leave a friend in the lurch. M","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1018)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Lurch","author":"Public Domain Proverb"},"sequenceIndex":1017},{"id":"world-prov-1019","text":"Maidens must be seen and not heard.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1019)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Maidens","author":"Public Domain Proverb"},"sequenceIndex":1018},{"id":"world-prov-1020","text":"Malice is mindful.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1020)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Malice","author":"Public Domain Proverb"},"sequenceIndex":1019},{"id":"world-prov-1021","text":"Slow fire makes sweet malt.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1021)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Malt","author":"Public Domain Proverb"},"sequenceIndex":1020},{"id":"world-prov-1022","text":"A man at five may be a fool at fifteen.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1022)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Man","author":"Public Domain Proverb"},"sequenceIndex":1021},{"id":"world-prov-1023","text":"Man proposes, God disposes.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1023)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Man","author":"Public Domain Proverb"},"sequenceIndex":1022},{"id":"world-prov-1024","text":"Man doth what he can, and God what He will.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1024)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Man","author":"Public Domain Proverb"},"sequenceIndex":1023},{"id":"world-prov-1025","text":"Manners often make fortunes.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1025)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Manners","author":"Public Domain Proverb"},"sequenceIndex":1024},{"id":"world-prov-1026","text":"Many hands make light work.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1026)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Many Hands","author":"Public Domain Proverb"},"sequenceIndex":1025},{"id":"world-prov-1027","text":"March wind and May sun, Make clothes white and maids dun.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1027)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"March","author":"Public Domain Proverb"},"sequenceIndex":1026},{"id":"world-prov-1028","text":"March many weathers.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1028)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"March","author":"Public Domain Proverb"},"sequenceIndex":1027},{"id":"world-prov-1029","text":"A bushel of March dust is worth a king's ransom.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1029)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"March Dust","author":"Public Domain Proverb"},"sequenceIndex":1028},{"id":"world-prov-1030","text":"A man must sell his ware at the rate of the market.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1030)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Market","author":"Public Domain Proverb"},"sequenceIndex":1029},{"id":"world-prov-1031","text":"Forsake not the market for the toll.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1031)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Market","author":"Public Domain Proverb"},"sequenceIndex":1030},{"id":"world-prov-1032","text":"If fools went not to market, bad ware would not be sold.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1032)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Market","author":"Public Domain Proverb"},"sequenceIndex":1031},{"id":"world-prov-1033","text":"Three women and a goose make a market.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1033)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Market","author":"Public Domain Proverb"},"sequenceIndex":1032},{"id":"world-prov-1034","text":"An ill marriage is a spring of ill fortune.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1034)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Marriage (Ill)","author":"Public Domain Proverb"},"sequenceIndex":1033},{"id":"world-prov-1035","text":"Marriage halves our griefs, and doubles our joys.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1035)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Marriage","author":"Public Domain Proverb"},"sequenceIndex":1034},{"id":"world-prov-1036","text":"Marriages are made in heaven.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1036)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Marriages","author":"Public Domain Proverb"},"sequenceIndex":1035},{"id":"world-prov-1037","text":"He who marries for wealth sells his liberty.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1037)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Marries","author":"Public Domain Proverb"},"sequenceIndex":1036},{"id":"world-prov-1038","text":"Marry in haste, repent at leisure.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1038)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Marry","author":"Public Domain Proverb"},"sequenceIndex":1037},{"id":"world-prov-1039","text":"Bachelors, before you marry, Have a house wherein to tarry.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1039)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Marry","author":"Public Domain Proverb"},"sequenceIndex":1038},{"id":"world-prov-1040","text":"If you regard old saws, mind, thus they say, 'Tis bad to marry in the month of May.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1040)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Marry","author":"Public Domain Proverb"},"sequenceIndex":1039},{"id":"world-prov-1041","text":"Like master like man.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1041)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Master","author":"Public Domain Proverb"},"sequenceIndex":1040},{"id":"world-prov-1042","text":"He that will too soon be his own master, will have a fool for his scholar.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1042)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Master","author":"Public Domain Proverb"},"sequenceIndex":1041},{"id":"world-prov-1043","text":"No man is his craft's master the first day.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1043)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Master","author":"Public Domain Proverb"},"sequenceIndex":1042},{"id":"world-prov-1044","text":"Marry above your match and you get a master.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1044)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Master","author":"Public Domain Proverb"},"sequenceIndex":1043},{"id":"world-prov-1045","text":"One eye of the master sees more than four of the servants'.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1045)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Master","author":"Public Domain Proverb"},"sequenceIndex":1044},{"id":"world-prov-1046","text":"Of all the crafts honesty is the master-craft.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1046)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Master-Craft","author":"Public Domain Proverb"},"sequenceIndex":1045},{"id":"world-prov-1047","text":"No man can serve two masters.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1047)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Masters","author":"Public Domain Proverb"},"sequenceIndex":1046},{"id":"world-prov-1048","text":"The master's eye makes the horse fat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1048)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Master'S Eye","author":"Public Domain Proverb"},"sequenceIndex":1047},{"id":"world-prov-1049","text":"The master's eye does more work than his hands.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1049)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Master'S Eye","author":"Public Domain Proverb"},"sequenceIndex":1048},{"id":"world-prov-1050","text":"Matrimony's a matter of money.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1050)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Matrimony","author":"Public Domain Proverb"},"sequenceIndex":1049},{"id":"world-prov-1051","text":"Every \"may be\" hath a \"may not be.\"","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1051)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"May Be","author":"Public Domain Proverb"},"sequenceIndex":1050},{"id":"world-prov-1052","text":"A windy March and a rainy April make a beautiful May.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1052)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"May","author":"Public Domain Proverb"},"sequenceIndex":1051},{"id":"world-prov-1053","text":"A cold May, Plenty of corn and hay.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1053)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"May (Cold)","author":"Public Domain Proverb"},"sequenceIndex":1052},{"id":"world-prov-1054","text":"A thin meadow is soon mowed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1054)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Meadow","author":"Public Domain Proverb"},"sequenceIndex":1053},{"id":"world-prov-1055","text":"Good measure is a merry mean.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1055)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Measure","author":"Public Domain Proverb"},"sequenceIndex":1054},{"id":"world-prov-1056","text":"With what measure ye mete it shall be measured to you again.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1056)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Measure","author":"Public Domain Proverb"},"sequenceIndex":1055},{"id":"world-prov-1057","text":"Measure twice before you cut once.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1057)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Measure","author":"Public Domain Proverb"},"sequenceIndex":1056},{"id":"world-prov-1058","text":"He measures your corn by his bushel.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1058)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Measures","author":"Public Domain Proverb"},"sequenceIndex":1057},{"id":"world-prov-1059","text":"Much meat, much maladies.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1059)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Meat","author":"Public Domain Proverb"},"sequenceIndex":1058},{"id":"world-prov-1060","text":"Meat is much, but manners is more.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1060)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Meat","author":"Public Domain Proverb"},"sequenceIndex":1059},{"id":"world-prov-1061","text":"There's a medium between painting the face and not washing it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1061)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Medium","author":"Public Domain Proverb"},"sequenceIndex":1060},{"id":"world-prov-1062","text":"Medlars are never good till they be rotten.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1062)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Medlars","author":"Public Domain Proverb"},"sequenceIndex":1061},{"id":"world-prov-1063","text":"Time and straw make medlars ripe.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1063)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Medlars","author":"Public Domain Proverb"},"sequenceIndex":1062},{"id":"world-prov-1064","text":"It is never too late to mend.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1064)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mend","author":"Public Domain Proverb"},"sequenceIndex":1063},{"id":"world-prov-1065","text":"If every one would mend one, all would be mended.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1065)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mend","author":"Public Domain Proverb"},"sequenceIndex":1064},{"id":"world-prov-1066","text":"In the end things will mend.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1066)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mend","author":"Public Domain Proverb"},"sequenceIndex":1065},{"id":"world-prov-1067","text":"Cry you mercy, who killed my cat?","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1067)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mercy","author":"Public Domain Proverb"},"sequenceIndex":1066},{"id":"world-prov-1068","text":"He that is of a merry heart hath a continual feast.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1068)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Merry","author":"Public Domain Proverb"},"sequenceIndex":1067},{"id":"world-prov-1069","text":"It's good to be merry and wise.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1069)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Merry","author":"Public Domain Proverb"},"sequenceIndex":1068},{"id":"world-prov-1070","text":"It is good to be merry at meat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1070)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Merry","author":"Public Domain Proverb"},"sequenceIndex":1069},{"id":"world-prov-1071","text":"Merry meet, merry part, merry meet again.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1071)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Merry","author":"Public Domain Proverb"},"sequenceIndex":1070},{"id":"world-prov-1072","text":"As long lives a merry heart as a sad.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1072)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Merry","author":"Public Domain Proverb"},"sequenceIndex":1071},{"id":"world-prov-1073","text":"The merry month of May.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1073)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Merry Month","author":"Public Domain Proverb"},"sequenceIndex":1072},{"id":"world-prov-1074","text":"Mettle is dangerous in a blind horse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1074)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mettle","author":"Public Domain Proverb"},"sequenceIndex":1073},{"id":"world-prov-1075","text":"Milk which will not be made into butter must be made into cheese.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1075)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Milk","author":"Public Domain Proverb"},"sequenceIndex":1074},{"id":"world-prov-1076","text":"Who would keep a cow when he may have a bottle of milk for a penny!","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1076)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Milk","author":"Public Domain Proverb"},"sequenceIndex":1075},{"id":"world-prov-1077","text":"No mill, no meal.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1077)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mill","author":"Public Domain Proverb"},"sequenceIndex":1076},{"id":"world-prov-1078","text":"I can see as far into a millstone as the picker.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1078)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Millstone","author":"Public Domain Proverb"},"sequenceIndex":1077},{"id":"world-prov-1079","text":"The lower millstone grinds as well as the upper.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1079)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Millstone","author":"Public Domain Proverb"},"sequenceIndex":1078},{"id":"world-prov-1080","text":"Out of sight, out of mind.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1080)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mind","author":"Public Domain Proverb"},"sequenceIndex":1079},{"id":"world-prov-1081","text":"In the forehead and the eye, The picture of the mind doth lie.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1081)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mind","author":"Public Domain Proverb"},"sequenceIndex":1080},{"id":"world-prov-1082","text":"A woman's mind and winter wind often change.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1082)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mind","author":"Public Domain Proverb"},"sequenceIndex":1081},{"id":"world-prov-1083","text":"A wise man changes his mind; a fool never.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1083)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mind","author":"Public Domain Proverb"},"sequenceIndex":1082},{"id":"world-prov-1084","text":"A pennyworth of mirth is worth a pound of sorrow.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1084)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mirth","author":"Public Domain Proverb"},"sequenceIndex":1083},{"id":"world-prov-1085","text":"A little mischief is too much.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1085)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mischief","author":"Public Domain Proverb"},"sequenceIndex":1084},{"id":"world-prov-1086","text":"Mischiefs come by the pound and go away by the ounce.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1086)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mischiefs","author":"Public Domain Proverb"},"sequenceIndex":1085},{"id":"world-prov-1087","text":"Misfortunes seldom come alone.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1087)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Misfortunes","author":"Public Domain Proverb"},"sequenceIndex":1086},{"id":"world-prov-1088","text":"A miss is as good as a mile.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1088)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Miss","author":"Public Domain Proverb"},"sequenceIndex":1087},{"id":"world-prov-1089","text":"So many mists in March you see, So many frosts in May will be.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1089)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mists","author":"Public Domain Proverb"},"sequenceIndex":1088},{"id":"world-prov-1090","text":"Misunderstanding brings lies to town.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1090)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Misunderstanding","author":"Public Domain Proverb"},"sequenceIndex":1089},{"id":"world-prov-1091","text":"The mob has many heads, but no brains.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1091)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mob","author":"Public Domain Proverb"},"sequenceIndex":1090},{"id":"world-prov-1092","text":"Mocking is catching.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1092)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mocking","author":"Public Domain Proverb"},"sequenceIndex":1091},{"id":"world-prov-1093","text":"Modesty is the handmaid of virtue.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1093)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Modesty","author":"Public Domain Proverb"},"sequenceIndex":1092},{"id":"world-prov-1094","text":"Monday for wealth, Tuesday for health, Wednesday the best day of all; Thursday for crosses, Friday for losses, Saturday no luck at all.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1094)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Monday","author":"Public Domain Proverb"},"sequenceIndex":1093},{"id":"world-prov-1095","text":"Money is more easily made than made use of.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1095)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Money","author":"Public Domain Proverb"},"sequenceIndex":1094},{"id":"world-prov-1096","text":"They who have money are troubled about it, And they who have none are troubled without it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1096)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Money","author":"Public Domain Proverb"},"sequenceIndex":1095},{"id":"world-prov-1097","text":"Money makes money.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1097)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Money","author":"Public Domain Proverb"},"sequenceIndex":1096},{"id":"world-prov-1098","text":"Money often makes the man.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1098)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Money","author":"Public Domain Proverb"},"sequenceIndex":1097},{"id":"world-prov-1099","text":"The abundance of money ruins youth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1099)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Money","author":"Public Domain Proverb"},"sequenceIndex":1098},{"id":"world-prov-1100","text":"A fool and his money are soon parted.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1100)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Money","author":"Public Domain Proverb"},"sequenceIndex":1099},{"id":"world-prov-1101","text":"A fool may make money, but a wise man should spend it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1101)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Money","author":"Public Domain Proverb"},"sequenceIndex":1100},{"id":"world-prov-1102","text":"'Tis money makes the mare to go.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1102)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Money","author":"Public Domain Proverb"},"sequenceIndex":1101},{"id":"world-prov-1103","text":"He that hath no money needeth no purse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1103)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Money","author":"Public Domain Proverb"},"sequenceIndex":1102},{"id":"world-prov-1104","text":"In the old of the moon, A cloudy morning bodes a fair afternoon.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1104)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Moon","author":"Public Domain Proverb"},"sequenceIndex":1103},{"id":"world-prov-1105","text":"A Saturday's moon Always comes too soon.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1105)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Moon","author":"Public Domain Proverb"},"sequenceIndex":1104},{"id":"world-prov-1106","text":"The moon's not seen where the sun shines.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1106)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Moon","author":"Public Domain Proverb"},"sequenceIndex":1105},{"id":"world-prov-1107","text":"The more the merrier; the fewer the better cheer.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1107)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"More","author":"Public Domain Proverb"},"sequenceIndex":1106},{"id":"world-prov-1108","text":"Lose an hour in the morning, and you'll be all day hunting for it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1108)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Morning","author":"Public Domain Proverb"},"sequenceIndex":1107},{"id":"world-prov-1109","text":"The morning sun never lasts a day.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1109)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Morning Sun","author":"Public Domain Proverb"},"sequenceIndex":1108},{"id":"world-prov-1110","text":"Do as most do, and fewest will speak ill of thee.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1110)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Most","author":"Public Domain Proverb"},"sequenceIndex":1109},{"id":"world-prov-1111","text":"Most take all.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1111)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Most","author":"Public Domain Proverb"},"sequenceIndex":1110},{"id":"world-prov-1112","text":"The mother's breath is always sweet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1112)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mother'S Breath","author":"Public Domain Proverb"},"sequenceIndex":1111},{"id":"world-prov-1113","text":"A mother's heart never grows old.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1113)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mother'S Heart","author":"Public Domain Proverb"},"sequenceIndex":1112},{"id":"world-prov-1114","text":"An ounce of mother-wit is worth a pound of clergy.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1114)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mother-Wit","author":"Public Domain Proverb"},"sequenceIndex":1113},{"id":"world-prov-1115","text":"Never make a mountain of a mole-hill.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1115)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mountain","author":"Public Domain Proverb"},"sequenceIndex":1114},{"id":"world-prov-1116","text":"If the mountain will not go to Mahomet, let Mahomet go to the mountain.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1116)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mountain","author":"Public Domain Proverb"},"sequenceIndex":1115},{"id":"world-prov-1117","text":"Mouth civility costs little but is worth less.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1117)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mouth Civility","author":"Public Domain Proverb"},"sequenceIndex":1116},{"id":"world-prov-1118","text":"He that sends mouths sends meat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1118)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mouths","author":"Public Domain Proverb"},"sequenceIndex":1117},{"id":"world-prov-1119","text":"A fool demands much, but he's a greater that gives it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1119)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Much","author":"Public Domain Proverb"},"sequenceIndex":1118},{"id":"world-prov-1120","text":"Much is expected where much is given.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1120)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Much","author":"Public Domain Proverb"},"sequenceIndex":1119},{"id":"world-prov-1121","text":"Much would have more, and lost all.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1121)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Much","author":"Public Domain Proverb"},"sequenceIndex":1120},{"id":"world-prov-1122","text":"Muddles at home make husbands roam.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1122)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Muddles","author":"Public Domain Proverb"},"sequenceIndex":1121},{"id":"world-prov-1123","text":"Muffled cats are bad mousers.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1123)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Muffled Cats","author":"Public Domain Proverb"},"sequenceIndex":1122},{"id":"world-prov-1124","text":"Murder will out.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1124)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Murder","author":"Public Domain Proverb"},"sequenceIndex":1123},{"id":"world-prov-1125","text":"Music helps not the toothache.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1125)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Music","author":"Public Domain Proverb"},"sequenceIndex":1124},{"id":"world-prov-1126","text":"Where music is no harm can be.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1126)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Music","author":"Public Domain Proverb"},"sequenceIndex":1125},{"id":"world-prov-1127","text":"When a musician hath forgot his note, he makes as though a crumb stuck in his throat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1127)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Musician","author":"Public Domain Proverb"},"sequenceIndex":1126},{"id":"world-prov-1128","text":"It's no use looking for musk in a dog's kennel.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1128)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Musk","author":"Public Domain Proverb"},"sequenceIndex":1127},{"id":"world-prov-1129","text":"They are as mute as fishes. N","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1129)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Mute","author":"Public Domain Proverb"},"sequenceIndex":1128},{"id":"world-prov-1130","text":"A good name is better than riches.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1130)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Name","author":"Public Domain Proverb"},"sequenceIndex":1129},{"id":"world-prov-1131","text":"A good name keeps its lustre in the dark.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1131)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Name","author":"Public Domain Proverb"},"sequenceIndex":1130},{"id":"world-prov-1132","text":"Take away my good name, and take away my life.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1132)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Name","author":"Public Domain Proverb"},"sequenceIndex":1131},{"id":"world-prov-1133","text":"'Tis the nature of the beast.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1133)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Nature","author":"Public Domain Proverb"},"sequenceIndex":1132},{"id":"world-prov-1134","text":"Necessity knows no law.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1134)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Necessity","author":"Public Domain Proverb"},"sequenceIndex":1133},{"id":"world-prov-1135","text":"Make a virtue of necessity.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1135)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Necessity","author":"Public Domain Proverb"},"sequenceIndex":1134},{"id":"world-prov-1136","text":"Necessity is the mother of invention.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1136)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Necessity","author":"Public Domain Proverb"},"sequenceIndex":1135},{"id":"world-prov-1137","text":"Need makes the old wife trot.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1137)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Need","author":"Public Domain Proverb"},"sequenceIndex":1136},{"id":"world-prov-1138","text":"A friend in need is a friend indeed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1138)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Need","author":"Public Domain Proverb"},"sequenceIndex":1137},{"id":"world-prov-1139","text":"To look for a needle in a pottle of hay.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1139)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Needle","author":"Public Domain Proverb"},"sequenceIndex":1138},{"id":"world-prov-1140","text":"He that's needy when he is married Shall be rich when he is buried.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1140)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Needy","author":"Public Domain Proverb"},"sequenceIndex":1139},{"id":"world-prov-1141","text":"Love thy neighbour, but pull not down thy hedge.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1141)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Neighbour","author":"Public Domain Proverb"},"sequenceIndex":1140},{"id":"world-prov-1142","text":"Neighbour-quart is good quart.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1142)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Neighbour-Quart","author":"Public Domain Proverb"},"sequenceIndex":1141},{"id":"world-prov-1143","text":"You must ask your neighbour if you shall live in peace.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1143)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Neighbour","author":"Public Domain Proverb"},"sequenceIndex":1142},{"id":"world-prov-1144","text":"When thy neighbour's house is on fire, be careful of thine own.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1144)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Neighbour'S House","author":"Public Domain Proverb"},"sequenceIndex":1143},{"id":"world-prov-1145","text":"All is fish that comes to his net.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1145)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Net","author":"Public Domain Proverb"},"sequenceIndex":1144},{"id":"world-prov-1146","text":"Be not the first by whom the new is tried, Be not the last to cast the old aside.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1146)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"New","author":"Public Domain Proverb"},"sequenceIndex":1145},{"id":"world-prov-1147","text":"A new broom sweeps clean.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1147)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"New Broom","author":"Public Domain Proverb"},"sequenceIndex":1146},{"id":"world-prov-1148","text":"No news is good news.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1148)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"News","author":"Public Domain Proverb"},"sequenceIndex":1147},{"id":"world-prov-1149","text":"A nimble ninepence is better than a slow shilling.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1149)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Nimble","author":"Public Domain Proverb"},"sequenceIndex":1148},{"id":"world-prov-1150","text":"Nip it in the bud.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1150)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Nip","author":"Public Domain Proverb"},"sequenceIndex":1149},{"id":"world-prov-1151","text":"The more noble the more humble.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1151)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Noble","author":"Public Domain Proverb"},"sequenceIndex":1150},{"id":"world-prov-1152","text":"The great Homer himself sometimes nods.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1152)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Nods","author":"Public Domain Proverb"},"sequenceIndex":1151},{"id":"world-prov-1153","text":"A little nonsense now and then Is relished by the wisest men.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1153)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Nonsense","author":"Public Domain Proverb"},"sequenceIndex":1152},{"id":"world-prov-1154","text":"It is the part of a wise man to take no notice of many things.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1154)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Notice","author":"Public Domain Proverb"},"sequenceIndex":1153},{"id":"world-prov-1155","text":"By doing nothing we learn to do ill.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1155)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Nothing","author":"Public Domain Proverb"},"sequenceIndex":1154},{"id":"world-prov-1156","text":"Of nothing comes nothing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1156)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Nothing","author":"Public Domain Proverb"},"sequenceIndex":1155},{"id":"world-prov-1157","text":"Doing nothing is the hardest work.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1157)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Nothing","author":"Public Domain Proverb"},"sequenceIndex":1156},{"id":"world-prov-1158","text":"Nothing came out of the sack but what was in it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1158)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Nothing","author":"Public Domain Proverb"},"sequenceIndex":1157},{"id":"world-prov-1159","text":"It is more painful to do nothing than something.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1159)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Nothing","author":"Public Domain Proverb"},"sequenceIndex":1158},{"id":"world-prov-1160","text":"Doing nothing is doing ill.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1160)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Nothing","author":"Public Domain Proverb"},"sequenceIndex":1159},{"id":"world-prov-1161","text":"November take flail, Let ships no more sail.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1161)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"November","author":"Public Domain Proverb"},"sequenceIndex":1160},{"id":"world-prov-1162","text":"Now or never.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1162)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Now","author":"Public Domain Proverb"},"sequenceIndex":1161},{"id":"world-prov-1163","text":"The nurse's tongue is privileged to talk.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1163)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Nurse","author":"Public Domain Proverb"},"sequenceIndex":1162},{"id":"world-prov-1164","text":"You may as well bid me lade the sea with a nutshell. O","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1164)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Nutshell","author":"Public Domain Proverb"},"sequenceIndex":1163},{"id":"world-prov-1165","text":"An oak is not felled by one blow.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1165)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Oak","author":"Public Domain Proverb"},"sequenceIndex":1164},{"id":"world-prov-1166","text":"An occasion lost cannot be redeemed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1166)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Occasion","author":"Public Domain Proverb"},"sequenceIndex":1165},{"id":"world-prov-1167","text":"Good October, a good blast, To blow the hog acorn and mast.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1167)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"October","author":"Public Domain Proverb"},"sequenceIndex":1166},{"id":"world-prov-1168","text":"Never refuse a good offer.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1168)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Offer","author":"Public Domain Proverb"},"sequenceIndex":1167},{"id":"world-prov-1169","text":"The offender never pardons.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1169)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Offender","author":"Public Domain Proverb"},"sequenceIndex":1168},{"id":"world-prov-1170","text":"Little and often fills the purse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1170)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Often","author":"Public Domain Proverb"},"sequenceIndex":1169},{"id":"world-prov-1171","text":"When old age is evil, youth can learn no good.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1171)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Old Age","author":"Public Domain Proverb"},"sequenceIndex":1170},{"id":"world-prov-1172","text":"Old young, old long.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1172)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Old","author":"Public Domain Proverb"},"sequenceIndex":1171},{"id":"world-prov-1173","text":"An old cat laps as much as a young kitten.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1173)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Old Cat","author":"Public Domain Proverb"},"sequenceIndex":1172},{"id":"world-prov-1174","text":"As the old cock crows so crows the young.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1174)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Old Cock","author":"Public Domain Proverb"},"sequenceIndex":1173},{"id":"world-prov-1175","text":"An old dog barks not in vain.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1175)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Old Dog","author":"Public Domain Proverb"},"sequenceIndex":1174},{"id":"world-prov-1176","text":"An old dog will learn no tricks.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1176)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Old Dog","author":"Public Domain Proverb"},"sequenceIndex":1175},{"id":"world-prov-1177","text":"Older and wiser.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1177)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Older","author":"Public Domain Proverb"},"sequenceIndex":1176},{"id":"world-prov-1178","text":"Old fools are the worst of fools.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1178)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Old Fools","author":"Public Domain Proverb"},"sequenceIndex":1177},{"id":"world-prov-1179","text":"Old foxes need no tutors.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1179)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Old Foxes","author":"Public Domain Proverb"},"sequenceIndex":1178},{"id":"world-prov-1180","text":"Old friends to meet, old wine to drink, and old wood to burn.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1180)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Old Friends","author":"Public Domain Proverb"},"sequenceIndex":1179},{"id":"world-prov-1181","text":"Old friends and old wine are best.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1181)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Old Friends","author":"Public Domain Proverb"},"sequenceIndex":1180},{"id":"world-prov-1182","text":"Old men are twice children.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1182)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Old Men","author":"Public Domain Proverb"},"sequenceIndex":1181},{"id":"world-prov-1183","text":"An old sack wanteth much patching.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1183)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Old Sack","author":"Public Domain Proverb"},"sequenceIndex":1182},{"id":"world-prov-1184","text":"Old saws speak the truth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1184)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Old Saws","author":"Public Domain Proverb"},"sequenceIndex":1183},{"id":"world-prov-1185","text":"It's ill healing an old sore.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1185)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Old Sore","author":"Public Domain Proverb"},"sequenceIndex":1184},{"id":"world-prov-1186","text":"You can't make omelettes without breaking eggs.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1186)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Omelettes","author":"Public Domain Proverb"},"sequenceIndex":1185},{"id":"world-prov-1187","text":"Once well done is twice done.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1187)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Once","author":"Public Domain Proverb"},"sequenceIndex":1186},{"id":"world-prov-1188","text":"Make much of one, good men are scarce.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1188)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"One","author":"Public Domain Proverb"},"sequenceIndex":1187},{"id":"world-prov-1189","text":"One hand will not clasp.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1189)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"One Hand","author":"Public Domain Proverb"},"sequenceIndex":1188},{"id":"world-prov-1190","text":"The mouse that hath but one hole is easily taken.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1190)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"One Hole","author":"Public Domain Proverb"},"sequenceIndex":1189},{"id":"world-prov-1191","text":"Too much of one thing is good for nothing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1191)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"One Thing","author":"Public Domain Proverb"},"sequenceIndex":1190},{"id":"world-prov-1192","text":"Opportunity makes the thief.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1192)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Opportunity","author":"Public Domain Proverb"},"sequenceIndex":1191},{"id":"world-prov-1193","text":"Opportunity lingers sometimes.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1193)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Opportunity","author":"Public Domain Proverb"},"sequenceIndex":1192},{"id":"world-prov-1194","text":"Oppression causeth rebellion.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1194)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Oppression","author":"Public Domain Proverb"},"sequenceIndex":1193},{"id":"world-prov-1195","text":"In an orderly house all is soon ready.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1195)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Orderly","author":"Public Domain Proverb"},"sequenceIndex":1194},{"id":"world-prov-1196","text":"Evening orts are good morning fodder.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1196)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Orts","author":"Public Domain Proverb"},"sequenceIndex":1195},{"id":"world-prov-1197","text":"Some are wise, and some are otherwise.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1197)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Otherwise","author":"Public Domain Proverb"},"sequenceIndex":1196},{"id":"world-prov-1198","text":"Do what thou ought, let come what may.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1198)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ought","author":"Public Domain Proverb"},"sequenceIndex":1197},{"id":"world-prov-1199","text":"Be not too hasty to outbid another.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1199)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Outbid","author":"Public Domain Proverb"},"sequenceIndex":1198},{"id":"world-prov-1200","text":"Over boots, over shoes.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1200)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Over","author":"Public Domain Proverb"},"sequenceIndex":1199},{"id":"world-prov-1201","text":"None is so wise but the fool overtakes him sometimes.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1201)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Overtakes","author":"Public Domain Proverb"},"sequenceIndex":1200},{"id":"world-prov-1202","text":"Oysters are not good in the month that hath not an R in it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1202)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Oysters","author":"Public Domain Proverb"},"sequenceIndex":1201},{"id":"world-prov-1203","text":"A man may cause his own dog to bite him. P","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1203)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Own Dog","author":"Public Domain Proverb"},"sequenceIndex":1202},{"id":"world-prov-1204","text":"Pain is forgotten where gain follows.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1204)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pain","author":"Public Domain Proverb"},"sequenceIndex":1203},{"id":"world-prov-1205","text":"Great pain and little gain make a man soon weary.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1205)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pain","author":"Public Domain Proverb"},"sequenceIndex":1204},{"id":"world-prov-1206","text":"No pains, no profit.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1206)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pains","author":"Public Domain Proverb"},"sequenceIndex":1205},{"id":"world-prov-1207","text":"Pains are the wages of ill-pleasures.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1207)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pains","author":"Public Domain Proverb"},"sequenceIndex":1206},{"id":"world-prov-1208","text":"On painting and fighting look aloof off.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1208)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Painting","author":"Public Domain Proverb"},"sequenceIndex":1207},{"id":"world-prov-1209","text":"Pardon all men, but never thyself.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1209)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pardon","author":"Public Domain Proverb"},"sequenceIndex":1208},{"id":"world-prov-1210","text":"Study to be worthy of your parents.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1210)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Parents","author":"Public Domain Proverb"},"sequenceIndex":1209},{"id":"world-prov-1211","text":"If the partridge had the woodcock's thigh, It would be the best bird that ever did fly.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1211)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Partridge","author":"Public Domain Proverb"},"sequenceIndex":1210},{"id":"world-prov-1212","text":"A man in a passion rides a horse that runs away with him.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1212)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Passion","author":"Public Domain Proverb"},"sequenceIndex":1211},{"id":"world-prov-1213","text":"Patch and sit long, build and soon flit.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1213)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Patch","author":"Public Domain Proverb"},"sequenceIndex":1212},{"id":"world-prov-1214","text":"Patience is a flower that grows not in every one's garden.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1214)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Patience","author":"Public Domain Proverb"},"sequenceIndex":1213},{"id":"world-prov-1215","text":"Patience is a plaister for all sores.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1215)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Patience","author":"Public Domain Proverb"},"sequenceIndex":1214},{"id":"world-prov-1216","text":"As patient as Job.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1216)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Patient","author":"Public Domain Proverb"},"sequenceIndex":1215},{"id":"world-prov-1217","text":"Pay him in his own coin.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1217)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pay","author":"Public Domain Proverb"},"sequenceIndex":1216},{"id":"world-prov-1218","text":"Pay as you go.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1218)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pay","author":"Public Domain Proverb"},"sequenceIndex":1217},{"id":"world-prov-1219","text":"He that pays last never pays twice.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1219)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pays Last","author":"Public Domain Proverb"},"sequenceIndex":1218},{"id":"world-prov-1220","text":"They who don't intend to pay, Will promise payment any day.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1220)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Payment","author":"Public Domain Proverb"},"sequenceIndex":1219},{"id":"world-prov-1221","text":"Cast not pearls before swine.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1221)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pearls","author":"Public Domain Proverb"},"sequenceIndex":1220},{"id":"world-prov-1222","text":"He who hath most peas may put most in the pot.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1222)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Peas","author":"Public Domain Proverb"},"sequenceIndex":1221},{"id":"world-prov-1223","text":"A small pack suits a small pedlar.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1223)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pedlar","author":"Public Domain Proverb"},"sequenceIndex":1222},{"id":"world-prov-1224","text":"Let every pedlar carry his own pack.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1224)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pedlar","author":"Public Domain Proverb"},"sequenceIndex":1223},{"id":"world-prov-1225","text":"Pen and ink are a wit's plough.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1225)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pen","author":"Public Domain Proverb"},"sequenceIndex":1224},{"id":"world-prov-1226","text":"Take care of the pence, and the pounds will take care of themselves.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1226)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pence","author":"Public Domain Proverb"},"sequenceIndex":1225},{"id":"world-prov-1227","text":"That penny is well spent that saves a groat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1227)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Penny","author":"Public Domain Proverb"},"sequenceIndex":1226},{"id":"world-prov-1228","text":"A penny in my purse will bid me drink when all my friends I have will not.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1228)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Penny","author":"Public Domain Proverb"},"sequenceIndex":1227},{"id":"world-prov-1229","text":"A penny in your pocket is a good companion.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1229)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Penny","author":"Public Domain Proverb"},"sequenceIndex":1228},{"id":"world-prov-1230","text":"In for a penny, in for a pound.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1230)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Penny","author":"Public Domain Proverb"},"sequenceIndex":1229},{"id":"world-prov-1231","text":"A penny saved is a penny got.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1231)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Penny","author":"Public Domain Proverb"},"sequenceIndex":1230},{"id":"world-prov-1232","text":"Penny wise and pound foolish.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1232)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Penny Wise","author":"Public Domain Proverb"},"sequenceIndex":1231},{"id":"world-prov-1233","text":"Pepper is black, yet it hath a good smack.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1233)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pepper","author":"Public Domain Proverb"},"sequenceIndex":1232},{"id":"world-prov-1234","text":"The topmost branch is not the safest perch.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1234)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Perch","author":"Public Domain Proverb"},"sequenceIndex":1233},{"id":"world-prov-1235","text":"Peril proves who dearly loves.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1235)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Peril","author":"Public Domain Proverb"},"sequenceIndex":1234},{"id":"world-prov-1236","text":"Perseverance kills the game.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1236)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Perseverance","author":"Public Domain Proverb"},"sequenceIndex":1235},{"id":"world-prov-1237","text":"The persuasion of the fortunate sways the doubtful.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1237)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Persuasion","author":"Public Domain Proverb"},"sequenceIndex":1236},{"id":"world-prov-1238","text":"He robs Peter to pay Paul.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1238)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Peter","author":"Public Domain Proverb"},"sequenceIndex":1237},{"id":"world-prov-1239","text":"Physician heal thyself.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1239)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Physician","author":"Public Domain Proverb"},"sequenceIndex":1238},{"id":"world-prov-1240","text":"The best physicians are Doctor Diet, Doctor Cheeriman, and Doctor Quiet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1240)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Physicians","author":"Public Domain Proverb"},"sequenceIndex":1239},{"id":"world-prov-1241","text":"Painted pictures are dead speakers.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1241)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pictures","author":"Public Domain Proverb"},"sequenceIndex":1240},{"id":"world-prov-1242","text":"You can't make a horn of a pig's tail.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1242)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pig'S Tail","author":"Public Domain Proverb"},"sequenceIndex":1241},{"id":"world-prov-1243","text":"Sleep on it; the pillow is the best counsellor.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1243)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pillow","author":"Public Domain Proverb"},"sequenceIndex":1242},{"id":"world-prov-1244","text":"Every man is a pilot in a calm sea.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1244)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pilot","author":"Public Domain Proverb"},"sequenceIndex":1243},{"id":"world-prov-1245","text":"He that will not stoop for a pin, shall never be worth a point.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1245)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pin","author":"Public Domain Proverb"},"sequenceIndex":1244},{"id":"world-prov-1246","text":"See a pin and let it lie, Want a pin before you die.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1246)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pin","author":"Public Domain Proverb"},"sequenceIndex":1245},{"id":"world-prov-1247","text":"A pin a day is a groat a year.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1247)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pin","author":"Public Domain Proverb"},"sequenceIndex":1246},{"id":"world-prov-1248","text":"No one knows where the shoe pinches so well as him who wears it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1248)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pinches","author":"Public Domain Proverb"},"sequenceIndex":1247},{"id":"world-prov-1249","text":"He can ill pipe that wants his upper lip.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1249)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pipe","author":"Public Domain Proverb"},"sequenceIndex":1248},{"id":"world-prov-1250","text":"The pitcher does not go so often to the water, but it comes home broken at last.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1250)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pitcher","author":"Public Domain Proverb"},"sequenceIndex":1249},{"id":"world-prov-1251","text":"Pity, promises, and blame, are always cheap and plentiful.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1251)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pity","author":"Public Domain Proverb"},"sequenceIndex":1250},{"id":"world-prov-1252","text":"Foolish pity spoils a city.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1252)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pity","author":"Public Domain Proverb"},"sequenceIndex":1251},{"id":"world-prov-1253","text":"Sit in your place, and none can make you rise.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1253)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Place","author":"Public Domain Proverb"},"sequenceIndex":1252},{"id":"world-prov-1254","text":"A place for everything, and everything in its place.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1254)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Place","author":"Public Domain Proverb"},"sequenceIndex":1253},{"id":"world-prov-1255","text":"Plain dealing's a jewel.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1255)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Plain Dealing","author":"Public Domain Proverb"},"sequenceIndex":1254},{"id":"world-prov-1256","text":"All play and no work, Gives Tom a ragged shirt.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1256)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Play","author":"Public Domain Proverb"},"sequenceIndex":1255},{"id":"world-prov-1257","text":"All work and no play makes Jack a dull boy.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1257)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Play","author":"Public Domain Proverb"},"sequenceIndex":1256},{"id":"world-prov-1258","text":"If you play with a fool at home, he'll play with you in the market.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1258)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Play","author":"Public Domain Proverb"},"sequenceIndex":1257},{"id":"world-prov-1259","text":"He that would please all, and himself too, Undertakes what he cannot do.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1259)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Please All","author":"Public Domain Proverb"},"sequenceIndex":1258},{"id":"world-prov-1260","text":"Pleasing ware is half sold.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1260)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pleasing","author":"Public Domain Proverb"},"sequenceIndex":1259},{"id":"world-prov-1261","text":"Make not a toil of your pleasure.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1261)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pleasure","author":"Public Domain Proverb"},"sequenceIndex":1260},{"id":"world-prov-1262","text":"Plenty as blackberries.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1262)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Plenty","author":"Public Domain Proverb"},"sequenceIndex":1261},{"id":"world-prov-1263","text":"Don't stop the plough to catch a mouse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1263)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Plough","author":"Public Domain Proverb"},"sequenceIndex":1262},{"id":"world-prov-1264","text":"A man must plough with such oxen as he hath.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1264)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Plough","author":"Public Domain Proverb"},"sequenceIndex":1263},{"id":"world-prov-1265","text":"He that by the plough would thrive, Himself must either hold or drive.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1265)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Plough","author":"Public Domain Proverb"},"sequenceIndex":1264},{"id":"world-prov-1266","text":"Do not live poor to die rich.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1266)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Poor","author":"Public Domain Proverb"},"sequenceIndex":1265},{"id":"world-prov-1267","text":"As poor as Job.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1267)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Poor","author":"Public Domain Proverb"},"sequenceIndex":1266},{"id":"world-prov-1268","text":"Poor folk have few kindred.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1268)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Poor Folk","author":"Public Domain Proverb"},"sequenceIndex":1267},{"id":"world-prov-1269","text":"Poor folk are glad of pottage.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1269)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Poor Folk","author":"Public Domain Proverb"},"sequenceIndex":1268},{"id":"world-prov-1270","text":"He that would be Pope must think of nothing else.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1270)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pope","author":"Public Domain Proverb"},"sequenceIndex":1269},{"id":"world-prov-1271","text":"Possession is nine points of the law, and they say there are but ten.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1271)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Possession","author":"Public Domain Proverb"},"sequenceIndex":1270},{"id":"world-prov-1272","text":"A little pot is soon hot.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1272)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pot","author":"Public Domain Proverb"},"sequenceIndex":1271},{"id":"world-prov-1273","text":"The pot calls the kettle black.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1273)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pot","author":"Public Domain Proverb"},"sequenceIndex":1272},{"id":"world-prov-1274","text":"Poverty parts friends.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1274)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Poverty","author":"Public Domain Proverb"},"sequenceIndex":1273},{"id":"world-prov-1275","text":"Poverty breeds strife.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1275)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Poverty","author":"Public Domain Proverb"},"sequenceIndex":1274},{"id":"world-prov-1276","text":"Poverty is the mother of health.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1276)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Poverty","author":"Public Domain Proverb"},"sequenceIndex":1275},{"id":"world-prov-1277","text":"When poverty comes in at the door, friendship leaps out of the window.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1277)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Poverty","author":"Public Domain Proverb"},"sequenceIndex":1276},{"id":"world-prov-1278","text":"Poverty parteth good fellowship.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1278)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Poverty","author":"Public Domain Proverb"},"sequenceIndex":1277},{"id":"world-prov-1279","text":"Poverty makes a man acquainted with strange bed-fellows.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1279)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Poverty","author":"Public Domain Proverb"},"sequenceIndex":1278},{"id":"world-prov-1280","text":"Practice makes perfect.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1280)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Practice","author":"Public Domain Proverb"},"sequenceIndex":1279},{"id":"world-prov-1281","text":"True praise takes root and spreads.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1281)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Praise","author":"Public Domain Proverb"},"sequenceIndex":1280},{"id":"world-prov-1282","text":"Neither praise nor dispraise thyself, thine actions serve the turn.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1282)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Praise","author":"Public Domain Proverb"},"sequenceIndex":1281},{"id":"world-prov-1283","text":"Never sound the trumpet of your own praise.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1283)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Praise","author":"Public Domain Proverb"},"sequenceIndex":1282},{"id":"world-prov-1284","text":"Praise a fair day at night.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1284)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Praise","author":"Public Domain Proverb"},"sequenceIndex":1283},{"id":"world-prov-1285","text":"Old praise dies, unless you feed it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1285)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Praise","author":"Public Domain Proverb"},"sequenceIndex":1284},{"id":"world-prov-1286","text":"Prate is but prate; 'tis money buys land.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1286)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Prate","author":"Public Domain Proverb"},"sequenceIndex":1285},{"id":"world-prov-1287","text":"He that would learn to pray let him go to sea.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1287)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pray","author":"Public Domain Proverb"},"sequenceIndex":1286},{"id":"world-prov-1288","text":"Prettiness makes no pottage.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1288)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Prettiness","author":"Public Domain Proverb"},"sequenceIndex":1287},{"id":"world-prov-1289","text":"Prettiness dies quickly.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1289)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Prettiness","author":"Public Domain Proverb"},"sequenceIndex":1288},{"id":"world-prov-1290","text":"Prevention is better than cure.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1290)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Prevention","author":"Public Domain Proverb"},"sequenceIndex":1289},{"id":"world-prov-1291","text":"Birds of prey do not sing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1291)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Prey","author":"Public Domain Proverb"},"sequenceIndex":1290},{"id":"world-prov-1292","text":"Pride feels no pain.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1292)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pride","author":"Public Domain Proverb"},"sequenceIndex":1291},{"id":"world-prov-1293","text":"Pride will have a fall.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1293)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pride","author":"Public Domain Proverb"},"sequenceIndex":1292},{"id":"world-prov-1294","text":"Pride goes before, and shame follows after.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1294)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pride","author":"Public Domain Proverb"},"sequenceIndex":1293},{"id":"world-prov-1295","text":"Procrastination is the thief of time.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1295)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Procrastination","author":"Public Domain Proverb"},"sequenceIndex":1294},{"id":"world-prov-1296","text":"He is poor indeed that cannot promise nothing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1296)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Promise","author":"Public Domain Proverb"},"sequenceIndex":1295},{"id":"world-prov-1297","text":"Be slow to promise, but quick to perform.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1297)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Promise","author":"Public Domain Proverb"},"sequenceIndex":1296},{"id":"world-prov-1298","text":"Apt to promise, apt to forget.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1298)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Promise","author":"Public Domain Proverb"},"sequenceIndex":1297},{"id":"world-prov-1299","text":"Promises are too much like pie-crusts, made to be broken.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1299)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Promises","author":"Public Domain Proverb"},"sequenceIndex":1298},{"id":"world-prov-1300","text":"The proof of the pudding is in the eating.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1300)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Proof","author":"Public Domain Proverb"},"sequenceIndex":1299},{"id":"world-prov-1301","text":"Prosperity gains friends, adversity tries them.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1301)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Prosperity","author":"Public Domain Proverb"},"sequenceIndex":1300},{"id":"world-prov-1302","text":"There's nothing agrees worse than a proud mind and a beggar's purse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1302)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Proud Mind","author":"Public Domain Proverb"},"sequenceIndex":1301},{"id":"world-prov-1303","text":"According to the old proverb.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1303)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Proverb","author":"Public Domain Proverb"},"sequenceIndex":1302},{"id":"world-prov-1304","text":"Proverbs are the texts of common life.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1304)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Proverbs","author":"Public Domain Proverb"},"sequenceIndex":1303},{"id":"world-prov-1305","text":"Pry not into other people's affairs.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1305)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pry","author":"Public Domain Proverb"},"sequenceIndex":1304},{"id":"world-prov-1306","text":"He that pryeth into every cloud, may be stricken with a thunder-bolt.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1306)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pryeth","author":"Public Domain Proverb"},"sequenceIndex":1305},{"id":"world-prov-1307","text":"Every path hath a puddle.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1307)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Puddle","author":"Public Domain Proverb"},"sequenceIndex":1306},{"id":"world-prov-1308","text":"Puff not against the wind.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1308)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Puff","author":"Public Domain Proverb"},"sequenceIndex":1307},{"id":"world-prov-1309","text":"Pull gently on a weak rope.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1309)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pull","author":"Public Domain Proverb"},"sequenceIndex":1308},{"id":"world-prov-1310","text":"It is easier to pull down than to build.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1310)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Pull Down","author":"Public Domain Proverb"},"sequenceIndex":1309},{"id":"world-prov-1311","text":"Punctuality begets confidence.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1311)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Punctuality","author":"Public Domain Proverb"},"sequenceIndex":1310},{"id":"world-prov-1312","text":"Many without punishment, none without sin.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1312)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Punishment","author":"Public Domain Proverb"},"sequenceIndex":1311},{"id":"world-prov-1313","text":"Be ruled by your purse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1313)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Purse","author":"Public Domain Proverb"},"sequenceIndex":1312},{"id":"world-prov-1314","text":"Let your purse be your master.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1314)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Purse","author":"Public Domain Proverb"},"sequenceIndex":1313},{"id":"world-prov-1315","text":"You cannot make a purse of a sow's ear.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1315)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Purse","author":"Public Domain Proverb"},"sequenceIndex":1314},{"id":"world-prov-1316","text":"A full purse maketh the mouth to speak.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1316)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Purse","author":"Public Domain Proverb"},"sequenceIndex":1315},{"id":"world-prov-1317","text":"He that shows his purse longs to be rid of it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1317)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Purse","author":"Public Domain Proverb"},"sequenceIndex":1316},{"id":"world-prov-1318","text":"Be it better or be it worse, Be ruled by him who bears the purse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1318)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Purse","author":"Public Domain Proverb"},"sequenceIndex":1317},{"id":"world-prov-1319","text":"A heavy purse makes a light heart.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1319)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Purse","author":"Public Domain Proverb"},"sequenceIndex":1318},{"id":"world-prov-1320","text":"He who gets four pounds and spends five has no need of a purse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1320)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Purse","author":"Public Domain Proverb"},"sequenceIndex":1319},{"id":"world-prov-1321","text":"Wrinkled purses make wrinkled faces. Q","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1321)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Purses (Wrinkled)","author":"Public Domain Proverb"},"sequenceIndex":1320},{"id":"world-prov-1322","text":"Don't quarrel with the beggar for his bone.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1322)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Quarrel","author":"Public Domain Proverb"},"sequenceIndex":1321},{"id":"world-prov-1323","text":"To cast oil in the fire is not the way to quench it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1323)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Quench","author":"Public Domain Proverb"},"sequenceIndex":1322},{"id":"world-prov-1324","text":"Quick at meat, quick at work.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1324)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Quick","author":"Public Domain Proverb"},"sequenceIndex":1323},{"id":"world-prov-1325","text":"Next to love, quietness.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1325)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Quietness","author":"Public Domain Proverb"},"sequenceIndex":1324},{"id":"world-prov-1326","text":"Anything for a quiet life.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1326)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Quiet Life","author":"Public Domain Proverb"},"sequenceIndex":1325},{"id":"world-prov-1327","text":"The devil can quote Scripture to suit his purpose. R","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1327)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Quote","author":"Public Domain Proverb"},"sequenceIndex":1326},{"id":"world-prov-1328","text":"A ragged colt may make a good horse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1328)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ragged Colt","author":"Public Domain Proverb"},"sequenceIndex":1327},{"id":"world-prov-1329","text":"Rain from east, Two days at least.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1329)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Rain","author":"Public Domain Proverb"},"sequenceIndex":1328},{"id":"world-prov-1330","text":"Should it rain on Easter Day, There'll be plenty of grass and little hay.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1330)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Rain","author":"Public Domain Proverb"},"sequenceIndex":1329},{"id":"world-prov-1331","text":"Some rain, some rest.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1331)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Rain","author":"Public Domain Proverb"},"sequenceIndex":1330},{"id":"world-prov-1332","text":"After rain comes fair weather.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1332)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Rain","author":"Public Domain Proverb"},"sequenceIndex":1331},{"id":"world-prov-1333","text":"Small rain lays great dust.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1333)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Rain","author":"Public Domain Proverb"},"sequenceIndex":1332},{"id":"world-prov-1334","text":"It never rains but it pours.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1334)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Rains","author":"Public Domain Proverb"},"sequenceIndex":1333},{"id":"world-prov-1335","text":"Raise no more spirits than you can conjure down.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1335)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Raise","author":"Public Domain Proverb"},"sequenceIndex":1334},{"id":"world-prov-1336","text":"Ready money will away.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1336)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ready Money","author":"Public Domain Proverb"},"sequenceIndex":1335},{"id":"world-prov-1337","text":"He is a real friend who assists one in a pinch.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1337)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Real Friend","author":"Public Domain Proverb"},"sequenceIndex":1336},{"id":"world-prov-1338","text":"If we do not hear reason she will one day make herself be heard.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1338)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Reason","author":"Public Domain Proverb"},"sequenceIndex":1337},{"id":"world-prov-1339","text":"There's reason in roasting of eggs.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1339)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Reason","author":"Public Domain Proverb"},"sequenceIndex":1338},{"id":"world-prov-1340","text":"The receiver is as bad as the thief.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1340)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Receiver","author":"Public Domain Proverb"},"sequenceIndex":1339},{"id":"world-prov-1341","text":"If there were no receivers there would be no thieves.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1341)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Receivers","author":"Public Domain Proverb"},"sequenceIndex":1340},{"id":"world-prov-1342","text":"Reckless youth makes rueful age.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1342)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Reckless Youth","author":"Public Domain Proverb"},"sequenceIndex":1341},{"id":"world-prov-1343","text":"He that reckons without his host must reckon again.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1343)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Reckons","author":"Public Domain Proverb"},"sequenceIndex":1342},{"id":"world-prov-1344","text":"Fools always come short of their reckoning.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1344)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Reckoning","author":"Public Domain Proverb"},"sequenceIndex":1343},{"id":"world-prov-1345","text":"Short reckonings make long friends.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1345)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Reckoning","author":"Public Domain Proverb"},"sequenceIndex":1344},{"id":"world-prov-1346","text":"Reconcile yourself to present trials, the future may bring worse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1346)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Reconcile","author":"Public Domain Proverb"},"sequenceIndex":1345},{"id":"world-prov-1347","text":"A good recorder sets all in order.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1347)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Recorder","author":"Public Domain Proverb"},"sequenceIndex":1346},{"id":"world-prov-1348","text":"Man reigns and woman rules.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1348)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Reigns","author":"Public Domain Proverb"},"sequenceIndex":1347},{"id":"world-prov-1349","text":"Men hold the reins, but the women tell them which way to drive.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1349)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Reins","author":"Public Domain Proverb"},"sequenceIndex":1348},{"id":"world-prov-1350","text":"Better wear a cloak for religion than religion for a cloak.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1350)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Religion","author":"Public Domain Proverb"},"sequenceIndex":1349},{"id":"world-prov-1351","text":"Remove an old tree and it will wither.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1351)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Remove","author":"Public Domain Proverb"},"sequenceIndex":1350},{"id":"world-prov-1352","text":"A plant often removed cannot thrive.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1352)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Removed","author":"Public Domain Proverb"},"sequenceIndex":1351},{"id":"world-prov-1353","text":"A smart reproof is better than smooth deceit.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1353)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Reproof","author":"Public Domain Proverb"},"sequenceIndex":1352},{"id":"world-prov-1354","text":"Reserve the master-blow.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1354)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Reserve","author":"Public Domain Proverb"},"sequenceIndex":1353},{"id":"world-prov-1355","text":"A story never loses by re-telling.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1355)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Re-Telling","author":"Public Domain Proverb"},"sequenceIndex":1354},{"id":"world-prov-1356","text":"To forget wrong is the greatest revenge.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1356)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Revenge","author":"Public Domain Proverb"},"sequenceIndex":1355},{"id":"world-prov-1357","text":"Revenge is sweet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1357)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Revenge","author":"Public Domain Proverb"},"sequenceIndex":1356},{"id":"world-prov-1358","text":"God help the rich, the poor can beg.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1358)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Rich","author":"Public Domain Proverb"},"sequenceIndex":1357},{"id":"world-prov-1359","text":"Riches are like muck, which stink in a heap, but spread abroad make the earth fruitful.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1359)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Riches","author":"Public Domain Proverb"},"sequenceIndex":1358},{"id":"world-prov-1360","text":"Riches are but the baggage of fortune.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1360)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Riches","author":"Public Domain Proverb"},"sequenceIndex":1359},{"id":"world-prov-1361","text":"Better ride on an ass that carries me than a horse that throws me.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1361)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ride","author":"Public Domain Proverb"},"sequenceIndex":1360},{"id":"world-prov-1362","text":"Let not thy right hand know what thy left hand doeth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1362)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Right Hand","author":"Public Domain Proverb"},"sequenceIndex":1361},{"id":"world-prov-1363","text":"He that riseth betimes hath something in his head.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1363)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Riseth","author":"Public Domain Proverb"},"sequenceIndex":1362},{"id":"world-prov-1364","text":"Follow the river and you'll get to the sea.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1364)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"River","author":"Public Domain Proverb"},"sequenceIndex":1363},{"id":"world-prov-1365","text":"Rich country, bad road.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1365)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Road","author":"Public Domain Proverb"},"sequenceIndex":1364},{"id":"world-prov-1366","text":"A bird can roost upon but one branch.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1366)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Roost","author":"Public Domain Proverb"},"sequenceIndex":1365},{"id":"world-prov-1367","text":"A rolling stone gathers no moss.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1367)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Rolling Stone","author":"Public Domain Proverb"},"sequenceIndex":1366},{"id":"world-prov-1368","text":"When you are at Rome, do as Rome does.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1368)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Rome","author":"Public Domain Proverb"},"sequenceIndex":1367},{"id":"world-prov-1369","text":"Rome was not built in a day.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1369)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Rome","author":"Public Domain Proverb"},"sequenceIndex":1368},{"id":"world-prov-1370","text":"He that will not be ruled by the rudder must be ruled by the rock.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1370)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Rudder","author":"Public Domain Proverb"},"sequenceIndex":1369},{"id":"world-prov-1371","text":"The fairest rose at last is withered.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1371)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Rose","author":"Public Domain Proverb"},"sequenceIndex":1370},{"id":"world-prov-1372","text":"A rotten apple injures its companions.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1372)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Rotten Apple","author":"Public Domain Proverb"},"sequenceIndex":1371},{"id":"world-prov-1373","text":"A rugged stone grows smooth from hand to hand.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1373)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Rugged Stone","author":"Public Domain Proverb"},"sequenceIndex":1372},{"id":"world-prov-1374","text":"There is no rule without an exception.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1374)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Rule","author":"Public Domain Proverb"},"sequenceIndex":1373},{"id":"world-prov-1375","text":"Love rules his kingdom without a sword.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1375)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Rules","author":"Public Domain Proverb"},"sequenceIndex":1374},{"id":"world-prov-1376","text":"He that runs fastest gets the prize.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1376)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Runs","author":"Public Domain Proverb"},"sequenceIndex":1375},{"id":"world-prov-1377","text":"He that runs fast will not run long. S","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1377)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Runs Fast","author":"Public Domain Proverb"},"sequenceIndex":1376},{"id":"world-prov-1378","text":"It's a bad sack will abide no clouting.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1378)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sack","author":"Public Domain Proverb"},"sequenceIndex":1377},{"id":"world-prov-1379","text":"Nothing comes out of the sack but what was in it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1379)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sack","author":"Public Domain Proverb"},"sequenceIndex":1378},{"id":"world-prov-1380","text":"Set the saddle on the right horse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1380)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Saddle","author":"Public Domain Proverb"},"sequenceIndex":1379},{"id":"world-prov-1381","text":"Sadness and gladness succeed each other.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1381)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sadness","author":"Public Domain Proverb"},"sequenceIndex":1380},{"id":"world-prov-1382","text":"DAVID'S DAY. Upon St. David's day, Put oats and barley in the clay.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1382)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"St","author":"Public Domain Proverb"},"sequenceIndex":1381},{"id":"world-prov-1383","text":"STEPHEN. Blessed be St. Stephen; There's no fast upon his even.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1383)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"St","author":"Public Domain Proverb"},"sequenceIndex":1382},{"id":"world-prov-1384","text":"Make not your sail too large for your ship.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1384)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sail","author":"Public Domain Proverb"},"sequenceIndex":1383},{"id":"world-prov-1385","text":"Salmon and sermon have their season in Lent.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1385)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Salmon","author":"Public Domain Proverb"},"sequenceIndex":1384},{"id":"world-prov-1386","text":"Catch a bird by putting salt on its tail.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1386)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Salt","author":"Public Domain Proverb"},"sequenceIndex":1385},{"id":"world-prov-1387","text":"You can't make ropes of sand.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1387)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sand","author":"Public Domain Proverb"},"sequenceIndex":1386},{"id":"world-prov-1388","text":"What's sauce for the goose is sauce for the gander.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1388)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sauce","author":"Public Domain Proverb"},"sequenceIndex":1387},{"id":"world-prov-1389","text":"Sweet meat must have some sauce.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1389)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sauce","author":"Public Domain Proverb"},"sequenceIndex":1388},{"id":"world-prov-1390","text":"If youth knew what age will crave, It sure would strive to get and save.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1390)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Save","author":"Public Domain Proverb"},"sequenceIndex":1389},{"id":"world-prov-1391","text":"Who will not save a penny, shall never have many.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1391)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Save","author":"Public Domain Proverb"},"sequenceIndex":1390},{"id":"world-prov-1392","text":"Saving is getting.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1392)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Saving","author":"Public Domain Proverb"},"sequenceIndex":1391},{"id":"world-prov-1393","text":"It's useless saving at the spigot and spending at the bung-hole.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1393)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Saving","author":"Public Domain Proverb"},"sequenceIndex":1392},{"id":"world-prov-1394","text":"Of saving cometh having.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1394)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Saving","author":"Public Domain Proverb"},"sequenceIndex":1393},{"id":"world-prov-1395","text":"Learn to say before you sing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1395)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Say","author":"Public Domain Proverb"},"sequenceIndex":1394},{"id":"world-prov-1396","text":"Saying and doing are two things.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1396)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Saying","author":"Public Domain Proverb"},"sequenceIndex":1395},{"id":"world-prov-1397","text":"If a man says little he thinks the more.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1397)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Says","author":"Public Domain Proverb"},"sequenceIndex":1396},{"id":"world-prov-1398","text":"\"Say well,\" and \"do well,\" end with one letter; To say well, it is well, but to do well is better.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1398)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Say Well","author":"Public Domain Proverb"},"sequenceIndex":1397},{"id":"world-prov-1399","text":"One scabbed sheep infects the whole flock.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1399)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Scabbed Sheep","author":"Public Domain Proverb"},"sequenceIndex":1398},{"id":"world-prov-1400","text":"Scald not your lips in another man's pottage.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1400)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Scald","author":"Public Domain Proverb"},"sequenceIndex":1399},{"id":"world-prov-1401","text":"A scalded cat fears cold water.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1401)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Scalded Cat","author":"Public Domain Proverb"},"sequenceIndex":1400},{"id":"world-prov-1402","text":"A sceptre is one thing, a ladle another.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1402)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sceptre","author":"Public Domain Proverb"},"sequenceIndex":1401},{"id":"world-prov-1403","text":"A mere scholar a mere ass.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1403)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Scholar","author":"Public Domain Proverb"},"sequenceIndex":1402},{"id":"world-prov-1404","text":"The greatest scholars are not always the wisest men.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1404)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Scholars","author":"Public Domain Proverb"},"sequenceIndex":1403},{"id":"world-prov-1405","text":"Scorning is catching.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1405)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Scorning","author":"Public Domain Proverb"},"sequenceIndex":1404},{"id":"world-prov-1406","text":"A Scotch mist will wet an Englishman through to the skin.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1406)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Scotch Mist","author":"Public Domain Proverb"},"sequenceIndex":1405},{"id":"world-prov-1407","text":"On the sea sail; on the land settle.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1407)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sea","author":"Public Domain Proverb"},"sequenceIndex":1406},{"id":"world-prov-1408","text":"Everything is good in its season.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1408)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Season","author":"Public Domain Proverb"},"sequenceIndex":1407},{"id":"world-prov-1409","text":"To everything there is a season; and a time to every purpose under heaven.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1409)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Season","author":"Public Domain Proverb"},"sequenceIndex":1408},{"id":"world-prov-1410","text":"'Tis the second blow that makes a fray.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1410)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Second Blow","author":"Public Domain Proverb"},"sequenceIndex":1409},{"id":"world-prov-1411","text":"He that revealeth his secret maketh himself a slave.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1411)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Secret","author":"Public Domain Proverb"},"sequenceIndex":1410},{"id":"world-prov-1412","text":"Seeing is believing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1412)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Seeing","author":"Public Domain Proverb"},"sequenceIndex":1411},{"id":"world-prov-1413","text":"Seek till you find, and you'll lose no labour.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1413)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Seek","author":"Public Domain Proverb"},"sequenceIndex":1412},{"id":"world-prov-1414","text":"Seldom seen, soon forgotten.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1414)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Seldom Seen","author":"Public Domain Proverb"},"sequenceIndex":1413},{"id":"world-prov-1415","text":"Self do, self have.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1415)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Self","author":"Public Domain Proverb"},"sequenceIndex":1414},{"id":"world-prov-1416","text":"Self love's a mote in every man's eye.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1416)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Self Love","author":"Public Domain Proverb"},"sequenceIndex":1415},{"id":"world-prov-1417","text":"Self praise is no recommendation.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1417)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Self Praise","author":"Public Domain Proverb"},"sequenceIndex":1416},{"id":"world-prov-1418","text":"September blow soft, Till the fruit's in the loft.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1418)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"September","author":"Public Domain Proverb"},"sequenceIndex":1417},{"id":"world-prov-1419","text":"Good servants make good masters.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1419)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Servants","author":"Public Domain Proverb"},"sequenceIndex":1418},{"id":"world-prov-1420","text":"Catch not at the shadow and lose the substance.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1420)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Shadow","author":"Public Domain Proverb"},"sequenceIndex":1419},{"id":"world-prov-1421","text":"Share and share alike.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1421)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Share","author":"Public Domain Proverb"},"sequenceIndex":1420},{"id":"world-prov-1422","text":"It's ill shaving against the wool.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1422)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Shaving","author":"Public Domain Proverb"},"sequenceIndex":1421},{"id":"world-prov-1423","text":"Shear your sheep in May, And shear them all away.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1423)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Shear","author":"Public Domain Proverb"},"sequenceIndex":1422},{"id":"world-prov-1424","text":"One sheep follows another.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1424)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sheep","author":"Public Domain Proverb"},"sequenceIndex":1423},{"id":"world-prov-1425","text":"Ships fear fire more than water.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1425)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ships","author":"Public Domain Proverb"},"sequenceIndex":1424},{"id":"world-prov-1426","text":"The finest shoe often hurts the foot.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1426)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Shoe","author":"Public Domain Proverb"},"sequenceIndex":1425},{"id":"world-prov-1427","text":"To know where the shoe pinches.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1427)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Shoe","author":"Public Domain Proverb"},"sequenceIndex":1426},{"id":"world-prov-1428","text":"Every man will shoot at the enemy, but few will go to fetch the shaft.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1428)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Shoot","author":"Public Domain Proverb"},"sequenceIndex":1427},{"id":"world-prov-1429","text":"Keep thy shop, and thy shop will keep thee.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1429)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Shop","author":"Public Domain Proverb"},"sequenceIndex":1428},{"id":"world-prov-1430","text":"God tempers the wind to the shorn sheep.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1430)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Shorn Sheep","author":"Public Domain Proverb"},"sequenceIndex":1429},{"id":"world-prov-1431","text":"Short cuts are sometimes longest.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1431)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Short Cuts","author":"Public Domain Proverb"},"sequenceIndex":1430},{"id":"world-prov-1432","text":"Short reckonings are soon cleared.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1432)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Short Reckonings","author":"Public Domain Proverb"},"sequenceIndex":1431},{"id":"world-prov-1433","text":"Short and sweet like a donkey's gallop.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1433)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Short And Sweet","author":"Public Domain Proverb"},"sequenceIndex":1432},{"id":"world-prov-1434","text":"Every one can tame a shrew but he that hath her.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1434)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Shrew","author":"Public Domain Proverb"},"sequenceIndex":1433},{"id":"world-prov-1435","text":"Never sigh but send.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1435)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sigh","author":"Public Domain Proverb"},"sequenceIndex":1434},{"id":"world-prov-1436","text":"Out of sight out of mind.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1436)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sight","author":"Public Domain Proverb"},"sequenceIndex":1435},{"id":"world-prov-1437","text":"Silence seldom doth harm.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1437)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Silence","author":"Public Domain Proverb"},"sequenceIndex":1436},{"id":"world-prov-1438","text":"Silence is consent.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1438)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Silence","author":"Public Domain Proverb"},"sequenceIndex":1437},{"id":"world-prov-1439","text":"Silence is the best ornament of a woman.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1439)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Silence","author":"Public Domain Proverb"},"sequenceIndex":1438},{"id":"world-prov-1440","text":"White silver draws black lines.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1440)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Silver","author":"Public Domain Proverb"},"sequenceIndex":1439},{"id":"world-prov-1441","text":"He was born with a silver spoon in his mouth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1441)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Silver Spoon","author":"Public Domain Proverb"},"sequenceIndex":1440},{"id":"world-prov-1442","text":"A bird that can sing and won't sing, must be made to sing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1442)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sing","author":"Public Domain Proverb"},"sequenceIndex":1441},{"id":"world-prov-1443","text":"None but fools and fiddlers sing at their meat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1443)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sing","author":"Public Domain Proverb"},"sequenceIndex":1442},{"id":"world-prov-1444","text":"Who sings drives away care.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1444)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sings","author":"Public Domain Proverb"},"sequenceIndex":1443},{"id":"world-prov-1445","text":"As good sit still as rise up and fall.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1445)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sit Still","author":"Public Domain Proverb"},"sequenceIndex":1444},{"id":"world-prov-1446","text":"Few people are out of the reach of slander.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1446)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Slander","author":"Public Domain Proverb"},"sequenceIndex":1445},{"id":"world-prov-1447","text":"Slander leaves a score behind it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1447)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Slander","author":"Public Domain Proverb"},"sequenceIndex":1446},{"id":"world-prov-1448","text":"Account not that work slavery That brings in penny savoury.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1448)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Slavery","author":"Public Domain Proverb"},"sequenceIndex":1447},{"id":"world-prov-1449","text":"One hour's sleep before midnight is worth two hours after.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1449)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sleep","author":"Public Domain Proverb"},"sequenceIndex":1448},{"id":"world-prov-1450","text":"There is sleeping enough in the grave.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1450)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sleeping","author":"Public Domain Proverb"},"sequenceIndex":1449},{"id":"world-prov-1451","text":"Don't wake a sleeping dog.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1451)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sleeping Dog","author":"Public Domain Proverb"},"sequenceIndex":1450},{"id":"world-prov-1452","text":"Better that the feet slip than the tongue.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1452)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Slip","author":"Public Domain Proverb"},"sequenceIndex":1451},{"id":"world-prov-1453","text":"Sloth turneth the edge of wit.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1453)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sloth","author":"Public Domain Proverb"},"sequenceIndex":1452},{"id":"world-prov-1454","text":"Sloth is the mother of poverty.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1454)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sloth","author":"Public Domain Proverb"},"sequenceIndex":1453},{"id":"world-prov-1455","text":"Slow and sure.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1455)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Slow","author":"Public Domain Proverb"},"sequenceIndex":1454},{"id":"world-prov-1456","text":"The sluggard's guise, Loth to go to bed and loth to rise.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1456)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sluggard'S Guise","author":"Public Domain Proverb"},"sequenceIndex":1455},{"id":"world-prov-1457","text":"Sluts are good enough to make slovens' pottage.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1457)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sluts","author":"Public Domain Proverb"},"sequenceIndex":1456},{"id":"world-prov-1458","text":"Better are small fish than an empty dish.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1458)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Small Fish","author":"Public Domain Proverb"},"sequenceIndex":1457},{"id":"world-prov-1459","text":"Small things affect light minds.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1459)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Small Things","author":"Public Domain Proverb"},"sequenceIndex":1458},{"id":"world-prov-1460","text":"He that despiseth small things shall fall by little and little.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1460)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Small Things","author":"Public Domain Proverb"},"sequenceIndex":1459},{"id":"world-prov-1461","text":"Where there is smoke there is fire.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1461)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Smoke","author":"Public Domain Proverb"},"sequenceIndex":1460},{"id":"world-prov-1462","text":"Put a snake in your bosom, and when it is warm it will sting you.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1462)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Snake","author":"Public Domain Proverb"},"sequenceIndex":1461},{"id":"world-prov-1463","text":"A snow year, a rich year.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1463)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Snow","author":"Public Domain Proverb"},"sequenceIndex":1462},{"id":"world-prov-1464","text":"He that goes softly goes surely.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1464)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Softly","author":"Public Domain Proverb"},"sequenceIndex":1463},{"id":"world-prov-1465","text":"Soft words butter no parsnips.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1465)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Soft Words","author":"Public Domain Proverb"},"sequenceIndex":1464},{"id":"world-prov-1466","text":"Soldiers in peace are like chimneys in summer.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1466)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Soldiers","author":"Public Domain Proverb"},"sequenceIndex":1465},{"id":"world-prov-1467","text":"My son's my son till he hath got him a wife, But my daughter's my daughter all the days of her life.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1467)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Son","author":"Public Domain Proverb"},"sequenceIndex":1466},{"id":"world-prov-1468","text":"Soon hot, soon cold.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1468)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Soon Hot","author":"Public Domain Proverb"},"sequenceIndex":1467},{"id":"world-prov-1469","text":"'Tis sooner said than done.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1469)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sooner Said","author":"Public Domain Proverb"},"sequenceIndex":1468},{"id":"world-prov-1470","text":"Sorrow and bad weather come unsent for.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1470)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sorrow","author":"Public Domain Proverb"},"sequenceIndex":1469},{"id":"world-prov-1471","text":"Sorrow will pay no debt.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1471)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sorrow","author":"Public Domain Proverb"},"sequenceIndex":1470},{"id":"world-prov-1472","text":"A fat sorrow is better than a lean one.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1472)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sorrow","author":"Public Domain Proverb"},"sequenceIndex":1471},{"id":"world-prov-1473","text":"Sorrow is good for nothing but sin.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1473)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sorrow","author":"Public Domain Proverb"},"sequenceIndex":1472},{"id":"world-prov-1474","text":"Sorrow will wear away in time.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1474)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sorrow","author":"Public Domain Proverb"},"sequenceIndex":1473},{"id":"world-prov-1475","text":"When sorrow is asleep, wake it not.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1475)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sorrow","author":"Public Domain Proverb"},"sequenceIndex":1474},{"id":"world-prov-1476","text":"Sorrow comes unsent for, and, like the unbidden guest, brings his own stool.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1476)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sorrow","author":"Public Domain Proverb"},"sequenceIndex":1475},{"id":"world-prov-1477","text":"He goes a-sorrowing, who goes a-borrowing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1477)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sorrowing","author":"Public Domain Proverb"},"sequenceIndex":1476},{"id":"world-prov-1478","text":"As sound as a nut.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1478)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sound","author":"Public Domain Proverb"},"sequenceIndex":1477},{"id":"world-prov-1479","text":"\"Sour grapes,\" as the fox said when he could not reach them.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1479)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sour Grapes","author":"Public Domain Proverb"},"sequenceIndex":1478},{"id":"world-prov-1480","text":"Every sow to her own trough.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1480)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sow","author":"Public Domain Proverb"},"sequenceIndex":1479},{"id":"world-prov-1481","text":"Who sows in May gets little that way.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1481)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sows","author":"Public Domain Proverb"},"sequenceIndex":1480},{"id":"world-prov-1482","text":"What a man sows, that shall he also reap.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1482)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sows","author":"Public Domain Proverb"},"sequenceIndex":1481},{"id":"world-prov-1483","text":"'Tis too late, to spare when the bottom is bare.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1483)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spare","author":"Public Domain Proverb"},"sequenceIndex":1482},{"id":"world-prov-1484","text":"It is better to spare at the brim than the bottom.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1484)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spare","author":"Public Domain Proverb"},"sequenceIndex":1483},{"id":"world-prov-1485","text":"Spare when young and spend when old.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1485)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spare","author":"Public Domain Proverb"},"sequenceIndex":1484},{"id":"world-prov-1486","text":"Spare to speak and spare to spend.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1486)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spare","author":"Public Domain Proverb"},"sequenceIndex":1485},{"id":"world-prov-1487","text":"There is a time to speak as well as to be silent.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1487)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Speak","author":"Public Domain Proverb"},"sequenceIndex":1486},{"id":"world-prov-1488","text":"Speak well of the dead.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1488)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Speak","author":"Public Domain Proverb"},"sequenceIndex":1487},{"id":"world-prov-1489","text":"Many speak much that cannot speak well.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1489)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Speak","author":"Public Domain Proverb"},"sequenceIndex":1488},{"id":"world-prov-1490","text":"Speak fair and think what you will.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1490)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Speak","author":"Public Domain Proverb"},"sequenceIndex":1489},{"id":"world-prov-1491","text":"He that speaks me fair and loves me not, I'll speak him fair and trust him not.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1491)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Speaks","author":"Public Domain Proverb"},"sequenceIndex":1490},{"id":"world-prov-1492","text":"Speculation completes what extravagance began.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1492)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Speculation","author":"Public Domain Proverb"},"sequenceIndex":1491},{"id":"world-prov-1493","text":"Speech is the picture of the mind.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1493)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Speech","author":"Public Domain Proverb"},"sequenceIndex":1492},{"id":"world-prov-1494","text":"Spend not where you may save; spare not where you must spend.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1494)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spend","author":"Public Domain Proverb"},"sequenceIndex":1493},{"id":"world-prov-1495","text":"Carefully spend, and God will send.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1495)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spend","author":"Public Domain Proverb"},"sequenceIndex":1494},{"id":"world-prov-1496","text":"Spend and be free, but make no waste.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1496)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spend","author":"Public Domain Proverb"},"sequenceIndex":1495},{"id":"world-prov-1497","text":"To a good spender God is the treasurer.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1497)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spender","author":"Public Domain Proverb"},"sequenceIndex":1496},{"id":"world-prov-1498","text":"Great spenders are bad lenders.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1498)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spenders","author":"Public Domain Proverb"},"sequenceIndex":1497},{"id":"world-prov-1499","text":"He who more than his worth doth spend, Makes a rope his life to end; He who spends more than he should, Shall not have to spend when he would.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1499)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spends","author":"Public Domain Proverb"},"sequenceIndex":1498},{"id":"world-prov-1500","text":"You may know by a penny how a shilling spends.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1500)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spends","author":"Public Domain Proverb"},"sequenceIndex":1499},{"id":"world-prov-1501","text":"It is the thrift of a spendthrift which ruins him most effectually.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1501)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spendthrift","author":"Public Domain Proverb"},"sequenceIndex":1500},{"id":"world-prov-1502","text":"Who hath spice enough may season his meat as he pleaseth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1502)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spice","author":"Public Domain Proverb"},"sequenceIndex":1501},{"id":"world-prov-1503","text":"Don't cut your nose off to spite your face.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1503)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spite","author":"Public Domain Proverb"},"sequenceIndex":1502},{"id":"world-prov-1504","text":"Who spits against the wind spits in his own face.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1504)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spits","author":"Public Domain Proverb"},"sequenceIndex":1503},{"id":"world-prov-1505","text":"He would split a hair.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1505)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Split","author":"Public Domain Proverb"},"sequenceIndex":1504},{"id":"world-prov-1506","text":"Too many cooks spoil the broth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1506)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spoil","author":"Public Domain Proverb"},"sequenceIndex":1505},{"id":"world-prov-1507","text":"Spoil not the ship for a penn'orth of tar.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1507)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spoil","author":"Public Domain Proverb"},"sequenceIndex":1506},{"id":"world-prov-1508","text":"Better be ill spoken of by one before all, than by all before one.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1508)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spoken Of","author":"Public Domain Proverb"},"sequenceIndex":1507},{"id":"world-prov-1509","text":"It's poor sport that is not worth the candle.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1509)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sport","author":"Public Domain Proverb"},"sequenceIndex":1508},{"id":"world-prov-1510","text":"No sport, no pie.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1510)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sport","author":"Public Domain Proverb"},"sequenceIndex":1509},{"id":"world-prov-1511","text":"Rich men's spots are covered with money.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1511)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spots","author":"Public Domain Proverb"},"sequenceIndex":1510},{"id":"world-prov-1512","text":"Throw a sprat to catch a whale.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1512)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sprat","author":"Public Domain Proverb"},"sequenceIndex":1511},{"id":"world-prov-1513","text":"Do not spur a free horse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1513)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Spur","author":"Public Domain Proverb"},"sequenceIndex":1512},{"id":"world-prov-1514","text":"Being born in a stable does not make a man a horse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1514)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stable","author":"Public Domain Proverb"},"sequenceIndex":1513},{"id":"world-prov-1515","text":"An ill stake standeth longest.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1515)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stake","author":"Public Domain Proverb"},"sequenceIndex":1514},{"id":"world-prov-1516","text":"Standers by see more than the gamesters.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1516)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Standers By","author":"Public Domain Proverb"},"sequenceIndex":1515},{"id":"world-prov-1517","text":"The higher the standing the lower the fall.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1517)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Standing","author":"Public Domain Proverb"},"sequenceIndex":1516},{"id":"world-prov-1518","text":"Standing pools gather filth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1518)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Standing Pools","author":"Public Domain Proverb"},"sequenceIndex":1517},{"id":"world-prov-1519","text":"Stars are not seen during sunshine.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1519)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stars","author":"Public Domain Proverb"},"sequenceIndex":1518},{"id":"world-prov-1520","text":"He would starve in a cook-shop.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1520)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Starve","author":"Public Domain Proverb"},"sequenceIndex":1519},{"id":"world-prov-1521","text":"He that will steal an egg will steal an ox.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1521)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Steal","author":"Public Domain Proverb"},"sequenceIndex":1520},{"id":"world-prov-1522","text":"He that will steal a pin will steal a better thing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1522)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Steal","author":"Public Domain Proverb"},"sequenceIndex":1521},{"id":"world-prov-1523","text":"One man may better steal a horse than another look over the hedge.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1523)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Steal","author":"Public Domain Proverb"},"sequenceIndex":1522},{"id":"world-prov-1524","text":"When the steed is stolen the stable door shall be shut.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1524)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Steed","author":"Public Domain Proverb"},"sequenceIndex":1523},{"id":"world-prov-1525","text":"Step by step the ladder is climbed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1525)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Step By Step","author":"Public Domain Proverb"},"sequenceIndex":1524},{"id":"world-prov-1526","text":"Little sticks kindle the fire, but great ones put it out.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1526)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sticks","author":"Public Domain Proverb"},"sequenceIndex":1525},{"id":"world-prov-1527","text":"He that will not go over the stile must be thrust through the gate.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1527)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stile","author":"Public Domain Proverb"},"sequenceIndex":1526},{"id":"world-prov-1528","text":"Trust not still water nor a silent man.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1528)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Still Water","author":"Public Domain Proverb"},"sequenceIndex":1527},{"id":"world-prov-1529","text":"Keep me from still water; from that which is rough I can keep myself.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1529)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Still Water","author":"Public Domain Proverb"},"sequenceIndex":1528},{"id":"world-prov-1530","text":"Still waters run deep.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1530)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Still Waters","author":"Public Domain Proverb"},"sequenceIndex":1529},{"id":"world-prov-1531","text":"Never cry \"Stinking fish.\"","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1531)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stinking Fish","author":"Public Domain Proverb"},"sequenceIndex":1530},{"id":"world-prov-1532","text":"A stitch in time saves nine.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1532)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stitch","author":"Public Domain Proverb"},"sequenceIndex":1531},{"id":"world-prov-1533","text":"Whoso lacketh a stock, his gain's not worth a chip.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1533)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stock","author":"Public Domain Proverb"},"sequenceIndex":1532},{"id":"world-prov-1534","text":"Stolen kisses are sweet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1534)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stolen Kisses","author":"Public Domain Proverb"},"sequenceIndex":1533},{"id":"world-prov-1535","text":"The full stomach loatheth the honeycomb, but to the hungry every bitter thing is sweet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1535)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stomach","author":"Public Domain Proverb"},"sequenceIndex":1534},{"id":"world-prov-1536","text":"With stomach, wife, and conscience keep on good terms.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1536)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stomach","author":"Public Domain Proverb"},"sequenceIndex":1535},{"id":"world-prov-1537","text":"Hard upon hard makes a bad stone wall; But soft upon soft makes none at all.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1537)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stone Wall","author":"Public Domain Proverb"},"sequenceIndex":1536},{"id":"world-prov-1538","text":"Between two stools he comes to the ground.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1538)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stools","author":"Public Domain Proverb"},"sequenceIndex":1537},{"id":"world-prov-1539","text":"He must stoop that hath a low door.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1539)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stoop","author":"Public Domain Proverb"},"sequenceIndex":1538},{"id":"world-prov-1540","text":"After a storm comes a calm.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1540)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Storm","author":"Public Domain Proverb"},"sequenceIndex":1539},{"id":"world-prov-1541","text":"Store is no sore.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1541)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Store","author":"Public Domain Proverb"},"sequenceIndex":1540},{"id":"world-prov-1542","text":"One story is good until another's told.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1542)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Story","author":"Public Domain Proverb"},"sequenceIndex":1541},{"id":"world-prov-1543","text":"Straight trees have crooked roots.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1543)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Straight Trees","author":"Public Domain Proverb"},"sequenceIndex":1542},{"id":"world-prov-1544","text":"By stratagem, not valour.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1544)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stratagem","author":"Public Domain Proverb"},"sequenceIndex":1543},{"id":"world-prov-1545","text":"No striving against the stream.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1545)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stream","author":"Public Domain Proverb"},"sequenceIndex":1544},{"id":"world-prov-1546","text":"Weight and measure take away strife.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1546)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Strife","author":"Public Domain Proverb"},"sequenceIndex":1545},{"id":"world-prov-1547","text":"Haste makes waste, and waste makes want, and want makes strife between the good man and his wife.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1547)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Strife","author":"Public Domain Proverb"},"sequenceIndex":1546},{"id":"world-prov-1548","text":"Strike while the iron is hot.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1548)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Strike","author":"Public Domain Proverb"},"sequenceIndex":1547},{"id":"world-prov-1549","text":"Little strokes fell great oaks.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1549)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Strokes","author":"Public Domain Proverb"},"sequenceIndex":1548},{"id":"world-prov-1550","text":"Morning is the time for study.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1550)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Study","author":"Public Domain Proverb"},"sequenceIndex":1549},{"id":"world-prov-1551","text":"He that runs in the night stumbles.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1551)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stumbles","author":"Public Domain Proverb"},"sequenceIndex":1550},{"id":"world-prov-1552","text":"He that stumbles twice over the same stone, deserves to break his shins.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1552)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stumbles","author":"Public Domain Proverb"},"sequenceIndex":1551},{"id":"world-prov-1553","text":"'Tis a good horse that never stumbles, and a good wife that never grumbles.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1553)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Stumbles","author":"Public Domain Proverb"},"sequenceIndex":1552},{"id":"world-prov-1554","text":"The subjects' love is the king's lifeguard.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1554)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Subjects' Love","author":"Public Domain Proverb"},"sequenceIndex":1553},{"id":"world-prov-1555","text":"Nothing succeeds like success.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1555)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Success","author":"Public Domain Proverb"},"sequenceIndex":1554},{"id":"world-prov-1556","text":"'Tis not in mortals to command success, But we'll do more, Sempronius, we'll deserve it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1556)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Success","author":"Public Domain Proverb"},"sequenceIndex":1555},{"id":"world-prov-1557","text":"The young suckers drain the old tree.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1557)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Suckers","author":"Public Domain Proverb"},"sequenceIndex":1556},{"id":"world-prov-1558","text":"Of sufferance comes ease.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1558)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sufferance","author":"Public Domain Proverb"},"sequenceIndex":1557},{"id":"world-prov-1559","text":"Sufficient for the day is the evil thereof.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1559)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sufficient","author":"Public Domain Proverb"},"sequenceIndex":1558},{"id":"world-prov-1560","text":"That suit is best that best fits me.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1560)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Suit","author":"Public Domain Proverb"},"sequenceIndex":1559},{"id":"world-prov-1561","text":"No sunshine but hath some shadow.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1561)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sunshine","author":"Public Domain Proverb"},"sequenceIndex":1560},{"id":"world-prov-1562","text":"Better go to bed supperless than to rise in debt.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1562)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Supperless","author":"Public Domain Proverb"},"sequenceIndex":1561},{"id":"world-prov-1563","text":"Light suppers make long lives.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1563)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Suppers","author":"Public Domain Proverb"},"sequenceIndex":1562},{"id":"world-prov-1564","text":"Sure bind, sure find.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1564)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sure","author":"Public Domain Proverb"},"sequenceIndex":1563},{"id":"world-prov-1565","text":"A good surgeon must have an eagle's eye, a lion's heart, and a lady's hand.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1565)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Surgeon","author":"Public Domain Proverb"},"sequenceIndex":1564},{"id":"world-prov-1566","text":"One swallow does not make a summer.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1566)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Swallow","author":"Public Domain Proverb"},"sequenceIndex":1565},{"id":"world-prov-1567","text":"One swallow makes not a spring, nor one woodcock a winter.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1567)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Swallow","author":"Public Domain Proverb"},"sequenceIndex":1566},{"id":"world-prov-1568","text":"No sweat, no sweet.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1568)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sweat","author":"Public Domain Proverb"},"sequenceIndex":1567},{"id":"world-prov-1569","text":"Sweep before your own door.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1569)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sweep","author":"Public Domain Proverb"},"sequenceIndex":1568},{"id":"world-prov-1570","text":"They have need of a besom that sweep the house with a turf.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1570)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sweep","author":"Public Domain Proverb"},"sequenceIndex":1569},{"id":"world-prov-1571","text":"He deserves not the sweet that will not taste the sour.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1571)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sweet","author":"Public Domain Proverb"},"sequenceIndex":1570},{"id":"world-prov-1572","text":"He must needs swim that's held up by the chin.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1572)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Swim","author":"Public Domain Proverb"},"sequenceIndex":1571},{"id":"world-prov-1573","text":"Never trust yourself out of your depth till you can swim.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1573)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Swim","author":"Public Domain Proverb"},"sequenceIndex":1572},{"id":"world-prov-1574","text":"He that strikes with the sword shall be beaten with the scabbard.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1574)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sword","author":"Public Domain Proverb"},"sequenceIndex":1573},{"id":"world-prov-1575","text":"Who draws his sword against his prince must throw away the scabbard. T","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1575)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Sword","author":"Public Domain Proverb"},"sequenceIndex":1574},{"id":"world-prov-1576","text":"A poor man's table is soon spread.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1576)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Table","author":"Public Domain Proverb"},"sequenceIndex":1575},{"id":"world-prov-1577","text":"Who depends upon another man's table often dines late.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1577)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Table","author":"Public Domain Proverb"},"sequenceIndex":1576},{"id":"world-prov-1578","text":"Remove the tale-bearer and contention ceaseth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1578)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tale-Bearer","author":"Public Domain Proverb"},"sequenceIndex":1577},{"id":"world-prov-1579","text":"Put no faith in tale-bearers.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1579)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tale-Bearers","author":"Public Domain Proverb"},"sequenceIndex":1578},{"id":"world-prov-1580","text":"Talk of the devil and his imp appears.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1580)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Talk","author":"Public Domain Proverb"},"sequenceIndex":1579},{"id":"world-prov-1581","text":"The greatest talkers are always the least doers.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1581)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Talkers","author":"Public Domain Proverb"},"sequenceIndex":1580},{"id":"world-prov-1582","text":"Talking pays no toll.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1582)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Talking","author":"Public Domain Proverb"},"sequenceIndex":1581},{"id":"world-prov-1583","text":"To him that hath lost his taste, sweet is sour.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1583)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Taste","author":"Public Domain Proverb"},"sequenceIndex":1582},{"id":"world-prov-1584","text":"He teacheth ill who teacheth all.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1584)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Teacheth","author":"Public Domain Proverb"},"sequenceIndex":1583},{"id":"world-prov-1585","text":"Nothing dries up sooner than tears.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1585)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tears","author":"Public Domain Proverb"},"sequenceIndex":1584},{"id":"world-prov-1586","text":"A man may dig his grave with his teeth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1586)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Teeth","author":"Public Domain Proverb"},"sequenceIndex":1585},{"id":"world-prov-1587","text":"Temperance is the best physic.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1587)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Temperance","author":"Public Domain Proverb"},"sequenceIndex":1586},{"id":"world-prov-1588","text":"The tempter is the greater rogue.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1588)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tempter","author":"Public Domain Proverb"},"sequenceIndex":1587},{"id":"world-prov-1589","text":"He loseth his thanks who promiseth and delayeth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1589)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thanks","author":"Public Domain Proverb"},"sequenceIndex":1588},{"id":"world-prov-1590","text":"When I have thatched his house he would throw me down.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1590)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thatched","author":"Public Domain Proverb"},"sequenceIndex":1589},{"id":"world-prov-1591","text":"Give a thief rope enough and he'll hang himself.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1591)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thief","author":"Public Domain Proverb"},"sequenceIndex":1590},{"id":"world-prov-1592","text":"The thief's sorry because he is caught, not because he is the thief.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1592)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thief","author":"Public Domain Proverb"},"sequenceIndex":1591},{"id":"world-prov-1593","text":"Set a thief to take a thief.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1593)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thief","author":"Public Domain Proverb"},"sequenceIndex":1592},{"id":"world-prov-1594","text":"All are not thieves that dogs bark at.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1594)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thieves","author":"Public Domain Proverb"},"sequenceIndex":1593},{"id":"world-prov-1595","text":"One may think that dares not speak.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1595)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Think","author":"Public Domain Proverb"},"sequenceIndex":1594},{"id":"world-prov-1596","text":"Think twice before you speak once.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1596)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Think","author":"Public Domain Proverb"},"sequenceIndex":1595},{"id":"world-prov-1597","text":"Think much, speak little, and write less.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1597)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Think","author":"Public Domain Proverb"},"sequenceIndex":1596},{"id":"world-prov-1598","text":"Who thinks to live must live to think, Else mind and body lose their link.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1598)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Think","author":"Public Domain Proverb"},"sequenceIndex":1597},{"id":"world-prov-1599","text":"The horse thinks one thing, and he that rides him another.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1599)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thinks","author":"Public Domain Proverb"},"sequenceIndex":1598},{"id":"world-prov-1600","text":"Thinkers govern toilers.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1600)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thinkers","author":"Public Domain Proverb"},"sequenceIndex":1599},{"id":"world-prov-1601","text":"Gather thistles, expect prickles.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1601)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thistles","author":"Public Domain Proverb"},"sequenceIndex":1600},{"id":"world-prov-1602","text":"He that sows nothing plants thistles.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1602)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thistles","author":"Public Domain Proverb"},"sequenceIndex":1601},{"id":"world-prov-1603","text":"No rose without a thorn.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1603)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thorn","author":"Public Domain Proverb"},"sequenceIndex":1602},{"id":"world-prov-1604","text":"The thorn comes forth with his point forwards.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1604)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thorn","author":"Public Domain Proverb"},"sequenceIndex":1603},{"id":"world-prov-1605","text":"Roses, mind you, have thorns.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1605)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thorns","author":"Public Domain Proverb"},"sequenceIndex":1604},{"id":"world-prov-1606","text":"He that handles thorns shall prick his fingers.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1606)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thorns","author":"Public Domain Proverb"},"sequenceIndex":1605},{"id":"world-prov-1607","text":"Second thoughts are best.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1607)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thoughts","author":"Public Domain Proverb"},"sequenceIndex":1606},{"id":"world-prov-1608","text":"Thoughts are free.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1608)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thoughts","author":"Public Domain Proverb"},"sequenceIndex":1607},{"id":"world-prov-1609","text":"There are more threatened than struck.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1609)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Threatened","author":"Public Domain Proverb"},"sequenceIndex":1608},{"id":"world-prov-1610","text":"If you make not much of threepence you'll ne'er be worth a groat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1610)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Threepence","author":"Public Domain Proverb"},"sequenceIndex":1609},{"id":"world-prov-1611","text":"Thrifty men are fond of thrifty sayings.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1611)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thrifty","author":"Public Domain Proverb"},"sequenceIndex":1610},{"id":"world-prov-1612","text":"He that will thrive must rise at five. He that hath thriven may lie till seven.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1612)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thrive","author":"Public Domain Proverb"},"sequenceIndex":1611},{"id":"world-prov-1613","text":"Thunder in December foretells fine weather.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1613)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thunder","author":"Public Domain Proverb"},"sequenceIndex":1612},{"id":"world-prov-1614","text":"When it thunders the thief becomes honest.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1614)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thunders","author":"Public Domain Proverb"},"sequenceIndex":1613},{"id":"world-prov-1615","text":"For what thou canst do thyself rely not on another.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1615)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Thyself","author":"Public Domain Proverb"},"sequenceIndex":1614},{"id":"world-prov-1616","text":"There is a tide in the affairs of man which, taken at the flood, leads on to fortune.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1616)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tide","author":"Public Domain Proverb"},"sequenceIndex":1615},{"id":"world-prov-1617","text":"Every tide has its ebb.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1617)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tide","author":"Public Domain Proverb"},"sequenceIndex":1616},{"id":"world-prov-1618","text":"The tide will fetch away what the ebb brings.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1618)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tide","author":"Public Domain Proverb"},"sequenceIndex":1617},{"id":"world-prov-1619","text":"Take time by the forelock.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1619)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Time","author":"Public Domain Proverb"},"sequenceIndex":1618},{"id":"world-prov-1620","text":"A mouse, in time, may bite in two a cable.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1620)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Time","author":"Public Domain Proverb"},"sequenceIndex":1619},{"id":"world-prov-1621","text":"Take time when time is, for time will away.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1621)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Time","author":"Public Domain Proverb"},"sequenceIndex":1620},{"id":"world-prov-1622","text":"Time and tide tarry for no man.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1622)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Time","author":"Public Domain Proverb"},"sequenceIndex":1621},{"id":"world-prov-1623","text":"Time assuages the greatest grief.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1623)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Time","author":"Public Domain Proverb"},"sequenceIndex":1622},{"id":"world-prov-1624","text":"Time cures sorrow.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1624)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Time","author":"Public Domain Proverb"},"sequenceIndex":1623},{"id":"world-prov-1625","text":"Time is the rider that breaks youth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1625)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Time","author":"Public Domain Proverb"},"sequenceIndex":1624},{"id":"world-prov-1626","text":"Time tries all.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1626)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Time","author":"Public Domain Proverb"},"sequenceIndex":1625},{"id":"world-prov-1627","text":"Timely blossom timely ripe.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1627)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Timely","author":"Public Domain Proverb"},"sequenceIndex":1626},{"id":"world-prov-1628","text":"Simon Noland, clown, is a better style and title than Humphrey Hadland, gent.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1628)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Title","author":"Public Domain Proverb"},"sequenceIndex":1627},{"id":"world-prov-1629","text":"To-day me, to-morrow thee.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1629)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"To-Day","author":"Public Domain Proverb"},"sequenceIndex":1628},{"id":"world-prov-1630","text":"He's Tom Tell-troth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1630)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tom","author":"Public Domain Proverb"},"sequenceIndex":1629},{"id":"world-prov-1631","text":"To-morrow comes never.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1631)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"To-Morrow","author":"Public Domain Proverb"},"sequenceIndex":1630},{"id":"world-prov-1632","text":"A man may hold his tongue in an ill time.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1632)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tongue","author":"Public Domain Proverb"},"sequenceIndex":1631},{"id":"world-prov-1633","text":"Temper the tongue.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1633)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tongue","author":"Public Domain Proverb"},"sequenceIndex":1632},{"id":"world-prov-1634","text":"Confine your tongue, lest it confine you.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1634)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tongue","author":"Public Domain Proverb"},"sequenceIndex":1633},{"id":"world-prov-1635","text":"Keep your tongue within your teeth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1635)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tongue","author":"Public Domain Proverb"},"sequenceIndex":1634},{"id":"world-prov-1636","text":"The tongue breaketh bone, Though itself have none.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1636)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tongue","author":"Public Domain Proverb"},"sequenceIndex":1635},{"id":"world-prov-1637","text":"The tongue's not steel, yet it cuts.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1637)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tongue","author":"Public Domain Proverb"},"sequenceIndex":1636},{"id":"world-prov-1638","text":"The tongue talks at the head's cost.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1638)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tongue","author":"Public Domain Proverb"},"sequenceIndex":1637},{"id":"world-prov-1639","text":"One tongue is enough for a woman.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1639)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tongue","author":"Public Domain Proverb"},"sequenceIndex":1638},{"id":"world-prov-1640","text":"Who has not a good tongue, ought to have good hands.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1640)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tongue","author":"Public Domain Proverb"},"sequenceIndex":1639},{"id":"world-prov-1641","text":"Better three hours too soon than a minute too late.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1641)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Too Late","author":"Public Domain Proverb"},"sequenceIndex":1640},{"id":"world-prov-1642","text":"A bad workman quarrels with his tools.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1642)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tools","author":"Public Domain Proverb"},"sequenceIndex":1641},{"id":"world-prov-1643","text":"What is a workman without his tools?","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1643)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tools","author":"Public Domain Proverb"},"sequenceIndex":1642},{"id":"world-prov-1644","text":"Too far east is west.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1644)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Too Far","author":"Public Domain Proverb"},"sequenceIndex":1643},{"id":"world-prov-1645","text":"He that grasps at too much, holds fast nothing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1645)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Too Much","author":"Public Domain Proverb"},"sequenceIndex":1644},{"id":"world-prov-1646","text":"We can't all be top sawyers.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1646)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Top Sawyers","author":"Public Domain Proverb"},"sequenceIndex":1645},{"id":"world-prov-1647","text":"He that hath a trade hath an estate.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1647)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Trade","author":"Public Domain Proverb"},"sequenceIndex":1646},{"id":"world-prov-1648","text":"Every man to his trade.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1648)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Trade","author":"Public Domain Proverb"},"sequenceIndex":1647},{"id":"world-prov-1649","text":"Trade knows neither friends nor kindred.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1649)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Trade","author":"Public Domain Proverb"},"sequenceIndex":1648},{"id":"world-prov-1650","text":"Trade is the mother of money.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1650)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Trade","author":"Public Domain Proverb"},"sequenceIndex":1649},{"id":"world-prov-1651","text":"Jack of all trades, and master of none.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1651)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Trades","author":"Public Domain Proverb"},"sequenceIndex":1650},{"id":"world-prov-1652","text":"A tradesman who gets not loseth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1652)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tradesman","author":"Public Domain Proverb"},"sequenceIndex":1651},{"id":"world-prov-1653","text":"He that travels far knows much.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1653)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Travels","author":"Public Domain Proverb"},"sequenceIndex":1652},{"id":"world-prov-1654","text":"A tree is known by its fruit, and not by its leaves.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1654)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tree","author":"Public Domain Proverb"},"sequenceIndex":1653},{"id":"world-prov-1655","text":"Remove an old tree and it will wither to death.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1655)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tree","author":"Public Domain Proverb"},"sequenceIndex":1654},{"id":"world-prov-1656","text":"Set trees poor, and they will grow rich; set them rich, and they will grow poor.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1656)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Trees","author":"Public Domain Proverb"},"sequenceIndex":1655},{"id":"world-prov-1657","text":"You cannot see wood for trees.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1657)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Trees","author":"Public Domain Proverb"},"sequenceIndex":1656},{"id":"world-prov-1658","text":"Fall not out with a friend for a trifle.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1658)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Trifle","author":"Public Domain Proverb"},"sequenceIndex":1657},{"id":"world-prov-1659","text":"He who seeketh trouble never misseth it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1659)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Trouble","author":"Public Domain Proverb"},"sequenceIndex":1658},{"id":"world-prov-1660","text":"Never fish in troubled waters.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1660)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Troubled Waters","author":"Public Domain Proverb"},"sequenceIndex":1659},{"id":"world-prov-1661","text":"Never make troubles of trifles.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1661)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Troubles","author":"Public Domain Proverb"},"sequenceIndex":1660},{"id":"world-prov-1662","text":"Hidden troubles disquiet most.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1662)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Troubles","author":"Public Domain Proverb"},"sequenceIndex":1661},{"id":"world-prov-1663","text":"There's many a true word spoken in jest.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1663)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"True Word","author":"Public Domain Proverb"},"sequenceIndex":1662},{"id":"world-prov-1664","text":"That is true which all men say.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1664)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"True","author":"Public Domain Proverb"},"sequenceIndex":1663},{"id":"world-prov-1665","text":"If you trust before you try, You may repent it ere you die.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1665)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Trust","author":"Public Domain Proverb"},"sequenceIndex":1664},{"id":"world-prov-1666","text":"Trust in God, and keep your powder dry.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1666)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Trust","author":"Public Domain Proverb"},"sequenceIndex":1665},{"id":"world-prov-1667","text":"Trust not a broken staff.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1667)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Trust Not","author":"Public Domain Proverb"},"sequenceIndex":1666},{"id":"world-prov-1668","text":"Trust not a horse's heel, nor a dog's tooth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1668)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Trust Not","author":"Public Domain Proverb"},"sequenceIndex":1667},{"id":"world-prov-1669","text":"Truth lies in a well.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1669)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Truth","author":"Public Domain Proverb"},"sequenceIndex":1668},{"id":"world-prov-1670","text":"Truth is stranger than fiction.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1670)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Truth","author":"Public Domain Proverb"},"sequenceIndex":1669},{"id":"world-prov-1671","text":"Fair fall truth and daylight.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1671)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Truth","author":"Public Domain Proverb"},"sequenceIndex":1670},{"id":"world-prov-1672","text":"Speak the truth and shame the devil.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1672)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Truth","author":"Public Domain Proverb"},"sequenceIndex":1671},{"id":"world-prov-1673","text":"Truth hath a good face, but bad clothes.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1673)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Truth","author":"Public Domain Proverb"},"sequenceIndex":1672},{"id":"world-prov-1674","text":"Truth may be blamed, but it can't be shamed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1674)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Truth","author":"Public Domain Proverb"},"sequenceIndex":1673},{"id":"world-prov-1675","text":"Whatever you do, whatever you say, Tell your doctor and lawyer the truth alway.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1675)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Truth","author":"Public Domain Proverb"},"sequenceIndex":1674},{"id":"world-prov-1676","text":"Try your friend before you trust him.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1676)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Try","author":"Public Domain Proverb"},"sequenceIndex":1675},{"id":"world-prov-1677","text":"Every tub must stand on its own bottom.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1677)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Tub","author":"Public Domain Proverb"},"sequenceIndex":1676},{"id":"world-prov-1678","text":"One good turn deserves another.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1678)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Turn","author":"Public Domain Proverb"},"sequenceIndex":1677},{"id":"world-prov-1679","text":"Swine, women, and bees are not to be turned.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1679)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Turned","author":"Public Domain Proverb"},"sequenceIndex":1678},{"id":"world-prov-1680","text":"At twelfth-day the days are lengthened a cock's stride.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1680)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Twelfth Day","author":"Public Domain Proverb"},"sequenceIndex":1679},{"id":"world-prov-1681","text":"As good twenty as nineteen.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1681)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Twenty","author":"Public Domain Proverb"},"sequenceIndex":1680},{"id":"world-prov-1682","text":"If things were to be done twice, all would be wise.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1682)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Twice","author":"Public Domain Proverb"},"sequenceIndex":1681},{"id":"world-prov-1683","text":"Never carry two faces under one hat.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1683)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Two Faces","author":"Public Domain Proverb"},"sequenceIndex":1682},{"id":"world-prov-1684","text":"Two heads are better than one.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1684)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Two Heads","author":"Public Domain Proverb"},"sequenceIndex":1683},{"id":"world-prov-1685","text":"One cannot be in two places at once.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1685)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Two Places","author":"Public Domain Proverb"},"sequenceIndex":1684},{"id":"world-prov-1686","text":"When two Sundays come in one week--that is, never. U","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1686)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Two Sundays","author":"Public Domain Proverb"},"sequenceIndex":1685},{"id":"world-prov-1687","text":"An unhappy lad may make a good man.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1687)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Unhappy","author":"Public Domain Proverb"},"sequenceIndex":1686},{"id":"world-prov-1688","text":"The greatest number is made up of units.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1688)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Units","author":"Public Domain Proverb"},"sequenceIndex":1687},{"id":"world-prov-1689","text":"Unknown, unmissed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1689)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Unknown","author":"Public Domain Proverb"},"sequenceIndex":1688},{"id":"world-prov-1690","text":"Unminded, unmoaned.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1690)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Unminded","author":"Public Domain Proverb"},"sequenceIndex":1689},{"id":"world-prov-1691","text":"Better untaught than ill-taught.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1691)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Untaught","author":"Public Domain Proverb"},"sequenceIndex":1690},{"id":"world-prov-1692","text":"Use is second nature.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1692)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Use","author":"Public Domain Proverb"},"sequenceIndex":1691},{"id":"world-prov-1693","text":"Use the means, and God will give the blessing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1693)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Use","author":"Public Domain Proverb"},"sequenceIndex":1692},{"id":"world-prov-1694","text":"Utility is preferable to grandeur. V","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1694)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Utility","author":"Public Domain Proverb"},"sequenceIndex":1693},{"id":"world-prov-1695","text":"On Valentine's day will a good goose lay, If she be a good goose, her dame well to pay, She will lay two eggs before Valentine's day.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1695)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Valentine'S Day","author":"Public Domain Proverb"},"sequenceIndex":1694},{"id":"world-prov-1696","text":"He who stays in the valley will never get over the hill.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1696)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Valley","author":"Public Domain Proverb"},"sequenceIndex":1695},{"id":"world-prov-1697","text":"Valour can do little without discretion.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1697)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Valour","author":"Public Domain Proverb"},"sequenceIndex":1696},{"id":"world-prov-1698","text":"Valour that parleys is near yielding.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1698)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Valour","author":"Public Domain Proverb"},"sequenceIndex":1697},{"id":"world-prov-1699","text":"Nothing venture nothing win.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1699)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Venture","author":"Public Domain Proverb"},"sequenceIndex":1698},{"id":"world-prov-1700","text":"Venture a small fish to catch a great one.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1700)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Venture","author":"Public Domain Proverb"},"sequenceIndex":1699},{"id":"world-prov-1701","text":"Venture not all in one ship.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1701)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Venture","author":"Public Domain Proverb"},"sequenceIndex":1700},{"id":"world-prov-1702","text":"Fools think themselves wise to the very last.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1702)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Very Last","author":"Public Domain Proverb"},"sequenceIndex":1701},{"id":"world-prov-1703","text":"The vicar of Bray will be vicar of Bray still.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1703)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Vicar Of Bray","author":"Public Domain Proverb"},"sequenceIndex":1702},{"id":"world-prov-1704","text":"Vice is nourished by being concealed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1704)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Vice","author":"Public Domain Proverb"},"sequenceIndex":1703},{"id":"world-prov-1705","text":"Make the vine poor, and it will make you rich.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1705)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Vine","author":"Public Domain Proverb"},"sequenceIndex":1704},{"id":"world-prov-1706","text":"The sweetest wine makes the sharpest vinegar.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1706)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Vinegar","author":"Public Domain Proverb"},"sequenceIndex":1705},{"id":"world-prov-1707","text":"Search others for their virtues, thyself for their faults.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1707)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Virtues","author":"Public Domain Proverb"},"sequenceIndex":1706},{"id":"world-prov-1708","text":"Vows made in storms are forgotten in calms. W","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1708)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Vows","author":"Public Domain Proverb"},"sequenceIndex":1707},{"id":"world-prov-1709","text":"A wager is a fool's argument.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1709)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wager","author":"Public Domain Proverb"},"sequenceIndex":1708},{"id":"world-prov-1710","text":"He who serves well need not be afraid to ask his wages.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1710)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wages","author":"Public Domain Proverb"},"sequenceIndex":1709},{"id":"world-prov-1711","text":"He that waits on another man's trencher, makes many a late dinner.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1711)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Waits","author":"Public Domain Proverb"},"sequenceIndex":1710},{"id":"world-prov-1712","text":"The worth of a thing is best known by the want of it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1712)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Want","author":"Public Domain Proverb"},"sequenceIndex":1711},{"id":"world-prov-1713","text":"For want of a nail the shoe is lost; for want of a shoe the horse is lost; for want of a horse the rider is lost.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1713)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Want Of","author":"Public Domain Proverb"},"sequenceIndex":1712},{"id":"world-prov-1714","text":"War, hunting, and law, are as full of trouble as pleasure.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1714)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"War","author":"Public Domain Proverb"},"sequenceIndex":1713},{"id":"world-prov-1715","text":"War is death's feast.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1715)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"War","author":"Public Domain Proverb"},"sequenceIndex":1714},{"id":"world-prov-1716","text":"Who preacheth war is the devil's chaplain.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1716)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"War","author":"Public Domain Proverb"},"sequenceIndex":1715},{"id":"world-prov-1717","text":"He that makes a good war makes a good peace.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1717)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"War (Good)","author":"Public Domain Proverb"},"sequenceIndex":1716},{"id":"world-prov-1718","text":"Good wares make quick markets.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1718)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wares (Good)","author":"Public Domain Proverb"},"sequenceIndex":1717},{"id":"world-prov-1719","text":"He that is warm thinks all are so.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1719)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Warm","author":"Public Domain Proverb"},"sequenceIndex":1718},{"id":"world-prov-1720","text":"He is wise enough that can keep himself warm in winter.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1720)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Warm","author":"Public Domain Proverb"},"sequenceIndex":1719},{"id":"world-prov-1721","text":"The head and feet kept warm, The rest will take no harm.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1721)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Warm","author":"Public Domain Proverb"},"sequenceIndex":1720},{"id":"world-prov-1722","text":"There's no washing the blackamore white.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1722)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Washing","author":"Public Domain Proverb"},"sequenceIndex":1721},{"id":"world-prov-1723","text":"Waste not, want not.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1723)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Waste","author":"Public Domain Proverb"},"sequenceIndex":1722},{"id":"world-prov-1724","text":"Wilful waste makes woeful want.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1724)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Waste","author":"Public Domain Proverb"},"sequenceIndex":1723},{"id":"world-prov-1725","text":"Good watch prevents misfortune.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1725)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Watch","author":"Public Domain Proverb"},"sequenceIndex":1724},{"id":"world-prov-1726","text":"You may be a wise man though you cannot make a watch.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1726)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Watch","author":"Public Domain Proverb"},"sequenceIndex":1725},{"id":"world-prov-1727","text":"A watched pot never boils.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1727)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Watched Pot","author":"Public Domain Proverb"},"sequenceIndex":1726},{"id":"world-prov-1728","text":"Water bewitched.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1728)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Water","author":"Public Domain Proverb"},"sequenceIndex":1727},{"id":"world-prov-1729","text":"We never know the worth of water till the well is dry.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1729)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Water","author":"Public Domain Proverb"},"sequenceIndex":1728},{"id":"world-prov-1730","text":"He that hath a head of wax must not walk in the sun.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1730)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wax","author":"Public Domain Proverb"},"sequenceIndex":1729},{"id":"world-prov-1731","text":"Where there's a will there's a way.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1731)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Way","author":"Public Domain Proverb"},"sequenceIndex":1730},{"id":"world-prov-1732","text":"There are more ways to kill a dog than hanging.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1732)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ways (More)","author":"Public Domain Proverb"},"sequenceIndex":1731},{"id":"world-prov-1733","text":"To him that wills ways are not wanting.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1733)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Ways","author":"Public Domain Proverb"},"sequenceIndex":1732},{"id":"world-prov-1734","text":"Let the weakest go to the wall.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1734)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Weakest","author":"Public Domain Proverb"},"sequenceIndex":1733},{"id":"world-prov-1735","text":"Where it is weakest there the thread breaketh.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1735)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Weakest","author":"Public Domain Proverb"},"sequenceIndex":1734},{"id":"world-prov-1736","text":"Their folly pleads the privilege of wealth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1736)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wealth","author":"Public Domain Proverb"},"sequenceIndex":1735},{"id":"world-prov-1737","text":"The wearer best knows where the shoe pinches.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1737)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wearer","author":"Public Domain Proverb"},"sequenceIndex":1736},{"id":"world-prov-1738","text":"Everything is the worse for wearing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1738)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wearing","author":"Public Domain Proverb"},"sequenceIndex":1737},{"id":"world-prov-1739","text":"Constant dropping wears the stone.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1739)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wears","author":"Public Domain Proverb"},"sequenceIndex":1738},{"id":"world-prov-1740","text":"'Tis pity fair weather should do any harm.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1740)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Weather","author":"Public Domain Proverb"},"sequenceIndex":1739},{"id":"world-prov-1741","text":"Any flat can talk of change of weather.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1741)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Weather (Change)","author":"Public Domain Proverb"},"sequenceIndex":1740},{"id":"world-prov-1742","text":"Wedding and ill-wintering tame both man and beast.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1742)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wedding","author":"Public Domain Proverb"},"sequenceIndex":1741},{"id":"world-prov-1743","text":"Wedlock is a padlock.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1743)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wedlock","author":"Public Domain Proverb"},"sequenceIndex":1742},{"id":"world-prov-1744","text":"Who weds ere he be wise shall die ere he thrive.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1744)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Weds","author":"Public Domain Proverb"},"sequenceIndex":1743},{"id":"world-prov-1745","text":"As great a pity to see a woman weep, as to see a goose go barefoot.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1745)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Weep","author":"Public Domain Proverb"},"sequenceIndex":1744},{"id":"world-prov-1746","text":"As welcome as the flowers in May.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1746)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Welcome","author":"Public Domain Proverb"},"sequenceIndex":1745},{"id":"world-prov-1747","text":"\"Welcome death,\" quoth the rat, when the trap fell down.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1747)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Welcome","author":"Public Domain Proverb"},"sequenceIndex":1746},{"id":"world-prov-1748","text":"Welcome is the best dish on the table.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1748)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Welcome","author":"Public Domain Proverb"},"sequenceIndex":1747},{"id":"world-prov-1749","text":"Let well alone.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1749)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Well","author":"Public Domain Proverb"},"sequenceIndex":1748},{"id":"world-prov-1750","text":"When the well is dug it is easy enough to pump.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1750)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Well","author":"Public Domain Proverb"},"sequenceIndex":1749},{"id":"world-prov-1751","text":"Be not weary of well-doing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1751)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Well-Doing","author":"Public Domain Proverb"},"sequenceIndex":1750},{"id":"world-prov-1752","text":"All things are soon prepared in a well-ordered house.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1752)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Well-Ordered","author":"Public Domain Proverb"},"sequenceIndex":1751},{"id":"world-prov-1753","text":"Well-drawn wells give the sweetest water.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1753)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wells","author":"Public Domain Proverb"},"sequenceIndex":1752},{"id":"world-prov-1754","text":"I wept when I was born, and every day shows why.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1754)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wept","author":"Public Domain Proverb"},"sequenceIndex":1753},{"id":"world-prov-1755","text":"A whet is no let [hindrance].","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1755)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Whet","author":"Public Domain Proverb"},"sequenceIndex":1754},{"id":"world-prov-1756","text":"You may pay too dear for your whistle.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1756)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Whistle","author":"Public Domain Proverb"},"sequenceIndex":1755},{"id":"world-prov-1757","text":"There's ne'er a why, but there's a wherefore.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1757)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Why","author":"Public Domain Proverb"},"sequenceIndex":1756},{"id":"world-prov-1758","text":"Wide will wear but narrow will tear.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1758)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wide","author":"Public Domain Proverb"},"sequenceIndex":1757},{"id":"world-prov-1759","text":"Choose your wife on Saturday, and not on a Sunday.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1759)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wife","author":"Public Domain Proverb"},"sequenceIndex":1758},{"id":"world-prov-1760","text":"He that goes far from home for a wife, either intends to cheat or will be cheated.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1760)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wife","author":"Public Domain Proverb"},"sequenceIndex":1759},{"id":"world-prov-1761","text":"A man's best fortune or his worst is his wife.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1761)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wife","author":"Public Domain Proverb"},"sequenceIndex":1760},{"id":"world-prov-1762","text":"There is one good wife in the country, and every man thinks he hath her.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1762)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wife","author":"Public Domain Proverb"},"sequenceIndex":1761},{"id":"world-prov-1763","text":"A good wife makes a good husband.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1763)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wife (Good)","author":"Public Domain Proverb"},"sequenceIndex":1762},{"id":"world-prov-1764","text":"A good wife and health Are a man's best wealth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1764)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wife (Good)","author":"Public Domain Proverb"},"sequenceIndex":1763},{"id":"world-prov-1765","text":"Saith Solomon the wise A good wife's a prize.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1765)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wife (Good)","author":"Public Domain Proverb"},"sequenceIndex":1764},{"id":"world-prov-1766","text":"He that tells his wife news is but newly married.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1766)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wife (News)","author":"Public Domain Proverb"},"sequenceIndex":1765},{"id":"world-prov-1767","text":"Happy is he who hath sown his wild oats betimes.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1767)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wild Oats","author":"Public Domain Proverb"},"sequenceIndex":1766},{"id":"world-prov-1768","text":"Wise men are not caught by wiles.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1768)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wiles","author":"Public Domain Proverb"},"sequenceIndex":1767},{"id":"world-prov-1769","text":"If wilful will to water, wilful must be drowned.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1769)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wilful","author":"Public Domain Proverb"},"sequenceIndex":1768},{"id":"world-prov-1770","text":"A wilful man never wants woe.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1770)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wilful Man","author":"Public Domain Proverb"},"sequenceIndex":1769},{"id":"world-prov-1771","text":"Take the will for the deed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1771)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Will","author":"Public Domain Proverb"},"sequenceIndex":1770},{"id":"world-prov-1772","text":"They that cannot do as they will, must do as they can.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1772)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Will","author":"Public Domain Proverb"},"sequenceIndex":1771},{"id":"world-prov-1773","text":"Will without reason is blind.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1773)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Will","author":"Public Domain Proverb"},"sequenceIndex":1772},{"id":"world-prov-1774","text":"If one will not, another will.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1774)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Will Not","author":"Public Domain Proverb"},"sequenceIndex":1773},{"id":"world-prov-1775","text":"Where the will is ready, the feet are light.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1775)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Will (Ready)","author":"Public Domain Proverb"},"sequenceIndex":1774},{"id":"world-prov-1776","text":"Where there's a will there's a way.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1776)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Will (Way)","author":"Public Domain Proverb"},"sequenceIndex":1775},{"id":"world-prov-1777","text":"All lay load on the willing horse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1777)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Willing Horse","author":"Public Domain Proverb"},"sequenceIndex":1776},{"id":"world-prov-1778","text":"Nothing is impossible to a willing mind.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1778)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Willing Mind","author":"Public Domain Proverb"},"sequenceIndex":1777},{"id":"world-prov-1779","text":"Willows are weak, yet they bend other wood.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1779)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Willows","author":"Public Domain Proverb"},"sequenceIndex":1778},{"id":"world-prov-1780","text":"Win first, lose last.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1780)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Win","author":"Public Domain Proverb"},"sequenceIndex":1779},{"id":"world-prov-1781","text":"When the wind's in the north You need not go forth [_to fish_].","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1781)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wind (North)","author":"Public Domain Proverb"},"sequenceIndex":1780},{"id":"world-prov-1782","text":"When the wind's in the east The fish will bite least.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1782)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wind (East)","author":"Public Domain Proverb"},"sequenceIndex":1781},{"id":"world-prov-1783","text":"When the wind's in the south The bait goes in their mouth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1783)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wind (South)","author":"Public Domain Proverb"},"sequenceIndex":1782},{"id":"world-prov-1784","text":"When the wind's in the west The fish will bite best.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1784)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wind (West)","author":"Public Domain Proverb"},"sequenceIndex":1783},{"id":"world-prov-1785","text":"Where the wind is on Candlemas Day There it will stick to the end of May.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1785)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wind","author":"Public Domain Proverb"},"sequenceIndex":1784},{"id":"world-prov-1786","text":"When the wind is in the east, 'Tis neither good for man nor beast.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1786)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wind (East)","author":"Public Domain Proverb"},"sequenceIndex":1785},{"id":"world-prov-1787","text":"It's an ill wind that blows nobody good.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1787)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wind (Ill)","author":"Public Domain Proverb"},"sequenceIndex":1786},{"id":"world-prov-1788","text":"When the wind's in the south It's in the rain's mouth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1788)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wind (South)","author":"Public Domain Proverb"},"sequenceIndex":1787},{"id":"world-prov-1789","text":"No weather is ill If the wind be still.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1789)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wind (Still)","author":"Public Domain Proverb"},"sequenceIndex":1788},{"id":"world-prov-1790","text":"None ever yet got fat on windfalls.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1790)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Windfalls","author":"Public Domain Proverb"},"sequenceIndex":1789},{"id":"world-prov-1791","text":"You cannot drive a windmill with a pair of bellows.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1791)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Windmill","author":"Public Domain Proverb"},"sequenceIndex":1790},{"id":"world-prov-1792","text":"More have been drowned in wine than water.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1792)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wine","author":"Public Domain Proverb"},"sequenceIndex":1791},{"id":"world-prov-1793","text":"When wine sinks, words swim.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1793)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wine","author":"Public Domain Proverb"},"sequenceIndex":1792},{"id":"world-prov-1794","text":"Wine is the master's, but the goodness is the drawer's.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1794)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wine","author":"Public Domain Proverb"},"sequenceIndex":1793},{"id":"world-prov-1795","text":"Good wine needs no bush.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1795)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wine (Good)","author":"Public Domain Proverb"},"sequenceIndex":1794},{"id":"world-prov-1796","text":"When wine is in, wit is out.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1796)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wine (In)","author":"Public Domain Proverb"},"sequenceIndex":1795},{"id":"world-prov-1797","text":"Wine is a turncoat, first a friend, then an enemy.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1797)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wine (Turncoat)","author":"Public Domain Proverb"},"sequenceIndex":1796},{"id":"world-prov-1798","text":"Wink at small faults.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1798)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wink","author":"Public Domain Proverb"},"sequenceIndex":1797},{"id":"world-prov-1799","text":"A wink's as good as a nod to a blind horse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1799)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wink","author":"Public Domain Proverb"},"sequenceIndex":1798},{"id":"world-prov-1800","text":"A good winter brings a good summer.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1800)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Winter (Good)","author":"Public Domain Proverb"},"sequenceIndex":1799},{"id":"world-prov-1801","text":"Winter finds out what summer lays up.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1801)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Winter","author":"Public Domain Proverb"},"sequenceIndex":1800},{"id":"world-prov-1802","text":"By wisdom peace, by peace plenty.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1802)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wisdom","author":"Public Domain Proverb"},"sequenceIndex":1801},{"id":"world-prov-1803","text":"The fear of the Lord is the beginning of wisdom.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1803)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wisdom","author":"Public Domain Proverb"},"sequenceIndex":1802},{"id":"world-prov-1804","text":"Wisdom rides upon the ruins of folly.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1804)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wisdom","author":"Public Domain Proverb"},"sequenceIndex":1803},{"id":"world-prov-1805","text":"Better wise than wealthy.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1805)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wise","author":"Public Domain Proverb"},"sequenceIndex":1804},{"id":"world-prov-1806","text":"Wise men care not for what they cannot have.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1806)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wise Men","author":"Public Domain Proverb"},"sequenceIndex":1805},{"id":"world-prov-1807","text":"If wishes were horses, beggars would ride.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1807)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wishes","author":"Public Domain Proverb"},"sequenceIndex":1806},{"id":"world-prov-1808","text":"If wishes were thrushes, beggars would eat birds.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1808)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wishes","author":"Public Domain Proverb"},"sequenceIndex":1807},{"id":"world-prov-1809","text":"If wishes would bide, beggars would ride.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1809)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wishes","author":"Public Domain Proverb"},"sequenceIndex":1808},{"id":"world-prov-1810","text":"If wishes were butter-cakes, beggars would bite.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1810)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wishes","author":"Public Domain Proverb"},"sequenceIndex":1809},{"id":"world-prov-1811","text":"Wit is the lightning of the mind.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1811)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wit","author":"Public Domain Proverb"},"sequenceIndex":1810},{"id":"world-prov-1812","text":"Wit bought is twice taught.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1812)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wit","author":"Public Domain Proverb"},"sequenceIndex":1811},{"id":"world-prov-1813","text":"You may truss up all his wit in an egg-shell.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1813)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wit","author":"Public Domain Proverb"},"sequenceIndex":1812},{"id":"world-prov-1814","text":"Wit ill applied is a dangerous weapon.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1814)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wit","author":"Public Domain Proverb"},"sequenceIndex":1813},{"id":"world-prov-1815","text":"Wit is folly, unless a wise man hath the keeping of it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1815)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wit","author":"Public Domain Proverb"},"sequenceIndex":1814},{"id":"world-prov-1816","text":"Wit may be bought too dear.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1816)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wit","author":"Public Domain Proverb"},"sequenceIndex":1815},{"id":"world-prov-1817","text":"He that lives upon his wits, breaks for want of stock.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1817)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wits","author":"Public Domain Proverb"},"sequenceIndex":1816},{"id":"world-prov-1818","text":"A man cannot both wive and thrive in a year.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1818)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wive","author":"Public Domain Proverb"},"sequenceIndex":1817},{"id":"world-prov-1819","text":"Woe follows wickedness.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1819)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Woe","author":"Public Domain Proverb"},"sequenceIndex":1818},{"id":"world-prov-1820","text":"He had enough to keep the wolf from the door.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1820)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wolf","author":"Public Domain Proverb"},"sequenceIndex":1819},{"id":"world-prov-1821","text":"Wolves lose their teeth, but not their memory.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1821)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wolves","author":"Public Domain Proverb"},"sequenceIndex":1820},{"id":"world-prov-1822","text":"A woman's strength is in her tongue.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1822)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Woman'S Strength","author":"Public Domain Proverb"},"sequenceIndex":1821},{"id":"world-prov-1823","text":"A woman's work is never at an end.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1823)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Woman'S Work","author":"Public Domain Proverb"},"sequenceIndex":1822},{"id":"world-prov-1824","text":"Discreet women have neither eyes nor ears.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1824)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Women","author":"Public Domain Proverb"},"sequenceIndex":1823},{"id":"world-prov-1825","text":"Women must have their wills while they live, because they make none when they die.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1825)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Women (Wills)","author":"Public Domain Proverb"},"sequenceIndex":1824},{"id":"world-prov-1826","text":"A wonder lasts but nine days.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1826)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wonder","author":"Public Domain Proverb"},"sequenceIndex":1825},{"id":"world-prov-1827","text":"To woo is a pleasure in young men, a fault in old.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1827)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Woo","author":"Public Domain Proverb"},"sequenceIndex":1826},{"id":"world-prov-1828","text":"One woodcock does not make a winter.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1828)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Woodcock","author":"Public Domain Proverb"},"sequenceIndex":1827},{"id":"world-prov-1829","text":"Happy is the wooing, That is not long a-doing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1829)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wooing","author":"Public Domain Proverb"},"sequenceIndex":1828},{"id":"world-prov-1830","text":"Many go for wool and come back shorn.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1830)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wool","author":"Public Domain Proverb"},"sequenceIndex":1829},{"id":"world-prov-1831","text":"Wool sellers know wool buyers.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1831)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wool Sellers","author":"Public Domain Proverb"},"sequenceIndex":1830},{"id":"world-prov-1832","text":"An honest man's word is as good as his bond.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1832)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Word","author":"Public Domain Proverb"},"sequenceIndex":1831},{"id":"world-prov-1833","text":"A man of words and not of deeds, Is like a garden full of weeds.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1833)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Words","author":"Public Domain Proverb"},"sequenceIndex":1832},{"id":"world-prov-1834","text":"Words are but sands, 'Tis money buys lands.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1834)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Words","author":"Public Domain Proverb"},"sequenceIndex":1833},{"id":"world-prov-1835","text":"Sometimes words Wound more than swords.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1835)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Words","author":"Public Domain Proverb"},"sequenceIndex":1834},{"id":"world-prov-1836","text":"Words are like weights, gravity gives them effect.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1836)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Words","author":"Public Domain Proverb"},"sequenceIndex":1835},{"id":"world-prov-1837","text":"Words are for women, actions for men.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1837)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Words","author":"Public Domain Proverb"},"sequenceIndex":1836},{"id":"world-prov-1838","text":"Words are but wind, But blows unkind.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1838)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Words And Blows","author":"Public Domain Proverb"},"sequenceIndex":1837},{"id":"world-prov-1839","text":"A word is enough to the wise.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1839)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Word (Enough)","author":"Public Domain Proverb"},"sequenceIndex":1838},{"id":"world-prov-1840","text":"Words spoken in an evening the wind carrieth away.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1840)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Words (Evening)","author":"Public Domain Proverb"},"sequenceIndex":1839},{"id":"world-prov-1841","text":"Fair words butter no parsnips.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1841)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Words (Fair)","author":"Public Domain Proverb"},"sequenceIndex":1840},{"id":"world-prov-1842","text":"Fair words will not keep a cat from starving.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1842)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Words (Fair)","author":"Public Domain Proverb"},"sequenceIndex":1841},{"id":"world-prov-1843","text":"Few words are best.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1843)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Words (Few)","author":"Public Domain Proverb"},"sequenceIndex":1842},{"id":"world-prov-1844","text":"Good words cool more than cold water.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1844)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Words (Good)","author":"Public Domain Proverb"},"sequenceIndex":1843},{"id":"world-prov-1845","text":"Good words fill not a sack.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1845)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Words (Good)","author":"Public Domain Proverb"},"sequenceIndex":1844},{"id":"world-prov-1846","text":"Many words will not fill a bushel.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1846)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Words (Many)","author":"Public Domain Proverb"},"sequenceIndex":1845},{"id":"world-prov-1847","text":"Soft words hurt not the mouth.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1847)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Words (Soft)","author":"Public Domain Proverb"},"sequenceIndex":1846},{"id":"world-prov-1848","text":"They that will not work in heat, must hunger in frost.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1848)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Work","author":"Public Domain Proverb"},"sequenceIndex":1847},{"id":"world-prov-1849","text":"Bad workmen always complain of their tools.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1849)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Workmen (Bad)","author":"Public Domain Proverb"},"sequenceIndex":1848},{"id":"world-prov-1850","text":"One half of the world knows not how the other half lives.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1850)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"World","author":"Public Domain Proverb"},"sequenceIndex":1849},{"id":"world-prov-1851","text":"The world is his who knows how to wait for it.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1851)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"World","author":"Public Domain Proverb"},"sequenceIndex":1850},{"id":"world-prov-1852","text":"The world was never so dull but if one won't another will.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1852)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"World","author":"Public Domain Proverb"},"sequenceIndex":1851},{"id":"world-prov-1853","text":"This world is nothing except it tend to the next.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1853)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"World","author":"Public Domain Proverb"},"sequenceIndex":1852},{"id":"world-prov-1854","text":"There needs a long time to know the world's pulse.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1854)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"World'S Pulse","author":"Public Domain Proverb"},"sequenceIndex":1853},{"id":"world-prov-1855","text":"Tread on a worm and it will turn.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1855)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Worm","author":"Public Domain Proverb"},"sequenceIndex":1854},{"id":"world-prov-1856","text":"When things get to the worst, they'll mend.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1856)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Worst","author":"Public Domain Proverb"},"sequenceIndex":1855},{"id":"world-prov-1857","text":"The worst spoke in the cart-wheel breaks first.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1857)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Worst Spoke","author":"Public Domain Proverb"},"sequenceIndex":1856},{"id":"world-prov-1858","text":"\"He that wolde not when he might, He shall not when he wold-a.\"","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1858)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Would","author":"Public Domain Proverb"},"sequenceIndex":1857},{"id":"world-prov-1859","text":"Wounds may heal, but not those made by ill words.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1859)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wounds","author":"Public Domain Proverb"},"sequenceIndex":1858},{"id":"world-prov-1860","text":"Wranglers never want words.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1860)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wranglers","author":"Public Domain Proverb"},"sequenceIndex":1859},{"id":"world-prov-1861","text":"A soft answer turneth away wrath.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1861)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wrath","author":"Public Domain Proverb"},"sequenceIndex":1860},{"id":"world-prov-1862","text":"He that is thrown would ever wrestle.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1862)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wrestle","author":"Public Domain Proverb"},"sequenceIndex":1861},{"id":"world-prov-1863","text":"He who maketh others wretched is himself a wretch, whether prince or peasant.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1863)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wretch","author":"Public Domain Proverb"},"sequenceIndex":1862},{"id":"world-prov-1864","text":"Two wrongs will not make a right.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1864)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wrongs","author":"Public Domain Proverb"},"sequenceIndex":1863},{"id":"world-prov-1865","text":"To take the wrong sow by the ear. Y","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1865)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Wrong Sow","author":"Public Domain Proverb"},"sequenceIndex":1864},{"id":"world-prov-1866","text":"Say no ill of the year till it is passed.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1866)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Year","author":"Public Domain Proverb"},"sequenceIndex":1865},{"id":"world-prov-1867","text":"Years know more than books.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1867)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Years","author":"Public Domain Proverb"},"sequenceIndex":1866},{"id":"world-prov-1868","text":"Between a woman's yes and no, There is not room for a pin to go.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1868)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Yes And No","author":"Public Domain Proverb"},"sequenceIndex":1867},{"id":"world-prov-1869","text":"Yorkshire fashion--every man pay his share.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1869)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Yorkshire","author":"Public Domain Proverb"},"sequenceIndex":1868},{"id":"world-prov-1870","text":"Old young, and old long.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1870)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Young","author":"Public Domain Proverb"},"sequenceIndex":1869},{"id":"world-prov-1871","text":"Help yourself and your friends will like you.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1871)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Yourself","author":"Public Domain Proverb"},"sequenceIndex":1870},{"id":"world-prov-1872","text":"If you want a thing done, do it yourself.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1872)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Yourself","author":"Public Domain Proverb"},"sequenceIndex":1871},{"id":"world-prov-1873","text":"A growing youth hath a wolf in his stomach.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1873)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Youth","author":"Public Domain Proverb"},"sequenceIndex":1872},{"id":"world-prov-1874","text":"If youth knew what age would crave. It would both get and save.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1874)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Youth","author":"Public Domain Proverb"},"sequenceIndex":1873},{"id":"world-prov-1875","text":"Youth and white paper take any impression.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1875)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Youth","author":"Public Domain Proverb"},"sequenceIndex":1874},{"id":"world-prov-1876","text":"Youth will have its swing.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1876)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Youth","author":"Public Domain Proverb"},"sequenceIndex":1875},{"id":"world-prov-1877","text":"Yule is good on Yule even. Z","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1877)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Yule","author":"Public Domain Proverb"},"sequenceIndex":1876},{"id":"world-prov-1878","text":"Zeal without knowledge is fire without light.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1878)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Zeal","author":"Public Domain Proverb"},"sequenceIndex":1877},{"id":"world-prov-1879","text":"Zeal without knowledge is frenzy.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1879)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Zeal","author":"Public Domain Proverb"},"sequenceIndex":1878},{"id":"world-prov-1880","text":"Zeal without knowledge is the sister of folly.","author":"Public Domain Proverb","source":"A Dictionary of English Proverbs (1880)","tags":["proverb","language:english","collection:proverbs"],"isProverb":true,"groups":{"topic":"Zeal","author":"Public Domain Proverb"},"sequenceIndex":1879}]}
{"formatVersion":"1","manifest":{"primaryCategory":"Proverbs & Folk Wisdom","subcategory":"African","audienceTags":["tradition:animism","theme:wisdom","theme:community"],"sortPriority":62,"groupingLevels":[],"groupingLabels":[],"dataPath":"Data/Collections/Yoruba_Proverbs.json","supplementalDataPath":null,"languageCode":"en","displayNameEnglish":"Yoruba Proverbs","script":"Latin","isRTL":false,"transliterationAvailable":false,"contentRating":"general","sourceId":"yorubaProverbs","displayName":"Yoruba Proverbs","version":"1.0","language":"English","edition":"Oral Tradition & Burton 1865","type":"quotes","browseOrder":"sequence","itemCount":300,"supportsRandom":true,"supportsBrowse":true},"data":[{"id":"yoruba-000001","text":"Oju to ba sunkun omo re, ko ni ri omo eniyan miran sunkun.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000002","text":"A ki i fi owo otun fun ni ki a si fi owo osi gba.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000003","text":"Bi a ba fori we ile eni, a o mo eni to ni ile.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000004","text":"Eniyan ni aso mi.","author":"Yoruba Proverb","source":"Yoruba oral tradition — Ubuntu variant","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000005","text":"Arugbo ti a ba mo ni iya a si mo bi a ti n da ogun si.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000006","text":"Ko si eni ti o dagba ju ojo ti o ti gbe aiye wa lo.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000007","text":"Eni ti o ni iwa rere, ko si ohun ti yio buru fun.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000008","text":"Bi eran ba ti de enu, ki i to de ikun maa n lo.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000009","text":"A ki i fi ori itan se ori agbado.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000010","text":"Agba ki wa ni oja, ki ori omo tuntun o wo.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000011","text":"Bi odo ba gun, igba ni o n so igi sile.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000012","text":"Ibi ti a ti bi ni ile eni, aye lo jeki a ri ile miran.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000013","text":"Agbado to ba gun ina ki i ro pelu egbin.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000014","text":"Eni ti o ba wi pe oun ti ko oja, oun ni o maa n ta oja.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000015","text":"Ko si ogun to dara ju iwa rere lo.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000016","text":"Omi to ba dakun ki i gbori apata.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000017","text":"Eni ti o ba ni emi, ki o ma paro.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000018","text":"Bi ewe ti n dagba, bebe ti n po si i.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000019","text":"A perfect character is the best jewel in the world.","author":"Yoruba Proverb","source":"Yoruba oral tradition — Owomoyela 1988","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000020","text":"The elder who stays at home while the battle rages does not deserve a share of the spoils.","author":"Yoruba Proverb","source":"Yoruba oral tradition — Owomoyela 1988","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000021","text":"However long the night, the dawn will break.","author":"Yoruba Proverb","source":"Yoruba proverb — widely documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000022","text":"Until the lion learns to write, every story will glorify the hunter.","author":"Yoruba Proverb","source":"Yoruba proverb — widely documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000023","text":"A child who is not embraced by the village will burn it down to feel its warmth.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000024","text":"Not to know is bad; not to wish to know is worse.","author":"Yoruba Proverb","source":"Yoruba proverb — widely documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000025","text":"Speak softly and carry a big stick; you will go far.","author":"Yoruba Proverb","source":"Yoruba proverb — documented by Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000026","text":"Rain does not fall on one roof alone.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000027","text":"When the music changes, so does the dance.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000028","text":"Knowledge is like a garden: if it is not cultivated, it cannot be harvested.","author":"Yoruba Proverb","source":"West African proverb — Guinean origin","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000029","text":"The forest would be silent if no bird sang except the one that sang best.","author":"Yoruba Proverb","source":"West African proverb","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000030","text":"A tree is straightened while it is young.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000031","text":"The hand that gives is always above the hand that receives.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000032","text":"One who tells the stories rules the world.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000033","text":"The axe forgets, but the tree remembers.","author":"Yoruba Proverb","source":"African proverb — widely documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000034","text":"If you want to go fast, go alone. If you want to go far, go together.","author":"Yoruba Proverb","source":"African proverb — widely documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000035","text":"He who learns, teaches.","author":"Yoruba Proverb","source":"Ethiopian proverb — often attributed pan-African","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000036","text":"Wisdom is like a baobab tree; no one individual can embrace it.","author":"Yoruba Proverb","source":"Akan proverb — Christaller 1879","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000037","text":"A child who is not trained will not know how to thank the person who gives water to drink.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000038","text":"It takes a village to raise a child.","author":"Yoruba Proverb","source":"African proverb — widely documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000039","text":"Cross the river in a crowd and the crocodile won't eat you.","author":"Yoruba Proverb","source":"Yoruba oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000040","text":"Wherever a man goes to dwell, his character goes with him.","author":"Yoruba Proverb","source":"Yoruba oral tradition — Owomoyela 1988","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"yoruba-000041","text":"OEUVRES COMPLÈTES DE ROLLIN.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000042","text":"NOUVELLE ÉDITION, ACCOMPAGNÉE D'OBSERVATIONS ET D'ÉCLAIRCISSEMENTS HISTORIQUES, PAR M. LETRONNE, MEMBRE DE L'INSTITUT (ACADÉMIE ROYALE DES INSCRIPTIONS ET BELLES-LETTRES).","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000043","text":"HISTOIRE ANCIENNE. TOME I.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000044","text":"PARIS, DE L'IMPRIMERIE DE FIRMIN DIDOT, IMPRIMEUR DU ROI ET DE L'INSTITUT, RUE JACOB, No 24.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000045","text":"AVERTISSEMENT DE L'AUTEUR DES OBSERVATIONS ET ÉCLAIRCISSEMENTS HISTORIQUES JOINTS À CETTE ÉDITION.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000046","text":"Depuis long-temps on sentait la nécessité d'une édition critique des oeuvres historiques de Rollin.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000047","text":"Il est en effet reconnu que Rollin n'a point également soigné toutes les parties du grand ensemble d'histoire dont il a fait présent à la France.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000048","text":"Ne pouvant examiner avec assez d'attention le sens de certains passages difficiles qui auraient exigé un examen approfondi, il a dû s'en rapporter quelquefois à des versions inexactes.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000049","text":"On ne saurait donc être surpris de ce que ses ouvrages historiques renferment quelques erreurs de détail, dont une critique malveillante s'est servie pour tâcher de décréditer ces ouvrages.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000050","text":"Ils n'ont pu réussir à en faire abandonner la lecture; mais ils en ont diminué l'autorité et le poids, en exagérant le nombre des fautes qui peuvent s'y trouver.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000051","text":"[Note 1: _Storia Antica_ di Carlo ROLLIN, etc. Genova, MDCCXCII.]","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000052","text":"Notre méthode est entièrement différente.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000053","text":"Nos observations sont rejetées au bas des pages, et se trouvent ainsi entièrement séparées du texte.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000054","text":"Nous croyons avoir évité cet écueil, en nous renfermant dans les limites indiquées par la nature même de l'ouvrage.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000055","text":"Ces notes sont en général fort courtes et précises: quelques-unes, en petit nombre, ont plus d'étendue; mais l'importance ou l'intérêt du sujet rendait nécessaires de plus grands développements.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000056","text":"Sans doute, il nous eût été facile de mettre quelquefois notre opinion en regard de celle de l'auteur; mais quelle eût été la plus vraie des deux?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000057","text":"Nous nous sommes également interdit des discussions générales sur la chronologie de l'ancienne Égypte et de l'empire d'Assyrie.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000058","text":"Rollin a sur-tout évité toute discussion approfondie sur ce sujet; il s'est contenté de suivre principalement Ussérius et Fréret: il a le soin d'en prévenir ses lecteurs.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000059","text":"Nous nous sommes donc contentés de donner quelques observations de détail.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000060","text":"Pour les mesures itinéraires, nous nous sommes servis des travaux les plus récents.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000061","text":"L'évaluation des monnaies grecques et romaines a été établie sur les bases dont nous avons démontré la certitude dans un ouvrage spécial[2].","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000062","text":"A la fin de l'histoire romaine, nous placerons un exposé des principes sur lesquels reposent ces diverses évaluations, et des tableaux dressés d'après ces principes.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000063","text":"[Note 2: _Considérations générales sur l'évaluation des monnaies grecques et romaines et sur la valeur de l'or et de l'argent avant la découverte de l'Amérique_, chez F. Didot.]","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000064","text":"Toutes les notes qui nous appartiennent sont suivies de la lettre--L.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000065","text":"Quand il nous arrive de compléter une note de l'auteur, par une addition qui nous paraît nécessaire, cette addition est précédée des deux traits ==, et suivie de la même lettre--L.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000066","text":"Paris, 20 décembre 1820.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000067","text":"ÉLOGE DE ROLLIN, DISCOURS QUI A REMPORTÉ LE PRIX D'ÉLOQUENCE DÉCERNÉ PAR L'ACADÉMIE FRANÇAISE, DANS SA SÉANCE DU 27 AOÛT 1818; PAR SAINT-ALBIN BERVILLE, AVOCAT À LA COUR ROYALE DE PARIS.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000068","text":"Nocturnâ versate manu, versate diurnâ. HORAT.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000069","text":"La nature commence l'homme, et l'éducation l'achève.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000070","text":"Par elle, ses facultés deviennent des talents; ses penchants, des vertus; par elle se perpétuent d'âge en âge, avec les traditions de la science, les leçons de la sagesse.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000071","text":"Aussi, dans l'antiquité, voyons-nous l'éducation exciter constamment la sollicitude des philosophes et des législateurs.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000072","text":"Lycurgue fonde sur son pouvoir les lois qu'il donne à son peuple; Platon, le code qu'a rêvé son génie; magistrat et père à-la-fois, Caton honore la pourpre consulaire par les fonctions d'instituteur.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000073","text":"Rollin servit l'enseignement par ses travaux; il honora sa carrière par des talents et des vertus.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000074","text":"Pour le louer, il suffit de raconter ce qu'il a fait, de montrer ce qu'il a été.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000075","text":"Mais ce germe resta long-temps stérile.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000076","text":"Héritier de leurs fonctions, il l'avait été de leurs succès: des réformes salutaires, de sages innovations, avaient marqué sa carrière.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000077","text":"Rollin, dans le _Traité des Études_, n'a point prétendu, ainsi qu'un philosophe célèbre, refaire l'éducation sur de nouvelles bases; il n'a voulu que rassembler des traditions consacrées par l'usage.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000078","text":"Rousseau, dans sa marche hardie, a poussé plus avant l'investigation des principes; mais, dominé par une imagination impérieuse, il a quelquefois abusé de la vérité.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000079","text":"Rollin, plus circonspect, s'arrête avant le but plutôt que de s'exposer à le franchir; mais, s'il se borne à cultiver des vérités connues, il sait les rendre fécondes.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000080","text":"Il n'appelle point les réformes, mais il les accepte des mains de l'expérience.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000081","text":"Il veut développer par l'émulation nos facultés naissantes, et paraît craindre qu'amollis par les douceurs de la vie domestique, l'ame ne perde son ressort et le corps sa vigueur.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000082","text":"Mais, si l'éducation peut varier dans sa forme, son objet est invariable.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000083","text":"Avant que les écrivains du siècle de Louis XIV eussent fixé la langue française, l'enseignement dut chercher dans les langues anciennes des formes régulières et des modèles pour l'éloquence.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000084","text":"Bientôt il nous transporte par l'étude loin de la terre natale; il veut agrandir notre intelligence en nous faisant connaître d'autres hommes, d'autres moeurs, d'autres sociétés.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000085","text":"Le langage, qui ne fut d'abord qu'un moyen de communication entre les hommes, devint un art, lorsque ces communications, en se multipliant, eurent étendu son usage et varié ses ressources.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000086","text":"Fille de la religion et des passions peut-être, la poésie peut se vanter d'une ancienne origine et nous offre les premiers monuments que le génie de la parole ait élevés chez les nations.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000087","text":"A travers l'immensité des âges, elle nous apparaît sous la majestueuse figure d'Homère, d'Homère qui, pareil aux dieux qu'il a chantés, semble avoir en partage une éternelle jeunesse.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000088","text":"A sa suite, se présente l'antiquité tout entière, avec ce cortége de beautés naïves que faisait éclore, sous un ciel riant, l'influence d'une société vierge encore.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000089","text":"Combien l'on aime à retrouver, dans ces tableaux des vieux âges, l'empreinte de la nature, presque effacée de nos sociétés modernes!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000090","text":"C'est elle que Rollin chérit dans leurs ouvrages; c'est elle qui en relève le prix aux yeux de l'homme simple et sensible: s'il ne retrouve plus le modèle, il est encore touché de l'image.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000091","text":"Admirateur sincère des anciens, Rollin n'est point l'adorateur de leurs défauts: il sait voir des taches dans leurs écrits: les anciens n'étaient-ils pas des hommes?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000092","text":"mais ses principes, ses remarques, son style même, révèlent encore en lui le sentiment profond, le sûr discernement de leurs beautés.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000093","text":"Ce même discernement ne brille pas moins dans les jugements qu'il porte sur ses contemporains; et ce n'est pas son moindre titre de gloire, d'avoir averti la France de la grandeur de Bossuet.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000094","text":"Le nom de Bossuet rappelle celui de l'éloquence.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000095","text":"Cette fille de la liberté fit long-temps retentir de ses mâles accents la tribune de Rome et d'Athènes.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000096","text":"Un tel oubli, qui accuse les institutions contemporaines, ne serait plus possible aujourd'hui.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000097","text":"Français, une gloire nouvelle vous attend!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000098","text":"En révélant à ses élèves les beautés de la poésie et de l'éloquence, Rollin n'oublie pas des études plus austères, mais non moins utiles.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000099","text":"L'éducation vulgaire ne se propose que la science pour objet: le sage voit plus loin.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000100","text":"Le savoir n'est à ses yeux qu'un progrès qui nous rapproche de la vertu, ou qu'un instrument dont elle doit diriger l'usage dans l'intérêt de la patrie et de l'humanité.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000101","text":"Des études que Rollin nous prescrit, la première est celle de nos devoirs.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000102","text":"En formant l'homme instruit, ses leçons tendent surtout à former l'honnête homme et le bon citoyen.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000103","text":"Tour-à-tour éclairant l'exemple par le précepte, autorisant le précepte par l'exemple, il appelle au secours de la morale l'expérience des siècles passés.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000104","text":"Quelquefois, s'élevant à de plus vastes considérations, il examine la vertu dans son alliance avec le pouvoir, préparant le bonheur des hommes et la prospérité des états.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000105","text":"Si la sagesse elle-même voulait parler aux hommes, il me semble que ce serait là son langage.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000106","text":"C'est par la religion que Rollin sanctionne ses enseignements, et c'est par la philosophie qu'il veut nous y conduire; car la vraie religion est soeur de la vraie philosophie.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000107","text":"Rollin ne veut point fonder sur les ruines de la raison le règne de la foi; il hait et la superstition qui l'avilit, et le fanatisme qui la déshonore.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000108","text":"J'oserais pourtant lui reprocher de s'être montré trop rigoureux envers la gloire.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000109","text":"La gloire porte des fruits si semblables à ceux de la vertu!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000110","text":"Rollin, dans son premier ouvrage, avait enseigné la manière d'étudier l'histoire: elle va maintenant devenir l'objet de ses travaux.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000111","text":"L'histoire de l'antiquité, au contraire, nous offre deux grands sujets d'étude, les institutions et les hommes.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000112","text":"Les anciens furent nos maîtres dans la liberté, et cette éducation n'est pas leur moindre titre à notre reconnaissance.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000113","text":"Déjà Bossuet avait éclairé du flambeau de la religion cet imposant tableau: mais son ouvrage est plutôt fait pour être médité par l'âge mûr, que pour instruire la jeunesse.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000114","text":"Dans son vol sublime, il plane sur toute l'histoire, mais il ne s'arrête que sur les hauteurs, pour y reconnaître l'empreinte d'une main divine.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000115","text":"La rapidité de sa marche exclut les détails, et les détails sont l'instruction elle-même, quand c'est le discernement qui les choisit.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000116","text":"Dans un cadre plus étendu, Rollin passe en revue les peuples les plus célèbres, parmi tant d'états qui tour-à-tour ont fleuri sur la terre.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000117","text":"Non loin d'elle s'élève cette fière Carthage, un instant la rivale de Rome, et dont les destinées vinrent échouer contre la puissance qui devait envahir le monde.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000118","text":"Un jour, une grande infortune viendra s'asseoir sur ses ruines et sera consolée.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000119","text":"Ici, j'entends, à travers le silence des âges, le bruit lointain des empires qui s'écroulent, et dont la chute retentit confusément sur les bords de l'Euphrate.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000120","text":"Cyrus paraît, et sur ces vastes débris s'élève l'empire des Perses.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000121","text":"Parvenue à ces peuples dont l'existence sociale a préparé la nôtre, l'histoire acquiert un nouvel intérêt.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000122","text":"Ce sont les archives de nos ancêtres, que Rollin met sous nos yeux.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000123","text":"Originaire des contrées orientales, mais semblable pour elles à ces germes qui se développent loin de la plante qui les a produits, la civilisation va jeter ses racines sur le sol fécond de la Grèce.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000124","text":"Là, s'élèvent sur un espace étroit vingt nations célèbres; là, fleurissent, aux rayons de la liberté, le génie et la vertu.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000125","text":"En vain le despotisme asiatique soulève contre ces petits états l'effort gigantesque de sa puissance: ce colosse d'argile vient se briser contre le bouclier d'airain de la liberté.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000126","text":"C'est un beau spectacle que cette lutte entre la puissance et la vertu, où la vertu remporte la victoire!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000127","text":"Éblouis de leurs prospérités, les Grecs oublient que l'ambition produit la servitude, et qu'aspirer à la domination, c'est courir à l'esclavage.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000128","text":"Deux cités rivales se disputent l'empire, et déjà la Grèce indignée a vu les descendants de Miltiade et de Léonidas humilier devant un satrape les lauriers de Marathon et les cyprès des Thermopyles.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000129","text":"Bientôt s'élève dans son sein une puissance nouvelle qui menace de l'asservir.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000130","text":"La Grèce, abattue par Philippe, accepte la servitude en triomphant sous Alexandre, et ratifie aux champs d'Arbelles le traité imposé par la victoire dans les plaines de Chéronée.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000131","text":"Le Macédonien l'a vengée, mais elle a payé de sa liberté le plaisir de la vengeance, et ce n'est qu'avec ses chaînes qu'elle a terrassé son ennemi.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000132","text":"Après la mort d'Alexandre, nous la verrons briser ses fers, mais pour en reprendre de nouveaux.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000133","text":"La politique romaine ne l'affranchit un instant que pour mieux l'asservir, et la Grèce, à son tour, va se perdre dans ce torrent dont les flots engloutiront l'univers.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000134","text":"Mais un nouveau triomphe l'attend dans sa défaite.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000135","text":"Les vainqueurs vont puiser chez les vaincus une civilisation nouvelle, et triomphants par les armes, ils sont conquis par les moeurs.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000136","text":"Dans la Grèce, j'admire les hommes; chez les Romains, c'est le peuple que j'admire.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000137","text":"L'aristocratie a remplacé chez lui le pouvoir monarchique; le gouvernement populaire a succédé à l'aristocratie; mais si la constitution change, l'esprit ne change pas.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000138","text":"Au milieu de ces variations, le peuple romain marche à son but, appuyé sur la force de ses moeurs et sur la sagesse de sa politique.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000139","text":"Il grandit, il s'élance, il renverse tout ce qui résiste: sa force s'accroît des succès de Pyrrhus, des triomphes d'Annibal.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000140","text":"En vain le héros de Carthage est à ses portes: Rome assiégée est encore la cité des maîtres de la terre; elle n'acceptera point la paix de la main du vainqueur.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000141","text":"Ses commencements ont été la rapine et le pillage: son terme ne sera que l'empire du monde.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000142","text":"Quel peuple, si sa gloire était pure et ses vertus sans mélange!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000143","text":"si la politique n'avait souvent fait taire la justice, et le patriotisme l'humanité!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000144","text":"Mais ces citoyens si généreux oublièrent trop qu'ils étaient des hommes.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000145","text":"Et qu'était-ce, après tout, que ce plan d'asservir le monde, conçu avec tant d'audace, suivi avec tant de constance?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000146","text":"une brillante erreur, une faute imposante.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000147","text":"Combien Sparte fut plus sage!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000148","text":"Quel fruit recueillit-elle de sept cents ans de victoires?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000149","text":"En dévorant l'univers, elle engraissait une victime pour les tyrans, et enfin une proie pour les barbares.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000150","text":"Chaque conquête était un progrès vers la décadence, chaque triomphe un pas vers la servitude.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000151","text":"Son abaissement fut égal à sa grandeur, et ses maux ont vengé les nations qu'elle avait opprimées.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000152","text":"En appelant notre admiration sur ces grands tableaux, Rollin ne veut pas toutefois qu'un enthousiasme légitime pour l'antiquité nous rende indifférents pour nos propres annales.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000153","text":"Peut-être va-t-il même trop loin, lorsqu'il laisse entendre que les fastes du moyen âge pourraient, sous la main du talent, balancer les brillants souvenirs de la Grèce et de l'Ausonie.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000154","text":"Mais on doit l'applaudir du moins d'avoir revendiqué pour l'histoire nationale le rang qui lui appartient dans le système des études.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000155","text":"Ces anciens, que nous admirons, doivent encore être ici nos maîtres.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000156","text":"Imitons cet exemple, et, dociles aux conseils de Rollin, ramenons quelquefois nos regards sur les monuments de notre histoire.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000157","text":"Ils nous révéleront des destinées assez brillantes.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000158","text":"Il sied bien à une nation d'être orgueilleuse d'elle-même, à un citoyen d'être fier de sa patrie; et cet orgueil est plus juste encore quand cette patrie est la France.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000159","text":"C'est à la jeunesse que Rollin destinait ses ouvrages: content d'être utile, il n'aspirait point à la renommée; et cependant la renommée a proclamé ses travaux.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000160","text":"Des mains de l'adolescence, ses écrits ont passé dans celles de l'âge mûr; du sein de la retraite, ils se sont répandus dans le monde.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000161","text":"Quel charme les recommandait?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000162","text":"C'est elle qui fait leur éloquence, et cette éloquence vaut bien celle du génie: si elle fait goûter le livre, elle fait estimer et chérir l'auteur.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000163","text":"Et qui, en lisant Rollin, pourrait ne pas l'aimer?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000164","text":"Quelle sagesse dans ses paroles!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000165","text":"quel zèle pour la vertu!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000166","text":"quel ton de candeur et de simplicité!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000167","text":"Et comment en effet être sévère avec lui?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000168","text":"Il se livre à vous avec tant d'abandon!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000169","text":"Il aime le bien de si bonne foi!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000170","text":"Découvrez-vous en lui quelques prétentions?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000171","text":"Aspire-t-il à faire secte?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000172","text":"Non: ce n'est point pour lui qu'il sollicite nos hommages; c'est pour la vérité.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000173","text":"Un tel succès n'a rien de brillant, mais du moins il est pur, et sur-tout il est durable.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000174","text":"L'erreur peut obtenir un triomphe passager, quand elle a le talent pour auxiliaire; mais elle ne garde point ses conquêtes.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000175","text":"Je n'oserais parler de l'originalité de Rollin: on me répondrait sans doute que ce mérite suppose la hardiesse de la pensée, l'énergie et la nouveauté de l'expression.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000176","text":"Rarement l'homme sans passion rencontre ces tours vifs, ces traits frappants qui donnent au style une couleur prononcée.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000177","text":"Ce sont les secrets de l'imagination; elle ne les révèle que lorsqu'elle est émue.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000178","text":"Cependant, sa manière n'est point d'emprunt: la bonté lui tient lieu d'originalité.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000179","text":"Alors même qu'il ressemble, il n'imite pas.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000180","text":"Imite-t-on la bonté?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000181","text":"Le style de Rollin favorise cette illusion; il a, pour ainsi dire, un parfum d'antiquité.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000182","text":"Cette simplicité, chez Rollin, n'exclut point cependant l'élégance; car l'élégance, qui n'est qu'un choix fait par le goût dans les formes du langage, a plus d'un caractère.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000183","text":"Travaillée chez Fléchier, riche et noble chez Massillon, attique et précise chez Voltaire, pompeuse chez Buffon, elle est doucement fleurie dans les ouvrages de Rollin.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000184","text":"Il écrit dans ce style tempéré, qui peut-être est le plus difficile, parce qu'il est le plus voisin des brillants défauts qui séduisent le goût et corrompent le talent.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000185","text":"Il s'occupe moins de parer l'expression que d'éclairer la pensée: d'autres cherchent les ornements du style; Rollin se les permet.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000186","text":"L'élégance n'offre point le même caractère aux diverses époques de la littérature.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000187","text":"L'éloquence oratoire fait place alors à l'éloquence philosophique; le langage prend des formes plus sévères; l'harmonie est souvent sacrifiée à la concision, la clarté à la profondeur.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000188","text":"C'est le temps des Tacite, c'est celui des Montesquieu.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000189","text":"Quelquefois cependant, le génie ou les études d'un écrivain lui font devancer son siècle, ou le retiennent dans le siècle précédent.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000190","text":"Ce caractère, il le doit à l'imitation des écrivains du siècle d'Auguste.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000191","text":"Il avait médité toute sa vie ces illustres modèles, et l'on reconnaît aisément qu'il s'est formé sur eux.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000192","text":"C'est qu'à leur lecture, il avait joint celle des chefs-d'oeuvre du siècle de Louis XIV.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000193","text":"Aussi, malgré la juste estime qu'ont obtenue ses essais dans la langue de Virgile, je les considère moins comme des titres littéraires que comme de savantes études.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000194","text":"Le génie des langues, qui n'est que le génie des sociétés, permet-il de traduire dans l'idiome de l'antique Ausonie les idées que la société fait éclore sous le ciel de la Gaule moderne?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000195","text":"Mais les anciens n'ont pu lui servir également de modèles pour la manière d'écrire l'histoire.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000196","text":"Écrivant dans un autre but, son talent a dû prendre un autre caractère.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000197","text":"L'austérité de Thucydide, l'énergique pénétration de Tacite, n'auraient pu convenir à la jeunesse: Rollin a tempéré pour elle la gravité de l'histoire.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000198","text":"La critique lui a reproché une crédulité trop facile: il aurait fallu ajouter que, si Rollin est crédule, c'est sur-tout en faveur de la vertu.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000199","text":"Il trouva dans son ame les raisons de cette confiance.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000200","text":"Et peut-on le blâmer d'avoir environné de nobles illusions les exemples qu'il offrait à l'adolescence, et qu'il proposait à son admiration?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000201","text":"Malheur à l'écrivain qui suborne l'histoire au gré de ses passions!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000202","text":"sa gloire n'est jamais qu'une brillante ignominie, et son talent, en immortalisant ses ouvrages, ne fait qu'éterniser sa honte.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000203","text":"Si je louais seulement un littérateur, j'ai parlé de ses écrits, je pourrais borner là son éloge.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000204","text":"Mais Rollin fut en même temps un sage, un bienfaiteur de l'humanité; je dois jeter un regard sur sa vie.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000205","text":"Elle fut plus utile que brillante; elle offre moins d'événements que de vertus.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000206","text":"Né dans une condition obscure, Rollin s'élève aux premières dignités de l'enseignement public.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000207","text":"Long-temps il se dévoue à ce noble ministère: il consacre ses talents à former des hommes pour la société, des citoyens pour la patrie.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000208","text":"Une disgrace est le prix de ses services.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000209","text":"Incapable d'orgueil ainsi que de faiblesse, Rollin se soumet sans se plaindre, mais sans se démentir.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000210","text":"La persécution a troublé sa destinée, sans altérer son ame.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000211","text":"Il emporte dans sa retraite l'estime publique, la paix du coeur et les consolations de l'étude; il y trouve encore des devoirs à remplir et des bienfaits à répandre.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000212","text":"Rollin était fait pour la connaître; elle acheva son bonheur; elle aurait satisfait tous ses voeux, quand la gloire n'aurait pas daigné sourire à sa vieillesse.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000213","text":"Cette vérité est douce à proclamer: elle réconcilie avec la destinée.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000214","text":"la vie de l'homme de lettres est si souvent troublée par des orages!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000215","text":"il y a si peu d'intelligence entre le talent et le bonheur!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000216","text":"Essaierai-je ici d'établir un parallèle entre deux hommes chers à notre mémoire?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000217","text":"Je crains qu'on ne m'accuse d'appeler à mon secours les lieux communs d'une trop facile éloquence.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000218","text":"Cependant, en faisant l'éloge de Rollin, pourrais-je être blâmé de prononcer le nom de Fénélon?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000219","text":"Ne voyons-nous pas des deux côtés même modestie, même douceur de sentiments et de style, même sagesse dans les desirs, même charité dans le coeur?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000220","text":"Tous deux ont défendu la religion, et tous deux, par leur vie, plus encore que par leurs écrits, ont rendu témoignage des vérités qu'ils avaient enseignées.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000221","text":"Le monde rit de ces hommes du siècle, que l'amour des vanités traîne au pied des autels, et qui, en présence de la divinité, n'adorent que la fortune et le pouvoir.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000222","text":"Mais l'incrédulité même s'incline avec respect devant la piété se dévouant à l'instruction de l'adolescence, ou gravant dans le coeur des rois les leçons de l'humanité.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000223","text":"C'est elle qui affermira nos institutions naissantes; c'est par elle que la génération qui se prépare s'élèvera pour la liberté et pour la patrie.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000224","text":"A SON ALTESSE SÉRÉNISSIME MONSEIGNEUR LE DUC DE CHARTRES.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000225","text":"Lorsque je commençai l'Histoire Ancienne, VOTRE ALTESSE SÉRÉNISSIME était encore dans les premières années de l'enfance, et ni l'ouvrage ni l'auteur n'avaient l'avantage d'être connus de vous.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000226","text":"Souffrez que je fasse maintenant ce que je n'ai pu faire alors, et qu'en finissant mon travail, il me soit permis de le décorer du nom de VOTRE ALTESSE.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000227","text":"C'est là proprement l'étude des princes, capable plus qu'aucune autre de leur former l'esprit et le coeur.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000228","text":"Comme la censure qu'elle fait des vices ne leur est point personnelle, elle n'a rien pour eux d'amer ni d'offensant.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000229","text":"Vous détestez maintenant la flatterie, MONSEIGNEUR.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000230","text":"Vous ne souffrez qu'avec peine les plus justes louanges.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000231","text":"Vous aimez sincèrement la vérité, lors même qu'elle pourrait ne vous être pas agréable.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000232","text":"Je n'oublierai jamais la sage réponse que vous me fîtes dans une occasion où j'usais de la liberté que vous m'aviez donnée de vous représenter tout ce que je croirais pouvoir vous être utile.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000233","text":"Bien loin de vous en tenir offensé, vous daignâtes vous récrier qu'à cette marque vous reconnaissiez que j'étais de vos meilleurs amis.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000234","text":"Que de belles choses, MONSEIGNEUR, ces grands hommes auront à vous dire sur tout ce qui peut rendre un prince véritablement estimable et aimable?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000235","text":"Quel facile accès ne trouveront-ils pas dans un coeur comme le vôtre, bon, compatissant, docile, sans hauteur et sans fierté!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000236","text":"Nos Grecs et nos Romains sont bien propres, MONSEIGNEUR, à détromper les grands des fausses idées que souvent ils se forment de la gloire et de la grandeur.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000237","text":"Or cette ame et cette vie, MONSEIGNEUR, c'est la piété, c'est la crainte de Dieu, sans laquelle tout ce qu'il y a de plus grand dans le monde n'est qu'un pur néant.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000238","text":"Puissiez-vous, MONSEIGNEUR, imiter ses exemples, et même (je ne crains point qu'il s'en trouve choqué) les surpasser!","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000239","text":"Ce sont les voeux que je ne cesserai de faire pour VOTRE ALTESSE SÉRÉNISSIME, et qu'elle agréera sans doute beaucoup plus que tous les éloges dont je la pourrais combler.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000240","text":"Je suis avec un profond respect et un parfait dévouement,","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000241","text":"DE VOTRE ALTESSE SÉRÉNISSIME","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000242","text":"Le très-humble et très-obéissant serviteur, C. ROLLIN.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000243","text":"_Utilité de l'Histoire profane, sur-tout par rapport à la Religion._","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000244","text":"Je ne fais que montrer légèrement tous ces objets, quelque importants qu'ils soient, parce que je les ai traités ailleurs[3] avec étendue.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000245","text":"[Note 3: Second volume de la _Manière d'étudier_.]","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000246","text":"Observer principalement ce qui a rapport à la religion.] Mais un autre objet, infiniment plus intéressant, doit attirer notre attention.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000247","text":"[Note 4: «Pietate ac religione, atque hàc uni sapientiâ quòd Deorum immortalium numine omnia regi gubernarique perspeximus, omnes gentes nationesque superavimus.» (Orat. _de Arusp. respons_. n. 19.)]","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000248","text":"[Note 5: «Regnum a gente in gentem transfertur propter injustitias, et injurias, et contumelias, et diversos dolos.» (_Eccl_. 10, 8.)]","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000249","text":"Dieu regardait la nation sainte comme son domaine propre, et comme son héritage.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000250","text":"Il y demeurait comme un maître dans sa maison, et comme un père dans sa famille.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000251","text":"Israël était son fils, et son fils premier-né.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000252","text":"Il avait pris plaisir à le former dès son enfance, et à l'instruire par lui-même.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000253","text":"Il se communiquait à lui par ses oracles; il le gouvernait par des hommes miraculeux; il le protégeait par les merveilles les plus étonnantes.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000254","text":"A la vue de tant de glorieux priviléges, qui ne s'écrierait avec le Prophète: «Ce n'est que dans Israël que Dieu fait éclater sa grandeur et sa magnificence!» [Marge: Isaï.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000255","text":"33, 21.] _Solummodò ibi magnificus est Dominus noster._","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000256","text":"23, 1.] Toute la terre est au Seigneur, dit le Prophète, et tous les hommes qui la remplissent sont également son ouvrage; et il n'a garde de le négliger.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000257","text":"Ce serait une erreur bien injurieuse à Dieu, que de penser qu'il n'est le maître que d'une seule famille, et non le maître de toutes les nations.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000258","text":"La liberté, le hasard, les vues d'intérêt, le goût pour certains pays, et d'autres motifs pareils, furent, ce semble, les seules causes des choix différents que firent les hommes.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000259","text":"11, 8 et 9.] règles de sa miséricorde et de sa justice: _Dispersit et divisit eos Dominus in universas terras._","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000260","text":"[Note 6: Les Anciens même, au rapport de Pindare (_Olymp._ Od.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000261","text":"7), avaient retenu quelque idée que la dispersion des hommes ne s'était point faite au hasard, et qu'ils avaient été placés par les ordres de la Providence.]","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000262","text":"Il est vrai que dès lors Dieu eut une attention particulière sur le peuple qu'il devait un jour s'attacher.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000263","text":"Il marqua la place qu'il lui destinait.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000264","text":"Il la fit garder par un autre peuple laborieux, qui s'appliqua à la cultiver et à l'embellir, et à faire valoir l'héritage futur des Israélites.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000265","text":"39, 19, 22, 25.]] _Tu es Deus conspector seculorum...","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000266","text":"A seculo usque in seculum respicis._","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000267","text":"15, 18.] _Notum a seculo est Domino opus suum_.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000268","text":"[Note 8: «Educam vos de ergastulo Ægyptiorum (_Exod._, 6, 6). De fornace ferrea Ægypti.» (_Deuteronom._ 4, 20.)]","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000269","text":"J'ai enlevé les anciennes bornes des peuples, j'ai pillé les trésors des princes, et, comme un conquérant, j'ai arraché les rois de leurs trônes.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000270","text":"Les peuples les plus redoutables ont été pour moi comme un nid de petits oiseaux qui s'est trouvé sous ma main.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000271","text":"Mais ce prince si grand et si sage à ses propres yeux, qu'était-il à ceux de Dieu?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000272","text":"Un ministre subalterne, un serviteur mandé par son maître, une verge et un bâton dans sa main: [Marge: Isaï.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000273","text":"10, 5.] _Virga furoris mei et baculus ipse est._ Le dessein de Dieu était de corriger ses enfants, et non de les exterminer.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000274","text":"Mais Sennachérib avait résolu de tout perdre et de tout détruire: [Marge: Isaï.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000275","text":"10, 7.] _Ipse autem non sic arbitrabitur, sed ad conterendum erit cor ejus._ Que deviendra donc cette espèce de combat entre les desseins de Dieu et ceux de ce prince?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000276","text":"Lorsqu'il se croyait déjà maître [Marge: Isaï.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000277","text":"[Note 9: «Insanisti in me, et superbia tua ascendit in aures meas: ponam itaque circulum in naribus tuis, et camum in labiis tuis, et reducam te in viam per quam venisti.» (_4 Reg._ 19, 28.)]","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000278","text":"26, 27 et 28.] Des raisons seules de politique semblaient déterminer ce conquérant au siége de Tyr, pour ne pas laisser derrière soi une ville si puissante et si bien fortifiée.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000279","text":"Mais le siége de cette place était ordonné par une volonté supérieure.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000280","text":"C'est par ces motifs que Dieu lui-même conduisit Nabuchodonosor à Tyr, lui faisant exécuter ses ordres sans qu'il les connût: IDCIRCO _ecce_ EGO ADDUCAM _ad Tyrum Nabuchodonosor_.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000281","text":"[Note 10: Ce fait est plus détaillé dans l'histoire des Égyptiens sous le règne d'Amasis. [p. 133.]]","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000282","text":"Le roi de Babylone est cité à ce tribunal, où préside le Juge souverain, qui réunit une vigilance à qui rien n'échappe, et une sainteté qui ne peut rien souffrir contre l'ordre: _vigil et sanctus_.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000283","text":"Toutes ses actions, qui faisaient l'objet de l'admiration publique, y sont examinées à la rigueur; et l'on fouille jusqu'au fond de son coeur pour en découvrir les pensées les plus cachées.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000284","text":"Où se terminera ce redoutable appareil?","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000285","text":"[Note 11: «In sententia vigilum decretum est, et sermo sanctorum et petitio, etc.» (DAN. 4, 14.)]","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000286","text":"[Marge: Cyrus.] Si Dieu faisait servir des Princes à l'exécution de ses vengeances, il en a rendu d'autres les ministres de sa bonté.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000287","text":"On voit tout cela dans les historiens profanes; mais on n'y voit point le principe secret de toutes ces grandes qualités, ni le ressort caché qui les mettait en mouvement.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000288","text":"Isaïe nous le montre, et s'explique en des termes dignes de la grandeur et de la majesté du Dieu qui le faisait parler[12].","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000289","text":"[Note 12: «Hæc dicit Dominus christo meo Cyro, cujus apprehendi dexteram, ut subjiciam ante faciem ejus gentes, et dorsa regum vertam, et aperiam coram eo januas, et portæ non claudentur.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000290","text":"Ego ante te ibo, et gloriosos terræ humiliabo: portas æreas conteram, et vectes ferreos confringam.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000291","text":"Et dabo tibi thesauros absconditos, et arcana secretorum; ut scias quia ego Dominus, qui voco nomen tuum, Deus Israël.» (ISAÏ.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000292","text":"45, 13 et 4.] Le Prophète ne nous laisse pas même ignorer les motifs de toutes ces merveilles.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000293","text":"Mais ce prince aveugle et ingrat ne connaît point son maître, et oublie son bienfaiteur.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000294","text":"45, 4, 5.] _Vocavi te nomine tuo, et non cognovisti me: accinxi te, et non cognovisti me_.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000295","text":"[Marge: Belle image de la royauté.] Il est rare qu'on juge sainement de la vraie gloire et des devoirs essentiels de la royauté.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000296","text":"Il n'appartient qu'à l'Écriture de nous en donner une juste idée; et elle le fait d'une manière admirable dans [Marge: Dan.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000297","text":"4, 7-9.] un arbre grand et fort, dont la hauteur monte jusqu'au ciel, et qui paraît s'étendre jusqu'aux extrémités de la terre.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000298","text":"Couvert de feuilles et chargé de fruits, il fait l'ornement et le bonheur de la campagne.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000299","text":"[Note 13: [Grec: Eduvêthê [de] epithumian embalein tosautên tou pantas autô charizesthai, ôste aei tê autou gnômê axioun kubernasthai.] [Cyrop. I. 5]]","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."},{"id":"yoruba-000300","text":"19, 2-7.] loin à piller, à dévorer les hommes, à faire des veuves et des malheureux, à dépeupler les villes.","author":"Yoruba Proverb","source":"Wit and Wisdom from West Africa — Burton 1865","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Burton 1865 — verify ethnic attribution."}]}
{"formatVersion":"1","manifest":{"primaryCategory":"Proverbs & Folk Wisdom","subcategory":"African","audienceTags":["tradition:animism","theme:community","theme:wisdom"],"sortPriority":65,"groupingLevels":[],"groupingLabels":[],"dataPath":"Data/Collections/Zulu_Proverbs.json","supplementalDataPath":null,"languageCode":"en","displayNameEnglish":"Zulu & Ubuntu Wisdom","script":"Latin","isRTL":false,"transliterationAvailable":false,"contentRating":"general","sourceId":"zuluProverbs","displayName":"Zulu & Ubuntu Wisdom","version":"1.0","language":"English","edition":"Ubuntu Philosophy & Nguni Oral Tradition","type":"quotes","browseOrder":"sequence","itemCount":170,"supportsRandom":true,"supportsBrowse":true},"data":[{"id":"zulu-000001","text":"Ubuntu ngumuntu ngabantu.","author":"Zulu Proverb","source":"Zulu proverb — Ubuntu philosophy","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000002","text":"Umuntu ngumuntu ngabantu.","author":"Zulu Proverb","source":"Zulu/Nguni proverb — Ubuntu philosophy","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000003","text":"Abantu abakhali ngendlala ababhedla bodwa.","author":"Zulu Proverb","source":"Zulu oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000004","text":"Indaba enhle iyazikhulumela.","author":"Zulu Proverb","source":"Zulu oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000005","text":"Izandla ziyagezana.","author":"Zulu Proverb","source":"Zulu proverb — hands wash each other","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000006","text":"Ikamva labantu lisezandleni zabo.","author":"Zulu Proverb","source":"Zulu oral tradition — the future of the people is in their hands","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000007","text":"Isihlahla esihle siyagcina.","author":"Zulu Proverb","source":"Zulu proverb","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000008","text":"Umhlaba awunandaba neze.","author":"Zulu Proverb","source":"Zulu oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000009","text":"Umlomo awulali.","author":"Zulu Proverb","source":"Zulu oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000010","text":"Isibaya esihle asinankomo.","author":"Zulu Proverb","source":"Zulu proverb","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000011","text":"A person is a person through other persons.","author":"Zulu Proverb","source":"Zulu/Ubuntu proverb — foundational","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000012","text":"I am because we are.","author":"Zulu Proverb","source":"Ubuntu philosophy — widely documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000013","text":"Speak less; listen more.","author":"Zulu Proverb","source":"Nguni oral tradition — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000014","text":"The wealth of the greedy always diminishes.","author":"Zulu Proverb","source":"Zulu oral tradition — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000015","text":"A happy man marries the girl he loves; a happier man loves the girl he marries.","author":"Zulu Proverb","source":"African proverb — Southern African tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000016","text":"The wind does not break a tree that bends.","author":"Zulu Proverb","source":"Zulu oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000017","text":"Until the lion tells his side of the story, the tale of the hunt will always glorify the hunter.","author":"Zulu Proverb","source":"African proverb — Southern African variant","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000018","text":"A nation is not conquered until the hearts of its women are on the ground.","author":"Zulu Proverb","source":"Cheyenne / widely adopted African variant","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000019","text":"However hard you throw a dead fish in the water, it still won't swim.","author":"Zulu Proverb","source":"Zulu oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000020","text":"Do not look at the small cuts; look at how we heal together.","author":"Zulu Proverb","source":"Ubuntu principle — Nguni oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000021","text":"A child's eyes are always looking up.","author":"Zulu Proverb","source":"Zulu proverb","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000022","text":"Character is like smoke — you cannot hide it.","author":"Zulu Proverb","source":"Nguni oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000023","text":"The elder of the village is the keeper of the fire.","author":"Zulu Proverb","source":"Zulu oral tradition — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000024","text":"Where there is unity, there is always victory.","author":"Zulu Proverb","source":"Zulu proverb — widely documented","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000025","text":"The strength of the crocodile is the water.","author":"Zulu Proverb","source":"Zulu proverb","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000026","text":"Rain falls on the chief's hut as well as the commoner's.","author":"Zulu Proverb","source":"Zulu oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000027","text":"When a man is stung by a bee he does not destroy all beehives.","author":"Zulu Proverb","source":"Zulu oral tradition — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000028","text":"The old woman looks after the child to grow its teeth and the young one in turn will look after the old woman when she loses hers.","author":"Zulu Proverb","source":"Nguni proverb — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000029","text":"He who is not courageous enough to take risks will accomplish nothing in life.","author":"Zulu Proverb","source":"Southern African oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000030","text":"A good chief gives; he does not take.","author":"Zulu Proverb","source":"Zulu oral tradition","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Curated from published ethnographic sources; verify exact citation."},{"id":"zulu-000031","text":"We have already alluded to the excessive development of the jaws in criminals.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000032","text":"This muscle, which is strongly developed in the dog, serves when contracted to draw back the lip leaving the canines exposed.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000033","text":"The lips of violators of women and murderers are fleshy, swollen and protruding, as in negroes. Swindlers have thin, straight lips. Hare-lip is more common in criminals than in normal persons.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000034","text":"_The Cheek-pouches._ Folds in the flesh of the cheek which recall the pouches of certain species of mammals, are not uncommon in criminals.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000035","text":"Another frequent abnormality is cleft palate, a fissure in the palate, due to defective development.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000036","text":"_The Teeth._ These are specially important, for criminals rarely have normal dentition.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000037","text":"The incisors show the greatest number of anomalies.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000038","text":"Sometimes both the lateral incisors are absent and the middle ones are of excessive size, a peculiarity which recalls the incisors of rodents.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000039","text":"The teeth are frequently striated transversely or set very wide apart (diastema) with gaps on either side of the upper canines into which the lower ones fit, a simian characteristic.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000040","text":"In some cases, these spaces occur between the middle incisors or between these and the lateral ones.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000041","text":"=FIG. 4 HEAD OF CRIMINAL (see page 14)=","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000042","text":"=FIG. 5 HEAD OF CRIMINAL (see page 18)=","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000043","text":"Very often the teeth show a strange uniformity, which recalls the homodontism of the lower vertebrates.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000044","text":"In some cases, however, this uniformity is limited to the premolars, which are furnished with tubercles like the molars, a peculiarity of gorillas and orang-outangs.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000045","text":"In 4% the canines are very strongly developed, long, sharp, and curving inwardly as in carnivores.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000046","text":"Premature caries is common.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000047","text":"_The Chin._ Generally speaking, this part of the face projects moderately in Europeans.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000048","text":"In criminals it is often small and receding, as in children, or else excessively long, short or flat, as in apes.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000049","text":"_Wrinkles._ Although common to normal individuals, the abundance, variety, and precocity of wrinkles almost invariably manifested by criminals, cannot fail to strike the observer.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000050","text":"_The Hair._ The hair of the scalp, cheeks and chin, eyebrows, and other parts of the body, shows a number of anomalies.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000051","text":"In general it may be said that in the distribution of hair, criminals of both sexes tend to exhibit characteristics of the opposite sex.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000052","text":"Dark hair prevails especially in murderers, and curly and woolly hair in swindlers.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000053","text":"Both grey hair and baldness are rare and when found make their appearance later in life than in the case of normal individuals.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000054","text":"The beard is scanty and frequently missing altogether.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000055","text":"On the other hand, the forehead is often covered with down.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000056","text":"The eyebrows are bushy and tend to meet across the nose.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000057","text":"Sometimes they grow in a slanting direction and give the face a satyr-like expression (see Fig.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000058","text":"The blemishes peculiar to the delinquent are not only confined to the face and head, but are found in the trunk and limbs.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000059","text":"_The Thorax._ An increase or decrease in the number of ribs is found in 12% of criminals.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000060","text":"This is an atavistic character common to animals and lower or prehistoric human races and contrasts with the numerical uniformity characteristic of civilised mankind.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000061","text":"Polymastia, or the presence of supernumerary nipples (which are generally placed symmetrically below the normal ones as in many mammals) is not an uncommon anomaly.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000062","text":"Gynecomastia or hypertrophy of the mammae is still more frequent in male criminals.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000063","text":"The chest is often covered with hair which gives the subject the appearance of an animal.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000064","text":"_The Pelvis and Abdomen._ The abdomen, pelvis, and reproductive organs sometimes show an inversion of sex-characters.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000065","text":"In 42% the sacral canal is uncovered, and in some cases there is a prolongation of the coccyx, which resembles the stump of a tail, sometimes tufted with hair.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000066","text":"exhibit an anomaly which is extremely rare among normal individuals--the olecranon foramen, a perforation in the head of the humerus where it articulates with the ulna.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000067","text":"This is normal in the ape and dog and is frequently found in the bones of prehistoric man and in some of the existing inferior races of mankind.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000068","text":"Several abnormal characters, which point to an atavistic origin, are found in the palm and fingers.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000069","text":"Supernumerary fingers (polydactylism) or a reduction in the usual number are not uncommon.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000070","text":"Sometimes we find syndactylism, or palmate fingers, a continuation of the interdigital skin to the second phalanx.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000071","text":"The length of the fingers varies according to the type of crime to which the individual is addicted.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000072","text":"Those guilty of crimes against the person have short, clumsy fingers and especially short thumbs.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000073","text":"Long fingers are common to swindlers, thieves, sexual offenders, and pickpockets.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000074","text":"The lines on the palmar surfaces of the finger-tips are often of a simple nature as in the anthropoids.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000075","text":"The principal lines on the palm are of special significance.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000076","text":"Normal persons possess three, two horizontal and one vertical, but in criminals these lines are often reduced to one or two of horizontal or transverse direction, as in apes.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000077","text":"_The Lower Limbs._ Of a number of criminals examined, 16% showed an unusual development of the third trochanter, a protuberance on the head of the femur where it articulates with the pelvis.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000078","text":"This distinctly atavistic character is connected with the position of the hind-limb in quadrupeds.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000079","text":"The foot is often flat, as in negroes.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000080","text":"The most notable anomaly of the cerebellum is the hypertrophy of the vermis, which represents the middle lobe found in the lower mammals.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000081","text":"Anomalies of a purely pathological character are still more common.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000082","text":"These are: adhesions of the meninges, thickening of the pia mater, congestion of the meninges, partial atrophy, centres of softening, seaming of the optic thalami, atrophy of the corpus callosum, etc.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000083","text":"Of great importance, too, are the histological anomalies discovered by Roncoroni in the brains of criminals and epileptics.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000084","text":"In normal individuals the layers of the frontal region are disposed in the following manner:","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000085","text":"1. Molecular layer. 2. Superficial layer of small cells. 3. Layer of small pyramidal cells. 4. Deep layer of small nerve cells. 5. Layer of polymorphous cells (see Fig. 6).","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000086","text":"In certain animals, the dog, ape, rabbit, ox, and domestic fowl, the superficial layer is frequently non-existent and the deep one is found only to some extent in the ape.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000087","text":"In born criminals and epileptics there is a prevalence of large, pyramidal, and polymorphous cells, whereas in normal individuals small, triangular, and star-shaped cells predominate.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000088","text":"Also the transition from the small superficial to the large pyramidal cells is not so regular, and the number of nervous cells is noticeably below the average.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000089","text":"_a_) Cortical strata of the circumvolutions of the parietal lobes of a normal person.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000090","text":"_b_) Cortical strata of the circumvolutions of the parietal lobes of a criminal epileptic.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000091","text":"External granular stratum.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000092","text":"Stratum of the small pyramidal cells.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000093","text":"Stratum of the large pyramidal cells.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000094","text":"Deep stratum of the small nervous cells or the deep granular stratum.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000095","text":"Stratum of polymorphic cells.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000096","text":"In neither case have the anomalies an intrinsic importance, since they are neither the cause of the anti-social tendencies of the criminal nor of the mental deficiencies of the cretin.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000097","text":"They are the outward and visible signs of a mysterious and complicated process of degeneration, which in the case of the criminal evokes evil impulses that are largely of atavistic origin.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000098","text":"SENSORY AND FUNCTIONAL PECULIARITIES OF THE BORN CRIMINAL","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000099","text":"An examination of the senses and sensibility of criminals gives the following results:","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000100","text":"_General Sensibility._ Tested simply by touching with the finger, a certain degree of obtuseness is noted.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000101","text":"By using an apparatus invented by Du Bois-Reymond and adopted by my father, the degree of sensibility obtained was 49.6 mm.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000102","text":"in criminals as against 64.2 mm.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000103","text":"in normal individuals.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000104","text":"Criminals are more sensitive on the left side, contrary to normal persons, in whom greater sensibility prevails on the right.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000105","text":"_Sensibility to Pain._ Compared with ordinary individuals, the criminal shows greater insensibility to pain as well as to touch.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000106","text":"This obtuseness sometimes reaches complete analgesia or total absence of feeling (16%), a phenomenon never encountered in normal persons.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000107","text":"The mean degree of dolorific sensibility in criminals is 34.1 mm.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000108","text":"whereas it is rarely lower than 40 mm.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000109","text":"Here again the left-handedness of criminals becomes apparent, 39% showing greater sensibility on the left.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000110","text":"_Tactile Sensibility._ The distance at which two points applied to the finger-tips are felt separately is more than 4 mm.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000111","text":"in 30% of criminals, a degree of obtuseness only found in 4% of normal individuals.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000112","text":"Criminals exhibit greater tactile sensibility on the left.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000113","text":"Tactile obtuseness varies with the class of crime practised by the individual.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000114","text":"While in burglars, swindlers, and assaulters, it is double that of normal persons, in murderers, violators, and incendiaries it is often four or five times as great.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000115","text":"_Sensibility to the Magnet_, which scarcely exists in normal persons, is common to a marked degree in criminals (48%).","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000116","text":"_Meteoric Sensibility._ This is far more apparent in criminals and the insane than in normal individuals.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000117","text":"_Sight_ is generally acute, perhaps more so than in ordinary individuals, and in this the criminal resembles the savage.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000118","text":"Chromatic sensibility, on the contrary, is decidedly defective, the percentage of colour-blindness being twice that of normal persons.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000119","text":"_Hearing_, _Smell_, _Taste_ are generally of less than average acuteness in criminals. Cases of complete anosmia and qualitative obtuseness are not uncommon.[2]","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000120","text":"_Agility._ Criminals are generally agile and preserve this quality even at an advanced age.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000121","text":"_Strength._ Contrary to what might be expected, tests by means of the dynamometer show that criminals do not usually possess an extraordinary degree of strength.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000122","text":"There is frequently a slight difference between the strength of the right and left limbs, but more often ambidexterity, as in children, and a greater degree of strength in the left limbs.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000123","text":"PSYCHOLOGY OF THE BORN CRIMINAL","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000124","text":"The physical type of the criminal is completed and intensified by his moral and intellectual physiognomy, which furnishes a further proof of his relationship to the savage and epileptic.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000125","text":"On the other hand, he shows exaggerated and abnormal fondness for animals and strangers.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000126","text":"In the place of domestic and social affections, the criminal is dominated by a few absorbing passions: vanity, impulsiveness, desire for revenge, licentiousness.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000127","text":"The ability to discriminate between right and wrong, which is the highest attribute of civilised humanity, is notably lacking in physically and psychically stunted organisms.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000128","text":"Many criminals do not realise the immorality of their actions.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000129","text":"In French criminal jargon conscience is called \"la muette,\" the thief \"l'ami,\" and \"travailler\" and \"servir\" signify to steal.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000130","text":"A Milanese thief once remarked to my father: \"I don't steal.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000131","text":"They seem to think they have a right to rob and murder and that those who hinder them are acting unfairly.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000132","text":"Murderers, especially when actuated by motives of revenge, consider their actions righteous in the extreme.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000133","text":"_Repentance and Remorse._ We hear a great deal about the remorse of criminals, but those who come into contact with these degenerates realise that they are rarely, if ever, tormented by such feelings.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000134","text":"Very few confess their crimes: the greater number deny all guilt in a most strenuous manner and are fond of protesting that they are victims of injustice, calumny, and jealousy.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000135","text":"As Despine once remarked with much insight, nothing resembles the sleep of the just more closely than the slumbers of an assassin.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000136","text":"Thus Lacenaire, when convicted for the first time, wrote in a moving strain to his friend Vigouroux in order to get money and help from him, \"Repentance is the only course left open to me.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000137","text":"When tried at the Assizes at Pavia, Rognoni pronounced a touching discourse on his repentance and refused the wine brought him in prison for some days because it reminded him of his murdered brother.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000138","text":"Sometimes remorse is advanced by criminals as a palliation of their crimes.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000139","text":"Michelieu justified the _coup de grace_ inflicted on his victim by saying, \"When I saw her in that state, I felt such terrible remorse that I shot her dead in order not to meet her glance.\"","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000140","text":"Sometimes an appearance of remorse is produced by hallucinations due to alcoholism.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000141","text":"Many criminals, when in prison, model sculptural representations of their crimes with crumbs of bread (see Fig. 7).","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000142","text":"One criminal humbly entreated to be allowed to retain his own crucifix while in prison.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000143","text":"It was subsequently discovered that the sacred image served as a sheath for his dagger (see Fig.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000144","text":"Philippe made the following statement to one of his female companions.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000145","text":"\"My way of loving women is a very strange one.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000146","text":"After enjoying their caresses, I take the greatest delight in strangling them or cutting their throats.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000147","text":"Soon you will hear everyone talking about me.\" Shortly before he murdered his father, Lachaud said to his friends, \"This evening I shall dig a grave and lay my father there to rest eternally.\"","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000148","text":"Sometimes, indeed, a criminal realises dimly the depravity of his actions; he rarely judges them, however, as a normal person would, but seeks to explain and justify them after his own fashion.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000149","text":"When asked by the magistrate if he denied having stolen a horse, Ansalone replied, \"Surely you do not call that a theft; a leader of brigands could hardly be expected to go on foot!\"","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000150","text":"Others consider that their actions are less criminal if their intentions were good; like Holland, who murdered to obtain food for his wife and children.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000151","text":"Others, again, think themselves excused by the fact that many do worse things with impunity.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000152","text":"\"London thieves,\" observes Mayhew, \"realise that they do wrong, but think that they are no worse than ordinary bankrupts.\"","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000153","text":"=FIG. 7 Figures made in Prison MURDER OF A SLEEPING VICTIM Work of a Prisoner (see page 31)=","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000154","text":"=FIG. 8 CRUCIFIX POIGNARD (see page 31)=","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000155","text":"These instances show that criminals are not entirely unable to distinguish between right and wrong.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000156","text":"Nevertheless, their moral sense is sterile because it is suffocated by passions and the deadening force of habit.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000157","text":"In the cant of Spanish thieves, justice is called \"la justa\" (the just), and this name is given in French slang to the Assizes, but, as Mayor observes, it may be applied ironically.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000158","text":"\"It is one thing [observes Harwick] to possess a theoretical notion of what is right and wrong, but quite another to act according to it.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000159","text":"If, on the contrary, good feelings really exist, the individual desires to do right and his convictions are translated into action with the same energy that he displayed in doing wrong.\"","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000160","text":"In this case, no doubt, envy and vanity played as great a part as a sense of integrity, in the resentment shown at this fancied breach of faith.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000161","text":"In the prisons at Moscow, offences against discipline are dealt with by the offenders' fellow-prisoners.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000162","text":"The convict population on the island of San Stefano compiled spontaneously a Draconian code to quell internal discord arising from racial jealousies.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000163","text":"_Treachery._ This species of morality and justice, which unexpectedly makes its appearance in the midst of a naturally unrighteous community, can only be forced and temporary.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000164","text":"When, instead of reaping advantages, interests and passions are injured by acting rightly, these notions of justice, unsustained by innate integrity suddenly fail.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000165","text":"_Vanity._ Pride, or rather vanity, and an exaggerated notion of their own importance, which we find in the masses, generally in inverse proportion to real merit, is especially strong in criminals.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000166","text":"In the cell occupied by La Gala, the following notice was found in his handwriting: \"March 24th.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000167","text":"\"I do not fear being hated,\" he is reported to have said, \"but I dread being despised--the tempest leaves traces of its passage, but unobserved the humble flower fades.\"","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000168","text":"Thus thieves are loth to confess that they are guilty of only petty larceny, and are sometimes prompted by vanity to commit more serious robberies.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000169","text":"The same false shame is common to fallen women, among whom contempt is incurred, not by excess of depravity but by the failure to command high prices.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."},{"id":"zulu-000170","text":"Grellinier, a petty thief, boasted in court of imaginary offences, with the desire of appearing in the light of a great criminal.","author":"Southern African Proverb","source":"African Folk-Lore — Theal 1886","tags":["audience:morning","language:en","theme:community","theme:resilience","theme:wisdom","tradition:animism"],"isProverb":true,"isVerified":false,"verificationNote":"Extracted from Theal 1886 — verify ethnic attribution."}]}
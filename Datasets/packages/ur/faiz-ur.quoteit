{"formatVersion":"1","manifest":{"sourceId":"faiz-ur","displayName":"فیض احمد فیض","displayNameEnglish":"Faiz Ahmed Faiz — Selected Poems","version":"1.0","language":"Urdu","languageCode":"ur","script":"Nastaliq","isRTL":true,"transliterationAvailable":false,"edition":"Public Domain & Curated / Hindi Wikiquote","primaryCategory":"Philosophy & Spirituality","subcategory":"Urdu Poetry","type":"quotes","browseOrder":"sequence","supportsRandom":true,"supportsBrowse":true,"groupingLevels":[],"groupingLabels":[],"sortPriority":55,"contentRating":"general","audienceTags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"itemCount":30,"dataPath":"Data/Collections/Faiz_Urdu.json"},"data":[{"id":"faiz-ur-0001","text":"ہم دیکھیں گے، لازم ہے کہ ہم بھی دیکھیں گے\nوہ دن کہ جس کا وعدہ ہے جو لوحِ ازل میں لکھا ہے","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0002","text":"گلوں میں رنگ بھرے، بادِ نو بہار چلے\nچلے بھی آؤ کہ گلشن کا کاروبار چلے","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0003","text":"مجھ سے پہلی سی محبت مری محبوب نہ مانگ\nمیں نے سمجھا تھا کہ تو ہے تو درخشاں ہے حیات","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0004","text":"اور بھی دُکھ ہیں زمانے میں محبت کے سوا\nراحتیں اور بھی ہیں وصل کی راحت کے سوا","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0005","text":"آج بازار میں پا بجولاں چلو\nدست افشاں چلو مست و رقصاں چلو","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0006","text":"بول کہ لب آزاد ہیں تیرے\nبول کہ ابھی وقت کم ہے","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0007","text":"رات یوں دل میں تری کھوئی ہوئی یاد آئی\nجیسے ویرانے میں چپکے سے بہار آ جائے","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0008","text":"یہ داغ داغ اُجالا، یہ شب گزیدہ سحر\nوہ انتظار تھا جس کا یہ وہ سحر تو نہیں","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0009","text":"تیرے آنے سے پہلے خوشیوں نے آنکھیں بھیگی کر رکھی تھیں\nتیرے جانے کے بعد ہر لمحہ اداس ہے","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0010","text":"نہ گنوا، اے دل بے تاب نفس گنتے ہیں\nکوئی شے چھن نہیں سکتی تری اس انجمن میں","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0011","text":"دشتِ تنہائی میں اے جانِ جہاں لرزاں ہیں\nتیری آواز کے سائے تیرے ہونٹوں کے سراب","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0012","text":"ابھی گرانی شب میں کمی نہیں آئی\nنجوم غروب ہوئے انتظار کرتا رہا","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0013","text":"وہ بات سارے فسانے میں جس کا ذکر نہ تھا\nوہ بات ان کو بہت ناگوار گزری ہے","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0014","text":"نثار میں تیری گلیوں کے اے وطن کہ جہاں\nچلی ہے رسم کہ کوئی نہ سر اٹھا کے چلے","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0015","text":"لے دے کے اپنے پاس فقط ایک نظر تو ہے\nکیوں دیکھیں زندگی کو کسی کی نظر سے ہم","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0016","text":"دل میں اب یوں ترے بھولے ہوئے غم آتے ہیں\nجیسے ویرانے میں خاموش صدا آتی ہے","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0017","text":"محبت کے لیے کچھ خاص دل مخصوص ہوتے ہیں\nیہ وہ موسم نہیں ہر دل کو جو نصیب ہو","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0018","text":"صبح آزادی یا رب کتنی سرد ہے\nاس منزل کا وعدہ جو کچھ اور تھا","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0019","text":"کتنی آوازیں ہیں دل میں ہائے\nکون سی آواز پہ یقین کریں","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0020","text":"دنیا نے تیری یاد سے بیگانہ کر دیا\nتجھ سے بھی دل فریب ہیں غم روزگار کے","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0021","text":"پھر بھی دل ہے کہ مانتا نہیں\nاک ستم اور بھی ہے آسماں کے آگے","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0022","text":"ملتے رہیں گے یار یہ راہیں بدل بدل\nوہ دن بھی آئے گا جب ہم ملیں گے کھل کھل","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0023","text":"زنداں کی شام تھی درد کا موسم\nپھر بھی تیرا خیال آتا رہا","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0024","text":"عشق کے درد کا اب نہیں کوئی علاج\nبس جینا ہے اس بوجھ کے ساتھ","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0025","text":"قفس اداس ہے یاران نغمہ کہاں ہیں\nفضا دباؤ میں ہے باد صبح کہاں ہے","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0026","text":"تجھ پہ روشن ہے میری تاریک رات\nتجھ سے روشن ہے میرا سویرا","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0027","text":"یہ کارواں کا جو مقام ہے\nوہی ہے جہاں سے ہم نکلیں گے","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0028","text":"جو تم ہو حسین و جواں اس میں کچھ تمہارا نہیں\nاللہ نے جو دیا ہے وہ تمہارے ہاتھ نہیں","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0029","text":"وقت آئے گا جب دنیا بدل جائے گی\nیہ ظلم کا دور بھی گزر جائے گا","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"faiz-ur-0030","text":"اُٹھ کہ اب بزمِ جہاں کا اور ہی انداز ہے\nمشرق و مغرب میں تیرے دور کا آغاز ہے","author":"Faiz Ahmed Faiz — Selected Poems","source":"فیض احمد فیض — منتخب کلام (Faiz Ahmed Faiz)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:hope","theme:justice","theme:love"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."}]}
{"formatVersion":"1","manifest":{"sourceId":"ghalib-ur","displayName":"ग़ालिब ग़ज़लें","displayNameEnglish":"Mirza Ghalib — Ghazals","version":"1.0","language":"Urdu","languageCode":"ur","script":"Nastaliq","isRTL":true,"transliterationAvailable":false,"edition":"Public Domain & Curated / Hindi Wikiquote","primaryCategory":"Philosophy & Spirituality","subcategory":"Urdu Poetry","type":"quotes","browseOrder":"sequence","supportsRandom":true,"supportsBrowse":true,"groupingLevels":[],"groupingLabels":[],"sortPriority":54,"contentRating":"general","audienceTags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"itemCount":61,"dataPath":"Data/Collections/Ghalib_Urdu.json"},"data":[{"id":"ghalib-ur-0001","text":"قید حیات و بند غم ، اصل میں دونوں ایک ہیں‬\n موت سے پہلے آدمی غم سے نجات پائے کیوں؟‬","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0002","text":"بازیچہ اطفال ہے دنیا میرے آگے\n ہوتا ہے شب و روز تماشا میرے آگے ‬","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0003","text":"اگر اپنا کہا تم آپ ہی سمجھے تو کیا سمجھے‬\nمزا کہنے کا جب ہے اک کہے اور دوسرا سمجھے‬","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0004","text":"نہ ستائش کی تمنّا نہ صلے کی پروا‬\n گر نہیں ہیں مرے اشعار میں معنی نہ سہی‬","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0005","text":"بسکہ دشوار ہے ہر کام کا آساں ہونا\nآدمی کو بھی میسر نہیں انساں ہونا","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0006","text":"نہ ہوئی گر مرے مرنے سے تسلی نہ سہی\nامتحاں اور بھی باقی ہو تو یہ بھی نہ سہی","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0007","text":"ترے وعدے پر جیے ہم تو یہ جان جھوٹ جانا\nکہ خوشی سے مر نہ جاتے اگر اعتبار ہوتا","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0008","text":"ہزاروں خواہشیں ایسی کہ ہر خواہش پہ دم نکلے\nبہت نکلے مرے ارمان لیکن پھر بھی کم نکلے","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0009","text":"دل ہی تو ہے نہ سنگ و خشت، درد سے بھر نہ آئے کیوں\nروئیں گے ہم ہزار بار، کوئی ہمیں ستائے کیوں","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0010","text":"کوئی امید بر نہیں آتی\nکوئی صورت نظر نہیں آتی","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0011","text":"دلِ ناداں تجھے ہوا کیا ہے\nآخر اس درد کی دوا کیا ہے","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0012","text":"ہم کو معلوم ہے جنت کی حقیقت لیکن\nدل کے خوش رکھنے کو غالبؔ یہ خیال اچھا ہے","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0013","text":"آہ کو چاہیے اک عمر اثر ہونے تک\nکون جیتا ہے تری زلف کے سر ہونے تک","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0014","text":"عشق نے غالبؔ نکما کر دیا\nورنہ ہم بھی آدمی تھے کام کے","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0015","text":"کہوں کس سے میں کہ کیا ہے شبِ غم بری بلا ہے\nمجھے کیا برا تھا مرنا اگر ایک بار ہوتا","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0016","text":"دل سے تری نگاہ جگر تک اتر گئی\nدونوں کو ایک ادا میں رضا مند کر گئی","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0017","text":"پکڑے جاتے ہیں فرشتوں کے لکھے پر ناحق\nآدمی کوئی ہمارا دمِ تحریر بھی تھا","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0018","text":"یہ مسائلِ تصوف، یہ تیرا بیان غالبؔ\nتجھے ہم ولی سمجھتے، جو نہ بادہ خوار ہوتا","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0019","text":"رہیے اب ایسی جگہ چل کر جہاں کوئی نہ ہو\nہم سخن کوئی نہ ہو اور ہم زباں کوئی نہ ہو","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0020","text":"دل میں پھر اس کی وہی باتیں بسی ہیں غالبؔ\nجیسے کہ عمرِ گزشتہ کی کہانی ہو کوئی","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0021","text":"نہ تھا کچھ تو خدا تھا، کچھ نہ ہوتا تو خدا ہوتا\nڈبویا مجھ کو ہونے نے، نہ ہوتا میں تو کیا ہوتا","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0022","text":"زندگی اپنی جب اس شکل سے گزری غالبؔ\nہم بھی کیا یاد کریں گے کہ خدا رکھتے تھے","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — اشعار","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0023","text":"غالب کی زِندگی بڑی ہی پہلودار تھی۔ وہ شروع سے آخر تک تہہ در تہہ نظر آتی ہے۔ اُس میں بے شمار نشیب و فراز دکھائی دیتے ہیں۔ وہ تو ایک حَسین اور دل آویز پہاڑی سلسلے کی طرح حَسین اور دل آویز، پر شکوہ اور شاندار ہے۔ جلال اور جمال دونوں اِس میں گلے ملتے نظر آتے ہیں۔ رومان و حقیقت کا اِس میں ایک نہایت ہی دلکش اور دِل موہ لینے والا امتزاج ملتا ہے۔","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — [[عبادت بریلوی|ڈاکٹر عبادت بریلوی]]","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0024","text":"غالب کو دیکھیے، ساری عمر ناقدری اور عُسرت و تنگدستی کا رونا روتے رہے ، خصوصاً آخری دِنوں میں۔ لیکن ذرا مرض الموت میں اُن کی آخری غذا تو ملاحظہ فرمائیے۔ صبح کو سات بادام کا شیرہ، قند کے شربت کے ساتھ۔ دوپہر کو سیر بھر گوشت کی یخنی۔تین شامی کباب۔ چھ گھڑی رات گئے پانچ روپئے بھر شرابِ خانہ ساز اور اِسی قدر عرقِ شیر۔","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — [[مشتاق احمد یوسفی]]","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0025","text":"مشتاق احمد یوسفی : آ ب گم، مطبوعہ مکتبہ دانیال، کراچی۔ پاکستان، فروری 1990ء","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (Wikiquote) — مزید دیکھیں","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0026","text":"قید حیات و بند غم ، اصل میں دونوں ایک ہیں\nموت سے پہلے آدمی غم سے نجات پائے کیوں؟","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0027","text":"ہزاروں خواہشیں ایسی کہ ہر خواہش پہ دم نکلے\nبہت نکلے مرے ارماں لیکن پھر بھی کم نکلے","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0028","text":"بازیچۂ اطفال ہے دنیا مرے آگے\nہوتا ہے شب و روز تماشا مرے آگے","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0029","text":"کوئی ویرانی سی ویرانی ہے\nدشت کو دیکھ کے گھر یاد آیا","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0030","text":"دردِ دل لکھوں کب تک جاؤں ان کو دکھاؤ\nانگلیاں فگار اپنی خامہ خونچکاں اپنا","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0031","text":"مری قسمت میں غم گر اتنا تھا\nدل بھی یا رب کئی دیے ہوتے","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0032","text":"نہ تھا کچھ تو خدا تھا کچھ نہ ہوتا تو خدا ہوتا\nڈبویا مجھ کو ہونے نے نہ ہوتا میں تو کیا ہوتا","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0033","text":"دیکھنا قسمت کہ آپ اپنے پہ رشک آ جائے\nموت کی بھی آرزو ہے اے خدا دل کو یہاں","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0034","text":"ہوئی مدت کہ غالبؔ مر گیا پر یاد آتا ہے\nوہ ہر اک بات پہ کہنا کہ یوں ہوتا تو کیا ہوتا","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0035","text":"یہ مسائل تصوف یہ تیرا بیان غالبؔ\nتجھے ہم ولی سمجھتے جو نہ بادہ خوار ہوتا","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0036","text":"غم ہستی کا اسدؔ کس سے ہو جز مرگ علاج\nشمع ہر رنگ میں جلتی ہے سحر ہونے تک","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0037","text":"دیتے ہیں جنت زہد کے عوض بھی\nعارف کی وفا کا یہ صلہ ہے؟","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0038","text":"ہم نے مانا کہ تغافل نہ کرو گے لیکن\nخاک ہو جائیں گے ہم تم کو خبر ہونے تک","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0039","text":"مجھ تک کب ان کی بزم میں آتا تھا دور جام\nساقی نے کچھ ملا نہ دیا ہو شراب میں","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0040","text":"عشق پر زور نہیں ہے یہ وہ آتش غالبؔ\nکہ لگائے نہ لگے اور بجھائے نہ بنے","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0041","text":"اس بازار میں کون بنے صیاد غالب\nبلبل کی جگہ نالہ کشِ طوق ہوں میں","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0042","text":"میں نے کہا میرے دل میں نہیں\nاس نے کہا پھر کہاں ہے؟","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0043","text":"مرتے ہیں آرزو میں مرنے کی\nموت آتی ہے پر نہیں آتی","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0044","text":"دل سے تری نگاہ جگر تک اتر گئی\nدونوں کو اک ادا میں رضامند کر گئی","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0045","text":"وہ آئے گھر میں ہمارے خدا کی قدرت ہے\nکبھی ہم ان کو کبھی اپنے گھر کو دیکھتے ہیں","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0046","text":"گو ہاتھ کو جنبش نہیں آنکھوں میں تو دم ہے\nرہنے دو ابھی ساغر و مینا مرے آگے","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0047","text":"بس کہ دشوار ہے ہر کام کا آساں ہونا\nآدمی کو بھی میسر نہیں انساں ہونا","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0048","text":"دل ڈھونڈتا ہے پھر وہی فرصت کے رات دن\nبیٹھے رہیں تصور جاناں کیے ہوئے","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0049","text":"حاصل کچھ نہ ہوا آہ سحر دیکھنے سے\nمر گئے ہم تو شاید نہ ملے نام نشاں","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0050","text":"نکلنا خلد سے آدم کا سنتے آئے ہیں لیکن\nبہت بے آبرو ہو کر تیرے کوچے سے ہم نکلے","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0051","text":"لطف مرنے میں ہے مگر اے دوست\nزندگی بھی بہانہ چاہیے","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0052","text":"جب مجھ کو یاد کیجے تو اشک بہاوے نہیں\nاور اشک آئیں آنکھ میں تو یاد کیجے نہیں","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0053","text":"گو میں رہا رہینِ ستم ہائے روزگار\nلیکن ترے خیال سے غافل نہیں رہا","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0054","text":"زخم بھی ہے اور درد بھی ہے اور\nوہ خنجر بھی ہے اور ہاتھ بھی ہے","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0055","text":"مے پی اور مجھ سے کہا کہ چھوڑ دے\nکیا ستم ہے اے ستمگر دیکھیں","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0056","text":"آتی ہے داغِ حسرتِ دل کی صدا ابھی\nتم کیا گئے کہ روٹھ گیا روزگار بھی","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0057","text":"شعر میرے ہیں گو خواصانِ زمانے کے لیے\nیعنی ہر چند نہیں مجھ میں ہنر لیکن ہے","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0058","text":"خوش ہوتے ہیں پر وصل میں یوں مر نہیں جاتے\nآئی شبِ ہجر میں جان نکلی","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0059","text":"خیال ہے کہ وہ دل میں ہے یا کہ ہے باہر\nعجیب ہے یہ مقامِ حیرت نظر","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0060","text":"کہاں میخانے کا دروازہ غالبؔ اور کہاں واعظ\nپر اتنا جانتے ہیں کل وہ جاتا تھا کہ ہم نکلے","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"ghalib-ur-0061","text":"الٹی ہو گئی سب تدبیریں کچھ نہ دوا نے کام کیا\nدیکھا اس بیماری دل نے آخر کام تمام کیا","author":"Mirza Ghalib — Ghazals","source":"دیوانِ غالب (مرزا غالب، Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:love","theme:poetry","theme:wisdom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."}]}
{"formatVersion":"1","manifest":{"sourceId":"iqbal-ur","displayName":"علامہ اقبال","displayNameEnglish":"Allama Iqbal — Poetry","version":"1.0","language":"Urdu","languageCode":"ur","script":"Nastaliq","isRTL":true,"transliterationAvailable":false,"edition":"Public Domain & Curated / Hindi Wikiquote","primaryCategory":"Philosophy & Spirituality","subcategory":"Urdu Poetry","type":"quotes","browseOrder":"sequence","supportsRandom":true,"supportsBrowse":true,"groupingLevels":[],"groupingLabels":[],"sortPriority":56,"contentRating":"devotional","audienceTags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"itemCount":101,"dataPath":"Data/Collections/Iqbal_Urdu.json"},"data":[{"id":"iqbal-ur-0001","text":"اختتام اور مقاصد، چاہے وہ شعوری یا لاشعوری رجحانات کے طور پر موجود ہوں، ہمارے شعوری تجربے کی تپش اور ڈھنگ کی تشکیل کرتے ہیں۔","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0002","text":"قوی انسان ماحول تخلیق کرتا ہے۔ کمزوروں کو ماحول کے مطابق اپنے آپ کو ڈھالنا پڑتا ہے۔","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0003","text":"قوت باطل کو چھو لیتی ہے تو باطل حق میں بدل جاتا ہے۔","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0004","text":"تہذیب مرد قوی کا ایک خیال ہے۔","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0005","text":"پیکر قوت مہدی کا انتظار چھوڑ دو، جاؤ اور مہدی کو تخلیق کرو۔","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0006","text":"یہ پیام دے گئی ہے مجھے باد صبحگاہی، کہ خودی کے عرفا کا ہے مقام پادشاہی","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0007","text":"تیری زندگی اسی سے، تیری آبرو اسی سے، جو رہی خودی تو شاہی، نہ رہی تو روسیاہی","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0008","text":"نہ دیا نشان منزل مجھے اے حکیم تو نے، مجھے کیا گلہ ہو تجھ سے، تو نہ رہ نشین نہ راہی","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0009","text":"میرے حلقہ سخن میں ابھی زیر تربیت ہیں، وہ گدا کہ جانتے ہیں راہ و رسم کجکلاحی","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0010","text":"یہ معاملے ہیں نازک، جو تری رضا ہو تو کر، کہ مجھے تو خوش نہ آیا یہ طریق خانقاہی","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0011","text":"تو ہما کا ہے شکاری، ابھی ابتدا ہے تیری، نہیں مصلحت سے خالی یہ جہان مرغ و ماہی","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0012","text":"تو عرب ہو یا عجم ہو، تیرا ”لا الہ الا اللہ“، لغت غریب، جب تک تیرا دل نہ دے گواہی","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0013","text":"کھول آنکھ، زمین دیکھ، فلک دیکھ، فضا دیکھ، مشرق سے ابھرتے ہوئے سورج کو ذرا دیکھ","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0014","text":"اس جلوۂ بے پردہ کو پردوں میں چھپا دیکھ، ایامِ جدائی کے ستم دیکھ، جفا دیکھ، بیتاب نہ ہو معرکۂ بیم و رجا دیکھ","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0015","text":"ہیں تیرے تصرف میں یہ بدل، یہ گھٹائیں، یہ گنبدِ افلاک، یہ خاموش فضائیں","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0016","text":"یہ کوہ یہ صحرا، یہ سمندر یہ ہوائیں، تھیں پیش نظر کل تو فرشتوں کی ادائیں، آئینۂ ایام میں آج اپنی ادا دیکھ","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0017","text":"سمجھے گا زمانہ تری آنکھوں کے اشارے، دیکھیں گے تجھے دور سے گردوں کے ستارے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0018","text":"نہ پيد تيرے بحر تخیل کے کنارے، پہنچیں گے فلک تک تری آہوں کے شرارے، تعمیر خودی کر، اثر آہ رسا دیکھ","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0019","text":"خورشید جہاں تاب کی جو تیرے شرر میں، آباد ہے اک تازہ جہاں تیرے ہنر میں","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0020","text":"جچتے نہیں بخشے ہوئے فردوس نظر میں، جنت تری پنہاں ہے تیرے خون جگر میں، اے پیکرِ گل کوشش پہم کی جزا دیکھ","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0021","text":"نالندا تیرے عود کا ہر تار ازل سے، تو جنس محبت کا خیریدار ازل سے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0022","text":"تو پیر صنم خانۂ اسرار ازل سے، محنت کش و خون ریز و کم آزار ازل سے، ہے رکاب تقدیر جہاں تیری رضا، دیکھ","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0023","text":"اے دردِ عشق! ہے گوہرِ ابد تُو، نہ مہرموں میں دیکھ نہ ہو آشکارا تُو","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0024","text":"پنہاں تہِ نقاب تری جلوگاہ ہے، ظاہر پرست محفلِ نو کی نگاہ ہے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0025","text":"آئی نئی ہوا چمنِ ہست و بود میں، اے دردِ عشق! اب نہیں لذت نمود میں","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0026","text":"ہاں، خود نمائیوں کی تجھے جستجو نہ ہو، مِنّت پذیر نالۂ بلبل کا تُو نہ ہو","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0027","text":"خالی شرابِ عشق سے لالہ کا جام ہو، پانی کی بوند گریۂ شبنم کا نام ہو","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0028","text":"پنہاں دروںِ سینا کہیں راز ہو تیرا، اشکِ جگر گداز نہ غمّاز ہو تیرا","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0029","text":"گویا زبانِ شاعرِ رنگین بیاں نہ ہو، آوازِ نے میں شکوۂ فرصت نہاں نہ ہو","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0030","text":"یہ دور نکته چین ہے، کہیں چُپ کے بیٹھ رہ، جس دل میں تُو مکیں ہے، وہیں چُپ کے بیٹھ رہ","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0031","text":"غافل ہے تجھ سے حیرتِ علم آفریدہ دیکھ! جویا نہیں تری نگاہِ نارسیدہ دیکھ","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0032","text":"رہنے دے جستجو میں خیالِ بلند کو، حیرت میں چھوڑ دیدۂ حکمت پسند کو","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0033","text":"جس کی بہار تُو ہو یہ ایسا چمن نہیں، قابل تری نمود کے یہ انجمن نہیں","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0034","text":"یہ انجمن ہے کشتۂ نظرۂ مجاز، مقصد تری نگاہ کا خلوت سرائے راز","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0035","text":"ہر دل مئے خیال کی مستی سے چور ہے، کچھ اور آج کل کے کلاموں کا طور ہے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0036","text":"تمیزِ حاکم و محکوم مٹ نہیں سکتی، مجال کیا کہ گداگر ہو شاہ کا ہم دوش","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0037","text":"جہاں میں خواجہ پرستی ہے بندے کا کمال، رضائے خواجہ طلب کن قبائے رنگین پوش","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0038","text":"مگر غرض جو حصولِ رضائے حاکم ہو، خطاب ملتا ہے منصب پرست و قوم فروش","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0039","text":"پرانے طرزِ عمل میں ہزار مشکل ہے، نئے اصول سے خالی ہے فکر کی آغوش","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0040","text":"مزا تو یہ ہے کہ یوں زیرِ آسمان رہیے، \"ہزار گونہ سخن در دہن و لب خاموش","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0041","text":"یہی اصول ہے سرمایۂ سکونِ حیات، \"گدائے گوشہ نشینی تو حافظہ مے خروش","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0042","text":"مگر خروش پہ مائل ہے تُو تو بسم اللہ، \"بگیر بادۂ صافی بہ بانگِ چنگ بنوش","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0043","text":"شریکِ بزمِ امیر و وزیر و سلطان ہو، لڑا کے توڑ دے سنگِ ہوس سے شیشۂ ہوش","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0044","text":"پیامِ مرشدِ شیراز بھی مگر سن لے، کہ ہے یہ سرِّ نہاں خانۂ ضمیرِ سر فروش","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0045","text":"\"مہلِ نورِ تجلّی ست رای انور شاہ، چو قرب طلبی در صفائے نیت کُش","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0046","text":"تجھے کیوں فکر ہے اے گل دلِ سد چاکِ بلبل کی، تو اپنے پیرہن کے چاک تو پہلے رفو کر لے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0047","text":"تمنّا آبرو کی ہو اگر گلزارِ ہستی میں، تو کانٹوں میں الجھ کر زندگی کرنے کی خو کر لے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0048","text":"صنوبر باغ میں آزاد بھی ہے، پابندِ گِل بھی ہے، انہیں پابندیوں میں حصولِ آزادی کو تو کر لے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0049","text":"تَنک بخشی کو استغنا سے پیغامِ خجالت دے، نہ رہ منّت کشِ شبنم، نگوں جام و سبو کر لے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0050","text":"نہیں یہ شانِ خوداری، چمن سے توڑ کر تجھ کو، کوئی دستار میں رکھ لے، کوئی زيبِ گلو کر لے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0051","text":"چمن میں غنچۂ گل سے یہ کہ کر اڑ گئی شبنم، مذاقِ جورِ گلچیں ہو تو پیدا رنگ و بو کر لے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0052","text":"اگر منظور ہو تجھ کو خزاں ناآشنا رہنا، جہانِ رنگ و بو سے، پہلے قطعِ آرزو کر لے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0053","text":"اس میں دیکھ، مضمر ہے کمالِ زندگی تیرا، جو تجھ کو زينتِ دامن کوئی آئینہ رو کر لے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0054","text":"ممکن ہے کہ تو جس کو سمجھتا ہے بہاراں، اوروں کی نگاہوں میں وہ موسم ہو خزاں کا","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0055","text":"ہے سلسلہ احوال کا ہر لمحہ دگرگوں، اے سالکِ راہ، فکر نہ کر سود و زیاں کا","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0056","text":"یہ کائنات چھپاتی نہیں ضمیر اپنا، کہ ذرہ ذرہ میں ہے ذوقِ آشکارائی","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0057","text":"کچھ اور ہی نظر آتا ہے کاروبارِ جہاں، نگاہِ شوق اگر ہو شریکِ بینائی","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0058","text":"اسی نگاہ سے مہجوم قوم کے فرزند، ہوئے جہاں میں سزاوارِ کار فرمائی","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0059","text":"اسی نگاہ میں ہے قاہری و جباری، اسی نگاہ میں ہے دلبری و رعنائی","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0060","text":"اسی نگاہ سے ہر ذرّے کو، جنون میرا، سکھا رہا ہے راہ و رسمِ دشتِ پیمائی","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0061","text":"نگاہِ شوق میسر نہیں اگر تجھ کو، ترا وجود ہے قلب و نظر کی رسوائی","author":"Allama Iqbal — Poetry","source":"علامہ اقبال (Wikiquote) — اقوال","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0062","text":"ستاروں سے آگے جہاں اور بھی ہیں\nابھی عشق کے امتحاں اور بھی ہیں","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0063","text":"خودی کو کر بلند اتنا کہ ہر تقدیر سے پہلے\nخدا بندے سے خود پوچھے بتا تیری رضا کیا ہے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0064","text":"یہ ایک سجدہ جسے تو گراں سمجھتا ہے\nہزار سجدوں سے دیتا ہے آدمی کو نجات","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0065","text":"تو شاہیں ہے پرواز ہے کام تیرا\nترے سامنے آسماں اور بھی ہیں","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0066","text":"اپنے من میں ڈوب کر پا جا سراغِ زندگی\nتو اگر میرا نہیں بنتا نہ بن اپنا تو بن","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0067","text":"ہزار ڈر ہیں ہماری زبان کو لیکن\nگُزر گیا وہ زمانہ کہ حرف منہ میں رہے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0068","text":"پرندہ کیا سمجھے گا عزتِ بازِ شکاری\nپرواز اس کو نہیں بس قفس سے واقف ہے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0069","text":"خدا نے آج تک اس قوم کی حالت نہیں بدلی\nنہ ہو جس کو خیال آپ اپنی حالت کے بدلنے کا","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0070","text":"آئینِ نو سے ڈرنا طرزِ کہن پہ اڑنا\nمنزل یہی کٹھن ہے قوموں کی زندگی میں","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0071","text":"وہ کون سا قفس ہے جس میں نہ ہو\nتمنائے پرواز کی کوئی تڑپ","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0072","text":"علم میں کیا شک ہے لیکن اس کا\nانجام ہے نادان کو پشیمانی","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0073","text":"نہیں ہے نا امید اقبالؔ اپنی کشتِ ویراں سے\nذرا نم ہو تو یہ مٹی بڑی زرخیز ہے ساقی","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0074","text":"جواں ہو پھر ہماری آنکھوں کے تارے\nوہی اول وہی آخر وہی معشوق وہی یار","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0075","text":"میری نوائے شوق سے شور حریم ذات میں\nغلغلہ ہائے الاماں بتکدۂ صفات میں","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0076","text":"اگر ہو عشق تو ہے کفر بھی مسلمانی\nنہیں تو مرد مسلماں نہیں نماز بھی کافی نہیں","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0077","text":"دنیا کو ہے اس مہدیٔ برحق کی ضرورت\nہو جس کی نگہ زلزلۂ عالمِ افکار","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0078","text":"یقین محکم عمل پیہم محبت فاتحِ عالم\nجہادِ زندگانی میں ہیں یہ مردوں کی شمشیریں","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0079","text":"تو بچا بچا کے نہ رکھ اسے تیرا آئینہ ہے وہ آئینہ\nکہ شکستہ ہو تو عزیزتر ہے نگاہِ آئینہ ساز میں","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0080","text":"لہو مسلم کو گرما دے گا اقبال کے اشعار\nتڑپ اٹھے گا یہ دریا بھی موجیں لیتے لیتے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0081","text":"ترا جادو سر چشمۂ کائنات ہے\nپیامِ زندگی لیکن تو ہی آگاہ ہے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0082","text":"دل درد سے خالی ہے نہ آنکھوں میں ہے نم کچھ\nکیا شے ہے محبت جسے کہتے ہیں بتا کچھ","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0083","text":"رہا نہ سرور تو محفل کو کیا کریں ہم\nہم اپنا ذوق دل کو دے اور کیا کریں ہم","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0084","text":"میں کہاں ہوں خبر نہیں\nمجھ کو آئینہ دیکھنا اچھا نہیں لگتا","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0085","text":"محبت مجھے ان جوانوں سے ہے\nستاروں پہ جو ڈالتے ہیں کمند","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0086","text":"ڈھونڈتا پھرتا ہوں اے اقبال اپنے آپ کو\nآپ ہی گویا مسافر آپ ہی منزل ہوں میں","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0087","text":"مذہب نہیں سکھاتا آپس میں بیر رکھنا\nہندی ہیں ہم وطن ہے ہندوستاں ہمارا","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0088","text":"سارے جہاں سے اچھا ہندوستاں ہمارا\nہم بلبلیں ہیں اس کی یہ گلستاں ہمارا","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0089","text":"یونان و مصر و روما سب مٹ گئے جہاں سے\nاب تک مگر ہے باقی نام و نشاں ہمارا","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0090","text":"کچھ بات ہے کہ ہستی مٹتی نہیں ہماری\nصدیوں رہا ہے دشمن دورِ زماں ہمارا","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0091","text":"اقبال کوئی محرمِ رازِ نہاں نہیں ہے\nبس آنکھوں کا دیا ہوں اور دلوں کا آئینہ","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0092","text":"ستاروں کی قسمت میں کیا ہے خبر نہیں\nہماری قسمت ہے اپنی روشنی میں جینا","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0093","text":"اے جوانانِ وطن راہِ عمل میں آگے بڑھو\nجذبۂ شوق سے روشن کرو دل آگے بڑھو","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0094","text":"پہلے تھا دل میں تیرا خیال اب ہوں میں تیرا سوال\nآگے سے کیا ہوگا تیرا اے میرے دل کا مآل","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0095","text":"گو ہماری گفتگو کافی نہیں ہے\nپر وہ جو سنتے ہیں ضرور سوچتے ہیں","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0096","text":"آدمی آدمی کو دیتا ہے درس زندگی\nلیکن فرشتہ بھی محتاج ہے سبق کا","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0097","text":"حقیقت ایک ہے ہر شے کی خاکی ہو کہ نوری ہو\nلہو خورشید کا ٹپکے اگر ذرے کا دل چیریں","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0098","text":"یہی ہے عبادت یہی دین و ایماں\nکہ کام آئے دنیا میں انسان کے انساں","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0099","text":"علم و عمل ہیں قوموں کی تعمیر کا سامان\nیہ دونوں مل کے ہی لاتے ہیں اعتبار","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0100","text":"غبار شوق جما ہے دلوں میں صدیوں سے\nوہ آگ چاہیے جو بھڑکائے اسے","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."},{"id":"iqbal-ur-0101","text":"اقوامِ عالم کی نظر میں وہی قوم معزز ہے\nجو اپنے حال سے واقف ہو اور ارادے پختہ ہوں","author":"Allama Iqbal — Poetry","source":"علامہ اقبال — کلیاتِ اقبال (Public Domain)","tags":["language:ur","script:nastaliq","tradition:urdu","theme:wisdom","theme:identity","theme:freedom"],"isProverb":false,"isVerified":true,"verificationNote":"Verified via Hindi Wikiquote / curated public-domain source."}]}